{#
/**
 * @file
 * Template para la landing del Método Jaraba v2.
 *
 * 8 secciones: hero, problema, solución, 3 capas, 4 competencias,
 * CID 90 días, 3 caminos, evidencia + CTA final.
 *
 * Variables (inyectadas desde MetodoLandingController):
 * - hero: badge, title, subtitle, stat_*, cta_primary, cta_secondary
 * - problema: title, intro, pain_points[]
 * - solucion: title, intro, steps[], metaphor_*
 * - capas: title, items[] (name, question, description, icon, color)
 * - competencias: title, items[] (name, description, example, icon, color)
 * - cid: title, phases[] (number, name, days, deliverable, color)
 * - caminos: title, paths[] (audience, description, cta_*, icon, color)
 * - evidencia: stat_*, quote, trust_logos, cta, cta_secondary
 *
 * @see MetodoLandingController::landing()
 */
#}

{# ── Schema.org Course ── #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "{{ 'Método Jaraba: Supervisión de Agentes IA'|trans }}",
  "description": "{{ 'Sistema de capacitación profesional en 90 días para generar impacto económico supervisando agentes de inteligencia artificial.'|trans }}",
  "provider": {
    "@type": "Organization",
    "name": "Plataforma de Ecosistemas Digitales S.L.",
    "url": "https://plataformadeecosistemas.com"
  },
  "hasCourseInstance": [
    { "@type": "CourseInstance", "name": "{{ 'Empleabilidad'|trans }}", "courseMode": "blended" },
    { "@type": "CourseInstance", "name": "{{ 'Emprendimiento'|trans }}", "courseMode": "blended" },
    { "@type": "CourseInstance", "name": "{{ 'Digitalización'|trans }}", "courseMode": "blended" }
  ]
}
</script>

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECCIÓN 1: HERO                                                    #}
{# ═══════════════════════════════════════════════════════════════════ #}
<section class="metodo-hero" aria-label="{{ 'Método Jaraba'|trans }}">
  <div class="metodo-container">
    {% if hero.badge %}
      <span class="metodo-hero__badge">{{ hero.badge }}</span>
    {% endif %}
    <h1 class="metodo-hero__title">{{ hero.title }}</h1>
    <p class="metodo-hero__subtitle">{{ hero.subtitle }}</p>

    {% if hero.stat_value %}
      <div class="metodo-hero__stat" aria-label="{{ hero.stat_label }}">
        <span class="metodo-hero__stat-value">{{ hero.stat_value }}<small>{{ hero.stat_suffix }}</small></span>
        <span class="metodo-hero__stat-label">{{ hero.stat_label }}</span>
        <span class="metodo-hero__stat-source">{{ hero.stat_source }}</span>
      </div>
    {% endif %}

    <div class="metodo-hero__actions">
      {% if hero.cta_primary %}
        <a href="{{ hero.cta_primary.url }}" class="metodo-btn metodo-btn--primary metodo-btn--large"
           data-track-cta="{{ hero.cta_primary.track }}" data-track-position="metodo_hero">
          {{ hero.cta_primary.text }} ↓
        </a>
      {% endif %}
      {% if hero.cta_secondary %}
        <a href="{{ hero.cta_secondary.url }}" class="metodo-btn metodo-btn--secondary"
           data-track-cta="{{ hero.cta_secondary.track }}" data-track-position="metodo_hero">
          {{ hero.cta_secondary.text }} →
        </a>
      {% endif %}
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECCIÓN 2: EL PROBLEMA                                            #}
{# ═══════════════════════════════════════════════════════════════════ #}
<section class="metodo-section metodo-problema" aria-labelledby="metodo-problema-title">
  <div class="metodo-container">
    <h2 id="metodo-problema-title" class="metodo-section__title">{{ problema.title }}</h2>
    <p class="metodo-section__intro">{{ problema.intro }}</p>

    <div class="metodo-cards metodo-cards--3">
      {% for point in problema.pain_points %}
        <div class="metodo-card metodo-card--pain">
          <div class="metodo-card__icon metodo-card__icon--{{ point.color }}">
            {{ jaraba_icon(point.icon.category, point.icon.name, { variant: 'duotone', size: '32px', color: point.color }) }}
          </div>
          <blockquote class="metodo-card__quote">{{ point.quote }}</blockquote>
          <p class="metodo-card__text">{{ point.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECCIÓN 3: LA SOLUCIÓN — FLUJO INVERTIDO                          #}
{# ═══════════════════════════════════════════════════════════════════ #}
<section id="solucion" class="metodo-section metodo-solucion" aria-labelledby="metodo-solucion-title">
  <div class="metodo-container">
    <h2 id="metodo-solucion-title" class="metodo-section__title">{{ solucion.title }}</h2>
    <p class="metodo-section__intro">{{ solucion.intro }}</p>

    <ol class="metodo-steps">
      {% for step in solucion.steps %}
        <li class="metodo-step">
          <span class="metodo-step__number">{{ step.number }}</span>
          <div class="metodo-step__content">
            <strong class="metodo-step__title">{{ step.title }}</strong>
            <p class="metodo-step__desc">{{ step.description }}</p>
          </div>
        </li>
      {% endfor %}
    </ol>

    <div class="metodo-metaphor">
      <h3 class="metodo-metaphor__title">{{ solucion.metaphor_title }}</h3>
      <p class="metodo-metaphor__text">{{ solucion.metaphor_text }}</p>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECCIÓN 4: LAS 3 CAPAS                                            #}
{# ═══════════════════════════════════════════════════════════════════ #}
<section class="metodo-section metodo-capas" aria-labelledby="metodo-capas-title">
  <div class="metodo-container">
    <h2 id="metodo-capas-title" class="metodo-section__title">{{ capas.title }}</h2>

    <div class="metodo-cards metodo-cards--3">
      {% for capa in capas.items %}
        <div class="metodo-card metodo-card--capa metodo-card--{{ capa.color }}">
          <div class="metodo-card__icon metodo-card__icon--{{ capa.color }}">
            {{ jaraba_icon(capa.icon.category, capa.icon.name, { variant: 'duotone', size: '40px', color: capa.color }) }}
          </div>
          <h3 class="metodo-card__name">{{ capa.name }}</h3>
          <span class="metodo-card__question">{{ capa.question }}</span>
          <p class="metodo-card__text">{{ capa.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECCIÓN 5: LAS 4 COMPETENCIAS                                     #}
{# ═══════════════════════════════════════════════════════════════════ #}
<section class="metodo-section metodo-competencias" aria-labelledby="metodo-comp-title">
  <div class="metodo-container">
    <h2 id="metodo-comp-title" class="metodo-section__title">{{ competencias.title }}</h2>

    <div class="metodo-competencia-grid">
      {% for comp in competencias.items %}
        <div class="metodo-competencia">
          <div class="metodo-competencia__icon metodo-competencia__icon--{{ comp.color }}">
            {{ jaraba_icon(comp.icon.category, comp.icon.name, { variant: 'duotone', size: '28px', color: comp.color }) }}
          </div>
          <div class="metodo-competencia__content">
            <h3 class="metodo-competencia__name">{{ comp.name }}</h3>
            <p class="metodo-competencia__desc">{{ comp.description }}</p>
            <p class="metodo-competencia__example"><em>{{ comp.example }}</em></p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECCIÓN 6: CID — CICLO DE IMPACTO DIGITAL 90 DÍAS                 #}
{# ═══════════════════════════════════════════════════════════════════ #}
<section class="metodo-section metodo-cid" aria-labelledby="metodo-cid-title">
  <div class="metodo-container">
    <h2 id="metodo-cid-title" class="metodo-section__title">{{ cid.title }}</h2>

    <div class="metodo-timeline">
      {% for phase in cid.phases %}
        <div class="metodo-timeline__phase metodo-timeline__phase--{{ phase.color }}">
          <div class="metodo-timeline__marker">
            <span class="metodo-timeline__number">{{ phase.number }}</span>
          </div>
          <div class="metodo-timeline__content">
            <span class="metodo-timeline__days">{{ phase.days }}</span>
            <h3 class="metodo-timeline__name">{{ phase.name }}</h3>
            <p class="metodo-timeline__deliverable">
              <strong>{% trans %}Entregable:{% endtrans %}</strong> {{ phase.deliverable }}
            </p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECCIÓN 7: 3 CAMINOS                                              #}
{# ═══════════════════════════════════════════════════════════════════ #}
<section class="metodo-section metodo-caminos" aria-labelledby="metodo-caminos-title">
  <div class="metodo-container">
    <h2 id="metodo-caminos-title" class="metodo-section__title">{{ caminos.title }}</h2>

    <div class="metodo-cards metodo-cards--3">
      {% for path in caminos.paths %}
        <div class="metodo-card metodo-card--camino metodo-card--{{ path.color }}">
          <div class="metodo-card__icon metodo-card__icon--{{ path.color }}">
            {{ jaraba_icon(path.icon.category, path.icon.name, { variant: 'duotone', size: '40px', color: path.color }) }}
          </div>
          <h3 class="metodo-card__name">{{ path.audience }}</h3>
          <p class="metodo-card__text">{{ path.description }}</p>
          <a href="{{ path.cta_url }}" class="metodo-btn metodo-btn--primary metodo-btn--sm"
             data-track-cta="{{ path.track }}" data-track-position="metodo_caminos"
             target="_blank" rel="noopener">
            {{ path.cta_text }} →
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECCIÓN 8: EVIDENCIA + CTA FINAL                                  #}
{# ═══════════════════════════════════════════════════════════════════ #}
<section class="metodo-section metodo-evidencia" aria-labelledby="metodo-evidencia-title">
  <div class="metodo-container">
    <div class="metodo-evidencia__stat">
      <span class="metodo-evidencia__value">{{ evidencia.stat_value }}<small>{{ evidencia.stat_suffix }}</small></span>
      <span class="metodo-evidencia__label" id="metodo-evidencia-title">{{ evidencia.stat_label }}</span>
      <span class="metodo-evidencia__source">{{ evidencia.stat_source }}</span>
    </div>

    <p class="metodo-evidencia__quote">{{ evidencia.quote }}</p>

    {% if evidencia.trust_logos %}
      {% include '@ecosistema_jaraba_theme/partials/_trust-strip.html.twig' with {
        context: 'metodo',
      } only %}
    {% endif %}

    <div class="metodo-evidencia__actions">
      {% if evidencia.cta %}
        <a href="{{ evidencia.cta.url }}" class="metodo-btn metodo-btn--primary metodo-btn--large"
           data-track-cta="{{ evidencia.cta.track }}" data-track-position="metodo_evidencia">
          {{ evidencia.cta.text }} →
        </a>
      {% endif %}
      {% if evidencia.cta_secondary %}
        <a href="{{ evidencia.cta_secondary.url }}" class="metodo-btn metodo-btn--secondary"
           data-track-cta="{{ evidencia.cta_secondary.track }}" data-track-position="metodo_evidencia">
          {{ evidencia.cta_secondary.text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>
