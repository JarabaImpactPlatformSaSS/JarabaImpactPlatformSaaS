<?php

/**
 * @file
 * Install, update and uninstall functions for jaraba_copilot_v2.
 */

use Drupal\jaraba_copilot_v2\Service\ModeDetectorService;

/**
 * Implements hook_schema().
 */
function jaraba_copilot_v2_schema() {
  $schema['copilot_query_log'] = [
    'description' => 'Log de consultas del Copiloto para analytics.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
        'description' => 'Primary Key.',
      ],
      'source' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'description' => 'Fuente: public, emprendimiento, empleabilidad.',
      ],
      'query' => [
        'type' => 'text',
        'size' => 'medium',
        'not null' => TRUE,
        'description' => 'Pregunta del usuario.',
      ],
      'response' => [
        'type' => 'text',
        'size' => 'medium',
        'not null' => TRUE,
        'description' => 'Respuesta generada.',
      ],
      'context_data' => [
        'type' => 'text',
        'size' => 'normal',
        'description' => 'Contexto adicional (JSON).',
      ],
      'session_id' => [
        'type' => 'varchar',
        'length' => 128,
        'description' => 'ID de sesión.',
      ],
      'page_url' => [
        'type' => 'varchar',
        'length' => 512,
        'description' => 'URL de la página.',
      ],
      'mode' => [
        'type' => 'varchar',
        'length' => 64,
        'description' => 'Modo del copiloto usado.',
      ],
      'was_helpful' => [
        'type' => 'int',
        'size' => 'tiny',
        'description' => 'Feedback: 1=útil, 0=no útil, NULL=sin feedback.',
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'description' => 'Timestamp de creación.',
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'source' => ['source'],
      'mode' => ['mode'],
      'created' => ['created'],
      'was_helpful' => ['was_helpful'],
    ],
  ];

  return $schema;
}

/**
 * Crea la tabla copilot_query_log para logging de queries.
 */
function jaraba_copilot_v2_update_10001() {
  $schema = jaraba_copilot_v2_schema();
  $database = \Drupal::database();

  if (!$database->schema()->tableExists('copilot_query_log')) {
    $database->schema()->createTable('copilot_query_log', $schema['copilot_query_log']);
    return t('Tabla copilot_query_log creada correctamente.');
  }

  return t('Tabla copilot_query_log ya existía.');
}

/**
 * Add user_id, role and tokens_used columns to copilot_query_log.
 */
function jaraba_copilot_v2_update_10002() {
  $database = \Drupal::database();
  $schema = $database->schema();
  $messages = [];

  if ($schema->tableExists('copilot_query_log')) {
    if (!$schema->fieldExists('copilot_query_log', 'user_id')) {
      $schema->addField('copilot_query_log', 'user_id', [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => FALSE,
        'description' => 'ID del usuario que hizo la consulta.',
      ]);
      $schema->addIndex('copilot_query_log', 'user_id', ['user_id'], [
        'fields' => [
          'user_id' => ['type' => 'int', 'unsigned' => TRUE],
        ],
      ]);
      $messages[] = 'Campo user_id agregado.';
    }

    if (!$schema->fieldExists('copilot_query_log', 'role')) {
      $schema->addField('copilot_query_log', 'role', [
        'type' => 'varchar',
        'length' => 32,
        'not null' => FALSE,
        'default' => 'user',
        'description' => 'Rol del mensaje: user o assistant.',
      ]);
      $messages[] = 'Campo role agregado.';
    }

    if (!$schema->fieldExists('copilot_query_log', 'tokens_used')) {
      $schema->addField('copilot_query_log', 'tokens_used', [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => FALSE,
        'default' => 0,
        'description' => 'Tokens consumidos en la consulta.',
      ]);
      $messages[] = 'Campo tokens_used agregado.';
    }
  }

  return implode(' ', $messages) ?: 'Sin cambios necesarios.';
}

/**
 * Crea tabla copilot_mode_triggers y la semilla con datos del const PHP.
 */
function jaraba_copilot_v2_update_10003() {
  $database = \Drupal::database();
  $schema = $database->schema();
  $messages = [];

  if (!$schema->tableExists('copilot_mode_triggers')) {
    $schema->createTable('copilot_mode_triggers', [
      'description' => 'Triggers configurables para deteccion de modo del copiloto.',
      'fields' => [
        'id' => [
          'type' => 'serial',
          'not null' => TRUE,
          'description' => 'Primary Key.',
        ],
        'mode' => [
          'type' => 'varchar',
          'length' => 32,
          'not null' => TRUE,
          'description' => 'Modo del copiloto (coach, consultor, sparring, etc.).',
        ],
        'trigger_word' => [
          'type' => 'varchar',
          'length' => 100,
          'not null' => TRUE,
          'description' => 'Palabra o frase trigger.',
        ],
        'weight' => [
          'type' => 'int',
          'not null' => TRUE,
          'default' => 1,
          'description' => 'Peso del trigger (1-15).',
        ],
        'active' => [
          'type' => 'int',
          'size' => 'tiny',
          'not null' => TRUE,
          'default' => 1,
          'description' => '0=desactivado, 1=activo.',
        ],
        'created' => [
          'type' => 'int',
          'not null' => TRUE,
          'description' => 'Timestamp de creacion.',
        ],
        'changed' => [
          'type' => 'int',
          'not null' => TRUE,
          'description' => 'Timestamp de ultima modificacion.',
        ],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'idx_mode' => ['mode'],
        'idx_active_mode' => ['active', 'mode'],
      ],
    ]);
    $messages[] = t('Tabla copilot_mode_triggers creada.');

    // Semilla desde const MODE_TRIGGERS de ModeDetectorService.
    $triggers = ModeDetectorService::MODE_TRIGGERS;
    $now = \Drupal::time()->getRequestTime();
    $count = 0;

    foreach ($triggers as $mode => $modeTriggers) {
      foreach ($modeTriggers as $trigger) {
        $database->insert('copilot_mode_triggers')
          ->fields([
            'mode' => $mode,
            'trigger_word' => $trigger['word'],
            'weight' => $trigger['weight'],
            'active' => 1,
            'created' => $now,
            'changed' => $now,
          ])
          ->execute();
        $count++;
      }
    }
    $messages[] = t('@count triggers sembrados desde configuracion por defecto.', ['@count' => $count]);
  }
  else {
    $messages[] = t('Tabla copilot_mode_triggers ya existia.');
  }

  return implode(' ', $messages);
}

/**
 * Crea tabla entrepreneur_milestone para registrar hitos del emprendedor.
 */
function jaraba_copilot_v2_update_10004() {
  $database = \Drupal::database();
  $schema = $database->schema();
  $messages = [];

  if (!$schema->tableExists('entrepreneur_milestone')) {
    $schema->createTable('entrepreneur_milestone', [
      'description' => 'Hitos del emprendedor con tipo, puntos y entidad relacionada.',
      'fields' => [
        'id' => [
          'type' => 'serial',
          'not null' => TRUE,
          'description' => 'Primary Key.',
        ],
        'entrepreneur_id' => [
          'type' => 'int',
          'not null' => TRUE,
          'description' => 'FK a entrepreneur_profile.',
        ],
        'milestone_type' => [
          'type' => 'varchar',
          'length' => 50,
          'not null' => TRUE,
          'description' => 'Tipo: EXPERIMENT_COMPLETED, HYPOTHESIS_VALIDATED, etc.',
        ],
        'description' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => FALSE,
          'description' => 'Descripcion legible del hito.',
        ],
        'points_awarded' => [
          'type' => 'int',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Puntos otorgados por este hito.',
        ],
        'related_entity_type' => [
          'type' => 'varchar',
          'length' => 50,
          'not null' => FALSE,
          'description' => 'Tipo de entidad relacionada (experiment, hypothesis).',
        ],
        'related_entity_id' => [
          'type' => 'int',
          'not null' => FALSE,
          'description' => 'ID de la entidad relacionada.',
        ],
        'created' => [
          'type' => 'int',
          'not null' => TRUE,
          'description' => 'Timestamp de creacion.',
        ],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'idx_entrepreneur' => ['entrepreneur_id'],
        'idx_type' => ['milestone_type'],
      ],
    ]);
    $messages[] = t('Tabla entrepreneur_milestone creada correctamente.');
  }
  else {
    $messages[] = t('Tabla entrepreneur_milestone ya existia.');
  }

  return implode(' ', $messages);
}

/**
 * Install entity types: entrepreneur_learning, entrepreneur_profile, experiment, field_exit, hypothesis.
 *
 * UPDATE-HOOK-REQUIRED-001: Ensure all entity type definitions are installed.
 */
function jaraba_copilot_v2_update_10005(): string {
  $messages = [];
  $updateManager = \Drupal::entityDefinitionUpdateManager();
  $entityTypeManager = \Drupal::entityTypeManager();

  $entityTypes = [
    'entrepreneur_learning',
    'entrepreneur_profile',
    'experiment',
    'field_exit',
    'hypothesis',
  ];

  foreach ($entityTypes as $entityTypeId) {
    try {
      if (!$updateManager->getEntityType($entityTypeId)) {
        $entityType = $entityTypeManager->getDefinition($entityTypeId, FALSE);
        if ($entityType) {
          $updateManager->installEntityType($entityType);
          $messages[] = "Installed entity type: $entityTypeId.";
        }
        else {
          $messages[] = "Definition not found: $entityTypeId.";
        }
      }
      else {
        $messages[] = "Already installed: $entityTypeId.";
      }
    }
    catch (\Throwable $e) {
      $messages[] = "Error installing $entityTypeId: " . $e->getMessage();
    }
  }

  return implode(' ', $messages);
}

/**
 * Create copilot_funnel_event table for funnel tracking.
 *
 * UPDATE-HOOK-CATCH-001: try-catch con \Throwable.
 */
function jaraba_copilot_v2_update_10006(): string {
  $schema = \Drupal::database()->schema();

  if ($schema->tableExists('copilot_funnel_event')) {
    return 'Table copilot_funnel_event already exists.';
  }

  try {
    $schema->createTable('copilot_funnel_event', [
      'description' => 'Eventos del embudo de ventas generados por el copilot.',
      'fields' => [
        'id' => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
        'session_id' => ['type' => 'varchar', 'length' => 64, 'not null' => TRUE],
        'event_type' => ['type' => 'varchar', 'length' => 64, 'not null' => TRUE],
        'vertical_detected' => ['type' => 'varchar', 'length' => 64, 'default' => NULL],
        'intent_type' => ['type' => 'varchar', 'length' => 64, 'default' => NULL],
        'promotion_mentioned' => ['type' => 'varchar', 'length' => 128, 'default' => NULL],
        'cta_generated' => ['type' => 'varchar', 'length' => 255, 'default' => NULL],
        'crm_contact_id' => ['type' => 'int', 'unsigned' => TRUE, 'default' => NULL],
        'crm_opportunity_id' => ['type' => 'int', 'unsigned' => TRUE, 'default' => NULL],
        'ip_hash' => ['type' => 'varchar', 'length' => 64, 'not null' => TRUE],
        'created' => ['type' => 'int', 'not null' => TRUE],
        'metadata' => ['type' => 'text', 'size' => 'normal', 'default' => NULL],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'session' => ['session_id'],
        'event_type' => ['event_type'],
        'vertical' => ['vertical_detected'],
        'created' => ['created'],
      ],
    ]);

    return 'Table copilot_funnel_event created successfully.';
  }
  catch (\Throwable $e) {
    return 'Error creating copilot_funnel_event: ' . $e->getMessage();
  }
}

/**
 * Implements hook_requirements().
 */
function jaraba_copilot_v2_requirements(string $phase): array {
  $requirements = [];

  if ($phase !== 'runtime') {
    return $requirements;
  }

  $entityTypes = [
    'entrepreneur_learning',
    'entrepreneur_profile',
    'experiment',
    'field_exit',
    'hypothesis',
  ];
  $updateManager = \Drupal::entityDefinitionUpdateManager();
  $missing = [];

  foreach ($entityTypes as $typeId) {
    if (!$updateManager->getEntityType($typeId)) {
      $missing[] = $typeId;
    }
  }

  if (!empty($missing)) {
    $requirements['jaraba_copilot_v2_entities'] = [
      'title' => t('Jaraba copilot v2: Entity Types'),
      'value' => t('Missing: @types', ['@types' => implode(', ', $missing)]),
      'description' => t('Run drush entity:updates to install missing entity types.'),
      'severity' => REQUIREMENT_ERROR,
    ];
  }
  else {
    $requirements['jaraba_copilot_v2_entities'] = [
      'title' => t('Jaraba copilot v2: Entity Types'),
      'value' => t('All @count entity types installed', ['@count' => count($entityTypes)]),
      'severity' => REQUIREMENT_OK,
    ];
  }

  // AI-SERVICE-CHAIN-001: Verify the copilot orchestrator service chain
  // instantiates without errors. A single missing arg in ANY transitive
  // dependency (e.g., LegalSearchService missing @current_user) silently
  // breaks the entire copilot, returning 503 to all users.
  $aiServices = [
    'jaraba_copilot_v2.copilot_orchestrator' => 'CopilotOrchestratorService',
    'jaraba_copilot_v2.streaming_orchestrator' => 'StreamingOrchestratorService',
    'jaraba_copilot_v2.mode_detector' => 'ModeDetectorService',
    'jaraba_copilot_v2.normative_rag' => 'NormativeRAGService',
    'jaraba_copilot_v2.copilot_cache' => 'CopilotCacheService',
  ];
  $brokenServices = [];

  foreach ($aiServices as $serviceId => $label) {
    try {
      if (\Drupal::hasService($serviceId)) {
        \Drupal::service($serviceId);
      }
      else {
        $brokenServices[] = "$label (not registered)";
      }
    }
    catch (\Throwable $e) {
      $brokenServices[] = "$label: " . $e->getMessage();
    }
  }

  if (!empty($brokenServices)) {
    $requirements['jaraba_copilot_v2_ai_chain'] = [
      'title' => t('Copilot IA: Service Chain'),
      'value' => t('@count services broken', ['@count' => count($brokenServices)]),
      'description' => t('The copilot will return 503 "El servicio de IA no está disponible" until fixed: @list', [
        '@list' => implode('; ', $brokenServices),
      ]),
      'severity' => REQUIREMENT_ERROR,
    ];
  }
  else {
    $requirements['jaraba_copilot_v2_ai_chain'] = [
      'title' => t('Copilot IA: Service Chain'),
      'value' => t('All @count services instantiate correctly', ['@count' => count($aiServices)]),
      'severity' => REQUIREMENT_OK,
    ];
  }

  return $requirements;
}
