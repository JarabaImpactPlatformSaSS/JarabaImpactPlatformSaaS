<?php

/**
 * @file
 * Primary module hooks for Jaraba Billing.
 */

declare(strict_types=1);

/**
 * Implements hook_cron().
 *
 * GAP-C02: Procesa dunning diario para suscripciones con pagos fallidos.
 * GAP-C04: Sincroniza metricas de uso con Stripe (metered billing).
 * GAP-M04: Limpia log de webhooks procesados > 30 dias.
 */
function jaraba_billing_cron(): void {
  $lastRun = \Drupal::state()->get('jaraba_billing.cron_last_run', 0);
  $now = \Drupal::time()->getRequestTime();

  // Ejecutar solo una vez al dia (no cada ejecucion de cron).
  if (($now - $lastRun) < 72000) {
    return;
  }

  // 1. Dunning: escalar pasos para tenants morosos.
  if (\Drupal::hasService('jaraba_billing.dunning')) {
    try {
      /** @var \Drupal\jaraba_billing\Service\DunningService $dunning */
      $dunning = \Drupal::service('jaraba_billing.dunning');
      $processed = $dunning->processDunning();
      if ($processed > 0) {
        \Drupal::logger('jaraba_billing')->info(
          'Dunning cron: @count suscripciones procesadas.',
          ['@count' => $processed]
        );
      }
    }
    catch (\Throwable $e) {
      \Drupal::logger('jaraba_billing')->error(
        'Dunning cron error: @msg',
        ['@msg' => $e->getMessage()]
      );
    }
  }

  // 2. Usage sync: enviar metricas de uso a Stripe.
  if (\Drupal::hasService('jaraba_billing.usage_stripe_sync')) {
    try {
      /** @var \Drupal\jaraba_billing\Service\UsageStripeSyncService $usageSync */
      $usageSync = \Drupal::service('jaraba_billing.usage_stripe_sync');
      $synced = $usageSync->syncUsageToStripe();
      if ($synced > 0) {
        \Drupal::logger('jaraba_billing')->info(
          'Usage sync cron: @count registros sincronizados con Stripe.',
          ['@count' => $synced]
        );
      }
    }
    catch (\Throwable $e) {
      \Drupal::logger('jaraba_billing')->error(
        'Usage sync cron error: @msg',
        ['@msg' => $e->getMessage()]
      );
    }
  }

  // 3. Cleanup: eliminar log de webhooks procesados > 30 dias.
  try {
    $deleted = \Drupal::database()->delete('stripe_webhook_event_log')
      ->condition('processed_at', $now - (30 * 86400), '<')
      ->execute();
    if ($deleted > 0) {
      \Drupal::logger('jaraba_billing')->info(
        'Webhook event log cleanup: @count eventos antiguos eliminados.',
        ['@count' => $deleted]
      );
    }
  }
  catch (\Throwable $e) {
    // Table may not exist yet — safe to ignore.
  }

  // 4. Kit Digital: transicionar acuerdos expirados a justification_pending.
  if (\Drupal::hasService('jaraba_billing.kit_digital')) {
    try {
      /** @var \Drupal\jaraba_billing\Service\KitDigitalService $kitDigital */
      $kitDigital = \Drupal::service('jaraba_billing.kit_digital');
      $transitioned = $kitDigital->processExpiredAgreements();
      if ($transitioned > 0) {
        \Drupal::logger('jaraba_billing')->info(
          'Kit Digital cron: @count acuerdos expirados transicionados a justification_pending.',
          ['@count' => $transitioned]
        );
      }
    }
    catch (\Throwable $e) {
      \Drupal::logger('jaraba_billing')->error(
        'Kit Digital cron error: @msg',
        ['@msg' => $e->getMessage()]
      );
    }
  }

  \Drupal::state()->set('jaraba_billing.cron_last_run', $now);
}

/**
 * Implements hook_entity_presave() for saas_plan.
 *
 * STRIPE-CHECKOUT-001 §4.3: Sincroniza automaticamente el plan con Stripe
 * Products/Prices. Aplica PRESAVE-RESILIENCE-001: servicio opcional + try-catch.
 * El save del plan NUNCA falla por errores de Stripe.
 */
function jaraba_billing_saas_plan_presave(\Drupal\Core\Entity\EntityInterface $entity): void {
  // Solo si el servicio existe (modulo habilitado).
  if (!\Drupal::hasService('jaraba_billing.stripe_product_sync')) {
    return;
  }

  // No sincronizar durante imports, syncs o migraciones.
  if ($entity->isSyncing()) {
    return;
  }

  try {
    /** @var \Drupal\jaraba_billing\Service\StripeProductSyncService $syncService */
    $syncService = \Drupal::service('jaraba_billing.stripe_product_sync');
    $result = $syncService->syncPlan($entity);

    // Actualizar campos del entity con los IDs de Stripe.
    if (!empty($result['product_id'])) {
      $entity->set('stripe_product_id', $result['product_id']);
    }
    if (!empty($result['price_monthly_id'])) {
      $entity->set('stripe_price_id', $result['price_monthly_id']);
    }
    if (!empty($result['price_yearly_id'])) {
      $entity->set('stripe_price_yearly_id', $result['price_yearly_id']);
    }

    // Si el plan se desactiva y tenia producto en Stripe, archivar.
    if (!$entity->get('status')->value && !empty($entity->getStripeProductId())) {
      $syncService->archiveProduct($entity->getStripeProductId());
    }
  }
  catch (\Throwable $e) {
    // PRESAVE-RESILIENCE-001: el save del plan NO debe fallar por Stripe.
    \Drupal::logger('jaraba_billing')->error(
      'Stripe sync failed for plan @id: @error',
      ['@id' => $entity->id() ?? 'new', '@error' => $e->getMessage()]
    );
  }
}

/**
 * Implements hook_entity_insert().
 *
 * GAP-M05: Auto-crear Stripe Customer cuando se crea un Tenant.
 */
function jaraba_billing_entity_insert(\Drupal\Core\Entity\EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'tenant') {
    return;
  }

  if (\Drupal::hasService('jaraba_billing.stripe_customer')) {
    try {
      /** @var \Drupal\jaraba_billing\Service\StripeCustomerService $stripeCustomer */
      $stripeCustomer = \Drupal::service('jaraba_billing.stripe_customer');
      $stripeCustomer->createOrGetCustomer($entity);
      \Drupal::logger('jaraba_billing')->info(
        'Stripe customer auto-created for tenant @id.',
        ['@id' => $entity->id()]
      );
    }
    catch (\Throwable $e) {
      \Drupal::logger('jaraba_billing')->error(
        'Auto Stripe customer creation failed for tenant @id: @msg',
        ['@id' => $entity->id(), '@msg' => $e->getMessage()]
      );
    }
  }
}

/**
 * Implements hook_mail().
 *
 * Define subject y body para emails transaccionales de billing.
 * Textos traducibles via t(). Parámetros inyectados desde webhook handlers.
 *
 * Keys:
 * - trial_will_end: Aviso de fin de periodo de prueba.
 * - payment_failed: Notificacion de fallo de pago.
 * - subscription_cancelled: Confirmacion de cancelacion de suscripcion.
 */
function jaraba_billing_mail(string $key, array &$message, array $params): void {
  $siteName = \Drupal::config('system.site')->get('name') ?: 'Jaraba Impact Platform';

  // Estilo inline para párrafos de email (compatible con todos los clientes).
  $pStyle = 'style="margin: 0 0 16px 0; font-family: \'Outfit\', \'Segoe UI\', Arial, sans-serif; font-size: 15px; line-height: 1.7; color: #334155;"';

  // Helper: el email-wrap.html.twig de Symfony Mailer inserta {{ body|nl2br }}
  // en un <td> HTML. Usamos Markup::create() para que Twig no escape el HTML.
  // salto visual en HTML. Cada párrafo debe ir en <p> para espaciado correcto.
  // Nota: t() es el patrón correcto para hook_mail() en PHP ({% trans %} es
  // para Twig). t() registra las cadenas para la interfaz de traducción.
  switch ($key) {
    case 'trial_will_end':
      $tenantLabel = $params['tenant_label'] ?? $siteName;
      $trialEnd = $params['trial_end'] ?? '';
      $message['subject'] = t('Tu período de prueba en @site termina el @date', [
        '@site' => $siteName,
        '@date' => $trialEnd,
      ]);
      $message['body'][] = \Drupal\Core\Render\Markup::create(
        "<p $pStyle>" . t('Hola:') . '</p>'
        . "<p $pStyle>" . t('El período de prueba de @tenant en @site termina el @date.', [
          '@tenant' => $tenantLabel,
          '@site' => $siteName,
          '@date' => $trialEnd,
        ]) . '</p>'
        . "<p $pStyle>" . t('Para continuar disfrutando de todas las funcionalidades, añade un método de pago antes de esa fecha.') . '</p>'
        . "<p $pStyle>" . t('Si ya has configurado tu método de pago, puedes ignorar este mensaje.') . '</p>'
        . "<p $pStyle>" . t('Un saludo,') . '<br>' . t('El equipo de @site', ['@site' => $siteName]) . '</p>'
      );
      break;

    case 'payment_failed':
      $tenantLabel = $params['tenant_label'] ?? $siteName;
      $invoiceId = $params['invoice_id'] ?? '';
      $invoiceLine = $invoiceId ? "<p $pStyle>" . t('Referencia de factura: @id', ['@id' => $invoiceId]) . '</p>' : '';
      $message['subject'] = t('Problema con tu pago en @site', ['@site' => $siteName]);
      $message['body'][] = \Drupal\Core\Render\Markup::create(
        "<p $pStyle>" . t('Hola:') . '</p>'
        . "<p $pStyle>" . t('No hemos podido procesar el pago de tu suscripción de @tenant.', [
          '@tenant' => $tenantLabel,
        ]) . '</p>'
        . $invoiceLine
        . "<p $pStyle>" . t('Por favor, actualiza tu método de pago para evitar la suspensión del servicio.') . '</p>'
        . "<p $pStyle>" . t('Un saludo,') . '<br>' . t('El equipo de @site', ['@site' => $siteName]) . '</p>'
      );
      break;

    case 'subscription_cancelled':
      $tenantLabel = $params['tenant_label'] ?? $siteName;
      $cancelAt = $params['cancel_at'] ?? '';
      $cancelLine = $cancelAt ? "<p $pStyle>" . t('Tu acceso continuará activo hasta el @date.', ['@date' => $cancelAt]) . '</p>' : '';
      $message['subject'] = t('Confirmación de cancelación en @site', ['@site' => $siteName]);
      $message['body'][] = \Drupal\Core\Render\Markup::create(
        "<p $pStyle>" . t('Hola:') . '</p>'
        . "<p $pStyle>" . t('Tu suscripción de @tenant ha sido cancelada.', [
          '@tenant' => $tenantLabel,
        ]) . '</p>'
        . $cancelLine
        . "<p $pStyle>" . t('Si cambias de opinión, puedes reactivar tu suscripción en cualquier momento desde tu panel de control.') . '</p>'
        . "<p $pStyle>" . t('Un saludo,') . '<br>' . t('El equipo de @site', ['@site' => $siteName]) . '</p>'
      );
      break;
  }

  // Dunning emails (DunningService: 6-step payment recovery sequence).
  // Keys: dunning_email_soft, dunning_email_urgent, dunning_restrict,
  //        dunning_suspend, dunning_final_notice, dunning_cancel.
  if (str_starts_with($key, 'dunning_')) {
    $tenantLabel = $params['tenant_label'] ?? $siteName;
    $step = (int) ($params['step'] ?? 0);
    $action = $params['action'] ?? $key;

    $subjects = [
      'dunning_email_soft' => t('Recordatorio: actualiza tu método de pago en @site', ['@site' => $siteName]),
      'dunning_email_urgent' => t('Urgente: tu pago no se ha podido procesar en @site', ['@site' => $siteName]),
      'dunning_restrict' => t('Tu acceso ha sido restringido en @site', ['@site' => $siteName]),
      'dunning_suspend' => t('Tu cuenta ha sido suspendida en @site', ['@site' => $siteName]),
      'dunning_final_notice' => t('Último aviso antes de cancelación en @site', ['@site' => $siteName]),
      'dunning_cancel' => t('Tu suscripción ha sido cancelada en @site', ['@site' => $siteName]),
    ];

    $message['subject'] = $subjects[$key] ?? t('Aviso de pago en @site', ['@site' => $siteName]);

    $dunningBody = "<p $pStyle>" . t('Hola:') . '</p>'
      . "<p $pStyle>" . t('Te escribimos sobre tu suscripción de @tenant en @site.', [
        '@tenant' => $tenantLabel,
        '@site' => $siteName,
      ]) . '</p>';

    if (in_array($key, ['dunning_email_soft', 'dunning_email_urgent'], TRUE)) {
      $dunningBody .= "<p $pStyle>" . t('No hemos podido procesar tu último pago. Por favor, actualiza tu método de pago para mantener tu acceso.') . '</p>';
    }
    elseif ($key === 'dunning_restrict') {
      $dunningBody .= "<p $pStyle>" . t('Debido al impago, hemos restringido temporalmente algunas funcionalidades. Actualiza tu método de pago para restaurar el acceso completo.') . '</p>';
    }
    elseif ($key === 'dunning_suspend') {
      $dunningBody .= "<p $pStyle>" . t('Tu cuenta ha sido suspendida por falta de pago. Actualiza tu método de pago para reactivarla.') . '</p>';
    }
    elseif ($key === 'dunning_final_notice') {
      $dunningBody .= "<p $pStyle>" . t('Este es el último aviso antes de la cancelación definitiva de tu suscripción. Tienes 7 días para regularizar tu situación.') . '</p>';
    }
    elseif ($key === 'dunning_cancel') {
      $dunningBody .= "<p $pStyle>" . t('Tu suscripción ha sido cancelada por falta de pago. Puedes reactivarla en cualquier momento desde tu panel de control.') . '</p>';
    }

    $dunningBody .= "<p $pStyle>" . t('Un saludo,') . '<br>' . t('El equipo de @site', ['@site' => $siteName]) . '</p>';
    $message['body'][] = \Drupal\Core\Render\Markup::create($dunningBody);
  }

  // === KIT DIGITAL — Emails de ciclo de vida del acuerdo ===
  if ($key === 'kit_digital_agreement_created') {
    $message['subject'] = t('Acuerdo Kit Digital creado — @agreement', [
      '@agreement' => $params['agreement_number'] ?? '',
    ]);
    $message['body'][] = \Drupal\Core\Render\Markup::create(
      "<p $pStyle>" . t('Hola:') . '</p>'
      . "<p $pStyle>" . t('Se ha creado el acuerdo Kit Digital @num para @beneficiary.', [
        '@num' => $params['agreement_number'] ?? '',
        '@beneficiary' => $params['beneficiary_name'] ?? '',
      ]) . '</p>'
      . "<p $pStyle>" . t('Paquete: @paquete | Segmento: @segmento | Bono: @bono EUR', [
        '@paquete' => $params['paquete_label'] ?? '',
        '@segmento' => $params['segmento'] ?? '',
        '@bono' => $params['bono_amount'] ?? '0',
      ]) . '</p>'
      . "<p $pStyle>" . t('Un saludo,') . '<br>' . t('El equipo de @site', ['@site' => $siteName]) . '</p>'
    );
  }

  if ($key === 'kit_digital_justification_reminder') {
    $message['subject'] = t('Recordatorio: justificación pendiente — @agreement', [
      '@agreement' => $params['agreement_number'] ?? '',
    ]);
    $message['body'][] = \Drupal\Core\Render\Markup::create(
      "<p $pStyle>" . t('Hola:') . '</p>'
      . "<p $pStyle>" . t('El acuerdo Kit Digital @num con @beneficiary requiere justificación ante Red.es antes del @date.', [
        '@num' => $params['agreement_number'] ?? '',
        '@beneficiary' => $params['beneficiary_name'] ?? '',
        '@date' => $params['justification_deadline'] ?? '',
      ]) . '</p>'
      . "<p $pStyle>" . t('Accede al panel de gestión para preparar la Memoria Técnica de Actuación.') . '</p>'
      . "<p $pStyle>" . t('Un saludo,') . '<br>' . t('El equipo de @site', ['@site' => $siteName]) . '</p>'
    );
  }

  if ($key === 'kit_digital_bono_expiring') {
    $message['subject'] = t('Bono Kit Digital próximo a expirar — @agreement', [
      '@agreement' => $params['agreement_number'] ?? '',
    ]);
    $message['body'][] = \Drupal\Core\Render\Markup::create(
      "<p $pStyle>" . t('Hola:') . '</p>'
      . "<p $pStyle>" . t('El bono digital del acuerdo @num con @beneficiary expira el @date. Tras esa fecha, el tenant pasará a facturación regular vía Stripe.', [
        '@num' => $params['agreement_number'] ?? '',
        '@beneficiary' => $params['beneficiary_name'] ?? '',
        '@date' => $params['end_date'] ?? '',
      ]) . '</p>'
      . "<p $pStyle>" . t('Un saludo,') . '<br>' . t('El equipo de @site', ['@site' => $siteName]) . '</p>'
    );
  }
}

/**
 * Implements hook_theme().
 */
function jaraba_billing_theme(): array {
  $themePath = \Drupal::service('extension.list.theme')
    ->getPath('ecosistema_jaraba_theme') . '/templates';

  return [
    'financial_dashboard' => [
      'variables' => [
        'balance' => 0,
        'usage' => [],
        'forecast' => [],
      ],
      'template' => 'financial-dashboard',
    ],
    'revenue_dashboard' => [
      'variables' => [
        'snapshot' => [],
      ],
      'template' => 'revenue-dashboard',
    ],
    // STRIPE-CHECKOUT-001 §5.3: Checkout templates.
    'checkout_page' => [
      'variables' => [
        'plan' => [],
        'stripe_ready' => FALSE,
        'bizum_enabled' => FALSE,
        'promo_title' => '',
        'promo_text' => '',
        'promo_url' => '',
        'promo_cta' => '',
        'is_admin' => FALSE,
        'admin_edit_url' => '',
        'contact_email' => '',
      ],
      'template' => 'checkout-page',
      'path' => $themePath,
    ],
    'checkout_success' => [
      'variables' => [
        'session' => [],
      ],
      'template' => 'checkout-success',
      'path' => $themePath,
    ],
    'checkout_cancel' => [
      'variables' => [],
      'template' => 'checkout-cancel',
      'path' => $themePath,
    ],
    // KIT-DIGITAL: Landing pages.
    'kit_digital_landing' => [
      'variables' => [
        'paquetes' => [],
        'logos' => [],
      ],
      'template' => 'kit-digital-landing',
      'path' => $themePath,
    ],
    'kit_digital_paquete' => [
      'variables' => [
        'paquete_data' => [],
        'logos' => [],
        'categorias' => [],
      ],
      'template' => 'kit-digital-paquete',
      'path' => $themePath,
    ],
    'kit_digital_admin_dashboard' => [
      'variables' => [
        'snapshot' => [],
      ],
      'template' => 'kit-digital-admin-dashboard',
      'path' => $themePath,
    ],
  ];
}

/**
 * Implements template_preprocess_kit_digital_agreement().
 *
 * ENTITY-PREPROCESS-001: Toda ContentEntity con view mode necesita preprocess.
 */
function template_preprocess_kit_digital_agreement(array &$variables): void {
  if (isset($variables['kit_digital_agreement'])) {
    $entity = $variables['kit_digital_agreement'];
    $variables['agreement_number'] = $entity->get('agreement_number')->value ?? '';
    $variables['beneficiary_name'] = $entity->get('beneficiary_name')->value ?? '';
    $variables['status'] = $entity->get('status')->value ?? 'draft';
  }
}
