<?php

/**
 * @file
 * Primary module hooks for Jaraba Email module.
 */

declare(strict_types=1);

use Drupal\Core\Render\Markup;

/**
 * Implements hook_theme().
 */
function jaraba_email_theme(): array {
  return [
    'email_campaign' => [
      'render element' => 'elements',
    ],
    'email_template_preview' => [
      'variables' => [
        'template' => NULL,
        'preview_data' => [],
      ],
    ],
    'jaraba_email_unsubscribe_confirm' => [
      'variables' => [
        'email' => NULL,
        'process_url' => NULL,
      ],
    ],
  ];
}

/**
 * Implements hook_mail().
 */
function jaraba_email_mail(string $key, array &$message, array $params): void {
  switch ($key) {
    case 'campaign':
    case 'sequence':
      $message['subject'] = $params['subject'];
      // Body is compiled HTML from MjmlCompilerService. Mark as Markup so
      // LegacyMailerHelper::formatBody() uses #markup (renders as-is) instead
      // of #type:processed_text (which HTML-escapes the content).
      $message['body'][] = Markup::create($params['body']);
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
      if (!empty($params['from'])) {
        $message['from'] = $params['from'];
      }
      // GAP-UNSUBSCRIBE: RFC 8058 List-Unsubscribe headers.
      if (\Drupal::hasService('jaraba_email.unsubscribe_token') && !empty($message['to'])) {
        try {
          $headers = \Drupal::service('jaraba_email.unsubscribe_token')
            ->generateListUnsubscribeHeaders($message['to']);
          $message['headers'] += $headers;
        }
        catch (\Throwable $e) {
          // Non-fatal: email sends without unsubscribe headers.
        }
      }
      break;

    case 'double_optin':
      $message['subject'] = $params['subject'];
      $message['body'][] = Markup::create($params['body']);
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
      break;
  }
}
