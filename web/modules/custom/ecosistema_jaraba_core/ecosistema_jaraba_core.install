      'vertical' => 'jarabalex',
      'name' => 'JarabaLex Free',
      'features' => ['legal_search', 'copilot_ia', 'soporte_email'],
      'limits' => '{"cases":5,"searches_per_month":10,"alerts":1,"vault_storage_mb":100,"billing_invoices_month":0,"lexnet_submissions_month":0,"template_generations_month":0}',
      'weight' => 0,
    ],
    [
      'vertical' => 'andalucia_ei',
      'name' => 'Andalucia +ei Free',
      'features' => ['copilot_ia', 'soporte_email'],
      'limits' => '{"participants":5,"sessions_per_month":3,"copilot_uses_per_month":10}',
      'weight' => 0,
    ],
    [
      'vertical' => 'formacion',
      'name' => 'Formacion Free',
      'features' => ['course_builder', 'student_portal', 'copilot_ia', 'soporte_email'],
      'limits' => '{"courses":1,"students_per_course":10,"copilot_uses_per_month":10,"certificates_per_month":5}',
      'weight' => 0,
    ],
  ];

  $entityTypeManager = \Drupal::entityTypeManager();
  $verticalStorage = $entityTypeManager->getStorage('vertical');
  $planStorage = $entityTypeManager->getStorage('saas_plan');
  $logger = \Drupal::logger('ecosistema_jaraba_core');

  // Build vertical machine_name -> entity ID map.
  $verticalMap = [];
  $allVerticals = $verticalStorage->loadMultiple();
  foreach ($allVerticals as $vertical) {
    $verticalMap[$vertical->getMachineName()] = $vertical->id();
  }

  $created = [];
  $skipped = [];
  $errors = [];

  foreach ($freePlans as $planData) {
    try {
      // Check if plan already exists by name (prevent duplicates).
      $existing = $planStorage->loadByProperties(['name' => $planData['name']]);
      if (!empty($existing)) {
        $skipped[] = $planData['name'];
        continue;
      }

      $verticalMachine = $planData['vertical'];
      $verticalId = $verticalMap[$verticalMachine] ?? NULL;

      $entity = $planStorage->create([
        'name' => $planData['name'],
        'vertical' => $verticalId,
        'price_monthly' => '0.00',
        'price_yearly' => '0.00',
        'features' => $planData['features'],
        'limits' => $planData['limits'],
        'stripe_price_id' => '',
        'weight' => $planData['weight'],
        'status' => TRUE,
      ]);
      $entity->save();

      $created[] = $planData['name'];
      $logger->notice('update_9038: Created Free plan "@name" for vertical @vertical.', [
        '@name' => $planData['name'],
        '@vertical' => $verticalMachine,
      ]);
    }
    catch (\Throwable $e) {
      $errors[] = $planData['name'] . ': ' . $e->getMessage();
      $logger->error('update_9038: Error creating "@name": @error', [
        '@name' => $planData['name'],
        '@error' => $e->getMessage(),
      ]);
    }
  }

  $parts = [];
  if (!empty($created)) {
    $parts[] = count($created) . ' Free plans created: ' . implode(', ', $created);
  }
  if (!empty($skipped)) {
    $parts[] = count($skipped) . ' already existed: ' . implode(', ', $skipped);
  }
  if (!empty($errors)) {
    $parts[] = count($errors) . ' errors: ' . implode('; ', $errors);
  }

  return empty($parts) ? 'No Free SaasPlan changes needed.' : implode(' | ', $parts);
}

/**
 * S10-03: Añade columnas funnel_lead_captured y funnel_lead_skipped a demo_analytics.
 *
 * UPDATE-HOOK-CATCH-001: try-catch con \Throwable.
 */
function ecosistema_jaraba_core_update_9039(): string {
  $schema = \Drupal::database()->schema();
  $table = 'demo_analytics';
  $added = [];

  try {
    if (!$schema->fieldExists($table, 'funnel_lead_captured')) {
      $schema->addField($table, 'funnel_lead_captured', [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Funnel: leads capturados via soft gate.',
      ]);
      $added[] = 'funnel_lead_captured';
    }

    if (!$schema->fieldExists($table, 'funnel_lead_skipped')) {
      $schema->addField($table, 'funnel_lead_skipped', [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Funnel: visitantes que saltaron el soft gate.',
      ]);
      $added[] = 'funnel_lead_skipped';
    }
  }
  catch (\Throwable $e) {
    return 'Error adding funnel columns to demo_analytics: ' . $e->getMessage();
  }

  return empty($added)
    ? 'demo_analytics: columnas ya existen.'
    : 'demo_analytics: añadidas ' . implode(', ', $added) . '.';
}

/**
 * Instala la entidad QuizResult (Quiz de Recomendación de Vertical).
 *
 * UPDATE-HOOK-REQUIRED-001: Toda nueva entity DEBE tener hook_update_N().
 */
function ecosistema_jaraba_core_update_9040(): string {
  try {
    $entityTypeManager = \Drupal::entityTypeManager();
    $updateManager = \Drupal::entityDefinitionUpdateManager();

    $entityType = $entityTypeManager->getDefinition('quiz_result');
    if ($entityType) {
      $updateManager->installEntityType($entityType);
      return 'QuizResult entity type installed successfully.';
    }
    return 'QuizResult entity type definition not found — check Entity annotation.';
  }
  catch (\Throwable $e) {
    return 'Error installing QuizResult: ' . $e->getMessage();
  }
}

/**
 * Assign baseline permissions to tenant-member group role.
 *
 * El rol tenant-member tenía permissions: {} (vacío), causando que
 * TODOS los tenant users no pudieran acceder al Page Builder (/my-pages → 403),
 * Content Hub, ni ver las cards de creación de contenido en su perfil.
 *
 * Este hook asigna los permisos básicos que todo miembro de tenant necesita
 * para usar las funcionalidades core del SaaS.
 *
 * Las funcionalidades premium (plantillas premium, A/B testing, admin)
 * se gestionan via PlanValidator + FeatureAccessService, no via permisos.
 */
function ecosistema_jaraba_core_update_9041(): string {
  try {
    $roleStorage = \Drupal::entityTypeManager()->getStorage('group_role');

    /** @var \Drupal\group\Entity\GroupRoleInterface|null $role */
    $role = $roleStorage->load('tenant-member');
    if ($role === NULL) {
      return 'Group role tenant-member not found — skipping.';
    }

    // Permisos básicos para TODO tenant member.
    $permissions = [
      // Page Builder — acceso y CRUD propio.
      'access page builder',
      'view page templates',
      'create page content',
      'view own page content',
      'view any page content',
      'edit own page content',
      'delete own page content',
      'publish own page content',
      'edit page builder content',
      'view page content revisions',
      'view page experiment',

      // Content Hub — acceso y CRUD propio.
      'access content article overview',
      'create content article',
      'edit own content article',
      'delete own content article',
      'publish content article',
      'view unpublished content article',
    ];

    $grantedCount = 0;
    foreach ($permissions as $permission) {
      if (!$role->hasPermission($permission)) {
        $role->grantPermission($permission);
        $grantedCount++;
      }
    }

    $role->save();

    return "Granted $grantedCount permissions to tenant-member role (" . count($permissions) . " total checked).";
  }
  catch (\Throwable $e) {
    return 'Error updating tenant-member permissions: ' . $e->getMessage();
  }
}

/**
 * Create tenant_user Drupal role and assign baseline permissions.
 *
 * Group module permissions (tenant-member) son permisos de GRUPO, no de Drupal.
 * Las rutas con _permission: 'X' verifican permisos GLOBALES de Drupal.
 * Este hook crea un rol Drupal 'tenant_user' con permisos basicos
 * y lo asigna a todos los usuarios que son miembros de al menos un grupo.
 *
 * El control fino de acceso (tenant isolation, plan limits, ownership)
 * se gestiona via AccessControlHandler + PlanValidator, no via permisos.
 */
function ecosistema_jaraba_core_update_9042(): string {
  try {
    $roleStorage = \Drupal::entityTypeManager()->getStorage('user_role');
    $messages = [];

    // 1. Crear rol si no existe.
    $role = $roleStorage->load('tenant_user');
    if ($role === NULL) {
      $role = $roleStorage->create([
        'id' => 'tenant_user',
        'label' => 'Usuario de Tenant',
        'weight' => 5,
      ]);
      $role->save();
      $messages[] = 'Created tenant_user role';
    }

    // 2. Asignar permisos basicos (las rutas verifican estos).
    $permissions = [
      // Page Builder.
      'access page builder',
      'view page templates',
      'create page content',
      'view own page content',
      'view any page content',
      'edit own page content',
      'delete own page content',
      'publish own page content',
      'edit page builder content',
      'view page content revisions',
      'view page experiment',

      // Content Hub.
      'access content article overview',
      'create content article',
      'edit own content article',
      'delete own content article',
      'publish content article',
      'view unpublished content article',
    ];

    $grantedCount = 0;
    foreach ($permissions as $permission) {
      if (!$role->hasPermission($permission)) {
        $role->grantPermission($permission);
        $grantedCount++;
      }
    }
    $role->save();
    $messages[] = "Granted $grantedCount permissions";

    // 3. Asignar rol a usuarios existentes que son miembros de grupo.
    $assignedCount = 0;
    if (\Drupal::moduleHandler()->moduleExists('group')) {
      $userStorage = \Drupal::entityTypeManager()->getStorage('user');
      $membershipStorage = \Drupal::entityTypeManager()->getStorage('group_relationship');

      // Buscar todos los group_relationship de tipo membership.
      $membershipIds = $membershipStorage->getQuery()
        ->accessCheck(FALSE)
        ->condition('type', '%group_membership', 'LIKE')
        ->execute();

      $uids = [];
      if (!empty($membershipIds)) {
        $memberships = $membershipStorage->loadMultiple($membershipIds);
        foreach ($memberships as $membership) {
          $uid = $membership->getEntity()?->id();
          if ($uid !== NULL && $uid > 0) {
            $uids[(int) $uid] = TRUE;
          }
        }
      }

      foreach (array_keys($uids) as $uid) {
        $user = $userStorage->load($uid);
        if ($user !== NULL && !$user->hasRole('tenant_user')) {
          $user->addRole('tenant_user');
          $user->save();
          $assignedCount++;
        }
      }
    }
    $messages[] = "Assigned role to $assignedCount users";

    return implode('. ', $messages) . '.';
  }
  catch (\Throwable $e) {
    return 'Error: ' . $e->getMessage();
  }
}

/**
 * PRICING-4TIER-001: Re-install SaasPlanTier to support 4-tier model (Free).
 *
 * Creates the 'free' SaasPlanTier ConfigEntity (weight=-10) and removes the
 * 'free' alias from the 'starter' tier. This makes the Free plan visible on
 * pricing pages — previously 4 SaasPlan entities existed in DB but only 3
 * SaasPlanTier entities were iterated by MetaSitePricingService.
 *
 * @see \Drupal\ecosistema_jaraba_core\Service\MetaSitePricingService::getPricingPreview()
 */
function ecosistema_jaraba_core_update_9043(): string {
  $messages = [];

  try {
    // 1. Re-install SaasPlanTier entity type definition.
    $edm = \Drupal::entityDefinitionUpdateManager();
    $entity_type = \Drupal::entityTypeManager()->getDefinition('saas_plan_tier');
    if ($entity_type) {
      $edm->installEntityType($entity_type);
      $messages[] = 'SaasPlanTier entity type re-installed';
    }
  }
  catch (\Throwable $e) {
    $messages[] = 'SaasPlanTier install: ' . $e->getMessage();
  }

  try {
    // 2. Create the 'free' tier if it doesn't exist yet.
    $storage = \Drupal::entityTypeManager()->getStorage('saas_plan_tier');
    $freeTier = $storage->load('free');
    if ($freeTier === NULL) {
      $freeTier = $storage->create([
        'id' => 'free',
        'label' => 'Free',
        'tier_key' => 'free',
        'aliases' => ['free', 'gratis', 'gratuito'],
        'stripe_price_monthly' => '',
        'stripe_price_yearly' => '',
        'description' => 'Plan gratuito para explorar la plataforma sin compromiso.',
        'weight' => -10,
      ]);
      $freeTier->save();
      $messages[] = 'Created SaasPlanTier "free" (weight=-10)';
    }
    else {
      $messages[] = 'SaasPlanTier "free" already exists';
    }

    // 3. Remove 'free' alias from 'starter' tier.
    $starterTier = $storage->load('starter');
    if ($starterTier !== NULL) {
      $aliases = $starterTier->getAliases();
      $filtered = array_values(array_filter($aliases, static fn($a) => $a !== 'free'));
      if (count($filtered) !== count($aliases)) {
        $starterTier->set('aliases', $filtered);
        $starterTier->save();
        $messages[] = 'Removed "free" alias from starter tier';
      }
    }
  }
  catch (\Throwable $e) {
    $messages[] = 'Tier creation error: ' . $e->getMessage();
  }

  return implode('. ', $messages) . '.';
}

/**
 * PRICING-4TIER-001 v2: Update all SaasPlan prices + weights in DB.
 *
 * The config/sync YAML files are seed data for fresh installs — they do NOT
 * update existing ContentEntities. This hook applies the pricing changes from
 * the 2026-03-20 audit to the live database:
 *
 * - 8 verticals with price adjustments (Emprendimiento ↓, JarabaLex ↑, etc.)
 * - All annual prices recalculated at 20% discount (was 17%)
 * - All weights normalized to 0/10/20/30 pattern
 *
 * @see docs/analisis/2026-03-20_Auditoria_Definitiva_Pricing_Suscripciones_Modelo_Negocio_SaaS_v1.md
 */
function ecosistema_jaraba_core_update_9044(): string {
  // Price map: entity_id => [monthly, yearly, weight (optional)].
  // Annual = monthly × 12 × 0.80 (20% discount, ANNUAL-DISCOUNT-001).
  $priceUpdates = [
    // Empleabilidad.
    5  => ['monthly' => 19.00,  'yearly' => 182.00],
    6  => ['yearly' => 758.00],
    7  => ['monthly' => 199.00, 'yearly' => 1910.00],
    // Emprendimiento.
    8  => ['monthly' => 19.00,  'yearly' => 182.00],
    9  => ['monthly' => 49.00,  'yearly' => 470.00],
    10 => ['monthly' => 99.00,  'yearly' => 950.00],
    // ComercioConecta.
    11 => ['monthly' => 29.00,  'yearly' => 278.00],
    12 => ['monthly' => 79.00,  'yearly' => 758.00, 'weight' => 20],
    13 => ['yearly' => 1910.00, 'weight' => 30],
    // AgroConecta.
    14 => ['monthly' => 39.00,  'yearly' => 374.00],
    15 => ['yearly' => 1238.00, 'weight' => 20],
    16 => ['yearly' => 2390.00, 'weight' => 30],
    // ServiciosConecta.
    17 => ['monthly' => 19.00,  'yearly' => 182.00],
    18 => ['yearly' => 758.00, 'weight' => 20],
    19 => ['yearly' => 1430.00, 'weight' => 30],
    // Andalucia +ei.
    20 => ['yearly' => 470.00],
    21 => ['monthly' => 129.00, 'yearly' => 1238.00],
    22 => ['yearly' => 2390.00],
    // Formacion (existing entities with old prices).
    23 => ['monthly' => 29.00,  'yearly' => 278.00],
    24 => ['monthly' => 79.00,  'yearly' => 758.00],
    25 => ['monthly' => 149.00, 'yearly' => 1430.00],
    // JarabaLex.
    26 => ['yearly' => 470.00],
    27 => ['monthly' => 149.00, 'yearly' => 1430.00, 'weight' => 20],
    28 => ['monthly' => 299.00, 'yearly' => 2870.00, 'weight' => 30],
  ];

  $storage = \Drupal::entityTypeManager()->getStorage('saas_plan');
  $updated = 0;
  $errors = [];

  foreach ($priceUpdates as $entityId => $changes) {
    try {
      $plan = $storage->load($entityId);
      if ($plan === NULL) {
        $errors[] = "Plan ID $entityId not found";
        continue;
      }

      if (isset($changes['monthly'])) {
        $plan->set('price_monthly', (string) $changes['monthly']);
      }
      if (isset($changes['yearly'])) {
        $plan->set('price_yearly', (string) $changes['yearly']);
      }
      if (isset($changes['weight'])) {
        $plan->set('weight', $changes['weight']);
      }

      $plan->save();
      $updated++;
    }
    catch (\Throwable $e) {
      $errors[] = "Plan $entityId: " . $e->getMessage();
    }
  }

  $msg = "Updated $updated/" . count($priceUpdates) . " plans.";
  if (!empty($errors)) {
    $msg .= ' Errors: ' . implode('; ', $errors);
  }

  return $msg;
}

/**
 * ADDON-PRICING-001: Update addon vertical prices (60% of Starter).
 *
 * Addon prices must be <= Starter price of the corresponding vertical.
 * Rule: addon_price ≈ 60% of Starter, rounded to nearest EUR.
 * Annual: monthly × 12 × 0.80 (20% discount).
 *
 * @see docs/analisis/2026-03-20_Auditoria_Definitiva §7 Coherencia Addon Pricing
 */
function ecosistema_jaraba_core_update_9045(): string {
  // addon_id => [monthly, yearly].
  $addonUpdates = [
    1 => ['monthly' => 12.00, 'yearly' => 115.00],   // Empleabilidad: 60% de 19€
    2 => ['monthly' => 12.00, 'yearly' => 115.00],   // Emprendimiento: 60% de 19€
    3 => ['monthly' => 19.00, 'yearly' => 182.00],   // ComercioConecta: 60% de 29€
    4 => ['monthly' => 25.00, 'yearly' => 240.00],   // AgroConecta: 60% de 39€
    5 => ['monthly' => 29.00, 'yearly' => 278.00],   // JarabaLex: 60% de 49€
    6 => ['monthly' => 12.00, 'yearly' => 115.00],   // ServiciosConecta: 60% de 19€
    7 => ['monthly' => 29.00, 'yearly' => 278.00],   // Andalucia +ei: sin cambio (ya OK)
    8 => ['monthly' => 12.00, 'yearly' => 115.00],   // Content Hub: alineado minimo
    9 => ['monthly' => 19.00, 'yearly' => 182.00],   // Formacion: 60% de 29€
  ];

  $storage = \Drupal::entityTypeManager()->getStorage('addon');
  $updated = 0;
  $errors = [];

  foreach ($addonUpdates as $addonId => $prices) {
    try {
      $addon = $storage->load($addonId);
      if ($addon === NULL) {
        $errors[] = "Addon $addonId not found";
        continue;
      }

      $addon->set('price_monthly', (string) $prices['monthly']);
      $addon->set('price_yearly', (string) $prices['yearly']);
      $addon->save();
      $updated++;
    }
    catch (\Throwable $e) {
      $errors[] = "Addon $addonId: " . $e->getMessage();
    }
  }

  $msg = "ADDON-PRICING-001: Updated $updated/" . count($addonUpdates) . " addon prices.";
  if ($errors !== []) {
    $msg .= ' Errors: ' . implode('; ', $errors);
  }

  return $msg;
}

/**
 * Install PromotionConfig entity type + default Andalucia +ei promotion.
 *
 * UPDATE-HOOK-REQUIRED-001: ConfigEntities tambien necesitan installEntityType.
 * UPDATE-HOOK-CATCH-001: try-catch con \Throwable (NO \Exception).
