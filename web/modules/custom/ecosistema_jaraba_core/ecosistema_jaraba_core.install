    ['vertical' => 'andalucia_ei', 'name' => 'Andalucia +ei Enterprise', 'price_monthly' => '249.00', 'price_yearly' => '2490.00', 'weight' => 30, 'limits' => '{"copilot_sessions_daily": -1, "mentoring_hours_monthly": -1, "sto_exports": -1, "training_modules": -1, "diagnostic_access": -1, "report_downloads": -1}'],
    // --- FORMACION: Free / 39€ / 149€ ---
    ['vertical' => 'formacion', 'name' => 'Formacion Starter', 'price_monthly' => '0.00', 'price_yearly' => '0.00', 'weight' => 10, 'limits' => '{"courses": 1, "students_per_course": 10, "certifications_month": 5, "learning_paths": 0, "xapi_tracking": 0, "gamification": 0, "copilot_uses_per_month": 5, "storage_gb": 1}'],
    ['vertical' => 'formacion', 'name' => 'Formacion Profesional', 'price_monthly' => '39.00', 'price_yearly' => '390.00', 'weight' => 20, 'limits' => '{"courses": 10, "students_per_course": 500, "certifications_month": -1, "learning_paths": -1, "xapi_tracking": 0, "gamification": -1, "copilot_uses_per_month": -1, "storage_gb": 25}'],
    ['vertical' => 'formacion', 'name' => 'Formacion Enterprise', 'price_monthly' => '149.00', 'price_yearly' => '1490.00', 'weight' => 30, 'limits' => '{"courses": -1, "students_per_course": -1, "certifications_month": -1, "learning_paths": -1, "xapi_tracking": -1, "gamification": -1, "copilot_uses_per_month": -1, "storage_gb": -1}'],
  ];

  // Resolve vertical entity IDs by machine_name.
  $verticalMap = [];
  $allVerticals = $verticalStorage->loadMultiple();
  foreach ($allVerticals as $vertical) {
    $verticalMap[$vertical->getMachineName()] = $vertical->id();
  }

  foreach ($plans as $planData) {
    $verticalMachine = $planData['vertical'];
    if (!isset($verticalMap[$verticalMachine])) {
      continue;
    }

    // Check if plan already exists (idempotent by name).
    $existing = $planStorage->loadByProperties(['name' => $planData['name']]);
    if (!empty($existing)) {
      continue;
    }

    $entity = $planStorage->create([
      'name' => $planData['name'],
      'vertical' => $verticalMap[$verticalMachine],
      'price_monthly' => $planData['price_monthly'],
      'price_yearly' => $planData['price_yearly'],
      'limits' => $planData['limits'],
      'weight' => $planData['weight'],
      'status' => TRUE,
    ]);
    $entity->save();
    $created[] = $planData['name'];
  }

  // Deactivate generic plans (basico, profesional, enterprise) that have no vertical.
  $genericPlans = $planStorage->getQuery()
    ->accessCheck(FALSE)
    ->notExists('vertical')
    ->condition('status', TRUE)
    ->execute();

  foreach ($planStorage->loadMultiple($genericPlans) as $genericPlan) {
    $genericPlan->set('status', FALSE);
    $genericPlan->save();
    $deactivated[] = $genericPlan->getName();
  }

  $msg = 'VERT-PRICING-001: Created SaasPlan entities: ' . (empty($created) ? 'none' : implode(', ', $created));
  if (!empty($deactivated)) {
    $msg .= '. Deactivated generic plans: ' . implode(', ', $deactivated);
  }
  return $msg;
}

/**
 * GAP-FVL-LMS: Create formacion_feature_usage table.
 */
function ecosistema_jaraba_core_update_9027(): string {
  $database = \Drupal::database();

  if ($database->schema()->tableExists('formacion_feature_usage')) {
    return 'Table formacion_feature_usage already exists.';
  }

  $database->schema()->createTable('formacion_feature_usage', [
    'description' => 'Tracking de uso de features del vertical formacion.',
    'fields' => [
      'id' => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
      'user_id' => ['type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE],
      'feature_key' => ['type' => 'varchar', 'length' => 128, 'not null' => TRUE],
      'usage_date' => ['type' => 'varchar', 'length' => 10, 'not null' => TRUE],
      'usage_count' => ['type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'user_feature_date' => ['user_id', 'feature_key', 'usage_date'],
      'feature_date' => ['feature_key', 'usage_date'],
    ],
  ]);

  \Drupal::logger('ecosistema_jaraba_core')->notice('Tabla formacion_feature_usage creada (GAP-FVL-LMS).');
  return 'Created formacion_feature_usage table.';
}

