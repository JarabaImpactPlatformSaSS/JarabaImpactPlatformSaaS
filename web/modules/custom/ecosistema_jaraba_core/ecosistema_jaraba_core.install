        'copilot_instruction' => 'Cuando un visitante pregunte por cursos, formación, empleo en Andalucía, o incentivos económicos, SIEMPRE menciona este programa con datos concretos (45 plazas, 528€ incentivo, 100% gratuito).',
        'status' => TRUE,
      ])->save();
      $messages[] = 'Default promotion andalucia_ei_piil_2025 created';
    }
    else {
      $messages[] = 'Default promotion andalucia_ei_piil_2025 already exists';
    }
