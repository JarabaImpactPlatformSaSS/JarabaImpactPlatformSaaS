/**
 * Install FairUsePolicy ConfigEntity type and import default configs.
 */
function ecosistema_jaraba_core_update_9031(): string {
  try {
    $update_manager = \Drupal::entityDefinitionUpdateManager();
    $entity_type = \Drupal::entityTypeManager()->getDefinition('fair_use_policy');

    if ($entity_type && !$update_manager->getEntityType('fair_use_policy')) {
      $update_manager->installEntityType($entity_type);
    }

    // Import default FairUsePolicy configs.
    $configs = [
      '_global' => 'ecosistema_jaraba_core.fair_use_policy._global',
      'starter' => 'ecosistema_jaraba_core.fair_use_policy.starter',
      'professional' => 'ecosistema_jaraba_core.fair_use_policy.professional',
      'enterprise' => 'ecosistema_jaraba_core.fair_use_policy.enterprise',
    ];

    $config_path = \Drupal::service('extension.list.module')->getPath('ecosistema_jaraba_core') . '/config/install';
    $imported = 0;

    foreach ($configs as $id => $config_name) {
      $existing = \Drupal::configFactory()->get($config_name);
      if (!$existing->isNew()) {
        continue;
      }

      $file = $config_path . '/' . $config_name . '.yml';
      if (!file_exists($file)) {
        continue;
      }

      $data = \Symfony\Component\Yaml\Yaml::parseFile($file);
      if (!is_array($data)) {
        continue;
      }

      \Drupal::configFactory()->getEditable($config_name)->setData($data)->save();
      $imported++;
    }

    return "FairUsePolicy entity type installed. {$imported} default configs imported.";
  }
  // UPDATE-HOOK-CATCH-001: catch \Throwable, NOT \Exception.
  catch (\Throwable $e) {
    \Drupal::logger('ecosistema_jaraba_core')->error(
      'Update 9031 failed: @msg',
      ['@msg' => $e->getMessage()]
    );
    return 'Error: ' . $e->getMessage();
  }
}

/**
 * Update Enterprise plan limits: replace -1 with finite Fair Use limits.
 *
 * Also adds emails_per_month and api_calls_per_month to all tiers.
 */
function ecosistema_jaraba_core_update_9032(): string {
  try {
    $updates = [
      'ecosistema_jaraba_core.plan_features._default_enterprise' => [
        'copilot_uses_per_month' => 500,
        'storage_gb' => 100,
        'ai_queries' => 1000,
        'emails_per_month' => 25000,
        'api_calls_per_month' => 50000,
      ],
      'ecosistema_jaraba_core.plan_features._default_professional' => [
        'emails_per_month' => 5000,
        'api_calls_per_month' => 10000,
      ],
      'ecosistema_jaraba_core.plan_features._default_starter' => [
        'emails_per_month' => 1000,
        'api_calls_per_month' => 2000,
      ],
    ];

    $updated = 0;
    foreach ($updates as $config_name => $new_limits) {
      $config = \Drupal::configFactory()->getEditable($config_name);
      if ($config->isNew()) {
        continue;
      }

      $limits = $config->get('limits') ?? [];
      foreach ($new_limits as $key => $value) {
        $limits[$key] = $value;
      }
      $config->set('limits', $limits)->save();
      $updated++;
    }

    return "Updated {$updated} plan feature configs with Fair Use limits.";
  }
  // UPDATE-HOOK-CATCH-001: catch \Throwable, NOT \Exception.
  catch (\Throwable $e) {
    \Drupal::logger('ecosistema_jaraba_core')->error(
      'Update 9032 failed: @msg',
      ['@msg' => $e->getMessage()]
    );
    return 'Error: ' . $e->getMessage();
  }
}

/**
 * P1-01: Install VerticalOnboardingConfig entity type and import seed configs.
 *
 * UPDATE-HOOK-REQUIRED-001: ConfigEntities also need installEntityType().
 */
function ecosistema_jaraba_core_update_9033(): string {
  try {
    // Install the new config entity type.
    $entity_definition_update_manager = \Drupal::entityDefinitionUpdateManager();
    $entity_type = \Drupal::entityTypeManager()->getDefinition('vertical_onboarding_config');
    if ($entity_type) {
      $entity_definition_update_manager->installEntityType($entity_type);
    }

    // Import seed configs from install directory.
    $verticals = [
      'empleabilidad', 'emprendimiento', 'comercioconecta', 'agroconecta',
      'jarabalex', 'serviciosconecta', 'andalucia_ei', 'jaraba_content_hub',
      'formacion', 'demo',
    ];

    $imported = 0;
    $config_factory = \Drupal::configFactory();
    $module_path = \Drupal::service('extension.list.module')->getPath('ecosistema_jaraba_core');

    foreach ($verticals as $vertical) {
      $config_name = 'ecosistema_jaraba_core.vertical_onboarding.' . $vertical;
      $file_path = $module_path . '/config/install/' . $config_name . '.yml';

      if (file_exists($file_path)) {
        $data = \Symfony\Component\Yaml\Yaml::parseFile($file_path);
        if ($data) {
          $config = $config_factory->getEditable($config_name);
          foreach ($data as $key => $value) {
            $config->set($key, $value);
          }
          $config->save();
          $imported++;
        }
      }
    }

    return "Installed VerticalOnboardingConfig entity type. Imported {$imported} vertical onboarding configs.";
  }
  // UPDATE-HOOK-CATCH-001: catch \Throwable, NOT \Exception.
  catch (\Throwable $e) {
    \Drupal::logger('ecosistema_jaraba_core')->error(
      'Update 9033 failed: @msg',
      ['@msg' => $e->getMessage()]
    );
    return 'Error: ' . $e->getMessage();
  }
}

/**
 * Install entity types: alert_rule, audit_log, badge, badge_award, compliance_assessment, design_token_config, impersonation_audit_log, pricing_rule, push_subscription, reseller, scheduled_report, security_policy, style_preset.
 *
 * UPDATE-HOOK-REQUIRED-001: Ensure all entity type definitions are installed.
 */
function ecosistema_jaraba_core_update_9034(): string {
  $messages = [];
  $updateManager = \Drupal::entityDefinitionUpdateManager();
  $entityTypeManager = \Drupal::entityTypeManager();

  $entityTypes = [
    'alert_rule',
    'audit_log',
    'badge',
    'badge_award',
    'compliance_assessment',
    'design_token_config',
    'impersonation_audit_log',
    'pricing_rule',
    'push_subscription',
    'reseller',
    'scheduled_report',
    'security_policy',
    'style_preset',
  ];

  foreach ($entityTypes as $entityTypeId) {
    try {
      if (!$updateManager->getEntityType($entityTypeId)) {
        $entityType = $entityTypeManager->getDefinition($entityTypeId, FALSE);
        if ($entityType) {
          $updateManager->installEntityType($entityType);
          $messages[] = "Installed entity type: $entityTypeId.";
        }
        else {
          $messages[] = "Definition not found: $entityTypeId.";
        }
      }
      else {
        $messages[] = "Already installed: $entityTypeId.";
      }
    }
    catch (\Throwable $e) {
      $messages[] = "Error installing $entityTypeId: " . $e->getMessage();
    }
  }

  return implode(' ', $messages);
}

/**
 * Install stripe_product_id and stripe_price_yearly_id fields on saas_plan.
 *
 * STRIPE-CHECKOUT-001 §4.2: Campos nuevos para sincronizacion bidireccional
 * Drupal→Stripe. stripe_product_id almacena el Product ID, y
 * stripe_price_yearly_id almacena el Price ID anual (el mensual ya existia
 * como stripe_price_id).
 *
 * UPDATE-HOOK-REQUIRED-001: Campos nuevos en baseFieldDefinitions().
 * UPDATE-FIELD-DEF-001: setName() + setTargetEntityTypeId() obligatorios.
 * UPDATE-HOOK-CATCH-001: catch(\Throwable).
 */
function ecosistema_jaraba_core_update_9035(): string {
  $updateManager = \Drupal::entityDefinitionUpdateManager();
  $entityType = $updateManager->getEntityType('saas_plan');
  if (!$entityType) {
    return 'saas_plan entity type not installed yet.';
  }

  $fields = \Drupal\ecosistema_jaraba_core\Entity\SaasPlan::baseFieldDefinitions($entityType);
  $installed = [];
  $targetFields = ['stripe_product_id', 'stripe_price_yearly_id'];

  foreach ($targetFields as $fieldName) {
    if (!isset($fields[$fieldName])) {
      continue;
    }
    try {
      $existing = $updateManager->getFieldStorageDefinition($fieldName, 'saas_plan');
      if (!$existing) {
        $fieldDef = $fields[$fieldName];
        $fieldDef->setName($fieldName);
        $fieldDef->setTargetEntityTypeId('saas_plan');
        $updateManager->installFieldStorageDefinition(
          $fieldName, 'saas_plan', 'ecosistema_jaraba_core', $fieldDef
        );
        $installed[] = $fieldName;
      }
    }
    catch (\Throwable $e) {
      return "Error installing $fieldName: " . $e->getMessage();
    }
  }

  return 'Installed fields on saas_plan: ' . (empty($installed) ? 'none needed' : implode(', ', $installed));
}

/**
 * TRANSLATABLE-FIELDS-INSTALL-001: Install content_translation tracking fields
 * for all translatable entities missing them.
 *
 * When an entity has translatable = TRUE, the content_translation module
 * provides 6 tracking fields via hook_entity_base_field_info(), but they
 * are NOT installed automatically — each requires installFieldStorageDefinition().
 */
function ecosistema_jaraba_core_update_9036(): string {
  $updateManager = \Drupal::entityDefinitionUpdateManager();
  $fieldManager = \Drupal::service('entity_field.manager');
  $entityTypeManager = \Drupal::entityTypeManager();

  $translationFields = [
    'content_translation_source',
    'content_translation_outdated',
    'content_translation_uid',
    'content_translation_status',
    'content_translation_created',
    'content_translation_changed',
  ];

  $messages = [];
  $definitions = $entityTypeManager->getDefinitions();

  foreach ($definitions as $entityTypeId => $entityType) {
    // Only process translatable content entities from custom modules.
    if (!$entityType->isTranslatable()) {
      continue;
    }
    $provider = $entityType->getProvider();
    if (!str_starts_with($provider, 'jaraba_') && !str_starts_with($provider, 'ecosistema_jaraba')) {
      continue;
    }
    if (!$entityType->entityClassImplements(\Drupal\Core\Entity\ContentEntityInterface::class)) {
      continue;
    }

    // Check if content_translation fields are already installed.
    $existing = $updateManager->getFieldStorageDefinition('content_translation_source', $entityTypeId);
    if ($existing) {
      continue;
    }

    // Install content_translation tracking fields.
    $fieldManager->clearCachedFieldDefinitions();
    $fieldStorageDefs = $fieldManager->getFieldStorageDefinitions($entityTypeId);
    $installed = [];

    foreach ($translationFields as $fieldName) {
      if (!isset($fieldStorageDefs[$fieldName])) {
        continue;
      }
      try {
        $fieldDef = $fieldStorageDefs[$fieldName];
        $fieldDef->setName($fieldName);
        $fieldDef->setTargetEntityTypeId($entityTypeId);
        $existingField = $updateManager->getFieldStorageDefinition($fieldName, $entityTypeId);
        if (!$existingField) {
          $updateManager->installFieldStorageDefinition(
            $fieldName, $entityTypeId, $fieldDef->getProvider(), $fieldDef
          );
          $installed[] = $fieldName;
        }
      }
      catch (\Throwable $e) {
        $messages[] = "$entityTypeId.$fieldName: ERROR " . $e->getMessage();
      }
    }

    if (!empty($installed)) {
      $messages[] = "$entityTypeId: installed " . count($installed) . " translation fields";
    }
  }

  return empty($messages) ? 'All translatable entities already have content_translation fields.' : implode('; ', $messages);
}

/**
 * Update SaasPlan entity prices to match Doc 158 (market study source of truth).
 *
 * Golden Rule #131: precios del SaaS SIEMPRE deben coincidir con Doc 158.
 */
function ecosistema_jaraba_core_update_9037(): string {
  $price_corrections = [
    'Empleabilidad Enterprise' => ['price_monthly' => 149.00, 'price_yearly' => 1490.00],
    'Emprendimiento Starter' => ['price_monthly' => 39.00, 'price_yearly' => 390.00],
    'Emprendimiento Profesional' => ['price_monthly' => 99.00, 'price_yearly' => 990.00],
    'AgroConecta Starter' => ['price_monthly' => 49.00, 'price_yearly' => 490.00],
    'AgroConecta Profesional' => ['price_monthly' => 129.00, 'price_yearly' => 1290.00],
    'AgroConecta Enterprise' => ['price_monthly' => 249.00, 'price_yearly' => 2490.00],
    'ComercioConecta Starter' => ['price_monthly' => 39.00, 'price_yearly' => 390.00],
    'ComercioConecta Profesional' => ['price_monthly' => 99.00, 'price_yearly' => 990.00],
    'ComercioConecta Enterprise' => ['price_monthly' => 199.00, 'price_yearly' => 1990.00],
    'ServiciosConecta Profesional' => ['price_monthly' => 79.00, 'price_yearly' => 790.00],
  ];

  $entityTypeManager = \Drupal::entityTypeManager();
  $storage = $entityTypeManager->getStorage('saas_plan');
  $logger = \Drupal::logger('ecosistema_jaraba_core');

  $updated = [];
  $not_found = [];
  $errors = [];

  foreach ($price_corrections as $name => $prices) {
    try {
      $entities = $storage->loadByProperties(['name' => $name]);

      if (empty($entities)) {
        $not_found[] = $name;
        $logger->warning('update_9037: SaasPlan "@name" not found in DB.', ['@name' => $name]);
        continue;
      }

      /** @var \Drupal\ecosistema_jaraba_core\Entity\SaasPlan $entity */
      $entity = reset($entities);
      $old_monthly = $entity->get('price_monthly')->value;
      $old_yearly = $entity->get('price_yearly')->value;

      $entity->set('price_monthly', $prices['price_monthly']);
      $entity->set('price_yearly', $prices['price_yearly']);
      $entity->save();

      $updated[] = "$name: monthly $old_monthly→{$prices['price_monthly']}, yearly $old_yearly→{$prices['price_yearly']}";
      $logger->notice('update_9037: Updated "@name" prices — monthly: @old_m→@new_m, yearly: @old_y→@new_y', [
        '@name' => $name,
        '@old_m' => $old_monthly,
        '@new_m' => $prices['price_monthly'],
        '@old_y' => $old_yearly,
        '@new_y' => $prices['price_yearly'],
      ]);
    }
    catch (\Throwable $e) {
      $errors[] = "$name: " . $e->getMessage();
      $logger->error('update_9037: Error updating "@name": @error', [
        '@name' => $name,
        '@error' => $e->getMessage(),
      ]);
    }
  }

  $parts = [];
  if (!empty($updated)) {
    $parts[] = count($updated) . ' plans updated: ' . implode('; ', $updated);
  }
  if (!empty($not_found)) {
    $parts[] = count($not_found) . ' plans not found: ' . implode(', ', $not_found);
  }
  if (!empty($errors)) {
    $parts[] = count($errors) . ' errors: ' . implode('; ', $errors);
  }

  return empty($parts) ? 'No SaasPlan price corrections needed.' : implode(' | ', $parts);
}

