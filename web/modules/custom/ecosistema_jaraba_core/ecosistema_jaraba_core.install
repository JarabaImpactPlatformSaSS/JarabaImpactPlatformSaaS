/**
 * GAP-CURRENCY + GAP-TIMEZONE: Add currency and timezone fields to Tenant.
 *
 * UPDATE-HOOK-REQUIRED-001: New baseFieldDefinitions require update hook.
 * UPDATE-HOOK-CATCH-001: \Throwable (not \Exception).
 * UPDATE-FIELD-DEF-001: setName() + setTargetEntityTypeId() required.
 */
function ecosistema_jaraba_core_update_9029(): string {
  $messages = [];
  $updateManager = \Drupal::entityDefinitionUpdateManager();

  // 1. Add currency field.
  try {
    $currencyField = \Drupal\Core\Field\BaseFieldDefinition::create('list_string')
      ->setName('currency')
      ->setTargetEntityTypeId('tenant')
      ->setLabel(t('Moneda'))
      ->setDescription(t('Moneda principal del tenant (ISO 4217).'))
      ->setDefaultValue('EUR')
      ->setSetting('allowed_values', [
        'EUR' => 'EUR — Euro',
        'USD' => 'USD — US Dollar',
        'GBP' => 'GBP — British Pound',
        'BRL' => 'BRL — Real Brasileño',
        'MXN' => 'MXN — Peso Mexicano',
        'COP' => 'COP — Peso Colombiano',
        'ARS' => 'ARS — Peso Argentino',
      ]);

    if (!$updateManager->getFieldStorageDefinition('currency', 'tenant')) {
      $updateManager->installFieldStorageDefinition('currency', 'tenant', 'ecosistema_jaraba_core', $currencyField);
      $messages[] = 'Installed currency field on tenant entity.';
    }
    else {
      $messages[] = 'Currency field already exists on tenant entity.';
    }
  }
  catch (\Throwable $e) {
    $messages[] = 'Error installing currency field: ' . $e->getMessage();
    \Drupal::logger('ecosistema_jaraba_core')->error('Update 9029 currency error: @error', [
      '@error' => $e->getMessage(),
    ]);
  }

  // 2. Add timezone field.
  try {
    $timezoneField = \Drupal\Core\Field\BaseFieldDefinition::create('string')
      ->setName('timezone')
      ->setTargetEntityTypeId('tenant')
      ->setLabel(t('Zona horaria'))
      ->setDescription(t('Zona horaria IANA del tenant (ej: Europe/Madrid).'))
      ->setDefaultValue('Europe/Madrid')
      ->setSetting('max_length', 64);

    if (!$updateManager->getFieldStorageDefinition('timezone', 'tenant')) {
      $updateManager->installFieldStorageDefinition('timezone', 'tenant', 'ecosistema_jaraba_core', $timezoneField);
      $messages[] = 'Installed timezone field on tenant entity.';
    }
    else {
      $messages[] = 'Timezone field already exists on tenant entity.';
    }
  }
  catch (\Throwable $e) {
    $messages[] = 'Error installing timezone field: ' . $e->getMessage();
    \Drupal::logger('ecosistema_jaraba_core')->error('Update 9029 timezone error: @error', [
      '@error' => $e->getMessage(),
    ]);
  }

  return implode(' ', $messages);
}

/**
