    // --- ANDALUCIA_EI (institutional, no free tier) ---
    ['vertical' => 'andalucia_ei', 'name' => 'Andalucia +ei Starter', 'price_monthly' => '49.00', 'price_yearly' => '490.00', 'weight' => 10, 'limits' => '{"copilot_sessions_daily": 15, "mentoring_hours_monthly": 5, "sto_exports": 10, "training_modules": 10, "diagnostic_access": 3, "report_downloads": 5}'],
