{#
/**
 * @file
 * Template para la pagina de Configuracion Self-Service del Tenant.
 *
 * Variables:
 * - tenant: Entidad del tenant actual
 * - sections: Array de TenantSettingsSectionInterface objects
 *   Cada section tiene: getId(), getLabel(), getIcon(), getDescription(),
 *   getRoute(), getRouteParameters(), getStatus()
 *
 * ZERO-REGION-001: Sin CSS inline, sin regions Drupal.
 * CSS-VAR-ALL-COLORS-001: Todos los colores via --ej-* tokens.
 * ICON-CONVENTION-001: jaraba_icon() con variante duotone, categoria ui.
 * i18n: Todos los textos en {% trans %} bloques.
 */
#}

<div class="tenant-settings" data-tenant-settings>

  {# --- Premium Hero Header with Particles --- #}
  <header class="tenant-settings__hero">
    <canvas class="tenant-settings__particles" data-dashboard-particles aria-hidden="true"></canvas>
    <div class="tenant-settings__hero-content">
      <div class="tenant-settings__hero-icon">
        {{ jaraba_icon('ui', 'settings', { variant: 'duotone', color: 'white', size: '40px' }) }}
      </div>
      <div class="tenant-settings__hero-text">
        <h1 class="tenant-settings__title">{% trans %}Configuracion{% endtrans %}</h1>
        {% if tenant %}
          <p class="tenant-settings__subtitle">
            {% trans %}Gestiona la configuracion de tu organizacion{% endtrans %}
          </p>
        {% endif %}
      </div>
    </div>
    <div class="tenant-settings__hero-actions">
      <a href="{{ path('ecosistema_jaraba_core.tenant_self_service.dashboard') }}"
         class="tenant-settings__back-link"
         aria-label="{% trans %}Volver al panel de control{% endtrans %}">
        {{ jaraba_icon('ui', 'arrow-left', { variant: 'duotone', color: 'white', size: '18px' }) }}
        {% trans %}Dashboard{% endtrans %}
      </a>
    </div>
    <div class="tenant-settings__hero-glow" aria-hidden="true"></div>
  </header>

  {# --- Buscador client-side --- #}
  <div class="tenant-settings__search" role="search">
    <label for="tenant-settings-search" class="visually-hidden">
      {% trans %}Buscar configuracion{% endtrans %}
    </label>
    <div class="tenant-settings__search-wrapper">
      <span class="tenant-settings__search-icon" aria-hidden="true">
        {{ jaraba_icon('ui', 'search', { variant: 'duotone', size: '18px' }) }}
      </span>
      <input type="search"
             id="tenant-settings-search"
             class="tenant-settings__search-input"
             placeholder="{% trans %}Buscar ajustes...{% endtrans %}"
             data-tenant-settings-search
             autocomplete="off" />
    </div>
  </div>

  {# --- Grid de secciones premium --- #}
  <div class="tenant-settings__grid" role="list">
    {% for section in sections %}
      <article class="tenant-settings-card"
               role="listitem"
               data-section-id="{{ section.getId() }}"
               data-section-label="{{ section.getLabel() }}"
               data-section-description="{{ section.getDescription() }}">

        <div class="tenant-settings-card__shine" aria-hidden="true"></div>

        <div class="tenant-settings-card__icon-wrapper">
          {% set icon = section.getIcon() %}
          {{ jaraba_icon(icon.category, icon.name, { variant: 'duotone', color: 'azul-corporativo', size: '28px' }) }}
        </div>

        <div class="tenant-settings-card__content">
          <h3 class="tenant-settings-card__title">{{ section.getLabel() }}</h3>
          <p class="tenant-settings-card__description">{{ section.getDescription() }}</p>
        </div>

        <div class="tenant-settings-card__footer">
          <span class="tenant-settings-card__status">{{ section.getStatus() }}</span>
          <a href="{{ path(section.getRoute(), section.getRouteParameters()) }}"
             class="tenant-settings-card__link"
             aria-label="{{ section.getLabel() }}">
            {% trans %}Configurar{% endtrans %}
            {{ jaraba_icon('ui', 'chevron-right', { variant: 'duotone', size: '14px' }) }}
          </a>
        </div>
      </article>
    {% else %}
      <div class="tenant-settings__empty">
        <p>{% trans %}No hay secciones de configuracion disponibles.{% endtrans %}</p>
      </div>
    {% endfor %}
  </div>

  {# --- Mensaje cuando la busqueda no encuentra resultados --- #}
  <div class="tenant-settings__no-results" data-tenant-settings-no-results hidden>
    <p>{% trans %}No se encontraron ajustes que coincidan con tu busqueda.{% endtrans %}</p>
  </div>

</div>
