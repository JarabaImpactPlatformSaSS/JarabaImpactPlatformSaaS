{#
/**
 * @file ecosistema-jaraba-change-plan.html.twig
 *
 * Comparador de planes para cambio de suscripcion del tenant.
 * Ruta: /tenant/change-plan
 *
 * Variables:
 *   - tenant: TenantInterface entity
 *   - current_plan: SaasPlan entity (o NULL)
 *   - plans: array de planes con id, name, monthly_price, yearly_price,
 *            max_producers, max_storage_mb, features, is_current, stripe_price_id
 *   - back_url: Url al dashboard del tenant
 *
 * Directrices:
 *   - i18n: {% trans %} en todo texto estatico (NO filtro |t)
 *   - ICON-CONVENTION-001, ICON-DUOTONE-001: jaraba_icon() siempre
 *   - CSS-VAR-ALL-COLORS-001: var(--ej-*) con fallbacks
 *   - ROUTE-LANGPREFIX-001: URLs via path()
 *   - NO-HARDCODE-PRICE-001: precios desde el array plans (BD)
 */
#}

<div class="change-plan-page">

  {# === HEADER === #}
  <header class="change-plan-page__header">
    {% if back_url %}
      <a href="{{ back_url }}" class="change-plan-page__back" aria-label="{% trans %}Volver al dashboard{% endtrans %}">
        {{ jaraba_icon('ui', 'arrow-left', { variant: 'outline', size: '18px' }) }}
        {% trans %}Volver{% endtrans %}
      </a>
    {% endif %}
    <h1 class="change-plan-page__title">{% trans %}Cambiar de plan{% endtrans %}</h1>
    <p class="change-plan-page__subtitle">
      {% if current_plan %}
        {% set plan_label = current_plan.label %}
        {% trans %}Tu plan actual es <strong>{{ plan_label }}</strong>. Compara y elige el que mejor se adapte a tu organización.{% endtrans %}
      {% else %}
        {% trans %}Elige el plan que mejor se adapte a las necesidades de tu organización.{% endtrans %}
      {% endif %}
    </p>
  </header>

  {# === GRID DE PLANES === #}
  {% if plans is not empty %}
    <div class="plans-grid" role="list" aria-label="{% trans %}Planes disponibles{% endtrans %}">
      {% for plan in plans %}
        <article class="plan-card{% if plan.is_current %} plan-card--current{% endif %}"
                 role="listitem"
                 aria-labelledby="plan-{{ plan.id }}">

          {# Badge plan actual #}
          {% if plan.is_current %}
            <div class="plan-card__badge">
              {{ jaraba_icon('status', 'check-circle', { variant: 'duotone', size: '14px', color: 'verde-innovacion' }) }}
              {% trans %}Plan actual{% endtrans %}
            </div>
          {% endif %}

          {# Nombre #}
          <h2 id="plan-{{ plan.id }}" class="plan-card__name">{{ plan.name }}</h2>

          {# Precio mensual #}
          <div class="plan-card__price">
            {% if plan.monthly_price <= 0 %}
              <span class="plan-card__price-value">{% trans %}Gratis{% endtrans %}</span>
            {% else %}
              <span class="plan-card__price-value">{{ plan.monthly_price|number_format(0, ',', '.') }}&euro;</span>
              <span class="plan-card__price-period">/{% trans %}mes{% endtrans %}</span>
              <span class="plan-card__price-tax">{% trans %}+ IVA{% endtrans %}</span>
            {% endif %}
          </div>

          {# Precio anual si disponible #}
          {% if plan.yearly_price > 0 and plan.monthly_price > 0 %}
            {% set yearly_monthly = (plan.yearly_price / 12)|round(0) %}
            {% set savings_pct = (((plan.monthly_price * 12 - plan.yearly_price) / (plan.monthly_price * 12)) * 100)|round(0) %}
            <p class="plan-card__yearly-note">
              {% trans %}{{ yearly_monthly|number_format(0, ',', '.') }}&euro;/mes anual{% endtrans %}
              {% if savings_pct > 0 %}
                <strong>(-{{ savings_pct }}%)</strong>
              {% endif %}
            </p>
          {% endif %}

          {# Limites #}
          <div class="plan-card__limits">
            {% if plan.max_producers > 0 %}
              <div class="plan-card__limit">
                {{ jaraba_icon('ui', 'users', { variant: 'duotone', size: '16px', color: 'azul-corporativo' }) }}
                <span>
                  {% if plan.max_producers >= 9999 %}
                    {% trans %}Productores ilimitados{% endtrans %}
                  {% else %}
                    {% trans %}{{ plan.max_producers }} productores{% endtrans %}
                  {% endif %}
                </span>
              </div>
            {% endif %}
            {% if plan.max_storage_mb > 0 %}
              {% set storage_gb = (plan.max_storage_mb / 1024)|round(0) %}
              <div class="plan-card__limit">
                {{ jaraba_icon('ui', 'database', { variant: 'duotone', size: '16px', color: 'azul-corporativo' }) }}
                <span>
                  {% if plan.max_storage_mb >= 99999 %}
                    {% trans %}Almacenamiento ilimitado{% endtrans %}
                  {% else %}
                    {{ storage_gb }} GB {% trans %}almacenamiento{% endtrans %}
                  {% endif %}
                </span>
              </div>
            {% endif %}
          </div>

          {# Features #}
          {% if plan.features is iterable and plan.features is not empty %}
            <ul class="plan-card__features" role="list">
              {% for feature in plan.features %}
                <li class="plan-card__feature">
                  {{ jaraba_icon('actions', 'check', { variant: 'duotone', size: '14px', color: 'verde-innovacion' }) }}
                  <span>{{ feature|t }}</span>
                </li>
              {% endfor %}
            </ul>
          {% endif %}

          {# CTA — enlace directo al checkout (ROUTE-LANGPREFIX-001) #}
          <div class="plan-card__actions">
            {% if plan.is_current %}
              <span class="plan-card__btn plan-card__btn--current" aria-disabled="true">
                {{ jaraba_icon('status', 'check-circle', { variant: 'duotone', size: '16px', color: 'verde-innovacion' }) }}
                {% trans %}Tu plan actual{% endtrans %}
              </span>
            {% elseif plan.stripe_price_id %}
              <a href="{{ path('jaraba_billing.checkout', {saas_plan: plan.id}) }}"
                 class="plan-card__btn plan-card__btn--select">
                {% if current_plan and plan.monthly_price > current_plan.getPriceMonthly() %}
                  {% trans %}Mejorar a este plan{% endtrans %}
                {% elseif current_plan and plan.monthly_price < current_plan.getPriceMonthly() %}
                  {% trans %}Cambiar a este plan{% endtrans %}
                {% else %}
                  {% trans %}Seleccionar plan{% endtrans %}
                {% endif %}
              </a>
            {% else %}
              <a href="{{ path('ecosistema_jaraba_core.pricing.page') }}"
                 class="plan-card__btn plan-card__btn--contact">
                {% trans %}Ver planes{% endtrans %}
              </a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="change-plan-page__empty">
      <p>{% trans %}No hay planes disponibles en este momento.{% endtrans %}</p>
    </div>
  {% endif %}

  {# Nota prorratas y legal #}
  <div class="change-plan-page__note">
    {{ jaraba_icon('ui', 'info', { variant: 'duotone', size: '18px', color: 'azul-corporativo' }) }}
    <p>
      {% trans %}Los cambios de plan se aplican inmediatamente. Si mejoras a un plan superior, se te cobrara la diferencia prorrateada. Si reduces el plan, el cambio se aplicara al próximo ciclo de facturación.{% endtrans %}
    </p>
  </div>

  {# Disclaimer IVA #}
  <p class="change-plan-page__disclaimer">
    {% trans %}Todos los precios son en EUR sin IVA. El IVA aplicable se calculara en el proceso de pago según tu ubicación fiscal.{% endtrans %}
  </p>

</div>
