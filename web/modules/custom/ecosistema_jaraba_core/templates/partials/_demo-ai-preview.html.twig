{#
/**
 * @file
 * Partial: AI Copilot Preview para demo dashboard.
 *
 * Muestra un preview interactivo del copilot IA con modos especializados
 * por vertical. Incluye chat mockup animado y scenario cards clicables.
 *
 * Variables:
 * - ai_scenarios: Array de escenarios IA (id, title, description, icon, prompt).
 * - profile: Perfil de demo actual (id, name, vertical).
 * - session_id: ID de sesión demo.
 *
 * ICON-CONVENTION-001: jaraba_icon() con variante duotone.
 * ICON-CANVAS-INLINE-001: SVGs de categoría ai/ tienen hex inline — NO pasar color.
 * ROUTE-LANGPREFIX-001: URLs via path().
 */
#}

<section class="demo-ai-preview" data-tour-step="demo-ai-copilot">
  <div class="demo-ai-preview__header">
    <h2 class="demo-section-title">
      {{ jaraba_icon('ai', 'brain', { size: '28px', variant: 'duotone' }) }}
      {% trans %}Copilot IA — Tu Asistente Inteligente{% endtrans %}
    </h2>
    <span class="demo-ai-preview__badge">
      {{ jaraba_icon('ai', 'sparkles', { size: '14px', variant: 'duotone' }) }}
      {% trans %}Potenciado por IA{% endtrans %}
    </span>
  </div>

  {# Chat mockup animado #}
  <div class="demo-ai-preview__chat-mockup" aria-hidden="true">
    <div class="demo-ai-preview__chat-bubble demo-ai-preview__chat-bubble--user">
      <span class="demo-ai-preview__chat-avatar">
        {{ jaraba_icon('ui', 'user', { size: '16px', color: 'blanco' }) }}
      </span>
      <p class="demo-ai-preview__chat-text" data-ai-demo-question>
        {{ copilot_chat.question|default('¿Cómo puedo hacer crecer mi negocio este mes?'|t) }}
      </p>
    </div>
    <div class="demo-ai-preview__chat-bubble demo-ai-preview__chat-bubble--ai">
      <span class="demo-ai-preview__chat-avatar demo-ai-preview__chat-avatar--ai">
        {{ jaraba_icon('ai', 'sparkles', { size: '16px', variant: 'duotone' }) }}
      </span>
      <div class="demo-ai-preview__chat-text">
        <p class="demo-ai-preview__typing" data-ai-demo-typing>
          {% trans %}Analizando tu consulta...{% endtrans %}
          <span class="demo-ai-preview__typing-dots">
            <span></span><span></span><span></span>
          </span>
        </p>
        <p class="demo-ai-preview__response" data-ai-demo-response style="display:none">
          {{ copilot_chat.answer|default('Basándome en tus datos, te recomiendo 3 estrategias personalizadas para hacer crecer tu negocio.'|t) }}
        </p>
      </div>
    </div>
  </div>

  {# Modos especializados IA — scenario cards #}
  <div class="demo-ai-preview__modes">
    <h3 class="demo-ai-preview__modes-title">
      {% trans %}Modos Especializados{% endtrans %}
    </h3>
    <div class="demo-ai-preview__modes-grid">
      {% if ai_scenarios is defined and ai_scenarios is iterable %}
        {% for scenario in ai_scenarios %}
          <button class="demo-ai-preview__mode-card"
                  data-ai-scenario="{{ scenario.id }}"
                  data-ai-prompt="{{ scenario.prompt }}"
                  type="button">
            <div class="demo-ai-preview__mode-icon">
              {{ jaraba_icon('ai', scenario.icon|default('sparkles'), { size: '24px', variant: 'duotone' }) }}
            </div>
            <h4 class="demo-ai-preview__mode-title">{{ scenario.title }}</h4>
            <p class="demo-ai-preview__mode-desc">{{ scenario.description }}</p>
          </button>
        {% endfor %}
      {% endif %}

      {# S14-04: Card de "Probar Copilot" — navega al AI Playground (no al modal de conversión) #}
      <a class="demo-ai-preview__mode-card demo-ai-preview__mode-card--cta"
         href="{{ path('ecosistema_jaraba_core.demo_ai_playground') }}"
         data-track-cta="demo_try_copilot"
         data-track-position="ai_preview">
        <div class="demo-ai-preview__mode-icon">
          {{ jaraba_icon('ai', 'brain', { size: '24px', variant: 'duotone' }) }}
        </div>
        <h4 class="demo-ai-preview__mode-title">{% trans %}Probar Copilot Completo{% endtrans %}</h4>
        <p class="demo-ai-preview__mode-desc">{% trans %}Chatea con la IA y descubre sus capacidades{% endtrans %}</p>
      </a>
    </div>
  </div>

  {# Stats sociales #}
  <div class="demo-ai-preview__stats">
    <div class="demo-ai-preview__stat">
      {{ jaraba_icon('analytics', 'chart-bar', { size: '16px', color: 'verde-innovacion' }) }}
      <span>{% trans %}+12.000 consultas IA/mes{% endtrans %}</span>
    </div>
    <div class="demo-ai-preview__stat">
      {{ jaraba_icon('ui', 'clock', { size: '16px', color: 'azul-corporativo' }) }}
      <span>{% trans %}Respuesta en &lt; 3 segundos{% endtrans %}</span>
    </div>
    <div class="demo-ai-preview__stat">
      {{ jaraba_icon('ai', 'sparkles', { size: '16px', variant: 'duotone' }) }}
      <span>{% trans %}11 agentes especializados{% endtrans %}</span>
    </div>
  </div>
</section>
