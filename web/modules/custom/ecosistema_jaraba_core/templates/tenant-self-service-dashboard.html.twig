{#
/**
 * @file
 * Template para el Dashboard Self-Service del Tenant.
 *
 * Variables:
 * - tenant: Entidad del tenant actual
 * - metrics: Array de metricas con 'value', 'label', 'description', 'trend', 'icon' (array)
 * - subscription_info: Informacion de la suscripcion (plan, status, trial_days)
 * - recent_activity: Array de actividad reciente
 * - quick_links: Array de acciones rapidas vertical-aware con route, label, icon, enabled
 *
 * ZERO-REGION-001: Sin CSS inline, sin regions Drupal.
 * CSS-VAR-ALL-COLORS-001: Todos los colores via --ej-* tokens.
 * ICON-CONVENTION-001: jaraba_icon() con variante duotone, NO emojis.
 * i18n: Todos los textos en {% trans %} bloques.
 */
#}

<div class="tenant-dashboard" data-tenant-dashboard>

  {# --- Premium Hero Header with Particles --- #}
  <header class="tenant-dashboard__hero">
    <canvas class="tenant-dashboard__particles" data-dashboard-particles aria-hidden="true"></canvas>
    <div class="tenant-dashboard__hero-glow" aria-hidden="true"></div>

    <div class="tenant-dashboard__hero-content">
      <div class="tenant-dashboard__hero-icon">
        {{ jaraba_icon('ui', 'dashboard', { variant: 'duotone', color: 'white', size: '36px' }) }}
      </div>
      <div class="tenant-dashboard__hero-text">
        <h1 class="tenant-dashboard__title">{% trans %}Mi Dashboard{% endtrans %}</h1>
        <p class="tenant-dashboard__subtitle">
          {% trans %}Bienvenido a tu panel de control{% endtrans %}{% if tenant %}, <strong>{{ tenant.label }}</strong>{% endif %}
        </p>
      </div>
    </div>

    <div class="tenant-dashboard__hero-actions">
      <a href="{{ path('ecosistema_jaraba_core.tenant_self_service.settings') }}"
         class="tenant-dashboard__settings-link"
         aria-label="{% trans %}Ir a configuración{% endtrans %}">
        {{ jaraba_icon('ui', 'settings', { variant: 'duotone', color: 'white', size: '16px' }) }}
        {% trans %}Configuración{% endtrans %}
      </a>
    </div>
  </header>

  {# --- Banner de estado de suscripcion --- #}
  {% if subscription_info %}
  <div class="tenant-subscription-banner">
    <div class="tenant-subscription-banner__info">
      <span class="tenant-subscription-banner__plan">{{ subscription_info.plan_name }}</span>
      <span class="tenant-subscription-banner__status tenant-subscription-banner__status--{{ subscription_info.status_class }}">
        {{ subscription_info.status_label }}
      </span>
    </div>

    {% if subscription_info.is_trial and subscription_info.trial_days_remaining > 0 %}
    <div class="tenant-subscription-banner__trial">
      <span class="tenant-trial-badge">
        {{ jaraba_icon('ui', 'clock', { variant: 'duotone', size: '16px' }) }}
        {{ subscription_info.trial_days_remaining }} {% trans %}dias restantes{% endtrans %}
      </span>
      <a href="{{ path('ecosistema_jaraba_core.tenant.change_plan') }}"
         class="tenant-trial-badge__btn">
        {% trans %}Elegir Plan{% endtrans %}
      </a>
    </div>
    {% endif %}
  </div>
  {% endif %}

  {# --- Grid de metricas principales --- #}
  <section class="tenant-metrics-grid" aria-label="{% trans %}Métricas principales{% endtrans %}">
    {% for key, metric in metrics %}
    <div class="tenant-metric-card">
      <div class="tenant-metric-card__shine" aria-hidden="true"></div>
      <div class="tenant-metric-card__icon-wrapper">
        {{ jaraba_icon(metric.icon.category, metric.icon.name, { variant: 'duotone', color: 'azul-corporativo', size: '24px' }) }}
      </div>
      <div class="tenant-metric-card__content">
        <span class="tenant-metric-card__value">{{ metric.value }}</span>
        <span class="tenant-metric-card__label">{{ metric.label }}</span>
        <span class="tenant-metric-card__description">{{ metric.description }}</span>
      </div>
      {% if metric.trend != 0 %}
      <span class="tenant-metric-card__trend tenant-metric-card__trend--{{ metric.trend > 0 ? 'up' : 'down' }}">
        {{ jaraba_icon('ui', metric.trend > 0 ? 'arrow-up' : 'arrow-down', { variant: 'duotone', size: '12px' }) }}
        {{ metric.trend|abs }}%
      </span>
      {% endif %}
    </div>
    {% endfor %}
  </section>

  {# --- Graficos: Ventas y MRR --- #}
  <div class="tenant-dashboard__grid">
    <section class="tenant-chart-section">
      <h2 class="tenant-section-title">
        {{ jaraba_icon('analytics', 'trending-up', { variant: 'duotone', color: 'verde-innovacion', size: '20px' }) }}
        {% trans %}Ventas (ultimos 30 dias){% endtrans %}
      </h2>
      <div class="tenant-chart-container" data-chart-type="sales" data-chart-id="sales-trend">
        <div class="tenant-chart-canvas-wrapper">
          <canvas id="sales-trend-chart" height="250"></canvas>
        </div>
        <div class="tenant-chart-summary"></div>
      </div>
    </section>

    <section class="tenant-chart-section">
      <h2 class="tenant-section-title">
        {{ jaraba_icon('finance', 'coins', { variant: 'duotone', color: 'verde-innovacion', size: '20px' }) }}
        {% trans %}MRR (ultimos 6 meses){% endtrans %}
      </h2>
      <div class="tenant-chart-container" data-chart-type="mrr" data-chart-id="mrr-trend">
        <div class="tenant-chart-canvas-wrapper">
          <canvas id="mrr-trend-chart" height="250"></canvas>
        </div>
        <div class="tenant-chart-summary"></div>
      </div>
    </section>
  </div>

  {# --- Actividad y Clientes --- #}
  <div class="tenant-dashboard__grid">
    <section class="tenant-activity-section">
      <h2 class="tenant-section-title">
        {{ jaraba_icon('ui', 'clipboard', { variant: 'duotone', color: 'azul-corporativo', size: '20px' }) }}
        {% trans %}Actividad Reciente{% endtrans %}
      </h2>
      <div class="tenant-activity-list">
        {% for activity in recent_activity %}
        <div class="tenant-activity-item">
          <div class="tenant-activity-item__info">
            <span class="tenant-activity-item__desc">{{ activity.description }}</span>
            {% if activity.date %}
            <span class="tenant-activity-item__date">{{ activity.date }}</span>
            {% endif %}
          </div>
          {% if activity.amount %}
          <span class="tenant-activity-item__amount">{{ activity.amount }}</span>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </section>

    <section class="tenant-chart-section">
      <h2 class="tenant-section-title">
        {{ jaraba_icon('ui', 'users', { variant: 'duotone', color: 'azul-corporativo', size: '20px' }) }}
        {% trans %}Clientes por Semana{% endtrans %}
      </h2>
      <div class="tenant-chart-container" data-chart-type="customers" data-chart-id="customers-trend">
        <div class="tenant-chart-canvas-wrapper">
          <canvas id="customers-trend-chart" height="250"></canvas>
        </div>
      </div>
    </section>
  </div>

  {# --- Acciones Rapidas (multi-vertical-aware) --- #}
  <section class="tenant-quick-links">
    <h2 class="tenant-section-title">{% trans %}Acciones Rapidas{% endtrans %}</h2>
    <div class="tenant-quick-links__grid">
      {% for link in quick_links %}
        {% if link.enabled %}
          <a href="{{ path(link.route, link.route_params) }}"
             class="tenant-quick-link{% if link.is_primary %} tenant-quick-link--primary{% endif %}">
        {% else %}
          <span class="tenant-quick-link tenant-quick-link--disabled"
                title="{% trans %}Proximamente{% endtrans %}">
        {% endif %}
            <span class="tenant-quick-link__icon" aria-hidden="true">
              {{ jaraba_icon(link.icon.category, link.icon.name, { variant: 'duotone', color: 'azul-corporativo', size: '24px' }) }}
            </span>
            <span class="tenant-quick-link__label">{{ link.label }}</span>
            {% if link.is_primary %}
              <span class="tenant-quick-link__badge">{% trans %}Principal{% endtrans %}</span>
            {% endif %}
        {% if link.enabled %}
          </a>
        {% else %}
          </span>
        {% endif %}
      {% endfor %}
    </div>
  </section>

</div>
