<?php

declare(strict_types=1);

/**
 * @file
 * Módulo de internacionalización avanzada para Jaraba Platform.
 *
 * PROPÓSITO:
 * Proporciona UI de traducción asistida por IA para múltiples tipos de
 * entidades (PageContent, BlogPost, Course, etc.)
 *
 * CARACTERÍSTICAS:
 * - Selector de idioma como parcial reutilizable
 * - Botón "Traducir con IA" que abre slide-panel
 * - Dashboard de estado de traducciones
 * - API REST para operaciones de traducción
 *
 * @see docs/planificacion/20260202-Gap_E_i18n_UI_v1.md
 */

use Drupal\Core\Entity\ContentEntityInterface;
use Drupal\Core\Entity\EntityInterface;


/**
 * Implements hook_theme().
 *
 * Registra los templates Twig del módulo.
 */
function jaraba_i18n_theme(): array {
  return [
    // Selector de idioma (parcial para incluir en otros templates).
    'i18n_selector' => [
      'template' => 'i18n-selector',
      'variables' => [
        'entity_id' => NULL,
        'entity_type' => NULL,
        'current_language' => 'es',
        'translation_status' => [],
        'can_translate' => FALSE,
      ],
    ],
    // Dashboard de traducciones.
    'i18n_dashboard' => [
      'template' => 'i18n-dashboard',
      'variables' => [
        'entity_types' => [],
        'stats' => [],
        'languages' => [],
      ],
    ],
  ];
}

/**
 * Implements hook_entity_insert().
 *
 * Encola entidades nuevas para traduccion automatica con IA.
 * Soporta Tier 1 (canvas) y Tier 2 (texto) — 13 entity types.
 * PRESAVE-RESILIENCE-001: hasService() + try-catch.
 */
function jaraba_i18n_entity_insert(EntityInterface $entity): void {
  jaraba_i18n_handle_entity_change($entity, TRUE);
}

/**
 * Implements hook_entity_update().
 *
 * Encola entidades actualizadas con cambios en campos traducibles.
 * PRESAVE-RESILIENCE-001: hasService() + try-catch.
 */
function jaraba_i18n_entity_update(EntityInterface $entity): void {
  jaraba_i18n_handle_entity_change($entity, FALSE);
}

/**
 * Handler compartido para insert/update de entidades.
 *
 * Delega a TranslationTriggerService para la logica de encolamiento.
 * Patron: jaraba_matching_handle_entity_change().
 *
 * @param \Drupal\Core\Entity\EntityInterface $entity
 *   La entidad insertada o actualizada.
 * @param bool $isInsert
 *   TRUE para insert, FALSE para update.
 */
function jaraba_i18n_handle_entity_change(EntityInterface $entity, bool $isInsert): void {
  if (!$entity instanceof ContentEntityInterface) {
    return;
  }

  try {
    if (!\Drupal::hasService('jaraba_i18n.translation_trigger')) {
      return;
    }
    \Drupal::service('jaraba_i18n.translation_trigger')
      ->handleEntityChange($entity, $isInsert);
  }
  catch (\Throwable $e) {
    // Queue failure must not break entity save.
    \Drupal::logger('jaraba_i18n')->error(
      'Failed to handle entity change for @type/@id: @msg',
      [
        '@type' => $entity->getEntityTypeId(),
        '@id' => $entity->id(),
        '@msg' => $e->getMessage(),
      ]
    );
  }
}

/**
 * Implements hook_cron().
 *
 * Ejecuta catch-up periodico (cada 6h) para detectar entidades
 * sin traduccion y encolarlas automaticamente.
 * Patron: ProactiveInsightsService::runCron().
 */
function jaraba_i18n_cron(): void {
  if (\Drupal::hasService('jaraba_i18n.translation_catchup')) {
    try {
      \Drupal::service('jaraba_i18n.translation_catchup')->runCron();
    }
    catch (\Throwable $e) {
      \Drupal::logger('jaraba_i18n')->warning(
        'Translation catchup cron failed: @error',
        ['@error' => $e->getMessage()]
      );
    }
  }
}

/**
 * Implements hook_preprocess_HOOK() para i18n_selector.
 *
 * Añade las librerías necesarias y prepara variables.
 */
function jaraba_i18n_preprocess_i18n_selector(array &$variables): void {
  // Añadir librería del componente.
  $variables['#attached']['library'][] = 'jaraba_i18n/i18n-selector';

  // Asegurar que can_translate está definido.
  if (!isset($variables['can_translate'])) {
    $variables['can_translate'] = \Drupal::currentUser()
      ->hasPermission('translate any entity');
  }
}
