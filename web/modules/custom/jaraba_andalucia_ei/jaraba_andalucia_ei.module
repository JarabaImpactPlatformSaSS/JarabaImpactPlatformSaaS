/**
 * Implements hook_html_head_alter().
 *
 * P0-1 fix: Suppress Drupal core's duplicate canonical tag on the reclutamiento
 * landing. Core generates /es/andaluciamasei.html from the route, but we also
 * inject our own canonical. Having two is a SEO penalty. We keep ours (with
 * the correct language prefix) and remove core's.
 */
function jaraba_andalucia_ei_html_head_alter(array &$head_elements): void {
  $route = \Drupal::routeMatch()->getRouteName();
  if ($route !== 'jaraba_andalucia_ei.reclutamiento') {
    return;
  }

  // Remove Drupal core's canonical link — ours is already injected via
  // _jaraba_andalucia_ei_reclutamiento_attachments() with the correct URL.
  // P2-15: Also remove theme-level hreflang tags (en, pt-br) that point to
  // untranslated content. Only our explicit es + x-default hreflang survive.
  foreach ($head_elements as $key => &$element) {
    if (!isset($element['#attributes']['rel'])) {
      continue;
    }
    $rel = $element['#attributes']['rel'];

    // Remove core's duplicate canonical (keep ours with 'andalucia_ei_rec_' prefix).
    if ($rel === 'canonical' && !str_starts_with($key, 'andalucia_ei_rec_')) {
      unset($head_elements[$key]);
      continue;
    }

    // P2-15: Remove theme-level hreflang tags (keep ours with 'andalucia_ei_rec_' prefix).
    if ($rel === 'alternate' && isset($element['#attributes']['hreflang'])) {
      if (!str_starts_with($key, 'andalucia_ei_rec_')) {
        unset($head_elements[$key]);
      }
    }
  }
}

/**
 * Helper: adds OG and Twitter Card meta tags.
 */
function _jaraba_andalucia_ei_add_og_tags(array &$attachments, $title, $description, string $url, string $prefix = '', string $imageUrl = ''): void {
  $og_tags = [
    'og:title' => (string) $title,
    'og:description' => (string) $description,
    'og:url' => $url,
    'og:type' => 'website',
    'og:site_name' => 'Plataforma de Ecosistemas',
    'og:locale' => \Drupal::languageManager()->getCurrentLanguage()->getId() === 'es' ? 'es_ES' : 'en_US',
    'twitter:card' => 'summary_large_image',
    'twitter:title' => (string) $title,
    'twitter:description' => (string) $description,
  ];

  // og:image + twitter:image — crítico para CTR en redes sociales (+30-40%).
  if ($imageUrl !== '') {
    $og_tags['og:image'] = $imageUrl;
    $og_tags['og:image:width'] = '1200';
    $og_tags['og:image:height'] = '630';
    $og_tags['og:image:type'] = str_contains($imageUrl, '.webp') ? 'image/webp' : 'image/png';
    $og_tags['twitter:image'] = $imageUrl;
  }

  foreach ($og_tags as $property => $content) {
    $tag_name = str_starts_with($property, 'twitter:') ? 'name' : 'property';
    $attachments['#attached']['html_head'][] = [
      [
        '#tag' => 'meta',
        '#attributes' => [
          $tag_name => $property,
          'content' => $content,
        ],
      ],
      'andalucia_ei_' . $prefix . str_replace([':', '/'], '_', $property),
    ];
  }
}

/**
 * Popup de reclutamiento en la home de meta-sitios corporativos.
 *
 * Se inyecta solo en:
 * - plataformadeecosistemas.es / plataformadeecosistemas.jaraba-saas.lndo.site
 * - pepejaraba.com / pepejaraba.jaraba-saas.lndo.site
 * - jarabaimpact.com / jarabaimpact.jaraba-saas.lndo.site
 *
 * Solo en la home (ruta de front page), no en la propia landing de reclutamiento.
 */
function _jaraba_andalucia_ei_popup_attachments(array &$attachments, ?string $route): void {
  // No mostrar en las propias páginas de Andalucía +ei.
  if ($route !== NULL && str_starts_with($route, 'jaraba_andalucia_ei.')) {
    return;
  }

  // Solo en la raíz del sitio (home del meta-sitio).
  // isFrontPage() no funciona aquí porque la home es una página del Page Builder,
  // no /node. Detectamos la raíz comparando el request path.
  $requestPath = \Drupal::request()->getPathInfo();
  if (!in_array($requestPath, ['/', '/es', '/es/'], TRUE)) {
    return;
  }

  // Solo en meta-sitios corporativos.
  $host = \Drupal::request()->getHost();
  $metaSiteHosts = [
    'plataformadeecosistemas.es',
    'plataformadeecosistemas.jaraba-saas.lndo.site',
    'pepejaraba.com',
    'pepejaraba.jaraba-saas.lndo.site',
    'jarabaimpact.com',
    'jarabaimpact.jaraba-saas.lndo.site',
  ];

  if (!in_array($host, $metaSiteHosts, TRUE)) {
    return;
  }

  $solicitarUrl = \Drupal\Core\Url::fromRoute('jaraba_andalucia_ei.solicitar')->toString();
  $landingUrl = \Drupal\Core\Url::fromRoute('jaraba_andalucia_ei.reclutamiento')->toString();

  $attachments['#attached']['library'][] = 'jaraba_andalucia_ei/reclutamiento-popup';
  $modulePath = '/' . \Drupal::service('extension.list.module')->getPath('jaraba_andalucia_ei');
  $attachments['#attached']['drupalSettings']['aeiRecPopup'] = [
    'solicitarUrl' => $solicitarUrl,
    'landingUrl' => $landingUrl,
    'modulePath' => $modulePath,
  ];
}

/**
 * Implements hook_preprocess_html().
 *
 * Adds body classes for Andalucia +ei pages.
 */
function jaraba_andalucia_ei_preprocess_html(array &$variables): void {
  $route = \Drupal::routeMatch()->getRouteName() ?? '';

  if (str_starts_with($route, 'jaraba_andalucia_ei.')) {
    $variables['attributes']['class'][] = 'page-andalucia-ei';

    if ($route === 'jaraba_andalucia_ei.landing') {
      $variables['attributes']['class'][] = 'page-andalucia-ei--landing';
    }
    elseif ($route === 'jaraba_andalucia_ei.reclutamiento') {
      $variables['attributes']['class'][] = 'page-andalucia-ei--reclutamiento';
    }
    elseif ($route === 'jaraba_andalucia_ei.solicitar') {
      $variables['attributes']['class'][] = 'page-andalucia-ei--solicitar';
    }
    elseif ($route === 'jaraba_andalucia_ei.dashboard') {
      $variables['attributes']['class'][] = 'page-andalucia-ei--dashboard';
    }
    elseif ($route === 'jaraba_andalucia_ei.participante_portal') {
      $variables['attributes']['class'][] = 'page-andalucia-ei--portal';
    }
  }
}

