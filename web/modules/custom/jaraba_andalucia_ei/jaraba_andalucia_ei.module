/**
 * Implements hook_simple_sitemap_links_alter().
 *
 * Adds Andalucía +ei public pages to the sitemap.
 */
function jaraba_andalucia_ei_simple_sitemap_links_alter(array &$links, $sitemap_variant): void {
  // Reclutamiento page — highest priority (main conversion funnel).
  $links[] = [
    'url' => '/andaluciamasei.html',
    'priority' => 0.95,
    'changefreq' => 'weekly',
    'lastmod' => date('Y-m-d'),
  ];

  // Landing page — high priority.
  $links[] = [
    'url' => '/andalucia-ei/programa',
    'priority' => 0.9,
    'changefreq' => 'weekly',
    'lastmod' => date('Y-m-d'),
  ];

  // Application form.
  $links[] = [
    'url' => '/andalucia-ei/solicitar',
    'priority' => 0.8,
    'changefreq' => 'monthly',
    'lastmod' => date('Y-m-d'),
  ];

  // Lead magnet / guide.
  $links[] = [
    'url' => '/andalucia-ei/guia-participante',
    'priority' => 0.6,
    'changefreq' => 'monthly',
    'lastmod' => date('Y-m-d'),
  ];
}


/**
 * Prepares variables for expediente_documento templates.
 *
 * ENTITY-PREPROCESS-001: Required for every ContentEntity with view mode.
 */
function template_preprocess_expediente_documento(array &$variables): void {
  $entity = $variables['elements']['#expediente_documento'] ?? NULL;
  if (!$entity) {
    return;
  }

  /** @var \Drupal\jaraba_andalucia_ei\Entity\ExpedienteDocumentoInterface $entity */
  $variables['expediente_documento'] = $entity;
  // LABEL-NULLSAFE-001: label() puede devolver NULL.
  $variables['label'] = $entity->label() ?? t('Documento #@id', ['@id' => $entity->id()]);
  $variables['categoria'] = $entity->getCategoria();
  $variables['estado_revision'] = $entity->getEstadoRevision();
}

/**
 * Implements hook_ENTITY_TYPE_insert() for expediente_documento.
 *
 * Sprint 3: Resuelve tipo de firma al crear documento via DocumentoFirmaOrchestrator.
 * PRESAVE-RESILIENCE-001: hasService() + try-catch.
 * SERVICE-CONSUMER-001: Conecta documento_firma_orchestrator.
 */
function jaraba_andalucia_ei_expediente_documento_insert(\Drupal\Core\Entity\EntityInterface $entity): void {
  if (!\Drupal::hasService('jaraba_andalucia_ei.documento_firma_orchestrator')) {
    return;
  }

  try {
    /** @var \Drupal\jaraba_andalucia_ei\Service\DocumentoFirmaOrchestrator $orchestrator */
    $orchestrator = \Drupal::service('jaraba_andalucia_ei.documento_firma_orchestrator');
    $categoria = $entity->hasField('categoria') ? ($entity->get('categoria')->value ?? '') : '';

    if ($categoria !== '' && $orchestrator->requiereFirma($categoria)) {
      $info = $orchestrator->getInfoFirma($categoria);
      \Drupal::logger('jaraba_andalucia_ei')->info(
        'Documento @id (cat: @cat) requiere firma tipo @tipo.',
        [
          '@id' => $entity->id(),
          '@cat' => $categoria,
          '@tipo' => $info['tipo'] ?? 'desconocido',
        ]
      );
    }
  }
  catch (\Throwable $e) {
    \Drupal::logger('jaraba_andalucia_ei')->warning(
      'Error resolviendo firma para documento @id: @msg',
      ['@id' => $entity->id(), '@msg' => $e->getMessage()]
    );
  }
}

