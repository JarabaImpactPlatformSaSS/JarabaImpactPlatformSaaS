/**
 * Implements template_preprocess_HOOK() for indicador_fse_plus.
 *
 * ENTITY-PREPROCESS-001.
 */
function jaraba_andalucia_ei_preprocess_indicador_fse_plus(array &$variables): void {
  $entity = $variables['elements']['#indicador_fse_plus'] ?? NULL;
  if ($entity === NULL) {
    return;
  }
  $variables['indicador_fse_plus'] = $entity;

  // Expose readable labels for Twig.
  $momento = $entity->get('momento_recogida')->value ?? '';
  $momentoLabels = \Drupal\jaraba_andalucia_ei\Entity\IndicadorFsePlus::MOMENTOS_RECOGIDA;
  $variables['momento_label'] = $momentoLabels[$momento] ?? $momento;
  $variables['is_momento_resultado'] = in_array($momento, ['salida', 'seguimiento_6m'], TRUE);

  // LABEL-NULLSAFE-001: Participante ref may be empty.
  $participanteRef = $entity->get('participante_id')->entity ?? NULL;
  $variables['participante_label'] = $participanteRef !== NULL
    ? ($participanteRef->label() ?? (string) $participanteRef->id())
    : '';
}

/**
 * Implements hook_ENTITY_TYPE_presave() for actuacion_sto.
 *
 * Presave logic:
 * 1. Calcula duracion_minutos desde hora_inicio/hora_fin.
 * 2. Copia fase_participante desde ProgramaParticipanteEi.
 * 3. Si es tipo 'formacion', establece vobo_sae_status = 'pendiente'.
 *
 * PRESAVE-RESILIENCE-001: Optional services con hasService() + try-catch.
 */
function jaraba_andalucia_ei_actuacion_sto_presave(\Drupal\Core\Entity\EntityInterface $entity): void {
  // 1. Calcular duración.
  $horaInicio = $entity->get('hora_inicio')->value ?? '';
  $horaFin = $entity->get('hora_fin')->value ?? '';
  if ($horaInicio !== '' && $horaFin !== '') {
    if (\Drupal::hasService('jaraba_andalucia_ei.actuacion_sto')) {
      try {
        $service = \Drupal::service('jaraba_andalucia_ei.actuacion_sto');
        $duracion = $service->calcularDuracionMinutos($horaInicio, $horaFin);
        $entity->set('duracion_minutos', $duracion);
      }
      catch (\Throwable) {
      }
    }
  }

  // 2. Copiar fase del participante.
  $participanteRef = $entity->get('participante_id')->entity;
  if ($participanteRef && method_exists($participanteRef, 'getFaseActual')) {
    try {
      $entity->set('fase_participante', $participanteRef->getFaseActual());
    }
    catch (\Throwable) {
    }
  }

  // 3. VoBo SAE para formación.
  $tipoActuacion = $entity->get('tipo_actuacion')->value ?? '';
  $voboStatus = $entity->get('vobo_sae_status')->value ?? 'no_requerido';
  if ($tipoActuacion === 'formacion' && $voboStatus === 'no_requerido') {
    $entity->set('vobo_sae_status', 'pendiente');
  }
}

/**
 * Implements hook_ENTITY_TYPE_insert() for actuacion_sto.
 *
 * Incrementa las horas del participante vinculado.
 * PRESAVE-RESILIENCE-001.
 */
function jaraba_andalucia_ei_actuacion_sto_insert(\Drupal\Core\Entity\EntityInterface $entity): void {
  $participanteId = (int) ($entity->get('participante_id')->target_id ?? 0);
  $tipoActuacion = $entity->get('tipo_actuacion')->value ?? '';
  $duracionMinutos = (int) ($entity->get('duracion_minutos')->value ?? 0);

  if ($participanteId <= 0 || $duracionMinutos <= 0) {
    return;
  }

  if (\Drupal::hasService('jaraba_andalucia_ei.actuacion_sto')) {
    try {
      \Drupal::service('jaraba_andalucia_ei.actuacion_sto')
        ->incrementarHorasParticipante($participanteId, $tipoActuacion, $duracionMinutos / 60);
    }
    catch (\Throwable) {
    }
  }

  // Generar recibo de servicio para la actuación (PRESAVE-RESILIENCE-001).
  if (\Drupal::hasService('jaraba_andalucia_ei.recibo_servicio')) {
    try {
      \Drupal::service('jaraba_andalucia_ei.recibo_servicio')
        ->generarRecibo((int) $entity->id());
    }
    catch (\Throwable) {
    }
  }
}

/**
 * Implements template_preprocess_HOOK() for insercion_laboral.
 *
 * ENTITY-PREPROCESS-001.
 */
function jaraba_andalucia_ei_preprocess_insercion_laboral(array &$variables): void {
  $entity = $variables['elements']['#insercion_laboral'] ?? NULL;
  if ($entity === NULL) {
    return;
  }
  $variables['insercion_laboral'] = $entity;

  // Extract primitives for Twig.
  $variables['tipo_insercion'] = $entity->get('tipo_insercion')->value ?? '';
  $variables['fecha_alta'] = $entity->get('fecha_alta')->value ?? '';
  $variables['verificado'] = (bool) ($entity->get('verificado')->value ?? FALSE);

  // Resolve label based on type.
  $tipoLabels = [
    'cuenta_ajena' => t('Cuenta ajena'),
    'cuenta_propia' => t('Cuenta propia'),
    'agrario' => t('Agrario'),
  ];
  $tipo = $variables['tipo_insercion'];
  $variables['tipo_insercion_label'] = $tipoLabels[$tipo] ?? $tipo;

  // Empresa name based on type.
  if ($tipo === 'cuenta_ajena') {
    $variables['empresa_label'] = $entity->get('empresa_nombre')->value ?? '';
  }
  elseif ($tipo === 'cuenta_propia') {
    $variables['empresa_label'] = t('Autónomo');
  }
  elseif ($tipo === 'agrario') {
    $variables['empresa_label'] = $entity->get('empresa_agraria')->value ?? '';
  }
  else {
    $variables['empresa_label'] = '';
  }

  // Resolve participante reference.
  $participanteRef = $entity->get('participante_id')->entity;
  if ($participanteRef) {
    $variables['participante_nombre'] = $participanteRef->label() ?? t('Participante #@id', ['@id' => $participanteRef->id()]);
  }
  else {
    $variables['participante_nombre'] = '';
  }
}

/**
 * Prepares variables for prospeccion_empresarial templates.
 *
 * ENTITY-PREPROCESS-001: Required for every ContentEntity with view mode.
 */
function template_preprocess_prospeccion_empresarial(array &$variables): void {
  $entity = $variables['elements']['#prospeccion_empresarial'] ?? NULL;
  if (!$entity) {
    return;
  }

  /** @var \Drupal\jaraba_andalucia_ei\Entity\ProspeccionEmpresarialInterface $entity */
  $variables['prospeccion_empresarial'] = $entity;
  // LABEL-NULLSAFE-001: label() puede devolver NULL.
  $variables['label'] = $entity->label() ?? t('Prospección #@id', ['@id' => $entity->id()]);
  $variables['estado'] = $entity->getEstado();
  $variables['tipo_colaboracion'] = $entity->getTipoColaboracion();
  $variables['is_colaborador'] = $entity->isColaboradorActivo();
}

