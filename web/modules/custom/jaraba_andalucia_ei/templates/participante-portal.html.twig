{#
/**
 * @file
 * Portal de participación premium — Andalucía +ei.
 *
 * Variables:
 * - participante: ProgramaParticipanteEiInterface entity
 * - health_score: { score, label } or null
 * - completitud: { total_requeridos, completados, porcentaje, por_categoria }
 * - documentos_por_categoria: Documents grouped by prefix
 * - bridges: Cross-vertical bridge data
 * - proactive_action: Proactive nudge data or null
 * - timeline: { atencion: { steps }, insercion: { steps } }
 * - formacion: { horas, meta, porcentaje, milestones }
 * - mis_sesiones: Array de sesiones inscritas (Sprint 13)
 * - vertical_access: { active_verticals, is_expired, dias_restantes }
 */
#}

{{ attach_library('jaraba_andalucia_ei/participante-portal') }}
{{ attach_library('ecosistema_jaraba_theme/slide-panel') }}

<div class="aei-portal" data-participante-id="{{ participante.id() }}">

  {# === HERO PERSONALIZADO === #}
  {% include '@jaraba_andalucia_ei/partials/_participante-hero.html.twig' with {
    participante: participante,
    health_score: health_score,
  } only %}

  {# === BANNER DE EXPIRACION (Sprint 13) === #}
  {% if vertical_access is defined and vertical_access.dias_restantes >= 0 and vertical_access.dias_restantes <= 30 %}
    <div class="aei-portal__expiration-banner aei-portal__expiration-banner--{{ vertical_access.dias_restantes <= 7 ? 'critical' : 'warning' }}" role="alert">
      {{ jaraba_icon('ui', 'alert-triangle', { variant: 'outline', color: vertical_access.dias_restantes <= 7 ? 'white' : 'naranja-impulso', size: '20px' }) }}
      <div class="aei-portal__expiration-text">
        {% if vertical_access.dias_restantes == 0 %}
          <strong>{% trans %}Tu acceso al ecosistema expira hoy.{% endtrans %}</strong>
        {% elseif vertical_access.dias_restantes == 1 %}
          <strong>{% trans %}Tu acceso al ecosistema expira manana.{% endtrans %}</strong>
        {% else %}
          <strong>{% trans %}Tu acceso al ecosistema expira en {{ vertical_access.dias_restantes }} dias.{% endtrans %}</strong>
        {% endif %}
        <span>{% trans %}Aprovecha las herramientas disponibles mientras tu acceso este activo.{% endtrans %}</span>
      </div>
    </div>
  {% endif %}

  {# === BANNER ACCESO EXPIRADO === #}
  {% if vertical_access is defined and vertical_access.is_expired %}
    <div class="aei-portal__expiration-banner aei-portal__expiration-banner--expired" role="alert">
      {{ jaraba_icon('ui', 'lock', { variant: 'outline', color: 'white', size: '20px' }) }}
      <div class="aei-portal__expiration-text">
        <strong>{% trans %}Tu acceso al ecosistema ha expirado.{% endtrans %}</strong>
        <span>{% trans %}Contacta con tu coordinador/a para mas informacion.{% endtrans %}</span>
      </div>
    </div>
  {% endif %}

  <div class="aei-portal__grid">

    <div class="aei-portal__main">

      {# === TIMELINE DE FASES === #}
      {% include '@jaraba_andalucia_ei/partials/_participante-timeline.html.twig' with {
        timeline: timeline,
        fase_actual: participante.getFaseActual(),
      } only %}

      {# === PROGRESO FORMATIVO === #}
      {% include '@jaraba_andalucia_ei/partials/_participante-formacion.html.twig' with {
        formacion: formacion,
        participante: participante,
      } only %}

      {# === CARPETA DOCUMENTAL === #}
      {% include '@jaraba_andalucia_ei/partials/_participante-expediente.html.twig' with {
        completitud: completitud,
        documentos_por_categoria: documentos_por_categoria,
        participante_id: participante.id(),
      } only %}

      {# === LOGROS Y BADGES === #}
      {% include '@jaraba_andalucia_ei/partials/_participante-logros.html.twig' with {
        participante: participante,
        formacion: formacion,
        timeline: timeline,
      } only %}

      {# === MIS SESIONES (Sprint 13) === #}
      {% if mis_sesiones is defined and mis_sesiones|length > 0 %}
        <section class="aei-portal__sesiones" data-effect="fade-up" aria-label="{% trans %}Mis proximas sesiones{% endtrans %}">
          <h3 class="aei-portal__section-title">
            {{ jaraba_icon('ui', 'calendar', { variant: 'duotone', color: 'naranja-impulso', size: '24px' }) }}
            {% trans %}Mis Proximas Sesiones{% endtrans %}
            <span class="aei-portal__count-badge">{{ mis_sesiones|length }}</span>
          </h3>
          <div class="aei-portal__sesiones-list">
            {% for sesion in mis_sesiones %}
              <div class="aei-portal__sesion-item aei-portal__sesion-item--{{ sesion.estado_inscripcion }}">
                <div class="aei-portal__sesion-date">
                  <span class="aei-portal__sesion-day">{{ sesion.fecha|date('d') }}</span>
                  <span class="aei-portal__sesion-month">{{ sesion.fecha|date('M') }}</span>
                </div>
                <div class="aei-portal__sesion-details">
                  <strong class="aei-portal__sesion-titulo">{{ sesion.titulo }}</strong>
                  <span class="aei-portal__sesion-hora">
                    {{ jaraba_icon('ui', 'clock', { variant: 'outline', color: 'neutral', size: '14px' }) }}
                    {{ sesion.hora_inicio }} - {{ sesion.hora_fin }}
                  </span>
                  <div class="aei-portal__sesion-meta">
                    <span class="aei-portal__sesion-tipo">{{ sesion.tipo_sesion|replace({'_': ' '})|capitalize }}</span>
                    <span class="aei-portal__sesion-modalidad">{{ sesion.modalidad|capitalize }}</span>
                  </div>
                </div>
                <span class="aei-portal__sesion-estado aei-portal__sesion-estado--{{ sesion.estado_inscripcion }}">
                  {{ sesion.estado_inscripcion|replace({'_': ' '})|capitalize }}
                </span>
              </div>
            {% endfor %}
          </div>
        </section>
      {% endif %}

    </div>

    <div class="aei-portal__sidebar">

      {# === ACCIONES RÁPIDAS === #}
      {% include '@jaraba_andalucia_ei/partials/_participante-acciones.html.twig' with {
        participante: participante,
      } only %}

      {# === VERTICALES ACTIVOS (Sprint 13) === #}
      {% if vertical_access is defined and vertical_access.active_verticals|length > 0 %}
        {% set vertical_labels = {
          'empleabilidad': 'Empleabilidad'|t,
          'emprendimiento': 'Emprendimiento'|t,
          'comercioconecta': 'ComercioConecta'|t,
          'agroconecta': 'AgroConecta'|t,
          'jarabalex': 'JarabaLex'|t,
          'serviciosconecta': 'ServiciosConecta'|t,
          'formacion': 'Formacion'|t,
        } %}
        <section class="aei-portal__verticals" data-effect="fade-up" aria-label="{% trans %}Herramientas disponibles{% endtrans %}">
          <h3 class="aei-portal__section-title">
            {{ jaraba_icon('verticals', 'ecosystem', { variant: 'duotone', color: 'verde-innovacion', size: '24px' }) }}
            {% trans %}Herramientas Activas{% endtrans %}
          </h3>
          <div class="aei-portal__verticals-list">
            {% for vertical in vertical_access.active_verticals %}
              <div class="aei-portal__vertical-chip">
                {{ jaraba_icon('verticals', vertical, { variant: 'duotone', color: 'azul-corporativo', size: '16px' }) }}
                <span>{{ vertical_labels[vertical]|default(vertical|capitalize) }}</span>
              </div>
            {% endfor %}
          </div>
          {% if vertical_access.dias_restantes >= 0 %}
            <p class="aei-portal__verticals-expiry">
              {{ jaraba_icon('ui', 'clock', { variant: 'outline', color: 'neutral', size: '14px' }) }}
              {% trans %}Acceso activo: {{ vertical_access.dias_restantes }} dias restantes{% endtrans %}
            </p>
          {% endif %}
        </section>
      {% endif %}

      {# === PUENTES CROSS-VERTICAL === #}
      {% if bridges is not empty %}
        <section class="aei-portal__bridges" data-effect="fade-up" aria-label="{{ 'Descubre el ecosistema'|t }}">
          <h3 class="aei-portal__section-title">
            {{ jaraba_icon('verticals', 'ecosystem', { variant: 'duotone', size: '24px' }) }}
            {{ 'Descubre el ecosistema'|t }}
          </h3>
          <div class="aei-portal__bridges-list">
            {% for bridge in bridges %}
              <a href="{{ bridge.url }}" class="aei-portal__bridge-card" data-effect="fade-up" data-delay="{{ loop.index0 * 80 }}">
                {% set icon_parts = bridge.icon|default('verticals:star')|split(':') %}
                {{ jaraba_icon(icon_parts[0], icon_parts[1], { variant: 'duotone', size: '24px' }) }}
                <div>
                  <span class="aei-portal__bridge-title">{{ bridge.label }}</span>
                  <span class="aei-portal__bridge-desc">{{ bridge.description }}</span>
                </div>
              </a>
            {% endfor %}
          </div>
        </section>
      {% endif %}

    </div>

  </div>

  {# === FAB PROACTIVO IA === #}
  {% if proactive_action %}
    <div class="aei-portal__fab" data-proactive='{{ proactive_action|json_encode }}' aria-label="{{ 'Sugerencia del programa'|t }}">
      <button type="button" class="aei-portal__fab-trigger" aria-expanded="false">
        {{ jaraba_icon('ai', 'sparkle', { variant: 'duotone', size: '24px' }) }}
      </button>
      <div class="aei-portal__fab-content" hidden>
        <p class="aei-portal__fab-message">{{ proactive_action.message }}</p>
        {% if proactive_action.cta_url %}
          <a href="{{ proactive_action.cta_url }}" class="aei-portal__fab-cta">
            {{ proactive_action.cta_label|default('Ver más'|t) }}
          </a>
        {% endif %}
      </div>
    </div>
  {% endif %}

</div>
