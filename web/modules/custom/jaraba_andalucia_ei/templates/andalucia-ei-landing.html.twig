{#
/**
 * @file
 * Landing page de conversion para Andalucia +ei.
 *
 * Zero Region Policy: No usa page.content ni bloques.
 * Orden optimizado para conversion:
 * Hero > Stats > Features > Content > Testimonials > FAQ > CTA
 *
 * i18n: {% trans %} bloques para texto inline, |t solo dentro de {% set %} arrays.
 */
#}

{# === HERO: Gancho emocional + CTA primario === #}
<section class="aei-landing__hero" data-effect="fade-up" aria-label="{% trans %}Programa Andalucia +ei{% endtrans %}">
  <div class="aei-landing__container">
    <div class="aei-landing__hero-content">
      <span class="aei-landing__eyebrow">{% trans %}Andalucia +ei{% endtrans %}</span>
      <h1 class="aei-landing__title">{% trans %}Emprendimiento e Insercion Laboral Aumentado con IA{% endtrans %}</h1>
      <p class="aei-landing__subtitle">{% trans %}Programa gratuito con mentoria IA, formacion adaptativa, expediente digital seguro, evaluacion automatica de perfil e insercion laboral real. 100% subvencionado por la Junta de Andalucia y el FSE+.{% endtrans %}</p>
      <div class="aei-landing__actions">
        <a href="{{ solicitar_url }}" class="aei-landing__cta aei-landing__cta--primary">
          {% trans %}Solicitar plaza{% endtrans %}
        </a>
        <a href="#como-funciona" class="aei-landing__cta aei-landing__cta--secondary">
          {% trans %}Conocer programa{% endtrans %}
        </a>
      </div>
    </div>
    <div class="aei-landing__hero-visual" aria-hidden="true">
      <div class="aei-landing__hero-placeholder">
        {{ jaraba_icon('programas', 'rocket', { variant: 'duotone', size: '64px' }) }}
      </div>
    </div>
  </div>
</section>

{# === STATS: Datos reales verificables (1a edicion auditada + capacidad plataforma) === #}
<section class="aei-landing__stats" data-effect="fade-up" aria-label="{% trans %}Datos del programa{% endtrans %}">
  <div class="aei-landing__container">
    <div class="aei-landing__stats-grid">
      {% set stats = [
        { value: '50', label: 'Personas atendidas (1.ª edicion)'|t, icon: 'users' },
        { value: '46%', label: 'Tasa de insercion verificada'|t, icon: 'trending-up' },
        { value: '45', label: 'Plazas 2.ª edicion (Malaga + Sevilla)'|t, icon: 'target' },
        { value: '528 €', label: 'Incentivo por participante'|t, icon: 'gift' },
        { value: '10', label: 'Servicios integrados en la plataforma'|t, icon: 'grid' },
        { value: '<48h', label: 'Evaluacion IA de tu perfil'|t, icon: 'clock' },
      ] %}
      {% for stat in stats %}
        <div class="aei-landing__stat-card" data-effect="fade-up" data-delay="{{ loop.index0 * 100 }}">
          <div class="aei-landing__stat-icon" aria-hidden="true">
            {{ jaraba_icon('ui', stat.icon, { variant: 'duotone', size: '32px' }) }}
          </div>
          <span class="aei-landing__stat-value" data-counter="{{ stat.value }}">{{ stat.value }}</span>
          <span class="aei-landing__stat-label">{{ stat.label }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# === FEATURES: Beneficios — 10 herramientas === #}
<section class="aei-landing__features" data-effect="fade-up" aria-label="{% trans %}Beneficios del programa{% endtrans %}">
  <div class="aei-landing__container">
    <div class="aei-landing__section-header">
      <span class="aei-landing__eyebrow">{% trans %}Que incluye{% endtrans %}</span>
      <h2 class="aei-landing__section-title">{% trans %}10 herramientas reales para tu insercion laboral{% endtrans %}</h2>
    </div>
    <div class="aei-landing__features-grid">
      {% set features = [
        {
          icon: 'cpu',
          icon_category: 'ui',
          title: 'Mentoria con Inteligencia Artificial'|t,
          desc: 'Tutor IA personalizado que mejora tu CV, prepara entrevistas, elabora planes de negocio y te guia en tu busqueda de empleo. Disponible 24/7.'|t,
        },
        {
          icon: 'graduation',
          icon_category: 'education',
          title: 'Formacion Adaptativa Certificada'|t,
          desc: 'Mas de 50 horas en competencias digitales, emprendimiento y habilidades profesionales. El motor de dificultad adaptativa ajusta el contenido a tu nivel.'|t,
        },
        {
          icon: 'briefcase',
          icon_category: 'legal',
          title: 'Insercion Laboral Real'|t,
          desc: 'Plan personalizado con orientacion individual, ofertas exclusivas, gestion de fases automatizada y acompanamiento hasta tu contratacion o lanzamiento de negocio.'|t,
        },
        {
          icon: 'folder',
          icon_category: 'ui',
          title: 'Expediente Digital Seguro'|t,
          desc: 'Tu expediente completo en 18 categorias documentales: CV, certificados, contratos, evaluaciones. Almacenamiento cifrado con firma digital y acceso controlado.'|t,
        },
        {
          icon: 'zap',
          icon_category: 'ui',
          title: 'Evaluacion IA de tu Perfil'|t,
          desc: 'Al solicitar plaza, la IA analiza tu perfil en menos de 48h: detecta fortalezas, areas de mejora y te asigna el itinerario mas adecuado automaticamente.'|t,
        },
        {
          icon: 'trending-up',
          icon_category: 'ui',
          title: 'Seguimiento de Progreso'|t,
          desc: 'Panel con tu health score, timeline de hitos, completitud de formacion y metricas de empleabilidad. Ve tu evolucion en tiempo real.'|t,
        },
        {
          icon: 'file-text',
          icon_category: 'ui',
          title: 'Informes PDF Personalizados'|t,
          desc: 'Genera informes de progreso en PDF con marca institucional: competencias adquiridas, horas completadas, evaluaciones y recomendaciones de la IA.'|t,
        },
        {
          icon: 'edit',
          icon_category: 'ui',
          title: 'Revision IA de Documentos'|t,
          desc: 'La IA revisa y mejora tu CV, carta de presentacion y plan de negocio. Sugerencias concretas de formato, contenido y adaptacion a cada oferta.'|t,
        },
        {
          icon: 'message-circle',
          icon_category: 'ui',
          title: 'Comunicacion Directa con Mentores'|t,
          desc: 'Mensajeria integrada con tus mentores y orientadores. Historial de conversaciones vinculado a tu expediente para seguimiento continuo.'|t,
        },
        {
          icon: 'share-2',
          icon_category: 'ui',
          title: 'Exportacion STO Automatica'|t,
          desc: 'Sincronizacion automatica con el Sistema Telematico de Orientacion de la Junta de Andalucia. Tu progreso queda registrado oficialmente sin tramites adicionales.'|t,
        },
      ] %}
      {% for feature in features %}
        <div class="aei-landing__feature-card" data-effect="fade-up" data-delay="{{ loop.index0 * 100 }}">
          <div class="aei-landing__feature-icon" aria-hidden="true">
            {{ jaraba_icon(feature.icon_category, feature.icon, { variant: 'duotone', size: '32px' }) }}
          </div>
          <h3 class="aei-landing__feature-title">{{ feature.title }}</h3>
          <p class="aei-landing__feature-desc">{{ feature.desc }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# === CONTENT: Como funciona — paso a paso === #}
<section id="como-funciona" class="aei-landing__content" data-effect="fade-up" aria-label="{% trans %}Como funciona{% endtrans %}">
  <div class="aei-landing__container">
    <div class="aei-landing__content-grid">
      <div class="aei-landing__content-text">
        <span class="aei-landing__eyebrow">{% trans %}Como funciona{% endtrans %}</span>
        <h2 class="aei-landing__section-title">{% trans %}Tu camino hacia el empleo en 4 pasos{% endtrans %}</h2>
        <div class="aei-landing__steps">
          {% set steps = [
            { num: '1', title: 'Solicita tu plaza'|t, desc: 'Rellena el formulario en 2 minutos. La IA evalua tu perfil en menos de 48h y te asigna el itinerario mas adecuado automaticamente.'|t },
            { num: '2', title: 'Diagnostico IA + Expediente'|t, desc: 'Se abre tu expediente digital seguro y el mentor IA analiza tus fortalezas, areas de mejora y objetivos. Tu documentacion queda organizada en 18 categorias.'|t },
            { num: '3', title: 'Formacion adaptativa'|t, desc: 'Formacion certificada con dificultad que se ajusta a tu nivel. Sesiones de orientacion, revision IA de CV y documentos, todo con seguimiento de progreso en tiempo real.'|t },
            { num: '4', title: 'Insercion laboral'|t, desc: 'Plan personalizado de busqueda activa o lanzamiento de tu emprendimiento. Informes PDF, sincronizacion STO y acompanamiento continuo hasta tu contratacion.'|t },
          ] %}
          {% for step in steps %}
            <div class="aei-landing__step" data-effect="fade-up" data-delay="{{ loop.index0 * 100 }}">
              <span class="aei-landing__step-num">{{ step.num }}</span>
              <div class="aei-landing__step-content">
                <h3 class="aei-landing__step-title">{{ step.title }}</h3>
                <p class="aei-landing__step-desc">{{ step.desc }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
      <div class="aei-landing__content-sidebar">
        <div class="aei-landing__eligibility-card">
          <h3 class="aei-landing__eligibility-title">{% trans %}Requisitos de elegibilidad{% endtrans %}</h3>
          <ul class="aei-landing__eligibility-list">
            {% set criteria = [
              'Residir en Andalucia'|t,
              'Estar en situacion de desempleo'|t,
              'Mayor de 16 anos'|t,
              'Inscrito/a como demandante de empleo'|t,
              'Motivacion y compromiso con el programa'|t,
            ] %}
            {% for criterion in criteria %}
              <li class="aei-landing__eligibility-item">
                {{ jaraba_icon('status', 'check-circle', { variant: 'duotone', size: '20px' }) }}
                <span>{{ criterion }}</span>
              </li>
            {% endfor %}
          </ul>
          <p class="aei-landing__eligibility-note">{% trans %}Colectivos prioritarios: jovenes 18-29, mayores de 45, desempleados de larga duracion y migrantes.{% endtrans %}</p>
        </div>
      </div>
    </div>
  </div>
</section>

{# === TESTIMONIALS: Prueba social con participantes reales 1a edicion === #}
<section class="aei-landing__testimonials" data-effect="fade-up" aria-label="{% trans %}Testimonios de participantes{% endtrans %}">
  <div class="aei-landing__container">
    <div class="aei-landing__section-header">
      <span class="aei-landing__eyebrow">{% trans %}Testimonios{% endtrans %}</span>
      <h2 class="aei-landing__section-title">{% trans %}Lo que dicen quienes ya lo han vivido{% endtrans %}</h2>
    </div>
    <div class="aei-landing__testimonials-grid">
      {% set testimonials = [
        {
          quote: 'No ha sido solamente el curso. Despues realmente hay un seguimiento real, que en muchos sitios se queda en el aire. Aqui no. Aqui funciona.'|t,
          name: 'Cristina M. P.',
          role: 'Emprendedora — Malaga'|t,
        },
        {
          quote: 'A mi me ha sacado de un punto muerto. Te abre el pensamiento, cambias totalmente todo. Desde calcular tu beneficio hasta networking, hasta creer en ti.'|t,
          name: 'Adrian C. T.',
          role: 'Produccion audiovisual — Malaga'|t,
        },
        {
          quote: 'Este curso es oro puro. Ninguno de los cursos de pago que he hecho me ha dado lo que me dio este curso gratuito.'|t,
          name: 'Marcela C.',
          role: 'Coach de comunicacion — Sevilla'|t,
        },
      ] %}
      {% for testimonial in testimonials %}
        <div class="aei-landing__testimonial-card" data-effect="fade-up" data-delay="{{ loop.index0 * 100 }}">
          <blockquote class="aei-landing__testimonial-quote">{{ testimonial.quote }}</blockquote>
          <div class="aei-landing__testimonial-author">
            <div class="aei-landing__testimonial-avatar" aria-hidden="true">{{ testimonial.name|first }}</div>
            <div>
              <span class="aei-landing__testimonial-name">{{ testimonial.name }}</span>
              <span class="aei-landing__testimonial-role">{{ testimonial.role }}</span>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# === FAQ: Manejo de objeciones === #}
<section class="aei-landing__faq" data-effect="fade-up" aria-label="{% trans %}Preguntas frecuentes{% endtrans %}">
  <div class="aei-landing__container">
    <div class="aei-landing__section-header">
      {{ jaraba_icon('ui', 'help', { variant: 'duotone', size: '48px' }) }}
      <span class="aei-landing__eyebrow">{% trans %}FAQ{% endtrans %}</span>
      <h2 class="aei-landing__section-title">{% trans %}Preguntas frecuentes{% endtrans %}</h2>
    </div>
    <div class="aei-landing__faq-list">
      {% set faqs = [
        { q: '¿Es realmente gratuito?'|t, a: 'Si, el programa esta 100% subvencionado por la Junta de Andalucia y el Fondo Social Europeo Plus (FSE+). No tiene ningun coste para los participantes. Ademas recibes 528 € de incentivo al completar la formacion.'|t },
        { q: '¿Que es la mentoria con IA?'|t, a: 'Tendras acceso a un tutor virtual basado en inteligencia artificial que te ayuda con tu CV, preparacion de entrevistas, plan de negocio y orientacion profesional personalizada. Disponible 24/7.'|t },
        { q: '¿Cuanto dura el programa?'|t, a: 'El programa dura hasta 18 meses. Incluye minimo 10 horas de orientacion personalizada, 50 horas de formacion certificada y 40 horas de acompanamiento a la insercion. Tu itinerario se adapta a tu perfil y tu ritmo.'|t },
        { q: '¿Puedo participar si soy autonomo?'|t, a: 'El programa esta dirigido a personas desempleadas inscritas como demandantes de empleo en el SAE. Si eres autonomo pero no estas facturando, consulta tu caso concreto.'|t },
        { q: '¿Obtengo algun certificado?'|t, a: 'Si, al completar la formacion recibes un certificado oficial de competencias. Ademas, puedes generar informes PDF personalizados con tus logros y el programa queda registrado en tu historial del STO.'|t },
        { q: '¿Que pasa si encuentro trabajo durante el programa?'|t, a: 'Transitas a la Fase de Insercion y el equipo te acompana en la incorporacion laboral. Es el objetivo del programa. El seguimiento post-contratacion dura 6 meses.'|t },
        { q: '¿Que es el expediente digital?'|t, a: 'Tu expediente digital organiza toda tu documentacion en 18 categorias: CV, certificados, evaluaciones, contratos y mas. Se almacena con cifrado AES-256 y firma digital, y solo tu y tus mentores autorizados tienen acceso.'|t },
        { q: '¿Como funciona la evaluacion IA de mi perfil?'|t, a: 'Al enviar tu solicitud, la IA analiza tu experiencia, formacion y objetivos para asignarte el itinerario mas adecuado. El proceso tarda menos de 48 horas y recibiras una notificacion con los resultados y recomendaciones.'|t },
        { q: '¿Necesito estar apuntado en el SAE?'|t, a: 'Si, es un requisito imprescindible. Debes estar inscrito/a como demandante de empleo no ocupado/a en el Servicio Andaluz de Empleo en el momento del alta en el programa.'|t },
        { q: '¿Puedo comunicarme directamente con mi mentor?'|t, a: 'Si, la plataforma incluye mensajeria integrada con tus mentores y orientadores. Las conversaciones quedan vinculadas a tu expediente para un seguimiento continuo y documentado.'|t },
        { q: '¿Mis datos estan seguros?'|t, a: 'Absolutamente. Toda la informacion se almacena con cifrado AES-256, cumplimiento RGPD completo y acceso controlado por roles. Solo tu y los profesionales autorizados del programa pueden acceder a tu expediente.'|t },
        { q: '¿Que es la sincronizacion STO?'|t, a: 'Tu progreso en el programa se sincroniza automaticamente con el Sistema Telematico de Orientacion de la Junta de Andalucia. No necesitas hacer tramites adicionales: los certificados y horas quedan registrados oficialmente.'|t },
      ] %}
      {% for faq in faqs %}
        <details class="aei-landing__faq-item" data-effect="fade-up" data-delay="{{ loop.index0 * 80 }}">
          <summary class="aei-landing__faq-question">{{ faq.q }}</summary>
          <div class="aei-landing__faq-answer">{{ faq.a }}</div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{# === CTA FINAL: Conversion === #}
<section class="aei-landing__cta-section" data-effect="fade-up" aria-label="{% trans %}Solicitar plaza{% endtrans %}">
  <div class="aei-landing__container">
    <div class="aei-landing__cta-content">
      <h2 class="aei-landing__cta-title">{% trans %}Solicita tu plaza ahora{% endtrans %}</h2>
      <p class="aei-landing__cta-subtitle">{% trans %}45 plazas entre Malaga y Sevilla. Mentoria IA, expediente digital seguro, formacion adaptativa y 528 € de incentivo. 100% gratuito.{% endtrans %}</p>
      <div class="aei-landing__cta-actions">
        <a href="{{ solicitar_url }}" class="aei-landing__cta aei-landing__cta--primary aei-landing__cta--large">
          {% trans %}Solicitar plaza{% endtrans %}
        </a>
      </div>
      <p class="aei-landing__cta-footer">{% trans %}Financiado por la Junta de Andalucia y el Fondo Social Europeo Plus (FSE+).{% endtrans %}</p>
    </div>
  </div>
</section>

{# === FAQPage Schema para rich results en Google === #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in faqs %}
    {
      "@type": "Question",
      "name": "{{ faq.q|e('html_attr') }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ faq.a|e('html_attr') }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
