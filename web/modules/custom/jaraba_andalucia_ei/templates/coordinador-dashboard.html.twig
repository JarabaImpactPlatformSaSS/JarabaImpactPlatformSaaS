{#
/**
 * @file
 * Hub unificado del coordinador para Andalucia +ei — Clase Mundial.
 *
 * Variables:
 *   - stats: {total_participants, active_participants, insertion_phase,
 *             completed_sessions, pending_solicitudes, insertion_rate}.
 *   - phase_distribution: {acogida, diagnostico, atencion, insercion, seguimiento, baja}.
 *   - mentor_utilization: Array de mentores con stats.
 *   - recent_activity: Array de actividad reciente con timestamp.
 *   - hub_kpis: KPIs desde CoordinadorHubService.
 *   - alertas: Array de alertas normativas.
 *   - alertas_resumen: {critico, alto, medio, info}.
 *   - compliance: {daci_rate, fse_entrada_rate, fse_salida_rate, ...}.
 *   - formacion_stats: {total_acciones, en_ejecucion, vobo_pendiente,
 *                       sesiones_programadas, planes_activos}.
 *   - vobo_pendientes: int.
 *   - sesiones_proximas: Array de SesionProgramadaEi (max 7 dias).
 *   - indicadores_esf: {tasa_asistencia, horas_totales, participantes_activos}.
 *
 * Directrices aplicadas:
 *   - ICON-CONVENTION-001, ICON-DUOTONE-001, ICON-COLOR-001
 *   - CSS-VAR-ALL-COLORS-001
 *   - INNERHTML-XSS-001 (via JS Drupal.checkPlain)
 *   - Textos {% trans %} para i18n
 */
#}

<div class="hub-coordinador" data-coordinador-hub>

  {# === PREMIUM HEADER (user-section-header pattern) === #}
  <header class="hub-coordinador__header" aria-labelledby="coord-title">
    <div class="hub-coordinador__header-hero">
      <div class="hub-coordinador__header-icon">
        {{ jaraba_icon('analytics', 'dashboard', { variant: 'duotone', color: 'azul-corporativo', size: '64px' }) }}
      </div>
      <div class="hub-coordinador__header-text">
        <h1 id="coord-title" class="hub-coordinador__title">
          {% trans %}Hub de Coordinacion{% endtrans %}
        </h1>
        <p class="hub-coordinador__subtitle">
          {% trans %}Centro de operaciones del programa Andalucia +ei — PIIL CV 2025{% endtrans %}
        </p>
      </div>
    </div>

    {# Quick Actions — aei-action pattern #}
    <div class="hub-coordinador__actions-grid">
      <a href="{{ path('entity.programa_participante_ei.add_form') }}" class="hub-coordinador__action-card hub-coordinador__action-card--primary" data-slide-panel>
        <span class="hub-coordinador__action-icon hub-coordinador__action-icon--add">
          {{ jaraba_icon('actions', 'plus', { variant: 'outline', color: 'white', size: '24px' }) }}
        </span>
        <span class="hub-coordinador__action-content">
          <span class="hub-coordinador__action-title">{% trans %}Nuevo participante{% endtrans %}</span>
          <span class="hub-coordinador__action-desc">{% trans %}Registrar alta en programa{% endtrans %}</span>
        </span>
        <span class="hub-coordinador__action-arrow" aria-hidden="true">&rarr;</span>
      </a>
      <a href="{{ path('jaraba_andalucia_ei.sto_export') }}" class="hub-coordinador__action-card hub-coordinador__action-card--secondary">
        <span class="hub-coordinador__action-icon hub-coordinador__action-icon--export">
          {{ jaraba_icon('actions', 'export', { variant: 'duotone', color: 'azul-corporativo', size: '24px' }) }}
        </span>
        <span class="hub-coordinador__action-content">
          <span class="hub-coordinador__action-title">{% trans %}Exportar STO{% endtrans %}</span>
          <span class="hub-coordinador__action-desc">{% trans %}Descarga seguimiento tecnico{% endtrans %}</span>
        </span>
        <span class="hub-coordinador__action-arrow" aria-hidden="true">&rarr;</span>
      </a>
      <a href="{{ path('jaraba_andalucia_ei.leads_guia') }}" class="hub-coordinador__action-card hub-coordinador__action-card--secondary">
        <span class="hub-coordinador__action-icon hub-coordinador__action-icon--leads">
          {{ jaraba_icon('business', 'talent-search', { variant: 'duotone', color: 'verde-innovacion', size: '24px' }) }}
        </span>
        <span class="hub-coordinador__action-content">
          <span class="hub-coordinador__action-title">{% trans %}Leads{% endtrans %}</span>
          <span class="hub-coordinador__action-desc">{% trans %}Gestion de candidatos{% endtrans %}</span>
        </span>
        <span class="hub-coordinador__action-arrow" aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </header>

  {# === ALERTAS NORMATIVAS PIIL === #}
  <section class="hub-coordinador__alertas" aria-label="{% trans %}Alertas normativas{% endtrans %}">
    <div class="hub-coordinador__alertas-header">
      {{ jaraba_icon('compliance', 'alert-bell', { variant: 'duotone', color: 'naranja-impulso', size: '20px' }) }}
      <h2 class="hub-coordinador__alertas-title">
        {% trans %}Alertas Normativas{% endtrans %}
      </h2>
      {% if alertas is not empty %}
        <div class="hub-coordinador__alertas-badges">
          {% if alertas_resumen.critico > 0 %}
            <span class="hub-coordinador__alerta-badge hub-coordinador__alerta-badge--critico">{{ alertas_resumen.critico }} {% trans %}criticas{% endtrans %}</span>
          {% endif %}
          {% if alertas_resumen.alto > 0 %}
            <span class="hub-coordinador__alerta-badge hub-coordinador__alerta-badge--alto">{{ alertas_resumen.alto }} {% trans %}altas{% endtrans %}</span>
          {% endif %}
          {% if alertas_resumen.medio > 0 %}
            <span class="hub-coordinador__alerta-badge hub-coordinador__alerta-badge--medio">{{ alertas_resumen.medio }} {% trans %}medias{% endtrans %}</span>
          {% endif %}
        </div>
      {% endif %}
    </div>
    {% if alertas is not empty %}
      <ul class="hub-coordinador__alertas-list" role="list">
        {% for alerta in alertas|slice(0, 8) %}
          <li class="hub-coordinador__alerta-item hub-coordinador__alerta-item--{{ alerta.nivel }}">
            <span class="hub-coordinador__alerta-icon">
              {% if alerta.nivel == 'critico' %}
                {{ jaraba_icon('status', 'x-circle', { variant: 'duotone', color: 'naranja-impulso', size: '16px' }) }}
              {% else %}
                {{ jaraba_icon('status', 'alert-circle', { variant: 'duotone', color: 'azul-corporativo', size: '16px' }) }}
              {% endif %}
            </span>
            <div class="hub-coordinador__alerta-body">
              <span class="hub-coordinador__alerta-msg">{{ alerta.mensaje }}</span>
              <span class="hub-coordinador__alerta-accion">{{ alerta.accion }}</span>
            </div>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <div class="hub-coordinador__empty-state">
        {{ jaraba_icon('status', 'check-circle', { variant: 'duotone', color: 'verde-innovacion', size: '32px' }) }}
        <p>{% trans %}Sin alertas normativas. Todo en orden.{% endtrans %}</p>
      </div>
    {% endif %}
  </section>

  {# === RIESGO DE ABANDONO === #}
  <section class="hub-coordinador__riesgo" aria-label="{% trans %}Riesgo de abandono{% endtrans %}">
    <div class="hub-coordinador__riesgo-header">
      {{ jaraba_icon('status', 'alert-triangle', { variant: 'duotone', color: 'naranja-impulso', size: '20px' }) }}
      <h2 class="hub-coordinador__riesgo-title">
        {% trans %}Participantes en Riesgo de Abandono{% endtrans %}
        {% if riesgo is not empty %}
          <span class="hub-coordinador__riesgo-count">{{ riesgo|length }}</span>
        {% endif %}
      </h2>
    </div>
    {% if riesgo is not empty %}
      <div class="hub-coordinador__riesgo-grid">
        {% for p in riesgo|slice(0, 6) %}
          <div class="hub-coordinador__riesgo-card hub-coordinador__riesgo-card--{{ p.riesgo.nivel }}">
            <div class="hub-coordinador__riesgo-top">
              <span class="hub-coordinador__riesgo-nombre">{{ p.nombre }}</span>
              <span class="hub-coordinador__badge hub-coordinador__badge--{{ p.riesgo.nivel }}">{{ p.riesgo.nivel }}</span>
            </div>
            <div class="hub-coordinador__riesgo-meta">
              <span>{% trans %}Fase:{% endtrans %} {{ p.fase_actual }}</span>
              <span>{% trans %}Semana{% endtrans %} {{ p.semana_actual }}</span>
              <span>{% trans %}Score:{% endtrans %} {{ p.riesgo.score }}</span>
            </div>
            {% if p.riesgo.factores is not empty %}
              <ul class="hub-coordinador__riesgo-factores">
                {% for factor in p.riesgo.factores|slice(0, 3) %}
                  <li>{{ factor.descripcion }} <small>(+{{ factor.puntos }})</small></li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="hub-coordinador__empty-state">
        {{ jaraba_icon('status', 'check-circle', { variant: 'duotone', color: 'verde-innovacion', size: '32px' }) }}
        <p>{% trans %}Ningun participante en riesgo de abandono detectado.{% endtrans %}</p>
      </div>
    {% endif %}
  </section>

  {# === KPI CARDS (Premium glassmorphism + shine — clickable) === #}
  <section class="hub-coordinador__kpis" aria-label="{% trans %}Indicadores clave{% endtrans %}">
    <button type="button" class="hub-coordinador__kpi-card" data-kpi-target="participantes" aria-label="{% trans %}Ver participantes activos{% endtrans %}">
      <span class="hub-coordinador__kpi-shine" aria-hidden="true"></span>
      <div class="hub-coordinador__kpi-icon hub-coordinador__kpi-icon--activos">
        {{ jaraba_icon('ui', 'users', { variant: 'duotone', color: 'azul-corporativo', size: '24px' }) }}
      </div>
      <div class="hub-coordinador__kpi-data">
        <span class="hub-coordinador__kpi-value" data-kpi="active_participants">{{ stats.active_participants }}</span>
        <span class="hub-coordinador__kpi-label">{% trans %}Participantes activos{% endtrans %}</span>
      </div>
      <span class="hub-coordinador__kpi-arrow" aria-hidden="true">&rarr;</span>
    </button>

    <button type="button" class="hub-coordinador__kpi-card hub-coordinador__kpi-card--alert" data-kpi-target="solicitudes" data-kpi-filter-key="estado" data-kpi-filter-value="pendiente" aria-label="{% trans %}Ver solicitudes pendientes{% endtrans %}">
      <span class="hub-coordinador__kpi-shine" aria-hidden="true"></span>
      <div class="hub-coordinador__kpi-icon hub-coordinador__kpi-icon--pendientes">
        {{ jaraba_icon('ui', 'inbox', { variant: 'duotone', color: 'naranja-impulso', size: '24px' }) }}
      </div>
      <div class="hub-coordinador__kpi-data">
        <span class="hub-coordinador__kpi-value" data-kpi="pending_solicitudes">{{ stats.pending_solicitudes }}</span>
        <span class="hub-coordinador__kpi-label">{% trans %}Solicitudes pendientes{% endtrans %}</span>
      </div>
      <span class="hub-coordinador__kpi-arrow" aria-hidden="true">&rarr;</span>
    </button>

    <button type="button" class="hub-coordinador__kpi-card hub-coordinador__kpi-card--highlight" data-kpi-target="participantes" data-kpi-filter-key="fase" data-kpi-filter-value="insercion" aria-label="{% trans %}Ver participantes en insercion{% endtrans %}">
      <span class="hub-coordinador__kpi-shine" aria-hidden="true"></span>
      <div class="hub-coordinador__kpi-icon hub-coordinador__kpi-icon--insercion">
        {{ jaraba_icon('analytics', 'trophy', { variant: 'duotone', color: 'verde-innovacion', size: '24px' }) }}
      </div>
      <div class="hub-coordinador__kpi-data">
        <span class="hub-coordinador__kpi-value" data-kpi="insertion_rate">{{ stats.insertion_rate }}%</span>
        <span class="hub-coordinador__kpi-label">{% trans %}Tasa de insercion{% endtrans %}</span>
      </div>
      <span class="hub-coordinador__kpi-arrow" aria-hidden="true">&rarr;</span>
    </button>

    <button type="button" class="hub-coordinador__kpi-card" data-kpi-target="sesiones" aria-label="{% trans %}Ver sesiones completadas{% endtrans %}">
      <span class="hub-coordinador__kpi-shine" aria-hidden="true"></span>
      <div class="hub-coordinador__kpi-icon hub-coordinador__kpi-icon--sesiones">
        {{ jaraba_icon('ui', 'calendar', { variant: 'duotone', color: 'azul-corporativo', size: '24px' }) }}
      </div>
      <div class="hub-coordinador__kpi-data">
        <span class="hub-coordinador__kpi-value" data-kpi="completed_sessions">{{ stats.completed_sessions }}</span>
        <span class="hub-coordinador__kpi-label">{% trans %}Sesiones completadas{% endtrans %}</span>
      </div>
      <span class="hub-coordinador__kpi-arrow" aria-hidden="true">&rarr;</span>
    </button>

    <button type="button" class="hub-coordinador__kpi-card" data-kpi-target="participantes" aria-label="{% trans %}Ver todos los participantes{% endtrans %}">
      <span class="hub-coordinador__kpi-shine" aria-hidden="true"></span>
      <div class="hub-coordinador__kpi-icon hub-coordinador__kpi-icon--total">
        {{ jaraba_icon('ui', 'user', { variant: 'duotone', color: 'azul-corporativo', size: '24px' }) }}
      </div>
      <div class="hub-coordinador__kpi-data">
        <span class="hub-coordinador__kpi-value" data-kpi="total_participants">{{ stats.total_participants }}</span>
        <span class="hub-coordinador__kpi-label">{% trans %}Total participantes{% endtrans %}</span>
      </div>
      <span class="hub-coordinador__kpi-arrow" aria-hidden="true">&rarr;</span>
    </button>
  </section>

  {# === COMPLIANCE SUMMARY === #}
  {% if compliance %}
    <section class="hub-coordinador__compliance" aria-label="{% trans %}Cumplimiento normativo{% endtrans %}">
      <h2 class="hub-coordinador__section-title">
        {{ jaraba_icon('compliance', 'shield-check', { variant: 'duotone', color: 'verde-innovacion', size: '20px' }) }}
        {% trans %}Cumplimiento PIIL{% endtrans %}
      </h2>
      <div class="hub-coordinador__compliance-grid">
        <div class="hub-coordinador__compliance-card">
          <div class="hub-coordinador__compliance-ring" data-percent="{{ compliance.acuerdo_rate }}" style="--ring-percent: {{ compliance.acuerdo_rate }}; --ring-color: var(--ej-color-azul-corporativo, #233D63);">
            <svg viewBox="0 0 36 36" class="hub-coordinador__compliance-svg" aria-hidden="true">
              <path class="hub-coordinador__compliance-track" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
              <path class="hub-coordinador__compliance-fill" stroke-dasharray="{{ compliance.acuerdo_rate }}, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
            </svg>
            <span class="hub-coordinador__compliance-percent">{{ compliance.acuerdo_rate }}%</span>
          </div>
          <div class="hub-coordinador__compliance-info">
            <span class="hub-coordinador__compliance-label">{% trans %}Acuerdos de Participacion{% endtrans %}</span>
            <span class="hub-coordinador__compliance-detail">{{ compliance.acuerdo_signed }}/{{ compliance.acuerdo_total }}</span>
          </div>
        </div>

        <div class="hub-coordinador__compliance-card">
          <div class="hub-coordinador__compliance-ring" data-percent="{{ compliance.daci_rate }}" style="--ring-percent: {{ compliance.daci_rate }}; --ring-color: var(--ej-color-naranja-impulso, #FF8C42);">
            <svg viewBox="0 0 36 36" class="hub-coordinador__compliance-svg" aria-hidden="true">
              <path class="hub-coordinador__compliance-track" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
              <path class="hub-coordinador__compliance-fill" stroke-dasharray="{{ compliance.daci_rate }}, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
            </svg>
            <span class="hub-coordinador__compliance-percent">{{ compliance.daci_rate }}%</span>
          </div>
          <div class="hub-coordinador__compliance-info">
            <span class="hub-coordinador__compliance-label">{% trans %}DACI (Compromisos){% endtrans %}</span>
            <span class="hub-coordinador__compliance-detail">{{ compliance.daci_signed }}/{{ compliance.daci_total }}</span>
          </div>
        </div>

        <div class="hub-coordinador__compliance-card">
          <div class="hub-coordinador__compliance-ring" data-percent="{{ compliance.fse_entrada_rate }}" style="--ring-percent: {{ compliance.fse_entrada_rate }}; --ring-color: var(--ej-color-verde-innovacion, #00A9A5);">
            <svg viewBox="0 0 36 36" class="hub-coordinador__compliance-svg" aria-hidden="true">
              <path class="hub-coordinador__compliance-track" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
              <path class="hub-coordinador__compliance-fill" stroke-dasharray="{{ compliance.fse_entrada_rate }}, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
            </svg>
            <span class="hub-coordinador__compliance-percent">{{ compliance.fse_entrada_rate }}%</span>
          </div>
          <div class="hub-coordinador__compliance-info">
            <span class="hub-coordinador__compliance-label">{% trans %}FSE+ entrada{% endtrans %}</span>
            <span class="hub-coordinador__compliance-detail">{{ compliance.fse_entrada_done }}/{{ compliance.fse_entrada_total }}</span>
          </div>
        </div>

        <div class="hub-coordinador__compliance-card">
          <div class="hub-coordinador__compliance-ring" data-percent="{{ compliance.fse_salida_rate }}" style="--ring-percent: {{ compliance.fse_salida_rate }}; --ring-color: var(--ej-color-naranja-impulso, #FF8C42);">
            <svg viewBox="0 0 36 36" class="hub-coordinador__compliance-svg" aria-hidden="true">
              <path class="hub-coordinador__compliance-track" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
              <path class="hub-coordinador__compliance-fill" stroke-dasharray="{{ compliance.fse_salida_rate }}, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
            </svg>
            <span class="hub-coordinador__compliance-percent">{{ compliance.fse_salida_rate }}%</span>
          </div>
          <div class="hub-coordinador__compliance-info">
            <span class="hub-coordinador__compliance-label">{% trans %}FSE+ salida{% endtrans %}</span>
            <span class="hub-coordinador__compliance-detail">{{ compliance.fse_salida_done }}/{{ compliance.fse_salida_total }}</span>
          </div>
        </div>

        {# Incentivo €528 — pagados + renunciados #}
        <div class="hub-coordinador__compliance-card">
          <div class="hub-coordinador__compliance-ring" data-percent="{{ compliance.incentivo_rate }}" style="--ring-percent: {{ compliance.incentivo_rate }}; --ring-color: var(--ej-color-verde-innovacion, #00A9A5);">
            <svg viewBox="0 0 36 36" class="hub-coordinador__compliance-svg" aria-hidden="true">
              <path class="hub-coordinador__compliance-track" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
              <path class="hub-coordinador__compliance-fill" stroke-dasharray="{{ compliance.incentivo_rate }}, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
            </svg>
            <span class="hub-coordinador__compliance-percent">{{ compliance.incentivo_rate }}%</span>
          </div>
          <div class="hub-coordinador__compliance-info">
            <span class="hub-coordinador__compliance-label">{% trans %}Incentivo €528{% endtrans %}</span>
            <span class="hub-coordinador__compliance-detail">{{ compliance.incentivo_gestionados }}/{{ compliance.incentivo_total }}</span>
            {% if compliance.incentivo_renunciados > 0 %}
              <span class="hub-coordinador__compliance-note">{% trans %}({{ compliance.incentivo_renunciados }} renuncias){% endtrans %}</span>
            {% endif %}
          </div>
        </div>
      </div>
    </section>
  {% endif %}

  {# === TAB NAVIGATION === #}
  <nav class="hub-coordinador__tabs" role="tablist" aria-label="{% trans %}Secciones del hub{% endtrans %}">
    <button class="hub-coordinador__tab hub-coordinador__tab--active" role="tab" aria-selected="true" aria-controls="panel-solicitudes" id="tab-solicitudes" data-tab="solicitudes">
      {{ jaraba_icon('ui', 'inbox', { variant: 'outline', color: 'azul-corporativo', size: '16px' }) }}
      {% trans %}Solicitudes{% endtrans %}
      {% if stats.pending_solicitudes > 0 %}
        <span class="hub-coordinador__tab-badge">{{ stats.pending_solicitudes }}</span>
      {% endif %}
    </button>
    <button class="hub-coordinador__tab" role="tab" aria-selected="false" aria-controls="panel-participantes" id="tab-participantes" data-tab="participantes">
      {{ jaraba_icon('ui', 'users', { variant: 'outline', color: 'azul-corporativo', size: '16px' }) }}
      {% trans %}Participantes{% endtrans %}
    </button>
    <button class="hub-coordinador__tab" role="tab" aria-selected="false" aria-controls="panel-sesiones" id="tab-sesiones" data-tab="sesiones">
      {{ jaraba_icon('ui', 'calendar', { variant: 'outline', color: 'azul-corporativo', size: '16px' }) }}
      {% trans %}Sesiones{% endtrans %}
    </button>
    <button class="hub-coordinador__tab" role="tab" aria-selected="false" aria-controls="panel-documentacion" id="tab-documentacion" data-tab="documentacion">
      {{ jaraba_icon('ui', 'folder', { variant: 'outline', color: 'azul-corporativo', size: '16px' }) }}
      {% trans %}Documentacion{% endtrans %}
    </button>
    <button class="hub-coordinador__tab" role="tab" aria-selected="false" aria-controls="panel-formacion" id="tab-formacion" data-tab="formacion">
      {{ jaraba_icon('education', 'book-open', { variant: 'outline', color: 'azul-corporativo', size: '16px' }) }}
      {% trans %}Formacion{% endtrans %}
      {% if formacion_stats.vobo_pendiente > 0 %}
        <span class="hub-coordinador__tab-badge hub-coordinador__tab-badge--warning">{{ formacion_stats.vobo_pendiente }}</span>
      {% endif %}
    </button>
    <button class="hub-coordinador__tab" role="tab" aria-selected="false" aria-controls="panel-planes" id="tab-planes" data-tab="planes">
      {{ jaraba_icon('education', 'clipboard-list', { variant: 'outline', color: 'azul-corporativo', size: '16px' }) }}
      {% trans %}Planes{% endtrans %}
    </button>
    <button class="hub-coordinador__tab" role="tab" aria-selected="false" aria-controls="panel-esf" id="tab-esf" data-tab="esf">
      {{ jaraba_icon('analytics', 'target', { variant: 'outline', color: 'verde-innovacion', size: '16px' }) }}
      {% trans %}ESF+{% endtrans %}
    </button>
    <button class="hub-coordinador__tab" role="tab" aria-selected="false" aria-controls="panel-metricas" id="tab-metricas" data-tab="metricas">
      {{ jaraba_icon('analytics', 'chart-line', { variant: 'outline', color: 'azul-corporativo', size: '16px' }) }}
      {% trans %}Metricas{% endtrans %}
    </button>
  </nav>

  {# === TAB PANELS === #}
  <div class="hub-coordinador__panels">

    {# --- Panel: Solicitudes --- #}
    <div class="hub-coordinador__panel hub-coordinador__panel--active" role="tabpanel" id="panel-solicitudes" aria-labelledby="tab-solicitudes" data-panel="solicitudes">
      <div class="hub-coordinador__panel-header">
        <h2 class="hub-coordinador__panel-title">{% trans %}Gestion de Solicitudes{% endtrans %}</h2>
