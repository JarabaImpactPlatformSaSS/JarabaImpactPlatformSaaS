    {# --- Panel: Documentacion --- #}
    <div class="hub-coordinador__panel" role="tabpanel" id="panel-documentacion" aria-labelledby="tab-documentacion" data-panel="documentacion" hidden>
      <div class="hub-coordinador__panel-header">
        <h2 class="hub-coordinador__panel-title">{% trans %}Estado Documental{% endtrans %}</h2>
        <button type="button" class="hub-coordinador__export-btn" data-export="documentacion" aria-label="{% trans %}Exportar documentacion CSV{% endtrans %}">
