          <div class="hub-coordinador__kpi-card" role="group" aria-label="{% trans %}Horas Totales{% endtrans %}">
            <div class="hub-coordinador__kpi-icon hub-coordinador__kpi-icon--horas">
              {{ jaraba_icon('ui', 'clock', { variant: 'duotone', color: 'azul-corporativo', size: '24px' }) }}
            </div>
            <div class="hub-coordinador__kpi-data">
              <span class="hub-coordinador__kpi-value">{{ indicadores_esf.horas_totales|default(0)|number_format(1) }}h</span>
              <span class="hub-coordinador__kpi-label">{% trans %}Horas Totales{% endtrans %}</span>
            </div>
            <span class="hub-coordinador__kpi-shine" aria-hidden="true"></span>
          </div>
          <div class="hub-coordinador__kpi-card" role="group" aria-label="{% trans %}Participantes Activos{% endtrans %}">
            <div class="hub-coordinador__kpi-icon hub-coordinador__kpi-icon--participantes">
              {{ jaraba_icon('ui', 'users', { variant: 'duotone', color: 'naranja-impulso', size: '24px' }) }}
            </div>
            <div class="hub-coordinador__kpi-data">
              <span class="hub-coordinador__kpi-value">{{ indicadores_esf.participantes_activos|default(0) }}</span>
              <span class="hub-coordinador__kpi-label">{% trans %}Participantes Activos{% endtrans %}</span>
            </div>
            <span class="hub-coordinador__kpi-shine" aria-hidden="true"></span>
          </div>
        </div>

        <div class="hub-coordinador__esf-tables">
          <div class="hub-coordinador__section-header">
            <h3 class="hub-coordinador__section-title">
              {{ jaraba_icon('analytics', 'target', { variant: 'duotone', color: 'verde-innovacion', size: '18px' }) }}
              {% trans %}Indicadores de Realizacion (CO01-CO14) y Resultado (CR01-CR06){% endtrans %}
            </h3>
            <button class="hub-coordinador__action-btn hub-coordinador__action-btn--secondary" data-esf-refresh aria-label="{% trans %}Actualizar indicadores{% endtrans %}">
              {{ jaraba_icon('actions', 'refresh', { variant: 'outline', color: 'azul-corporativo', size: '16px' }) }}
              {% trans %}Actualizar{% endtrans %}
            </button>
          </div>
          <div class="hub-coordinador__table-wrapper">
            <table class="hub-coordinador__table" data-table="esf-indicadores">
              <thead>
                <tr>
                  <th scope="col">{% trans %}Codigo{% endtrans %}</th>
                  <th scope="col">{% trans %}Indicador{% endtrans %}</th>
                  <th scope="col">{% trans %}Valor{% endtrans %}</th>
                  <th scope="col">{% trans %}Tipo{% endtrans %}</th>
                </tr>
              </thead>
              <tbody data-content="esf-indicadores">
                <tr><td colspan="4" class="hub-coordinador__loading">{% trans %}Cargando...{% endtrans %}</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      {% else %}
        <div class="hub-coordinador__empty-state">
          {{ jaraba_icon('analytics', 'target', { variant: 'duotone', color: 'neutral', size: '48px' }) }}
          <p>{% trans %}Los indicadores ESF+ estaran disponibles cuando haya participantes activos.{% endtrans %}</p>
        </div>
      {% endif %}
    </div>

    {# --- Panel: PIIL — Itinerario por Fases (Sprint 14) --- #}
    <div class="hub-coordinador__panel" role="tabpanel" id="panel-piil" aria-labelledby="tab-piil" data-panel="piil" hidden>
      <div class="hub-coordinador__panel-header">
        <div class="hub-coordinador__panel-title-group">
          <div class="hub-coordinador__panel-title-icon hub-coordinador__panel-title-icon--piil">
            {{ jaraba_icon('compliance', 'shield-check', { variant: 'duotone', color: 'verde-innovacion', size: '28px' }) }}
          </div>
          <div>
            <h2 class="hub-coordinador__panel-title">{% trans %}Itinerario PIIL — Fases Normativas{% endtrans %}</h2>
            <p class="hub-coordinador__panel-subtitle">{% trans %}Persona Atendida + Persona Insertada (BBRR Art. 2, STO Manual ICV25){% endtrans %}</p>
          </div>
        </div>
      </div>

      {# KPIs Persona Atendida / Persona Insertada #}
      <div class="hub-coordinador__piil-personas">
        <div class="hub-coordinador__kpi-card hub-coordinador__kpi-card--piil" role="group" aria-label="{% trans %}Personas Atendidas{% endtrans %}">
          <div class="hub-coordinador__kpi-icon hub-coordinador__kpi-icon--atendida">
            {{ jaraba_icon('ui', 'badge-check', { variant: 'duotone', color: 'naranja-impulso', size: '24px' }) }}
          </div>
          <div class="hub-coordinador__kpi-data">
            <span class="hub-coordinador__kpi-value">{{ estadisticas_por_fase.personas.atendidas|default(0) }}</span>
            <span class="hub-coordinador__kpi-label">{% trans %}Personas Atendidas{% endtrans %}</span>
            <span class="hub-coordinador__kpi-sublabel">{% trans %}≥10h orient. + ≥50h form. + ≥75% asist.{% endtrans %}</span>
          </div>
          <span class="hub-coordinador__kpi-shine" aria-hidden="true"></span>
        </div>
        <div class="hub-coordinador__kpi-card hub-coordinador__kpi-card--piil" role="group" aria-label="{% trans %}Personas Insertadas{% endtrans %}">
          <div class="hub-coordinador__kpi-icon hub-coordinador__kpi-icon--insertada">
            {{ jaraba_icon('analytics', 'trophy', { variant: 'duotone', color: 'verde-innovacion', size: '24px' }) }}
          </div>
          <div class="hub-coordinador__kpi-data">
            <span class="hub-coordinador__kpi-value">{{ estadisticas_por_fase.personas.insertadas|default(0) }}</span>
            <span class="hub-coordinador__kpi-label">{% trans %}Personas Insertadas{% endtrans %}</span>
            <span class="hub-coordinador__kpi-sublabel">{% trans %}Atendida + ≥40h orient. ins. + contrato ≥4m{% endtrans %}</span>
          </div>
          <span class="hub-coordinador__kpi-shine" aria-hidden="true"></span>
        </div>
      </div>

      {# === FASE ATENCION === #}
      <div class="hub-coordinador__fase hub-coordinador__fase--atencion">
        <div class="hub-coordinador__fase-header">
          <div class="hub-coordinador__fase-badge hub-coordinador__fase-badge--atencion">
            {{ jaraba_icon('education', 'book-open', { variant: 'duotone', color: 'white', size: '16px' }) }}
            {% trans %}Fase de Atencion{% endtrans %}
          </div>
          <span class="hub-coordinador__fase-desc">{% trans %}Orientacion laboral + Formacion{% endtrans %}</span>
        </div>
        <div class="hub-coordinador__fase-kpis">
          <div class="hub-coordinador__fase-kpi">
            <span class="hub-coordinador__fase-kpi-value">{{ estadisticas_por_fase.atencion.sesiones_orientacion|default(0) }}</span>
            <span class="hub-coordinador__fase-kpi-label">{% trans %}Sesiones orient. laboral{% endtrans %}</span>
          </div>
          <div class="hub-coordinador__fase-kpi">
            <span class="hub-coordinador__fase-kpi-value">{{ estadisticas_por_fase.atencion.acciones_formativas|default(0) }}</span>
            <span class="hub-coordinador__fase-kpi-label">{% trans %}Acciones formativas{% endtrans %}</span>
          </div>
          <div class="hub-coordinador__fase-kpi">
            <span class="hub-coordinador__fase-kpi-value">{{ estadisticas_por_fase.atencion.acciones_vobo_aprobado|default(0) }}</span>
            <span class="hub-coordinador__fase-kpi-label">{% trans %}VoBo aprobado{% endtrans %}</span>
          </div>
          <div class="hub-coordinador__fase-kpi">
            <span class="hub-coordinador__fase-kpi-value">{{ estadisticas_por_fase.atencion.sesiones_formativas|default(0) }}</span>
            <span class="hub-coordinador__fase-kpi-label">{% trans %}Sesiones formativas{% endtrans %}</span>
          </div>
        </div>

        {# Sesiones próximas — Fase Atención #}
        {% set sesiones_atencion = [] %}
        {% for sesion in sesiones_proximas_piil %}
          {% if sesion.fase_piil == 'atencion' %}
            {% set sesiones_atencion = sesiones_atencion|merge([sesion]) %}
          {% endif %}
        {% endfor %}
        {% if sesiones_atencion|length > 0 %}
          <div class="hub-coordinador__fase-sesiones">
            <h4 class="hub-coordinador__fase-sesiones-title">
              {{ jaraba_icon('ui', 'calendar', { variant: 'outline', color: 'naranja-impulso', size: '14px' }) }}
              {% trans %}Proximas sesiones (14 dias){% endtrans %}
              <span class="hub-coordinador__section-count">{{ sesiones_atencion|length }}</span>
            </h4>
            <div class="hub-coordinador__sesiones-grid hub-coordinador__sesiones-grid--compact">
              {% for sesion in sesiones_atencion[:4] %}
                <div class="hub-coordinador__sesion-card hub-coordinador__sesion-card--fase-atencion">
                  <div class="hub-coordinador__sesion-date-block">
                    <span class="hub-coordinador__sesion-day">{{ sesion.fecha|date('d') }}</span>
                    <span class="hub-coordinador__sesion-month">{{ sesion.fecha|date('M') }}</span>
                  </div>
                  <div class="hub-coordinador__sesion-body">
                    <span class="hub-coordinador__sesion-title">{{ sesion.titulo }}</span>
                    <div class="hub-coordinador__sesion-meta">
                      <span class="hub-coordinador__sesion-hora">
                        {{ jaraba_icon('ui', 'clock', { variant: 'outline', color: 'neutral', size: '12px' }) }}
                        {{ sesion.hora_inicio }} - {{ sesion.hora_fin }}
                      </span>
                      <span class="hub-coordinador__sesion-tipo hub-coordinador__sesion-tipo--{{ sesion.tipo_sesion }}">
                        {{ sesion.tipo_sesion|replace({'_': ' '})|capitalize }}
                      </span>
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>

      {# === FASE INSERCION === #}
      <div class="hub-coordinador__fase hub-coordinador__fase--insercion">
        <div class="hub-coordinador__fase-header">
          <div class="hub-coordinador__fase-badge hub-coordinador__fase-badge--insercion">
            {{ jaraba_icon('analytics', 'trophy', { variant: 'duotone', color: 'white', size: '16px' }) }}
            {% trans %}Fase de Insercion{% endtrans %}
          </div>
          <span class="hub-coordinador__fase-desc">{% trans %}Orientacion para la insercion + Prospeccion{% endtrans %}</span>
        </div>
        <div class="hub-coordinador__fase-kpis">
          <div class="hub-coordinador__fase-kpi">
            <span class="hub-coordinador__fase-kpi-value">{{ estadisticas_por_fase.insercion.sesiones_orientacion|default(0) }}</span>
            <span class="hub-coordinador__fase-kpi-label">{% trans %}Sesiones orient. insercion{% endtrans %}</span>
          </div>
          <div class="hub-coordinador__fase-kpi">
            <span class="hub-coordinador__fase-kpi-value">{{ estadisticas_por_fase.insercion.prospecciones|default(0) }}</span>
            <span class="hub-coordinador__fase-kpi-label">{% trans %}Prospecciones empresariales{% endtrans %}</span>
          </div>
        </div>

        {# Sesiones próximas — Fase Inserción #}
        {% set sesiones_insercion = [] %}
        {% for sesion in sesiones_proximas_piil %}
          {% if sesion.fase_piil == 'insercion' %}
            {% set sesiones_insercion = sesiones_insercion|merge([sesion]) %}
          {% endif %}
        {% endfor %}
        {% if sesiones_insercion|length > 0 %}
          <div class="hub-coordinador__fase-sesiones">
            <h4 class="hub-coordinador__fase-sesiones-title">
              {{ jaraba_icon('ui', 'calendar', { variant: 'outline', color: 'verde-innovacion', size: '14px' }) }}
              {% trans %}Proximas sesiones (14 dias){% endtrans %}
              <span class="hub-coordinador__section-count">{{ sesiones_insercion|length }}</span>
            </h4>
            <div class="hub-coordinador__sesiones-grid hub-coordinador__sesiones-grid--compact">
              {% for sesion in sesiones_insercion[:4] %}
                <div class="hub-coordinador__sesion-card hub-coordinador__sesion-card--fase-insercion">
                  <div class="hub-coordinador__sesion-date-block">
                    <span class="hub-coordinador__sesion-day">{{ sesion.fecha|date('d') }}</span>
                    <span class="hub-coordinador__sesion-month">{{ sesion.fecha|date('M') }}</span>
                  </div>
                  <div class="hub-coordinador__sesion-body">
                    <span class="hub-coordinador__sesion-title">{{ sesion.titulo }}</span>
                    <div class="hub-coordinador__sesion-meta">
                      <span class="hub-coordinador__sesion-hora">
                        {{ jaraba_icon('ui', 'clock', { variant: 'outline', color: 'neutral', size: '12px' }) }}
                        {{ sesion.hora_inicio }} - {{ sesion.hora_fin }}
                      </span>
                      <span class="hub-coordinador__sesion-tipo hub-coordinador__sesion-tipo--{{ sesion.tipo_sesion }}">
                        {{ sesion.tipo_sesion|replace({'_': ' '})|capitalize }}
                      </span>
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    {# --- Panel: Emprendimiento BMC (Sprint 15) --- #}
    {% if emprendimiento_stats and emprendimiento_stats.total_planes > 0 %}
    <div class="hub-coordinador__panel" role="tabpanel" id="panel-emprendimiento" aria-labelledby="tab-emprendimiento" data-panel="emprendimiento" hidden>
      <h2 class="hub-coordinador__panel-title">
        {{ jaraba_icon('business', 'rocket', { variant: 'duotone', color: 'naranja-impulso', size: '22px' }) }}
        {% trans %}Emprendimiento — Carril Acelera Pro{% endtrans %}
      </h2>

      {# Semáforo de viabilidad global #}
      <div class="hub-coordinador__kpi-grid hub-coordinador__kpi-grid--4col">
        <div class="hub-coordinador__kpi-card hub-coordinador__kpi-card--success">
          <span class="hub-coordinador__kpi-value">{{ emprendimiento_stats.semaforo.verde|default(0) }}</span>
          <span class="hub-coordinador__kpi-label">{% trans %}Viables{% endtrans %}</span>
        </div>
        <div class="hub-coordinador__kpi-card hub-coordinador__kpi-card--warning">
          <span class="hub-coordinador__kpi-value">{{ emprendimiento_stats.semaforo.amarillo|default(0) }}</span>
          <span class="hub-coordinador__kpi-label">{% trans %}Con condiciones{% endtrans %}</span>
        </div>
        <div class="hub-coordinador__kpi-card hub-coordinador__kpi-card--danger">
          <span class="hub-coordinador__kpi-value">{{ emprendimiento_stats.semaforo.rojo|default(0) }}</span>
          <span class="hub-coordinador__kpi-label">{% trans %}No viables{% endtrans %}</span>
        </div>
        <div class="hub-coordinador__kpi-card">
          <span class="hub-coordinador__kpi-value">{{ emprendimiento_stats.semaforo.pendiente|default(0) }}</span>
          <span class="hub-coordinador__kpi-label">{% trans %}Pendientes{% endtrans %}</span>
        </div>
      </div>

      {# Distribución por fase de emprendimiento #}
      {% if emprendimiento_stats.por_fase %}
      <div class="hub-coordinador__metric-section">
        <h3 class="hub-coordinador__metric-title">
          {{ jaraba_icon('ui', 'layers', { variant: 'outline', color: 'azul-corporativo', size: '16px' }) }}
          {% trans %}Distribucion por Fase{% endtrans %}
        </h3>
        <div class="hub-coordinador__emprendimiento-fases">
          {% set fase_labels = {
            'ideacion': 'Ideacion',
            'validacion': 'Validacion',
            'lanzamiento': 'Lanzamiento',
            'consolidacion': 'Consolidacion'
          } %}
          {% for fase, count in emprendimiento_stats.por_fase %}
            <div class="hub-coordinador__emprendimiento-fase">
              <span class="hub-coordinador__emprendimiento-fase-label">{{ fase_labels[fase]|default(fase) }}</span>
              <span class="hub-coordinador__emprendimiento-fase-count">{{ count }}</span>
            </div>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      {# Planes recientes con score #}
      {% if emprendimiento_stats.planes_recientes %}
      <div class="hub-coordinador__metric-section">
        <h3 class="hub-coordinador__metric-title">
          {{ jaraba_icon('content', 'book-open', { variant: 'outline', color: 'naranja-impulso', size: '16px' }) }}
          {% trans %}Planes de emprendimiento{% endtrans %}
        </h3>
        <div class="hub-coordinador__table-wrap">
          <table class="hub-coordinador__table">
            <thead>
              <tr>
                <th scope="col">{% trans %}Plan{% endtrans %}</th>
                <th scope="col">{% trans %}Fase{% endtrans %}</th>
                <th scope="col">{% trans %}Viabilidad{% endtrans %}</th>
                <th scope="col">{% trans %}Score{% endtrans %}</th>
              </tr>
            </thead>
            <tbody>
              {% for plan in emprendimiento_stats.planes_recientes %}
                <tr>
                  <td>{{ plan.label }}</td>
                  <td>
                    <span class="hub-coordinador__badge hub-coordinador__badge--fase-{{ plan.fase }}">
                      {{ fase_labels[plan.fase]|default(plan.fase) }}
                    </span>
                  </td>
                  <td>
                    {% set viab_class = {
                      'viable': 'success',
                      'viable_con_condiciones': 'warning',
                      'no_viable': 'danger',
                      'pendiente': 'info'
                    } %}
                    <span class="hub-coordinador__badge hub-coordinador__badge--{{ viab_class[plan.viabilidad]|default('info') }}">
                      {{ plan.viabilidad|replace({'_': ' '})|capitalize }}
                    </span>
                  </td>
                  <td>
                    <div class="hub-coordinador__progress-mini">
                      <div class="hub-coordinador__progress-mini-bar" style="width: {{ plan.score }}%"></div>
                      <span class="hub-coordinador__progress-mini-label">{{ plan.score|round }}%</span>
                    </div>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      {% endif %}
    </div>
    {% endif %}

    {# --- Panel: Metricas --- #}
    <div class="hub-coordinador__panel" role="tabpanel" id="panel-metricas" aria-labelledby="tab-metricas" data-panel="metricas" hidden>
      <h2 class="hub-coordinador__panel-title">{% trans %}Metricas del Programa{% endtrans %}</h2>

      {# Distribucion por fase — TODAS las 6 fases #}
      <div class="hub-coordinador__metric-section">
        <h3 class="hub-coordinador__metric-title">
          {{ jaraba_icon('analytics', 'chart-bar', { variant: 'duotone', color: 'azul-corporativo', size: '18px' }) }}
          {% trans %}Distribucion por Fase{% endtrans %}
        </h3>
        <div class="hub-coordinador__phases">
          {% set total_phases = 0 %}
          {% for phase, count in phase_distribution %}
            {% set total_phases = total_phases + count %}
          {% endfor %}

          {% set lbl_acogida %}{% trans %}Acogida{% endtrans %}{% endset %}
          {% set lbl_diagnostico %}{% trans %}Diagnostico{% endtrans %}{% endset %}
          {% set lbl_atencion %}{% trans %}Atencion{% endtrans %}{% endset %}
          {% set lbl_insercion %}{% trans %}Insercion{% endtrans %}{% endset %}
          {% set lbl_seguimiento %}{% trans %}Seguimiento{% endtrans %}{% endset %}
          {% set lbl_baja %}{% trans %}Baja{% endtrans %}{% endset %}
          {% set phase_labels = {
            'acogida': lbl_acogida,
            'diagnostico': lbl_diagnostico,
            'atencion': lbl_atencion,
            'insercion': lbl_insercion,
            'seguimiento': lbl_seguimiento,
            'baja': lbl_baja
          } %}

          {% for phase, count in phase_distribution %}
            {% set percent = total_phases > 0 ? ((count / total_phases) * 100)|round : 0 %}
            <div class="hub-coordinador__phase-bar">
              <div class="hub-coordinador__phase-label">
                <span class="hub-coordinador__phase-name hub-coordinador__phase-name--{{ phase }}">
                  {{ phase_labels[phase]|default(phase) }}
                </span>
                <span class="hub-coordinador__phase-count">{{ count }} ({{ percent }}%)</span>
              </div>
              <div class="hub-coordinador__phase-track">
                <div class="hub-coordinador__phase-fill hub-coordinador__phase-fill--{{ phase }}" style="width: {{ percent }}%"></div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      {# Actividad de Mentores #}
      {% if mentor_utilization|length > 0 %}
        <div class="hub-coordinador__metric-section">
          <h3 class="hub-coordinador__metric-title">
            {{ jaraba_icon('ui', 'badge-check', { variant: 'duotone', color: 'verde-innovacion', size: '18px' }) }}
            {% trans %}Actividad de Mentores{% endtrans %}
          </h3>
          <div class="hub-coordinador__table-wrapper">
            <table class="hub-coordinador__table">
              <thead>
                <tr>
                  <th scope="col">{% trans %}Mentor{% endtrans %}</th>
                  <th scope="col">{% trans %}Sesiones{% endtrans %}</th>
                  <th scope="col">{% trans %}Rating{% endtrans %}</th>
                  <th scope="col">{% trans %}Disponible{% endtrans %}</th>
                </tr>
              </thead>
              <tbody>
                {% for mentor in mentor_utilization %}
                  <tr>
                    <td>
                      <div class="hub-coordinador__mentor-name">
                        {{ jaraba_icon('ui', 'user', { variant: 'outline', color: 'azul-corporativo', size: '14px' }) }}
                        {{ mentor.name }}
                      </div>
                    </td>
                    <td>{{ mentor.total_sessions }}</td>
                    <td>
                      {% if mentor.average_rating > 0 %}
                        <span class="hub-coordinador__rating">
                          {{ jaraba_icon('ui', 'star', { variant: 'duotone', color: 'naranja-impulso', size: '14px' }) }}
                          {{ mentor.average_rating|number_format(1) }}
                        </span>
                      {% else %}
                        <span class="hub-coordinador__rating hub-coordinador__rating--empty">-</span>
                      {% endif %}
                    </td>
                    <td>
                      {% if mentor.is_available %}
                        <span class="hub-coordinador__badge hub-coordinador__badge--success">{% trans %}Disponible{% endtrans %}</span>
                      {% else %}
                        <span class="hub-coordinador__badge hub-coordinador__badge--inactive">{% trans %}No disponible{% endtrans %}</span>
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      {% endif %}

      {# Justificacion Economica PIIL #}
      {% if justificacion %}
        <div class="hub-coordinador__metric-section">
          <h3 class="hub-coordinador__metric-title">
            {{ jaraba_icon('business', 'wallet', { variant: 'duotone', color: 'verde-innovacion', size: '18px' }) }}
            {% trans %}Justificacion Economica PIIL{% endtrans %}
          </h3>
          <div class="hub-coordinador__justificacion">
            <div class="hub-coordinador__justificacion-progress">
              <div class="hub-coordinador__justificacion-bar">
                <div class="hub-coordinador__justificacion-fill" style="width: {{ justificacion.porcentaje }}%"></div>
              </div>
              <div class="hub-coordinador__justificacion-labels">
                <span>{{ justificacion.total_justificado|number_format(0, ',', '.') }} €</span>
                <span>{{ justificacion.total_presupuesto|number_format(0, ',', '.') }} €</span>
              </div>
              <span class="hub-coordinador__justificacion-percent">{{ justificacion.porcentaje|number_format(1) }}% {% trans %}justificado{% endtrans %}</span>
            </div>
            {% if justificacion.desglose_por_modulo is not empty %}
              <div class="hub-coordinador__justificacion-desglose">
                {% if justificacion.desglose_por_modulo.atendidos is defined %}
                  <div class="hub-coordinador__justificacion-modulo">
                    <span class="hub-coordinador__justificacion-modulo-label">{% trans %}Personas Atendidas{% endtrans %}</span>
                    <span class="hub-coordinador__justificacion-modulo-count">{{ justificacion.desglose_por_modulo.atendidos.count }}</span>
                    <span class="hub-coordinador__justificacion-modulo-importe">{{ justificacion.desglose_por_modulo.atendidos.importe|number_format(0, ',', '.') }} €</span>
                  </div>
                {% endif %}
                {% if justificacion.desglose_por_modulo.insertados is defined %}
                  <div class="hub-coordinador__justificacion-modulo">
                    <span class="hub-coordinador__justificacion-modulo-label">{% trans %}Personas Insertadas{% endtrans %}</span>
                    <span class="hub-coordinador__justificacion-modulo-count">{{ justificacion.desglose_por_modulo.insertados.count }}</span>
                    <span class="hub-coordinador__justificacion-modulo-importe">{{ justificacion.desglose_por_modulo.insertados.importe|number_format(0, ',', '.') }} €</span>
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {# Puntos de Impacto del Programa #}
      {% if puntos_impacto %}
        <div class="hub-coordinador__metric-section">
          <h3 class="hub-coordinador__metric-title">
            {{ jaraba_icon('analytics', 'trophy', { variant: 'duotone', color: 'naranja-impulso', size: '18px' }) }}
            {% trans %}Impacto del Programa{% endtrans %}
          </h3>
          <div class="hub-coordinador__impacto-grid">
            <div class="hub-coordinador__impacto-stat">
              <span class="hub-coordinador__impacto-value">{{ puntos_impacto.total_puntos }}</span>
              <span class="hub-coordinador__impacto-label">{% trans %}Puntos totales{% endtrans %}</span>
            </div>
            <div class="hub-coordinador__impacto-stat">
              <span class="hub-coordinador__impacto-value">{{ puntos_impacto.media_puntos|number_format(1) }}</span>
              <span class="hub-coordinador__impacto-label">{% trans %}Media por participante{% endtrans %}</span>
            </div>
            <div class="hub-coordinador__impacto-stat">
              <span class="hub-coordinador__impacto-value">{{ puntos_impacto.max_puntos }}</span>
              <span class="hub-coordinador__impacto-label">{% trans %}Maximo{% endtrans %}</span>
            </div>
            <div class="hub-coordinador__impacto-stat">
              <span class="hub-coordinador__impacto-value">{{ puntos_impacto.participantes_evaluados }}</span>
              <span class="hub-coordinador__impacto-label">{% trans %}Evaluados{% endtrans %}</span>
            </div>
          </div>
        </div>
      {% endif %}

      {# Sprint 17: Leaderboard de gamificación #}
      {% if ranking_impacto is not empty %}
        <div class="hub-coordinador__metric-section">
          <h3 class="hub-coordinador__metric-title">
            {{ jaraba_icon('analytics', 'leaderboard', { variant: 'duotone', color: 'naranja-impulso', size: '18px' }) }}
            {% trans %}Leaderboard — Top 10{% endtrans %}
          </h3>
          <div class="hub-coordinador__leaderboard">
            <table class="hub-coordinador__leaderboard-table">
              <thead>
                <tr>
                  <th scope="col" class="hub-coordinador__leaderboard-rank">#</th>
                  <th scope="col" class="hub-coordinador__leaderboard-name">{% trans %}Participante{% endtrans %}</th>
                  <th scope="col" class="hub-coordinador__leaderboard-phase">{% trans %}Fase{% endtrans %}</th>
                  <th scope="col" class="hub-coordinador__leaderboard-points">{% trans %}Puntos{% endtrans %}</th>
                </tr>
              </thead>
              <tbody>
                {% for entry in ranking_impacto %}
                  <tr class="hub-coordinador__leaderboard-row{% if loop.index <= 3 %} hub-coordinador__leaderboard-row--top3{% endif %}">
                    <td class="hub-coordinador__leaderboard-rank">
                      {% if loop.index == 1 %}
                        <span class="hub-coordinador__medal hub-coordinador__medal--gold">1</span>
                      {% elseif loop.index == 2 %}
                        <span class="hub-coordinador__medal hub-coordinador__medal--silver">2</span>
                      {% elseif loop.index == 3 %}
                        <span class="hub-coordinador__medal hub-coordinador__medal--bronze">3</span>
                      {% else %}
                        {{ loop.index }}
                      {% endif %}
                    </td>
                    <td class="hub-coordinador__leaderboard-name">{{ entry.nombre }}</td>
                    <td class="hub-coordinador__leaderboard-phase">
                      <span class="hub-coordinador__fase-badge hub-coordinador__fase-badge--{{ entry.fase }}">
                        {{ entry.fase|capitalize }}
                      </span>
                    </td>
                    <td class="hub-coordinador__leaderboard-points">
                      <strong>{{ entry.puntos }}</strong>
                      <span class="hub-coordinador__points-label">pts</span>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      {% endif %}

      {# Sprint 17: Club Alumni — stats e historias de éxito #}
      {% if alumni_stats and alumni_stats.total > 0 %}
        <div class="hub-coordinador__metric-section">
          <h3 class="hub-coordinador__metric-title">
            {{ jaraba_icon('social', 'users-group', { variant: 'duotone', color: 'verde-innovacion', size: '18px' }) }}
            {% trans %}Club Alumni{% endtrans %}
            <span class="hub-coordinador__metric-count">{{ alumni_stats.total }}</span>
          </h3>

          {# KPIs alumni #}
          <div class="hub-coordinador__kpi-grid hub-coordinador__kpi-grid--4col">
            <div class="hub-coordinador__kpi-card hub-coordinador__kpi-card--success">
              <span class="hub-coordinador__kpi-value">{{ alumni_stats.total }}</span>
              <span class="hub-coordinador__kpi-label">{% trans %}Alumni activos{% endtrans %}</span>
            </div>
            <div class="hub-coordinador__kpi-card">
              <span class="hub-coordinador__kpi-value">{{ alumni_stats.por_tipo_insercion|length }}</span>
              <span class="hub-coordinador__kpi-label">{% trans %}Tipos de inserción{% endtrans %}</span>
            </div>
            <div class="hub-coordinador__kpi-card">
              <span class="hub-coordinador__kpi-value">{{ alumni_stats.por_sector|length }}</span>
              <span class="hub-coordinador__kpi-label">{% trans %}Sectores{% endtrans %}</span>
            </div>
            <div class="hub-coordinador__kpi-card hub-coordinador__kpi-card--accent">
              <span class="hub-coordinador__kpi-value">{{ alumni_stats.tasa_retencion }}%</span>
              <span class="hub-coordinador__kpi-label">{% trans %}Retención 6m{% endtrans %}</span>
            </div>
          </div>

          {# Distribución por tipo de inserción #}
          {% if alumni_stats.por_tipo_insercion %}
          <div class="hub-coordinador__alumni-distribution">
            <h4 class="hub-coordinador__alumni-subtitle">{% trans %}Por tipo de inserción{% endtrans %}</h4>
            <div class="hub-coordinador__alumni-bars">
              {% for tipo, count in alumni_stats.por_tipo_insercion %}
                <div class="hub-coordinador__alumni-bar-item">
                  <span class="hub-coordinador__alumni-bar-label">{{ tipo|replace({'_': ' '})|capitalize }}</span>
                  <div class="hub-coordinador__alumni-bar-track">
                    <div class="hub-coordinador__alumni-bar-fill" style="width: {{ (count / alumni_stats.total * 100)|round }}%"></div>
                  </div>
                  <span class="hub-coordinador__alumni-bar-value">{{ count }}</span>
                </div>
              {% endfor %}
            </div>
          </div>
          {% endif %}

          {# Distribución por sector #}
          {% if alumni_stats.por_sector %}
          <div class="hub-coordinador__alumni-distribution">
            <h4 class="hub-coordinador__alumni-subtitle">{% trans %}Por sector{% endtrans %}</h4>
            <div class="hub-coordinador__alumni-bars">
              {% for sector, count in alumni_stats.por_sector %}
                <div class="hub-coordinador__alumni-bar-item">
                  <span class="hub-coordinador__alumni-bar-label">{{ sector|replace({'_': ' '})|capitalize }}</span>
                  <div class="hub-coordinador__alumni-bar-track">
                    <div class="hub-coordinador__alumni-bar-fill hub-coordinador__alumni-bar-fill--sector" style="width: {{ (count / alumni_stats.total * 100)|round }}%"></div>
                  </div>
                  <span class="hub-coordinador__alumni-bar-value">{{ count }}</span>
                </div>
              {% endfor %}
            </div>
          </div>
          {% endif %}
        </div>

        {# Historias de éxito #}
        {% if historias_exito is not empty %}
        <div class="hub-coordinador__metric-section">
          <h3 class="hub-coordinador__metric-title">
            {{ jaraba_icon('social', 'star', { variant: 'duotone', color: 'naranja-impulso', size: '18px' }) }}
            {% trans %}Historias de éxito{% endtrans %}
          </h3>
          <div class="hub-coordinador__alumni-stories">
            {% for historia in historias_exito %}
              <div class="hub-coordinador__alumni-story-card">
                <div class="hub-coordinador__alumni-story-header">
                  <span class="hub-coordinador__alumni-story-name">{{ historia.nombre }}</span>
                  {% if historia.meses_retencion > 0 %}
                    <span class="hub-coordinador__alumni-story-retention">
                      {{ historia.meses_retencion }} {% trans %}meses{% endtrans %}
                    </span>
                  {% endif %}
                </div>
                <div class="hub-coordinador__alumni-story-meta">
                  {% if historia.sector %}
                    <span class="hub-coordinador__alumni-story-tag">{{ historia.sector|replace({'_': ' '})|capitalize }}</span>
                  {% endif %}
                  {% if historia.tipo_insercion %}
                    <span class="hub-coordinador__alumni-story-tag hub-coordinador__alumni-story-tag--tipo">{{ historia.tipo_insercion|replace({'_': ' '})|capitalize }}</span>
                  {% endif %}
                  {% if historia.municipio %}
                    <span class="hub-coordinador__alumni-story-tag hub-coordinador__alumni-story-tag--location">{{ historia.municipio }}</span>
                  {% endif %}
                </div>
                {% if historia.testimonio %}
                  <blockquote class="hub-coordinador__alumni-story-quote">
                    {{ historia.testimonio }}
                  </blockquote>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        </div>
        {% endif %}
      {% endif %}

      {# Sprint 17: STO Sincronización bidireccional #}
      {% if sto_resumen and sto_resumen.total > 0 %}
        <div class="hub-coordinador__metric-section">
          <h3 class="hub-coordinador__metric-title">
            {{ jaraba_icon('compliance', 'sync', { variant: 'duotone', color: 'azul-corporativo', size: '18px' }) }}
            {% trans %}Sincronización STO{% endtrans %}
          </h3>
          <div class="hub-coordinador__kpi-grid hub-coordinador__kpi-grid--4col">
            <div class="hub-coordinador__kpi-card hub-coordinador__kpi-card--success">
              <span class="hub-coordinador__kpi-value">{{ sto_resumen.synced }}</span>
              <span class="hub-coordinador__kpi-label">{% trans %}Sincronizados{% endtrans %}</span>
            </div>
            <div class="hub-coordinador__kpi-card hub-coordinador__kpi-card--warning">
              <span class="hub-coordinador__kpi-value">{{ sto_resumen.pending }}</span>
              <span class="hub-coordinador__kpi-label">{% trans %}Pendientes{% endtrans %}</span>
            </div>
            <div class="hub-coordinador__kpi-card hub-coordinador__kpi-card--danger">
              <span class="hub-coordinador__kpi-value">{{ sto_resumen.error }}</span>
              <span class="hub-coordinador__kpi-label">{% trans %}Con error{% endtrans %}</span>
            </div>
            <div class="hub-coordinador__kpi-card">
              <span class="hub-coordinador__kpi-value">{{ sto_resumen.sin_estado }}</span>
              <span class="hub-coordinador__kpi-label">{% trans %}Sin estado{% endtrans %}</span>
            </div>
          </div>
          {% if sto_resumen.pending > 0 %}
            <p class="hub-coordinador__sto-notice">
              {{ jaraba_icon('ui', 'alert-circle', { variant: 'outline', color: 'naranja-impulso', size: '14px' }) }}
              {% trans %}Hay participantes pendientes de sincronización con el STO.{% endtrans %}
            </p>
          {% endif %}
        </div>
      {% endif %}

      {# Prospecciones Empresariales #}
      {% if prospecciones %}
        <div class="hub-coordinador__metric-section">
          <h3 class="hub-coordinador__metric-title">
            {{ jaraba_icon('business', 'briefcase', { variant: 'duotone', color: 'azul-corporativo', size: '18px' }) }}
            {% trans %}Prospecciones Empresariales{% endtrans %}
          </h3>
          <div class="hub-coordinador__prospeccion-grid">
            <div class="hub-coordinador__prospeccion-stat">
              <span class="hub-coordinador__prospeccion-value">{{ prospecciones.total }}</span>
              <span class="hub-coordinador__prospeccion-label">{% trans %}Total empresas{% endtrans %}</span>
            </div>
            {% if prospecciones.por_estado is defined %}
              <div class="hub-coordinador__prospeccion-stat">
                <span class="hub-coordinador__prospeccion-value">{{ prospecciones.por_estado.colaborando|default(0) }}</span>
                <span class="hub-coordinador__prospeccion-label">{% trans %}Colaborando{% endtrans %}</span>
              </div>
            {% endif %}
            <div class="hub-coordinador__prospeccion-stat">
              <span class="hub-coordinador__prospeccion-value">{{ prospecciones.puestos_ofertados|default(0) }}</span>
              <span class="hub-coordinador__prospeccion-label">{% trans %}Puestos ofertados{% endtrans %}</span>
            </div>
            <div class="hub-coordinador__prospeccion-stat">
              <span class="hub-coordinador__prospeccion-value">{{ prospecciones.puestos_cubiertos|default(0) }}</span>
              <span class="hub-coordinador__prospeccion-label">{% trans %}Puestos cubiertos{% endtrans %}</span>
            </div>
          </div>
          {% if prospecciones.por_estado is defined %}
            <div class="hub-coordinador__prospeccion-estados">
              {% for estado, count in prospecciones.por_estado %}
                <span class="hub-coordinador__badge hub-coordinador__badge--prospeccion-{{ estado }}">{{ estado }}: {{ count }}</span>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {# Sprint 17: Funnel de conversion PIIL #}
      {% if advanced_analytics and advanced_analytics.funnel %}
        <div class="hub-coordinador__metric-section">
          <h3 class="hub-coordinador__metric-title">
            {{ jaraba_icon('analytics', 'funnel', { variant: 'duotone', color: 'naranja-impulso', size: '18px' }) }}
            {% trans %}Funnel de Conversion PIIL{% endtrans %}
          </h3>
          <div class="hub-coordinador__funnel">
            {% for step in advanced_analytics.funnel %}
              <div class="hub-coordinador__funnel-step">
                <div class="hub-coordinador__funnel-bar-wrap">
                  <div class="hub-coordinador__funnel-bar hub-coordinador__funnel-bar--{{ step.fase }}" style="width: {{ step.pct }}%">
                    <span class="hub-coordinador__funnel-count">{{ step.count }}</span>
                  </div>
                </div>
                <span class="hub-coordinador__funnel-label">{{ step.fase|capitalize }} ({{ step.pct }}%)</span>
              </div>
            {% endfor %}
          </div>
        </div>
      {% endif %}

      {# Sprint 17: Promedios de horas (burndown) #}
      {% if advanced_analytics and advanced_analytics.horas_promedio %}
        <div class="hub-coordinador__metric-section">
          <h3 class="hub-coordinador__metric-title">
            {{ jaraba_icon('analytics', 'chart-line', { variant: 'duotone', color: 'verde-innovacion', size: '18px' }) }}
            {% trans %}Promedios de Horas por Participante{% endtrans %}
          </h3>
          <div class="hub-coordinador__kpi-grid hub-coordinador__kpi-grid--4col">
            <div class="hub-coordinador__kpi-card">
              <span class="hub-coordinador__kpi-value">{{ advanced_analytics.horas_promedio.orientacion }}h</span>
              <span class="hub-coordinador__kpi-label">{% trans %}Orientacion{% endtrans %} <small>({% trans %}obj: 10h{% endtrans %})</small></span>
            </div>
            <div class="hub-coordinador__kpi-card">
              <span class="hub-coordinador__kpi-value">{{ advanced_analytics.horas_promedio.orientacion_individual }}h</span>
              <span class="hub-coordinador__kpi-label">{% trans %}Orient. Individual{% endtrans %} <small>({% trans %}obj: 2h{% endtrans %})</small></span>
            </div>
            <div class="hub-coordinador__kpi-card">
              <span class="hub-coordinador__kpi-value">{{ advanced_analytics.horas_promedio.formacion }}h</span>
              <span class="hub-coordinador__kpi-label">{% trans %}Formacion{% endtrans %} <small>({% trans %}obj: 50h{% endtrans %})</small></span>
            </div>
            <div class="hub-coordinador__kpi-card">
              <span class="hub-coordinador__kpi-value">{{ advanced_analytics.horas_promedio.asistencia_media }}%</span>
              <span class="hub-coordinador__kpi-label">{% trans %}Asistencia Media{% endtrans %} <small>({% trans %}obj: 75%{% endtrans %})</small></span>
            </div>
          </div>
        </div>
      {% endif %}

      {# Sprint 17: Distribucion por colectivo y provincia #}
      {% if advanced_analytics and advanced_analytics.por_colectivo %}
        <div class="hub-coordinador__metric-section">
          <h3 class="hub-coordinador__metric-title">
            {{ jaraba_icon('ui', 'users', { variant: 'duotone', color: 'azul-corporativo', size: '18px' }) }}
            {% trans %}Distribucion por Colectivo{% endtrans %}
          </h3>
          <div class="hub-coordinador__distribution-bars">
            {% for colectivo, count in advanced_analytics.por_colectivo %}
              <div class="hub-coordinador__distribution-item">
                <span class="hub-coordinador__distribution-label">{{ colectivo|replace({'_': ' '})|capitalize }}</span>
                <span class="hub-coordinador__distribution-count">{{ count }}</span>
              </div>
            {% endfor %}
          </div>
        </div>
      {% endif %}

      {% if advanced_analytics and advanced_analytics.por_provincia %}
        <div class="hub-coordinador__metric-section">
          <h3 class="hub-coordinador__metric-title">
            {{ jaraba_icon('ui', 'map-pin', { variant: 'duotone', color: 'verde-innovacion', size: '18px' }) }}
            {% trans %}Distribucion por Provincia{% endtrans %}
          </h3>
          <div class="hub-coordinador__distribution-bars">
            {% for provincia, count in advanced_analytics.por_provincia %}
              <div class="hub-coordinador__distribution-item">
                <span class="hub-coordinador__distribution-label">{{ provincia|capitalize }}</span>
                <span class="hub-coordinador__distribution-count">{{ count }}</span>
              </div>
            {% endfor %}
          </div>
        </div>
      {% endif %}

      {# Actividad reciente #}
      {% if recent_activity|length > 0 %}
        <div class="hub-coordinador__metric-section">
          <h3 class="hub-coordinador__metric-title">
            {{ jaraba_icon('ui', 'clock', { variant: 'duotone', color: 'azul-corporativo', size: '18px' }) }}
            {% trans %}Actividad Reciente{% endtrans %}
          </h3>
          <div class="hub-coordinador__activity-list">
            {% for item in recent_activity %}
              <div class="hub-coordinador__activity-item hub-coordinador__activity-item--{{ item.type }}">
                <div class="hub-coordinador__activity-dot"></div>
                <div class="hub-coordinador__activity-content">
                  <span class="hub-coordinador__activity-label">{{ item.label }}</span>
                  {% if item.detail %}
                    <span class="hub-coordinador__activity-detail">{{ item.detail }}</span>
                  {% endif %}
                  {% if item.timestamp %}
                    <time class="hub-coordinador__activity-time" datetime="{{ item.timestamp|date('Y-m-d\\TH:i:s') }}">
                      {{ item.timestamp|date('d/m/Y H:i') }}
                    </time>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>

  </div>

  {# === MODAL DIALOG (reutilizable por JS) === #}
  <div class="hub-coordinador__modal" role="dialog" aria-modal="true" aria-labelledby="modal-title" data-modal hidden>
    <div class="hub-coordinador__modal-backdrop" data-modal-close></div>
    <div class="hub-coordinador__modal-content">
      <div class="hub-coordinador__modal-header">
        <h3 class="hub-coordinador__modal-title" id="modal-title" data-modal-title></h3>
        <button class="hub-coordinador__modal-close" data-modal-close aria-label="{% trans %}Cerrar{% endtrans %}">
          {{ jaraba_icon('actions', 'close', { variant: 'outline', color: 'neutral', size: '20px' }) }}
        </button>
      </div>
      <div class="hub-coordinador__modal-body" data-modal-body></div>
      <div class="hub-coordinador__modal-footer">
        <button class="hub-coordinador__action-btn hub-coordinador__action-btn--secondary" data-modal-close>
          {% trans %}Cancelar{% endtrans %}
        </button>
        <button class="hub-coordinador__action-btn hub-coordinador__action-btn--primary" data-modal-confirm>
          {% trans %}Confirmar{% endtrans %}
        </button>
      </div>
    </div>
  </div>

  {# ARIA live region para notificaciones de acciones #}
  <div class="hub-coordinador__notifications" role="status" aria-live="polite" data-notifications></div>

</div>
