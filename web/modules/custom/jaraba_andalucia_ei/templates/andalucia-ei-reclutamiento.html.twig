      <div class="aei-rec__paso aei-rec--reveal">
        <span class="aei-rec__paso-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--ej-color-verde-innovacion,#00A9A5)" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </span>
        <span class="aei-rec__paso-num">2</span>
        <div class="aei-rec__paso-content">
          <h3 class="aei-rec__paso-titulo">{% trans %}Acogida y diagnóstico{% endtrans %}</h3>
          <p class="aei-rec__paso-desc">{% trans %}Te recibimos en tu sede más cercana, firmamos el Acuerdo de Participación y evaluamos tu situación laboral, competencias y objetivos profesionales.{% endtrans %}</p>
        </div>
      </div>
      <div class="aei-rec__paso aei-rec--reveal">
        <span class="aei-rec__paso-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--ej-color-verde-innovacion,#00A9A5)" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </span>
        <span class="aei-rec__paso-num">3</span>
        <div class="aei-rec__paso-content">
          <h3 class="aei-rec__paso-titulo">{% trans %}Formación + orientación{% endtrans %}</h3>
          <p class="aei-rec__paso-desc">{% trans %}Mínimo 50 horas de formación certificada y 10 horas de orientación personalizada. Acceso al tutor IA 24/7, expediente digital y seguimiento de tu progreso en tiempo real.{% endtrans %}</p>
        </div>
