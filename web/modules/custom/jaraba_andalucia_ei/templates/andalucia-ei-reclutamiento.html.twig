{#
/**
 * @file
 * Landing de reclutamiento de participantes — Andalucía +ei.
 *
 * URL canónica: /andaluciamasei.html (preservar reputación SEO).
 * Datos reales del expediente SC/ICV/0111/2025.
 * Financiado: Junta de Andalucía + FSE+ (85%).
 *
 * Zero Region Policy: No usa page.content ni bloques.
 * Orden: Hero > Institucional > Qué recibes > Requisitos > Sedes >
 *        Cómo funciona > Equipo > FAQ > CTA Final
 */
#}

{# === STICKY URGENCY BAR: Visible al hacer scroll pasado el hero === #}
<div class="aei-rec__sticky-bar" aria-label="{% trans %}Solicitar plaza{% endtrans %}">
  <div class="aei-rec__sticky-bar-inner">
    <span class="aei-rec__sticky-bar-text">
      <strong>{{ programa.participantes }}</strong> {% trans %}plazas{% endtrans %} &middot;
      <strong>{{ programa.incentivo }} &euro;</strong> {% trans %}incentivo{% endtrans %} &middot;
      {% trans %}100% gratuito{% endtrans %}
    </span>
    {# Countdown: populated by JS from drupalSettings.aeiReclutamiento #}
    {% if programa.mostrar_countdown|default(true) %}
      <span class="aei-rec__countdown" aria-label="{% trans %}Tiempo restante para solicitar{% endtrans %}">
        <span class="aei-rec__countdown-unit"><span class="aei-rec__countdown-days">--</span>{% trans %}d{% endtrans %}</span>
        <span class="aei-rec__countdown-sep" aria-hidden="true">:</span>
        <span class="aei-rec__countdown-unit"><span class="aei-rec__countdown-hours">--</span>{% trans %}h{% endtrans %}</span>
        <span class="aei-rec__countdown-sep" aria-hidden="true">:</span>
        <span class="aei-rec__countdown-unit"><span class="aei-rec__countdown-mins">--</span>{% trans %}m{% endtrans %}</span>
      </span>
    {% endif %}
    <a href="{{ solicitar_url }}" class="aei-rec__sticky-bar-cta"
       data-track-cta="aei_sticky_solicitar" data-track-position="reclutamiento_sticky">{% trans %}Solicitar plaza{% endtrans %}</a>
  </div>
</div>

{# === PUBLICIDAD OFICIAL: Obligatorio por normativa de subvenciones === #}
{# Logos institucionales: UE + Ministerio + Fondos Europeos + Junta de Andalucía + SAE #}
<div class="aei-rec__publicidad-oficial" role="banner" aria-label="{% trans %}Financiación institucional del programa{% endtrans %}">
  <div class="aei-rec__container">
    <p class="aei-rec__publicidad-titulo">{% trans %}T-Acompañamos: Programa de Proyectos Integrales para la Inserción Laboral de la Junta de Andalucía{% endtrans %}</p>
    <img src="/{{ module_path }}/images/publicidad-oficial-piil.png"
         alt="{% trans %}Cofinanciado por la Unión Europea | Ministerio de Trabajo y Economía Social | Fondos Europeos | Junta de Andalucía — Consejería de Empleo, Empresa y Trabajo Autónomo — Servicio Andaluz de Empleo{% endtrans %}"
         class="aei-rec__publicidad-img"
         width="2937"
         height="277"
         loading="eager">
  </div>
</div>

{# === HERO: Gancho emocional directo al candidato === #}
<section class="aei-rec__hero" aria-label="{% trans %}Programa Andalucía +ei{% endtrans %}">
  <div class="aei-rec__container">
    <div class="aei-rec__hero-badges">
      <span class="aei-rec__badge aei-rec__badge--institucional">{% trans %}Programa oficial{% endtrans %}</span>
      <span class="aei-rec__badge aei-rec__badge--gratuito">{% trans %}100% gratuito{% endtrans %}</span>
      <span class="aei-rec__badge aei-rec__badge--fse">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2L3 7v10l9 5 9-5V7l-9-5zm0 2.18l6.5 3.64v7.36L12 18.82 5.5 15.18V7.82L12 4.18z"/><path d="M12 8l-4 2.25v4.5L12 17l4-2.25v-4.5L12 8z"/></svg>
        {% trans %}Financiado FSE+{% endtrans %}
      </span>
    </div>
    {# === VÍDEO HERO: Autoplay muted para máximo impacto visual === #}
    <div class="aei-rec__hero-video-wrapper">
      <video class="aei-rec__hero-video"
             autoplay
             muted
             loop
             playsinline
             preload="metadata"
             poster="/{{ module_path }}/images/reclutamiento-popup-hero.webp"
             aria-label="{% trans %}Vídeo presentación del programa T-Acompañamos{% endtrans %}">
        <source src="/{{ module_path }}/images/reclutamiento-hero-video.mp4" type="video/mp4">
      </video>
      {# P1-3: Play/pause control for accessibility #}
      <button class="aei-rec__hero-video-control" type="button"
              aria-label="{% trans %}Pausar vídeo{% endtrans %}"
              data-label-play="{% trans %}Reproducir vídeo{% endtrans %}"
              data-label-pause="{% trans %}Pausar vídeo{% endtrans %}">
        <svg class="aei-rec__hero-video-icon aei-rec__hero-video-icon--pause" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
        <svg class="aei-rec__hero-video-icon aei-rec__hero-video-icon--play" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none"><polygon points="5,3 19,12 5,21"/></svg>
      </button>
    </div>
    <h1 class="aei-rec__title">{% trans %}Fórmate gratis, cobra 528 € y encuentra empleo en Andalucía{% endtrans %}</h1>
    <p class="aei-rec__subtitle">
      {% trans %}Programa oficial T-Acompañamos: orientación personalizada, formación certificada, mentoría con IA y acompañamiento hasta tu contratación. Compatible con tu subsidio por desempleo.{% endtrans %}
    </p>
    <div class="aei-rec__hero-stats">
      <div class="aei-rec__hero-stat">
        <span class="aei-rec__hero-stat-value">{{ programa.participantes }}</span>
        <span class="aei-rec__hero-stat-label">{% trans %}plazas disponibles{% endtrans %}</span>
      </div>
      <div class="aei-rec__hero-stat">
        <span class="aei-rec__hero-stat-value">{{ programa.incentivo }} &euro;</span>
        <span class="aei-rec__hero-stat-label">{% trans %}incentivo al participante{% endtrans %}</span>
      </div>
      <div class="aei-rec__hero-stat">
        <span class="aei-rec__hero-stat-value">46%</span>
        <span class="aei-rec__hero-stat-label">{% trans %}inserción laboral 1ª Ed.{% endtrans %}</span>
      </div>
    </div>
    <div class="aei-rec__hero-actions" data-ab-experiment="aei_hero_cta">
      <a href="{{ solicitar_url }}" class="aei-rec__cta aei-rec__cta--primary js-ab-hero-cta"
         data-track-cta="aei_hero_solicitar" data-track-position="reclutamiento_hero"
         data-ab-convert="aei_hero_cta">
        {% trans %}Solicitar plaza ahora{% endtrans %}
      </a>
      <a href="#que-recibes" class="aei-rec__cta aei-rec__cta--secondary"
         data-track-cta="aei_hero_conocer" data-track-position="reclutamiento_hero">
        {% trans %}Conocer el programa{% endtrans %}
      </a>
      <a href="https://wa.me/34623174304?text=%C2%BFPuedo%20participar%20en%20el%20programa%20T-Acompa%C3%B1amos%3F"
         class="aei-rec__cta aei-rec__cta--whatsapp-hero" target="_blank" rel="noopener noreferrer"
         aria-label="{% trans %}Consultar por WhatsApp{% endtrans %}"
         data-track-cta="aei_hero_whatsapp" data-track-position="reclutamiento_hero">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12.05 21.785c-1.774 0-3.513-.477-5.036-1.378l-.36-.214-3.742.982.999-3.648-.235-.374A9.86 9.86 0 0 1 2.17 12.06C2.17 6.58 6.58 2.17 12.06 2.17c2.67 0 5.156 1.04 7.028 2.912A9.827 9.827 0 0 1 21.93 12.1c-.005 5.49-4.42 9.895-9.88 9.895v-.01zM12.05 0C5.405 0 .005 5.392 0 12.029c0 2.12.555 4.19 1.61 6.013L0 24l6.102-1.6A12.02 12.02 0 0 0 12.05 24C18.69 24 24.1 18.607 24.1 11.97 24.1 5.332 18.69 0 12.05 0z"/></svg>
        {% trans %}WhatsApp{% endtrans %}
      </a>
    </div>
    {# P2-6: Indicador de actividad reciente (FOMO) #}
    <div class="aei-rec__hero-fomo" aria-live="polite">
      <span class="aei-rec__hero-fomo-dot" aria-hidden="true"></span>
      <span class="aei-rec__hero-fomo-text">{% trans %}Última solicitud hace 3 horas — {{ programa.participantes }} plazas disponibles{% endtrans %}</span>
    </div>
  </div>
</section>

{# === INSTITUCIONAL: Quién financia, quién gestiona === #}
<section class="aei-rec__institucional" aria-label="{% trans %}Financiación del programa{% endtrans %}">
  <div class="aei-rec__container">
    <p class="aei-rec__institucional-text">
      {% trans %}Programa de Itinerarios Integrados y Personalizados de Inserción Laboral (PIIL) — Convocatoria Colectivos Vulnerables 2025{% endtrans %}
    </p>
    <div class="aei-rec__institucional-logos">
      <div class="aei-rec__institucional-item">
        <span class="aei-rec__institucional-name">{% trans %}Junta de Andalucía{% endtrans %}</span>
        <span class="aei-rec__institucional-detail">{% trans %}Servicio Andaluz de Empleo{% endtrans %}</span>
      </div>
      <div class="aei-rec__institucional-divider" aria-hidden="true"></div>
      <div class="aei-rec__institucional-item">
        <span class="aei-rec__institucional-name">{% trans %}Unión Europea{% endtrans %}</span>
        <span class="aei-rec__institucional-detail">{% trans %}Fondo Social Europeo Plus (FSE+){% endtrans %}</span>
      </div>
      <div class="aei-rec__institucional-divider" aria-hidden="true"></div>
      <div class="aei-rec__institucional-item">
        <span class="aei-rec__institucional-name">{% trans %}PED S.L.{% endtrans %}</span>
        <span class="aei-rec__institucional-detail">{% trans %}Entidad gestora{% endtrans %}</span>
      </div>
    </div>
    <p class="aei-rec__institucional-expediente">
      {% trans %}Expediente{% endtrans %}: {{ programa.expediente }}
    </p>
  </div>
</section>

{# === PAIN POINTS: ¿Te identificas? === #}
<section class="aei-rec__painpoints" aria-label="{% trans %}Situaciones que resuelve el programa{% endtrans %}">
  <div class="aei-rec__container">
    <h2 class="aei-rec__section-title aei-rec__section-title--center">{% trans %}¿Te identificas con alguna de estas situaciones?{% endtrans %}</h2>
    <div class="aei-rec__painpoints-grid">
      <div class="aei-rec__painpoint-card aei-rec--reveal">
        <span class="aei-rec__painpoint-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--ej-color-naranja-impulso, #FF8C42)" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </span>
        <h3 class="aei-rec__painpoint-title">{% trans %}Llevas meses buscando empleo sin resultados{% endtrans %}</h3>
        <p class="aei-rec__painpoint-desc">{% trans %}Envías currículums, te apuntas a ofertas, pero no recibes respuesta. Necesitas un método estructurado y acompañamiento profesional.{% endtrans %}</p>
      </div>
      <div class="aei-rec__painpoint-card aei-rec--reveal">
        <span class="aei-rec__painpoint-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--ej-color-naranja-impulso, #FF8C42)" stroke-width="2"><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><circle cx="12" cy="12" r="10"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </span>
        <h3 class="aei-rec__painpoint-title">{% trans %}No sabes por dónde empezar ni qué formación necesitas{% endtrans %}</h3>
        <p class="aei-rec__painpoint-desc">{% trans %}Hay tantas opciones que te sientes paralizado/a. Necesitas que alguien analice tu perfil y te oriente hacia lo que realmente funciona.{% endtrans %}</p>
      </div>
      <div class="aei-rec__painpoint-card aei-rec--reveal">
        <span class="aei-rec__painpoint-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--ej-color-naranja-impulso, #FF8C42)" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="9" y1="12" x2="15" y2="12"/></svg>
        </span>
        <h3 class="aei-rec__painpoint-title">{% trans %}Estás harto/a de cursos que no sirven para nada{% endtrans %}</h3>
        <p class="aei-rec__painpoint-desc">{% trans %}Formación genérica, sin seguimiento real, sin resultados. Esto no es otro curso más: aquí supervisas herramientas de IA profesionales desde las primeras semanas y sales con un portfolio de 29 entregables demostrables.{% endtrans %}</p>
      </div>
      <div class="aei-rec__painpoint-card aei-rec--reveal">
        <span class="aei-rec__painpoint-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--ej-color-naranja-impulso, #FF8C42)" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a4 4 0 0 0-8 0v2"/><line x1="12" y1="11" x2="12" y2="15"/></svg>
        </span>
        <h3 class="aei-rec__painpoint-title">{% trans %}No puedes permitirte pagar una formación privada{% endtrans %}</h3>
        <p class="aei-rec__painpoint-desc">{% trans %}Las academias cuestan cientos o miles de euros. T-Acompañamos es 100% gratuito y además recibes 528 € de incentivo al completarlo.{% endtrans %}</p>
      </div>
    </div>
  </div>
</section>

{# === QUÉ RECIBES: Beneficios tangibles === #}
<section id="que-recibes" class="aei-rec__beneficios" aria-label="{% trans %}Qué recibes en el programa{% endtrans %}">
  <div class="aei-rec__container">
    <div class="aei-rec__section-header">
      <h2 class="aei-rec__section-title">{% trans %}Qué recibes gratuitamente{% endtrans %}</h2>
      <p class="aei-rec__section-desc">{% trans %}Todo incluido, sin ningún coste. Financiado íntegramente con fondos públicos.{% endtrans %}</p>
    </div>
    <div class="aei-rec__beneficios-grid">
      {% set beneficios = [
        {
          titulo: 'Orientación laboral personalizada'|t,
          desc: 'Mínimo 10 horas con sesiones individuales. Diagnóstico de empleabilidad, diseño de tu itinerario, técnicas de búsqueda activa de empleo, confección de CV y preparación de entrevistas.'|t,
          destacado: '10+ horas'|t,
        },
        {
          titulo: 'Formación práctica certificada'|t,
          desc: 'Mínimo 50 horas en competencias digitales y supervisión de IA profesional. No es teoría: desde las primeras semanas supervisas herramientas reales y construyes un portfolio de 29 entregables demostrables.'|t,
          destacado: '50+ horas'|t,
        },
        {
          titulo: 'Mentoría con Inteligencia Artificial'|t,
          desc: 'Asistente IA personalizado disponible en la plataforma: te ayuda con tu CV, prepara entrevistas, elabora planes de negocio y te orienta profesionalmente. Tecnología propia del programa.'|t,
          destacado: 'Asistente IA'|t,
        },
        {
          titulo: 'Acompañamiento hacia el empleo'|t,
          desc: 'Hasta 40 horas de orientación para la inserción laboral: acompañamiento en procesos de selección, prospección de ofertas y preparación para tu incorporación. Incluye seguimiento durante 6 meses post-contratación.'|t,
          destacado: '40+ horas'|t,
        },
        {
          titulo: 'Expediente digital seguro'|t,
          desc: 'Toda tu documentación organizada: CV, certificados, evaluaciones, contratos. Almacenamiento cifrado, firma digital y acceso controlado. Tu historial profesional en un solo lugar.'|t,
          destacado: '18 categorías'|t,
        },
        {
          titulo: 'Incentivo económico de 528 €'|t,
          desc: 'Al completar el itinerario formativo (10h orientación + 50h formación) recibes un incentivo de 528 euros. Verificado y gestionado a través de la plataforma.'|t,
          destacado: '528 €'|t,
        },
      ] %}
      {# Benefit cards con iconos SVG — colores de paleta Jaraba #}
      {% set benefit_icons = [
        '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00A9A5" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
        '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00A9A5" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
        '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00A9A5" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/><path d="M7 8h2m2 0h2m2 0h2"/><path d="M7 12h10"/></svg>',
        '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00A9A5" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
        '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00A9A5" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>',
        '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF8C42" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
      ] %}
      {% for beneficio in beneficios %}
        <div class="aei-rec__beneficio-card">
          <span class="aei-rec__beneficio-icon" aria-hidden="true">{{ benefit_icons[loop.index0]|raw }}</span>
          <span class="aei-rec__beneficio-destacado">{{ beneficio.destacado }}</span>
          <h3 class="aei-rec__beneficio-titulo">{{ beneficio.titulo }}</h3>
          <p class="aei-rec__beneficio-desc">{{ beneficio.desc }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# === COMPARATIVA: Por qué este programa y no otro === #}
<section class="aei-rec__comparativa" aria-label="{% trans %}Comparativa con alternativas{% endtrans %}">
  <div class="aei-rec__container">
    <h2 class="aei-rec__section-title aei-rec__section-title--center">{% trans %}¿En qué se diferencia T-Acompañamos?{% endtrans %}</h2>
    <p class="aei-rec__section-desc aei-rec__section-desc--center">
      {% trans %}Comparación objetiva con las alternativas más comunes para personas desempleadas en Andalucía.{% endtrans %}
    </p>
    <div class="aei-rec__comparativa-table-wrap" role="region" aria-label="{% trans %}Tabla comparativa{% endtrans %}" tabindex="0">
      <table class="aei-rec__comparativa-table">
        <thead>
          <tr>
            <th class="aei-rec__comparativa-th aei-rec__comparativa-th--feature" scope="col">{% trans %}Característica{% endtrans %}</th>
            <th class="aei-rec__comparativa-th aei-rec__comparativa-th--highlight" scope="col">
              <span class="aei-rec__comparativa-badge">{% trans %}Recomendado{% endtrans %}</span>
              {% trans %}T-Acompañamos (nuestro programa){% endtrans %}
            </th>
            <th class="aei-rec__comparativa-th" scope="col">{% trans %}Curso estándar del SAE{% endtrans %}</th>
            <th class="aei-rec__comparativa-th" scope="col">{% trans %}Academia privada{% endtrans %}</th>
          </tr>
        </thead>
        <tbody>
          {% set rows = [
            {
              feature: 'Coste para el participante'|t,
              ours: '100% gratuito + 528 € de incentivo'|t,
              sae: 'Gratuito (sin incentivo)'|t,
              private: 'Desde 500 € a 3.000 €'|t,
              ours_icon: 'check',
              sae_icon: 'partial',
              private_icon: 'cross',
            },
            {
              feature: 'Orientación personalizada'|t,
              ours: '10+ horas individuales con profesional'|t,
              sae: 'Puntual (1-2 citas)'|t,
              private: 'No incluida'|t,
              ours_icon: 'check',
              sae_icon: 'partial',
              private_icon: 'cross',
            },
            {
              feature: 'Formación certificada'|t,
              ours: '50+ horas adaptativas con IA'|t,
              sae: '20-200 horas (temario fijo)'|t,
              private: 'Variable (temario fijo)'|t,
              ours_icon: 'check',
              sae_icon: 'check',
              private_icon: 'partial',
            },
            {
              feature: 'Mentoría con IA 24/7'|t,
              ours: 'Tutor virtual exclusivo'|t,
              sae: 'No disponible'|t,
              private: 'No disponible'|t,
              ours_icon: 'check',
              sae_icon: 'cross',
              private_icon: 'cross',
            },
            {
              feature: 'Supervisión de IA profesional'|t,
              ours: 'Diriges agentes IA reales como competencia central'|t,
              sae: 'No disponible'|t,
              private: 'No disponible'|t,
              ours_icon: 'check',
              sae_icon: 'cross',
              private_icon: 'cross',
            },
            {
              feature: 'Portfolio de 29 entregables'|t,
