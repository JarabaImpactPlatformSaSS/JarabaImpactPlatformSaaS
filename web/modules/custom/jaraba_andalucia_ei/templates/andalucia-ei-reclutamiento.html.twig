{#
/**
 * @file
 * Landing de reclutamiento de participantes — Andalucía +ei.
 *
 * URL canónica: /andaluciamasei.html (preservar reputación SEO).
 * Datos reales del expediente SC/ICV/0111/2025.
 * Financiado: Junta de Andalucía + FSE+ (85%).
 *
 * Zero Region Policy: No usa page.content ni bloques.
 * Orden: Hero > Institucional > Qué recibes > Requisitos > Sedes >
 *        Cómo funciona > Equipo > FAQ > CTA Final
 */
#}

{# === STICKY URGENCY BAR: Visible al hacer scroll pasado el hero === #}
<div class="aei-rec__sticky-bar" aria-label="{% trans %}Solicitar plaza{% endtrans %}">
  <div class="aei-rec__sticky-bar-inner">
    <span class="aei-rec__sticky-bar-text">
      <strong>{{ programa.participantes }}</strong> {% trans %}plazas{% endtrans %} &middot;
      <strong>{{ programa.incentivo }} &euro;</strong> {% trans %}incentivo{% endtrans %} &middot;
      {% trans %}100% gratuito{% endtrans %}
    </span>
    <a href="{{ solicitar_url }}" class="aei-rec__sticky-bar-cta">{% trans %}Solicitar plaza{% endtrans %}</a>
  </div>
</div>

{# === PUBLICIDAD OFICIAL: Obligatorio por normativa de subvenciones === #}
{# Logos institucionales: UE + Ministerio + Fondos Europeos + Junta de Andalucía + SAE #}
<div class="aei-rec__publicidad-oficial" role="banner" aria-label="{% trans %}Financiación institucional del programa{% endtrans %}">
  <div class="aei-rec__container">
    <p class="aei-rec__publicidad-titulo">{% trans %}T-Acompañamos: Programa de Proyectos Integrales para la Inserción Laboral de la Junta de Andalucía{% endtrans %}</p>
    <img src="/{{ module_path }}/images/publicidad-oficial-piil.png"
         alt="{% trans %}Cofinanciado por la Unión Europea | Ministerio de Trabajo y Economía Social | Fondos Europeos | Junta de Andalucía — Consejería de Empleo, Empresa y Trabajo Autónomo — Servicio Andaluz de Empleo{% endtrans %}"
         class="aei-rec__publicidad-img"
         width="2937"
         height="277"
         loading="eager">
  </div>
</div>

{# === HERO: Gancho emocional directo al candidato === #}
<section class="aei-rec__hero" aria-label="{% trans %}Programa Andalucía +ei{% endtrans %}">
  <div class="aei-rec__container">
    <div class="aei-rec__hero-badges">
      <span class="aei-rec__badge aei-rec__badge--institucional">{% trans %}Programa oficial{% endtrans %}</span>
      <span class="aei-rec__badge aei-rec__badge--gratuito">{% trans %}100% gratuito{% endtrans %}</span>
    </div>
    {# === VÍDEO HERO: Autoplay muted para máximo impacto visual === #}
    <div class="aei-rec__hero-video-wrapper">
      <video class="aei-rec__hero-video"
             autoplay
             muted
             loop
             playsinline
             preload="metadata"
             poster="/{{ module_path }}/images/reclutamiento-popup-hero.webp"
             aria-label="{% trans %}Vídeo presentación del programa T-Acompañamos{% endtrans %}">
        <source src="/{{ module_path }}/images/reclutamiento-hero-video.mp4" type="video/mp4">
      </video>
      {# P1-3: Play/pause control for accessibility #}
      <button class="aei-rec__hero-video-control" type="button"
              aria-label="{% trans %}Pausar vídeo{% endtrans %}"
              data-label-play="{% trans %}Reproducir vídeo{% endtrans %}"
              data-label-pause="{% trans %}Pausar vídeo{% endtrans %}">
        <svg class="aei-rec__hero-video-icon aei-rec__hero-video-icon--pause" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
        <svg class="aei-rec__hero-video-icon aei-rec__hero-video-icon--play" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none"><polygon points="5,3 19,12 5,21"/></svg>
      </button>
    </div>
    <h1 class="aei-rec__title">{% trans %}Fórmate gratis, cobra 528 € y encuentra empleo en Andalucía{% endtrans %}</h1>
    <p class="aei-rec__subtitle">
      {% trans %}Programa oficial T-Acompañamos: orientación personalizada, formación certificada, mentoría con IA y acompañamiento hasta tu contratación. Compatible con tu subsidio por desempleo.{% endtrans %}
    </p>
    <div class="aei-rec__hero-stats">
      <div class="aei-rec__hero-stat">
        <span class="aei-rec__hero-stat-value">{{ programa.participantes }}</span>
        <span class="aei-rec__hero-stat-label">{% trans %}plazas disponibles{% endtrans %}</span>
      </div>
      <div class="aei-rec__hero-stat">
        <span class="aei-rec__hero-stat-value">{{ programa.incentivo }} &euro;</span>
        <span class="aei-rec__hero-stat-label">{% trans %}incentivo al participante{% endtrans %}</span>
      </div>
      <div class="aei-rec__hero-stat">
        <span class="aei-rec__hero-stat-value">{{ programa.tasa_insercion }}%</span>
        <span class="aei-rec__hero-stat-label">{% trans %}objetivo de inserción{% endtrans %}</span>
      </div>
    </div>
    <div class="aei-rec__hero-actions">
      <a href="{{ solicitar_url }}" class="aei-rec__cta aei-rec__cta--primary">
        {% trans %}Solicitar plaza ahora{% endtrans %}
      </a>
      <a href="#que-recibes" class="aei-rec__cta aei-rec__cta--secondary">
        {% trans %}Conocer el programa{% endtrans %}
      </a>
      <a href="https://wa.me/34623174304?text=%C2%BFPuedo%20participar%20en%20el%20programa%20T-Acompa%C3%B1amos%3F"
         class="aei-rec__cta aei-rec__cta--whatsapp-hero" target="_blank" rel="noopener noreferrer"
         aria-label="{% trans %}Consultar por WhatsApp{% endtrans %}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12.05 21.785c-1.774 0-3.513-.477-5.036-1.378l-.36-.214-3.742.982.999-3.648-.235-.374A9.86 9.86 0 0 1 2.17 12.06C2.17 6.58 6.58 2.17 12.06 2.17c2.67 0 5.156 1.04 7.028 2.912A9.827 9.827 0 0 1 21.93 12.1c-.005 5.49-4.42 9.895-9.88 9.895v-.01zM12.05 0C5.405 0 .005 5.392 0 12.029c0 2.12.555 4.19 1.61 6.013L0 24l6.102-1.6A12.02 12.02 0 0 0 12.05 24C18.69 24 24.1 18.607 24.1 11.97 24.1 5.332 18.69 0 12.05 0z"/></svg>
        {% trans %}WhatsApp{% endtrans %}
      </a>
    </div>
    {# P2-6: Indicador de actividad reciente (FOMO) #}
    <div class="aei-rec__hero-fomo" aria-live="polite">
      <span class="aei-rec__hero-fomo-dot" aria-hidden="true"></span>
      <span class="aei-rec__hero-fomo-text">{% trans %}Última solicitud hace 3 horas — {{ programa.participantes }} plazas disponibles{% endtrans %}</span>
    </div>
  </div>
</section>

{# === INSTITUCIONAL: Quién financia, quién gestiona === #}
<section class="aei-rec__institucional" aria-label="{% trans %}Financiación del programa{% endtrans %}">
  <div class="aei-rec__container">
    <p class="aei-rec__institucional-text">
      {% trans %}Programa de Itinerarios Integrados y Personalizados de Inserción Laboral (PIIL) — Convocatoria Colectivos Vulnerables 2025{% endtrans %}
    </p>
    <div class="aei-rec__institucional-logos">
      <div class="aei-rec__institucional-item">
        <span class="aei-rec__institucional-name">{% trans %}Junta de Andalucía{% endtrans %}</span>
        <span class="aei-rec__institucional-detail">{% trans %}Servicio Andaluz de Empleo{% endtrans %}</span>
      </div>
      <div class="aei-rec__institucional-divider" aria-hidden="true"></div>
      <div class="aei-rec__institucional-item">
        <span class="aei-rec__institucional-name">{% trans %}Unión Europea{% endtrans %}</span>
        <span class="aei-rec__institucional-detail">{% trans %}Fondo Social Europeo Plus (FSE+){% endtrans %}</span>
      </div>
      <div class="aei-rec__institucional-divider" aria-hidden="true"></div>
      <div class="aei-rec__institucional-item">
        <span class="aei-rec__institucional-name">{% trans %}PED S.L.{% endtrans %}</span>
        <span class="aei-rec__institucional-detail">{% trans %}Entidad gestora{% endtrans %}</span>
      </div>
    </div>
    <p class="aei-rec__institucional-expediente">
      {% trans %}Expediente{% endtrans %}: {{ programa.expediente }}
    </p>
  </div>
</section>

{# === QUÉ RECIBES: Beneficios tangibles === #}
<section id="que-recibes" class="aei-rec__beneficios" aria-label="{% trans %}Qué recibes en el programa{% endtrans %}">
  <div class="aei-rec__container">
    <div class="aei-rec__section-header">
      <h2 class="aei-rec__section-title">{% trans %}Qué recibes gratuitamente{% endtrans %}</h2>
      <p class="aei-rec__section-desc">{% trans %}Todo incluido, sin ningún coste. Financiado íntegramente con fondos públicos.{% endtrans %}</p>
    </div>
    <div class="aei-rec__beneficios-grid">
      {% set beneficios = [
        {
          titulo: 'Orientación laboral personalizada'|t,
          desc: 'Mínimo 10 horas con sesiones individuales. Diagnóstico de empleabilidad, diseño de tu itinerario, técnicas de búsqueda activa de empleo, confección de CV y preparación de entrevistas.'|t,
          destacado: '10+ horas'|t,
        },
        {
          titulo: 'Formación práctica certificada'|t,
          desc: 'Mínimo 50 horas en competencias digitales, habilidades profesionales y conocimientos técnicos adaptados a tu perfil. Motor de dificultad adaptativa que se ajusta a tu nivel.'|t,
          destacado: '50+ horas'|t,
        },
        {
          titulo: 'Mentoría con Inteligencia Artificial'|t,
          desc: 'Tutor virtual disponible 24/7 que te ayuda con tu CV, prepara entrevistas, elabora planes de negocio y te orienta profesionalmente. Tecnología exclusiva del programa.'|t,
          destacado: 'Tutor IA 24/7'|t,
        },
        {
          titulo: 'Acompañamiento hacia el empleo'|t,
          desc: '40 horas adicionales de orientación para la inserción: acompañamiento en procesos de selección, prospección de ofertas, preparación para la incorporación laboral.'|t,
          destacado: '40+ horas'|t,
        },
        {
          titulo: 'Expediente digital seguro'|t,
          desc: 'Toda tu documentación organizada: CV, certificados, evaluaciones, contratos. Almacenamiento cifrado, firma digital y acceso controlado. Tu historial profesional en un solo lugar.'|t,
          destacado: '18 categorías'|t,
        },
        {
          titulo: 'Incentivo económico de 528 €'|t,
          desc: 'Al completar el itinerario formativo (10h orientación + 50h formación) recibes un incentivo de 528 euros. Verificado y gestionado a través de la plataforma.'|t,
          destacado: '528 €'|t,
        },
      ] %}
      {% for beneficio in beneficios %}
        <div class="aei-rec__beneficio-card">
          <span class="aei-rec__beneficio-destacado">{{ beneficio.destacado }}</span>
          <h3 class="aei-rec__beneficio-titulo">{{ beneficio.titulo }}</h3>
          <p class="aei-rec__beneficio-desc">{{ beneficio.desc }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# === P2-9: SECTORES DE EMPLEO: Salidas profesionales === #}
<section class="aei-rec__sectores" aria-label="{% trans %}Sectores de empleo{% endtrans %}">
  <div class="aei-rec__container">
    <h2 class="aei-rec__section-title aei-rec__section-title--center">{% trans %}Sectores con más oportunidades{% endtrans %}</h2>
    <p class="aei-rec__section-desc aei-rec__section-desc--center">
      {% trans %}Nuestro equipo de prospección empresarial trabaja con empleadores de estos sectores clave en Málaga y Sevilla:{% endtrans %}
    </p>
    <div class="aei-rec__sectores-tags">
      {% for sector in programa.sectores %}
        <span class="aei-rec__sector-tag">{{ sector }}</span>
      {% endfor %}
    </div>
  </div>
</section>

{# === REQUISITOS: Quién puede participar === #}
<section class="aei-rec__requisitos" aria-label="{% trans %}Requisitos de participación{% endtrans %}">
  <div class="aei-rec__container">
    <div class="aei-rec__requisitos-layout">
      <div class="aei-rec__requisitos-main">
        <h2 class="aei-rec__section-title">{% trans %}¿Puedo participar?{% endtrans %}</h2>
        <p class="aei-rec__section-desc">
          {% trans %}El programa está dirigido a personas desempleadas inscritas como demandantes de empleo en el SAE que pertenezcan a alguno de estos colectivos:{% endtrans %}
        </p>
        <ul class="aei-rec__colectivos-list">
          {% for colectivo in programa.colectivos %}
            <li class="aei-rec__colectivo-item">
              <svg class="aei-rec__check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--ej-verde-innovacion, #00A9A5)" stroke-width="2.5" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
              <span>{{ colectivo }}</span>
            </li>
          {% endfor %}
        </ul>
      </div>
      <div class="aei-rec__requisitos-sidebar">
        <div class="aei-rec__requisito-card">
          <h3 class="aei-rec__requisito-card-title">{% trans %}Requisito imprescindible{% endtrans %}</h3>
          <p class="aei-rec__requisito-card-text">
            {% trans %}Estar inscrito/a como demandante de empleo no ocupado/a en el Servicio Andaluz de Empleo (SAE) en el momento del alta en el programa.{% endtrans %}
          </p>
          <div class="aei-rec__requisito-card-action">
            <a href="{{ solicitar_url }}" class="aei-rec__cta aei-rec__cta--primary">
              {% trans %}Comprobar elegibilidad{% endtrans %}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{# === SEDES: Dónde se imparte === #}
<section class="aei-rec__sedes" aria-label="{% trans %}Sedes del programa{% endtrans %}">
  <div class="aei-rec__container">
    <h2 class="aei-rec__section-title aei-rec__section-title--center">{% trans %}Sedes del programa{% endtrans %}</h2>
    <div class="aei-rec__sedes-grid">
      {% for sede in programa.sedes %}
        <div class="aei-rec__sede-card">
          <span class="aei-rec__sede-plazas">{{ sede.plazas }} {% trans %}plazas{% endtrans %}</span>
          <h3 class="aei-rec__sede-ciudad">{{ sede.ciudad }}</h3>
          <address class="aei-rec__sede-direccion">
            {{ sede.direccion }}<br>
            CP {{ sede.cp }} {{ sede.ciudad }}
          </address>
          {# P2-2: Enlace a Google Maps #}
          <a href="https://www.google.com/maps/search/?api=1&query={{ sede.direccion|url_encode }}+{{ sede.cp }}+{{ sede.ciudad|url_encode }}"
             class="aei-rec__sede-map-link" target="_blank" rel="noopener noreferrer"
             aria-label="{% trans %}Ver {{ sede.ciudad }} en Google Maps{% endtrans %}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {% trans %}Ver en mapa{% endtrans %}
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# === CÓMO FUNCIONA: Paso a paso claro === #}
<section class="aei-rec__pasos" aria-label="{% trans %}Cómo funciona{% endtrans %}">
  <div class="aei-rec__container">
    <h2 class="aei-rec__section-title aei-rec__section-title--center">{% trans %}Cómo funciona{% endtrans %}</h2>
    <div class="aei-rec__pasos-timeline">
      {% set pasos = [
        {
          num: '1',
          titulo: 'Solicita tu plaza'|t,
          desc: 'Rellena el formulario online en 2 minutos. Nuestro sistema de inteligencia artificial evalúa tu perfil y te asigna el itinerario más adecuado en menos de 48 horas.'|t,
        },
        {
          num: '2',
          titulo: 'Acogida y diagnóstico'|t,
          desc: 'Te recibimos en tu sede más cercana, firmamos el Acuerdo de Participación y evaluamos tu situación laboral, competencias y objetivos profesionales.'|t,
        },
        {
          num: '3',
          titulo: 'Formación + orientación'|t,
          desc: 'Mínimo 50 horas de formación certificada y 10 horas de orientación personalizada. Acceso al tutor IA 24/7, expediente digital y seguimiento de tu progreso en tiempo real.'|t,
        },
        {
          num: '4',
          titulo: 'Inserción laboral'|t,
          desc: 'Acompañamiento activo en procesos de selección o lanzamiento de tu emprendimiento. Prospección de ofertas, preparación de entrevistas y seguimiento post-contratación durante 6 meses.'|t,
        },
      ] %}
      {% for paso in pasos %}
        <div class="aei-rec__paso">
          <span class="aei-rec__paso-num">{{ paso.num }}</span>
          <div class="aei-rec__paso-content">
            <h3 class="aei-rec__paso-titulo">{{ paso.titulo }}</h3>
            <p class="aei-rec__paso-desc">{{ paso.desc }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# === EQUIPO: Quién te acompaña === #}
<section class="aei-rec__equipo" aria-label="{% trans %}Equipo técnico{% endtrans %}">
  <div class="aei-rec__container">
    <h2 class="aei-rec__section-title aei-rec__section-title--center">{% trans %}Quién te acompaña{% endtrans %}</h2>
    <p class="aei-rec__section-desc aei-rec__section-desc--center">
      {% trans %}Profesionales con décadas de experiencia en empleabilidad, emprendimiento y desarrollo local. No somos teóricos: hemos estado donde tú estás.{% endtrans %}
    </p>
    <div class="aei-rec__equipo-impacto" aria-label="{% trans %}Impacto combinado del equipo{% endtrans %}">
      <div class="aei-rec__equipo-impacto-item">
        <span class="aei-rec__equipo-impacto-valor">+50</span>
        <span class="aei-rec__equipo-impacto-label">{% trans %}años de experiencia combinada{% endtrans %}</span>
      </div>
      <div class="aei-rec__equipo-impacto-sep" aria-hidden="true"></div>
      <div class="aei-rec__equipo-impacto-item">
        <span class="aei-rec__equipo-impacto-valor">+500</span>
        <span class="aei-rec__equipo-impacto-label">{% trans %}proyectos de emprendimiento y empleo{% endtrans %}</span>
      </div>
      <div class="aei-rec__equipo-impacto-sep" aria-hidden="true"></div>
      <div class="aei-rec__equipo-impacto-item">
        <span class="aei-rec__equipo-impacto-valor">+100M&euro;</span>
        <span class="aei-rec__equipo-impacto-label">{% trans %}en fondos europeos gestionados{% endtrans %}</span>
      </div>
    </div>
    <div class="aei-rec__equipo-grid">
      {% for miembro in programa.equipo %}
        <article class="aei-rec__equipo-card{% if not miembro.foto %} aei-rec__equipo-card--compact{% endif %}">
          <div class="aei-rec__equipo-foto-wrap">
            {% if miembro.foto %}
              <img class="aei-rec__equipo-foto"
                   src="/{{ module_path }}/images/{{ miembro.foto }}"
                   srcset="/{{ module_path }}/images/{{ miembro.foto }} 2x"
                   alt="{{ miembro.nombre }}"
                   width="160" height="160" loading="lazy">
            {% else %}
              {# P2-8: CSS-generated initials avatar for team members without photo #}
              <span class="aei-rec__equipo-iniciales" aria-hidden="true">{{ miembro.iniciales }}</span>
            {% endif %}
            <span class="aei-rec__equipo-sede-badge">{{ miembro.sede }}</span>
          </div>
          <div class="aei-rec__equipo-body">
            <h3 class="aei-rec__equipo-nombre">{{ miembro.nombre }}</h3>
            <p class="aei-rec__equipo-cargo">{{ miembro.cargo }}</p>
            <p class="aei-rec__equipo-bio">{{ miembro.bio }}</p>
            <ul class="aei-rec__equipo-badges" aria-label="{% trans %}Credenciales{% endtrans %}">
              {% for badge in miembro.badges %}
                <li class="aei-rec__equipo-badge">
                  <span class="aei-rec__equipo-badge-icon aei-rec__equipo-badge-icon--{{ badge.icono }}" aria-hidden="true"></span>
                  <span>{{ badge.texto }}</span>
                </li>
              {% endfor %}
            </ul>
            {% if miembro.cita %}
              <blockquote class="aei-rec__equipo-cita">
                <p>&laquo;{{ miembro.cita }}&raquo;</p>
              </blockquote>
            {% endif %}
            {% if miembro.linkedin %}
              <a href="{{ miembro.linkedin }}" target="_blank" rel="noopener noreferrer"
                 class="aei-rec__equipo-linkedin" aria-label="{% trans %}Ver perfil de {{ miembro.nombre }} en LinkedIn{% endtrans %}">
                <svg class="aei-rec__equipo-linkedin-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                {% trans %}Ver perfil en LinkedIn{% endtrans %}
              </a>
            {% endif %}
          </div>
