      <div class="aei-rec__paso aei-rec--reveal">
        <span class="aei-rec__paso-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--ej-color-verde-innovacion,#00A9A5)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </span>
        <span class="aei-rec__paso-num">4</span>
        <div class="aei-rec__paso-content">
          <h3 class="aei-rec__paso-titulo">{% trans %}Inserción laboral{% endtrans %}</h3>
          <p class="aei-rec__paso-desc">{% trans %}Acompañamiento activo en procesos de selección o lanzamiento de tu emprendimiento. Prospección de ofertas, preparación de entrevistas y seguimiento post-contratación durante 6 meses.{% endtrans %}</p>
