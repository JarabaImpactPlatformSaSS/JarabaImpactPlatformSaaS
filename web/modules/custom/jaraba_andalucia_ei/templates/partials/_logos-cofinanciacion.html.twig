{#
/**
 * @file
 * Logos de cofinanciación FSE+ — Art. 50 Reg. UE 2021/1060.
 *
 * Parcial incluido en TODAS las páginas del Programa Andalucía +ei.
 * Muestra los logos institucionales obligatorios oficiales y el texto legal
 * de cofinanciación por el Fondo Social Europeo Plus.
 *
 * Variables:
 *   Ninguna requerida (self-contained).
 *   Ruta del módulo hardcoded (parcial exclusivo de jaraba_andalucia_ei).
 *
 * ICON-EMOJI-001: NO emojis. Logos oficiales como imagen PNG.
 * TWIG-INCLUDE-ONLY-001: Incluir con `only`.
 * CSS-VAR-ALL-COLORS-001: Tokens --ej-*.
 */
#}

{% set _module_path = 'modules/custom/jaraba_andalucia_ei' %}

<aside class="aei-cofinanciacion" aria-label="{% trans %}Información de cofinanciación{% endtrans %}">
  <div class="aei-cofinanciacion__content">

    <p class="aei-cofinanciacion__text">
      {% trans %}Programa cofinanciado por el Fondo Social Europeo Plus (FSE+) de la Unión Europea y la Junta de Andalucía.{% endtrans %}
    </p>

    <div class="aei-cofinanciacion__logos">
      <img src="/{{ _module_path }}/images/logos-cofinanciacion-oficial.png"
           alt="{% trans %}Cofinanciado por la Unión Europea, Ministerio de Trabajo y Economía Social, Fondos Europeos, Junta de Andalucía — Consejería de Empleo, Empresa y Trabajo Autónomo, Servicio Andaluz de Empleo{% endtrans %}"
           class="aei-cofinanciacion__logos-img"
           width="2937" height="277"
           loading="lazy">
    </div>

    <p class="aei-cofinanciacion__legal">
      {% trans %}Programa Integrales de Inserción Laboral (PIIL) — Convocatoria Voluntaria 2025. Resolución de concesión SC/ICV/0111/2025. Cofinanciación: 85% Unión Europea (FSE+), 15% Junta de Andalucía.{% endtrans %}
    </p>

  </div>
</aside>
