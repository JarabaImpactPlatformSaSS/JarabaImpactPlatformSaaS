{#
/**
 * @file
 * Lead magnet — Guía del Participante Andalucía +ei.
 *
 * Variables:
 * - solicitar_url: URL to application form
 */
#}

<section class="aei-guia" aria-label="{{ 'Guía del Participante'|t }}">
  <div class="aei-guia__container">
    <div class="aei-guia__content">
      <span class="aei-guia__eyebrow">{{ 'Recurso gratuito'|t }}</span>
      <h1 class="aei-guia__title">{{ 'Guía del Participante Andalucía +ei'|t }}</h1>
      <p class="aei-guia__subtitle">
        {{ 'Todo lo que necesitas saber sobre el PIIL CV 2025: las 6 fases del itinerario, los requisitos de acceso, el incentivo de 528 €, la tutoría con IA 24/7 y cómo aprovechar al máximo las 45 plazas disponibles entre Málaga y Sevilla.'|t }}
      </p>

      <ul class="aei-guia__highlights">
        {% set highlights = [
          'Las 6 fases del itinerario: Acogida, Diagnóstico, Atención, Inserción, Seguimiento y Baja'|t,
          'Requisitos de acceso y colectivos prioritarios'|t,
          '10h de orientación + 50h de formación certificada + 40h de inserción'|t,
          'Tutoría virtual con IA disponible 24/7'|t,
          'Incentivo económico de 528 € al completar el itinerario'|t,
          'Expediente digital seguro y documentación STO necesaria'|t,
          'Resultados 1ª Edición: 46% de inserción real (23 de 50)'|t,
        ] %}
        {% for item in highlights %}
          <li class="aei-guia__highlight">
            {{ jaraba_icon('status', 'check-circle', { variant: 'duotone', size: '20px' }) }}
            <span>{{ item }}</span>
          </li>
        {% endfor %}
      </ul>
    </div>

    <div class="aei-guia__form-wrapper">
      <div class="aei-guia__form-card">
        <h2 class="aei-guia__form-title">{{ 'Descarga la guía gratis'|t }}</h2>
        <p class="aei-guia__form-desc">{{ 'Recibe en tu email la guía completa del PIIL CV 2025 en PDF con el detalle de las 6 fases y todos los recursos.'|t }}</p>

        <form class="aei-guia__form" data-guia-form>
          <div class="aei-guia__field">
            <label for="guia-nombre" class="aei-guia__label">{{ 'Nombre'|t }}</label>
            <input type="text" id="guia-nombre" name="nombre" required class="aei-guia__input" placeholder="{{ 'Tu nombre'|t }}" />
          </div>
          <div class="aei-guia__field">
            <label for="guia-email" class="aei-guia__label">{{ 'Email'|t }}</label>
            <input type="email" id="guia-email" name="email" required class="aei-guia__input" placeholder="{{ 'tu@email.com'|t }}" />
          </div>
          <div class="aei-guia__field">
            <label class="aei-guia__checkbox-label">
              <input type="checkbox" name="consentimiento" required class="aei-guia__checkbox" />
              <span>{{ 'Acepto recibir información sobre el programa Andalucía +ei'|t }}</span>
            </label>
          </div>
          <button type="submit" class="aei-guia__submit">
            {{ jaraba_icon('ui', 'download', { variant: 'duotone', size: '20px' }) }}
            {{ 'Descargar guía'|t }}
          </button>
          <p class="aei-guia__legal">
            {{ 'Tus datos serán tratados conforme a nuestra política de privacidad. Puedes darte de baja en cualquier momento.'|t }}
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

{# CTA to apply #}
<section class="aei-guia__cta" aria-label="{{ 'Solicitar plaza'|t }}">
  <div class="aei-guia__container">
    <h2 class="aei-guia__cta-title">{{ '¿Listo para transformar tu futuro profesional?'|t }}</h2>
    <p class="aei-guia__cta-subtitle">{{ '100% gratuito · 528 € de incentivo · 45 plazas entre Málaga y Sevilla'|t }}</p>
    <a href="{{ solicitar_url }}" class="aei-guia__cta-btn">
      {{ 'Solicitar plaza'|t }}
    </a>
  </div>
</section>
