        'caducado' => 'Caducado',
      ])
      ->setDefaultValue('borrador')
      ->setDisplayConfigurable('form', TRUE)
      ->setDisplayConfigurable('view', TRUE);

    $newFields['firma_solicitada_fecha'] = \Drupal\Core\Field\BaseFieldDefinition::create('datetime')
