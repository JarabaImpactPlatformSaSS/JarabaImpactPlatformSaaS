/**
 * Install the insercion_laboral entity type.
 *
 * Records complete detail of each labor insertion achieved by participants,
 * differentiating by type: cuenta_ajena, cuenta_propia, agrario.
 *
 * UPDATE-HOOK-REQUIRED-001: New ContentEntity needs installEntityType().
 * UPDATE-HOOK-CATCH-001: \Throwable.
 */
function jaraba_andalucia_ei_update_10009(): string {
  try {
    $entityDefinitionUpdateManager = \Drupal::entityDefinitionUpdateManager();
    $entityTypeManager = \Drupal::entityTypeManager();

    $entityType = $entityTypeManager->getDefinition('insercion_laboral', FALSE);
    if ($entityType && !$entityDefinitionUpdateManager->getEntityType('insercion_laboral')) {
      $entityDefinitionUpdateManager->installEntityType($entityType);
      return 'Entidad InsercionLaboral instalada correctamente.';
    }

    return 'InsercionLaboral ya instalada o definición no encontrada.';
  }
  catch (\Throwable $e) {
