        ->setSetting('scale', 2)
        ->setDisplayConfigurable('form', TRUE)
        ->setDisplayConfigurable('view', TRUE),

      'asistencia_porcentaje' => \Drupal\Core\Field\BaseFieldDefinition::create('decimal')
        ->setName('asistencia_porcentaje')
        ->setTargetEntityTypeId($entityTypeId)
        ->setLabel(t('Porcentaje de Asistencia'))
        ->setDescription(t('Porcentaje de asistencia calculado sobre actuaciones programadas.'))
        ->setDefaultValue(0)
        ->setSetting('precision', 5)
        ->setSetting('scale', 2)
        ->setDisplayConfigurable('form', TRUE)
        ->setDisplayConfigurable('view', TRUE),

      'es_persona_atendida' => \Drupal\Core\Field\BaseFieldDefinition::create('boolean')
        ->setName('es_persona_atendida')
        ->setTargetEntityTypeId($entityTypeId)
        ->setLabel(t('¿Persona Atendida?'))
        ->setDescription(t('Cumple requisitos de persona atendida (módulo económico 3.500€).'))
        ->setDefaultValue(FALSE)
        ->setDisplayConfigurable('view', TRUE),

      'es_persona_insertada' => \Drupal\Core\Field\BaseFieldDefinition::create('boolean')
        ->setName('es_persona_insertada')
        ->setTargetEntityTypeId($entityTypeId)
        ->setLabel(t('¿Persona Insertada?'))
        ->setDescription(t('Cumple requisitos de persona insertada (módulo económico 2.500€).'))
        ->setDefaultValue(FALSE)
        ->setDisplayConfigurable('view', TRUE),

      'candidate_profile_id' => \Drupal\Core\Field\BaseFieldDefinition::create('integer')
        ->setName('candidate_profile_id')
        ->setTargetEntityTypeId($entityTypeId)
        ->setLabel(t('Perfil de Candidato'))
        ->setDescription(t('ID del CandidateProfile en jaraba_candidate (cross-vertical).'))
        ->setSetting('unsigned', TRUE)
        ->setDisplayConfigurable('view', TRUE),

      'canvas_id' => \Drupal\Core\Field\BaseFieldDefinition::create('integer')
        ->setName('canvas_id')
        ->setTargetEntityTypeId($entityTypeId)
        ->setLabel(t('Business Model Canvas'))
        ->setDescription(t('ID del BusinessModelCanvas en jaraba_business_tools (cross-vertical).'))
        ->setSetting('unsigned', TRUE)
        ->setDisplayConfigurable('view', TRUE),

      'is_alumni' => \Drupal\Core\Field\BaseFieldDefinition::create('boolean')
        ->setName('is_alumni')
        ->setTargetEntityTypeId($entityTypeId)
        ->setLabel(t('¿Alumni?'))
        ->setDescription(t('El participante forma parte del Club Alumni.'))
        ->setDefaultValue(FALSE)
        ->setDisplayConfigurable('view', TRUE),

      'alumni_fecha' => \Drupal\Core\Field\BaseFieldDefinition::create('datetime')
        ->setName('alumni_fecha')
        ->setTargetEntityTypeId($entityTypeId)
        ->setLabel(t('Fecha Alumni'))
        ->setDescription(t('Fecha en que se convirtió en alumni.'))
        ->setSetting('datetime_type', 'date')
        ->setDisplayConfigurable('view', TRUE),

      'alumni_disponible_mentoria' => \Drupal\Core\Field\BaseFieldDefinition::create('boolean')
        ->setName('alumni_disponible_mentoria')
        ->setTargetEntityTypeId($entityTypeId)
        ->setLabel(t('Disponible para Mentoría Alumni'))
        ->setDescription(t('Disponible para mentorizar en futuras ediciones.'))
        ->setDefaultValue(FALSE)
        ->setDisplayConfigurable('form', TRUE)
        ->setDisplayConfigurable('view', TRUE),
    ];

    foreach ($newFields as $fieldName => $definition) {
      $existing = $updateManager->getFieldStorageDefinition($fieldName, $entityTypeId);
      if (!$existing) {
        $updateManager->installFieldStorageDefinition($fieldName, $entityTypeId, 'jaraba_andalucia_ei', $definition);
        $messages[] = $fieldName . ': installed.';
      }
      else {
        $messages[] = $fieldName . ': already exists, skipped.';
      }
    }

    // === 2. Update expediente_documento categoria allowed_values ===

    $expedienteEntityTypeId = 'expediente_documento';
    if ($updateManager->getEntityType($expedienteEntityTypeId)) {
      $existingCategoria = $updateManager->getFieldStorageDefinition('categoria', $expedienteEntityTypeId);
      if ($existingCategoria) {
        $newAllowed = array_map('t', \Drupal\jaraba_andalucia_ei\Entity\ExpedienteDocumento::CATEGORIAS);
        $existingCategoria->setSetting('allowed_values', $newAllowed);
        $updateManager->updateFieldStorageDefinition($existingCategoria);
        $messages[] = 'expediente_documento.categoria: updated with 11 new categories.';
      }
    }

    return 'update_10010 complete: ' . implode(' ', $messages);
  }
  catch (\Throwable $e) {
    return 'Error in update_10010: ' . $e->getMessage();
  }
}

