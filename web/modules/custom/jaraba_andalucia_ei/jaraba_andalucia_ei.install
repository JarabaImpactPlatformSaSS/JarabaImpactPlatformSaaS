/**
 * Separate Acuerdo de Participación from DACI: install new fields + data migration.
 *
 * The code previously conflated the Acuerdo de Participación (Acuerdo_participacion_ICV25.odt)
 * with the DACI (Anexo_DACI_ICV25.odt). They are TWO distinct official PIIL CV 2025 documents.
 *
 * This hook:
 * 1. Installs acuerdo_participacion_firmado (boolean) and acuerdo_participacion_fecha (datetime).
 * 2. Migrates existing daci_firmado/daci_fecha_firma data → acuerdo_participacion_* fields
 *    (because historical data actually tracked Acuerdo signatures, not DACI).
 * 3. Resets daci_firmado = FALSE and daci_fecha_firma = NULL so DACI tracking starts clean.
 * 4. Updates expediente_documento categoria with new sto_acuerdo_participacion category.
 *
 * UPDATE-FIELD-DEF-001: setName() + setTargetEntityTypeId() on each definition.
 * UPDATE-HOOK-CATCH-001: \Throwable.
 */
function jaraba_andalucia_ei_update_10012(): string {
  $updateManager = \Drupal::entityDefinitionUpdateManager();
  $entityTypeId = 'programa_participante_ei';
  $messages = [];

  try {
    // === 1. Install new Acuerdo de Participación fields ===

    $acuerdoFields = [
      'acuerdo_participacion_firmado' => \Drupal\Core\Field\BaseFieldDefinition::create('boolean')
        ->setName('acuerdo_participacion_firmado')
        ->setTargetEntityTypeId($entityTypeId)
        ->setLabel(t('Acuerdo de Participación Firmado'))
        ->setDescription(t('Indica si se ha firmado el Acuerdo de Participación (Acuerdo_participacion_ICV25.odt).'))
        ->setDefaultValue(FALSE)
        ->setDisplayConfigurable('form', TRUE)
        ->setDisplayConfigurable('view', TRUE),

      'acuerdo_participacion_fecha' => \Drupal\Core\Field\BaseFieldDefinition::create('datetime')
        ->setName('acuerdo_participacion_fecha')
        ->setTargetEntityTypeId($entityTypeId)
        ->setLabel(t('Fecha Firma Acuerdo de Participación'))
        ->setDescription(t('Fecha en que se firmó el Acuerdo de Participación.'))
        ->setSetting('datetime_type', 'date')
        ->setDisplayConfigurable('form', TRUE)
        ->setDisplayConfigurable('view', TRUE),
    ];

    foreach ($acuerdoFields as $fieldName => $definition) {
      $existing = $updateManager->getFieldStorageDefinition($fieldName, $entityTypeId);
      if (!$existing) {
        $updateManager->installFieldStorageDefinition($fieldName, $entityTypeId, 'jaraba_andalucia_ei', $definition);
        $messages[] = $fieldName . ': installed.';
      }
      else {
        $messages[] = $fieldName . ': already exists, skipped.';
      }
    }

    // === 2. Data migration: daci_firmado → acuerdo_participacion_firmado ===
    // Historical data in daci_firmado actually tracked Acuerdo de Participación signatures.

    $database = \Drupal::database();
    $table = $entityTypeId;

    if ($database->schema()->fieldExists($table, 'daci_firmado')
      && $database->schema()->fieldExists($table, 'acuerdo_participacion_firmado')) {

      // Copy daci_firmado → acuerdo_participacion_firmado.
      $migrated = $database->update($table)
        ->expression('acuerdo_participacion_firmado', 'daci_firmado')
        ->execute();
      $messages[] = 'acuerdo_participacion_firmado: migrated ' . $migrated . ' rows from daci_firmado.';

      // Copy daci_fecha_firma → acuerdo_participacion_fecha.
      if ($database->schema()->fieldExists($table, 'daci_fecha_firma')
        && $database->schema()->fieldExists($table, 'acuerdo_participacion_fecha')) {
        $database->update($table)
          ->expression('acuerdo_participacion_fecha', 'daci_fecha_firma')
          ->execute();
        $messages[] = 'acuerdo_participacion_fecha: migrated from daci_fecha_firma.';
      }

      // === 3. Reset DACI fields (clean slate for real DACI tracking) ===

      $database->update($table)
        ->fields([
          'daci_firmado' => 0,
          'daci_fecha_firma' => NULL,
        ])
        ->execute();
      $messages[] = 'daci_firmado + daci_fecha_firma: reset to default (clean DACI tracking).';
    }
    else {
      $messages[] = 'Data migration skipped: fields not yet in schema.';
    }

    // === 4. Update expediente_documento categoria with sto_acuerdo_participacion ===

    $expedienteEntityTypeId = 'expediente_documento';
    if ($updateManager->getEntityType($expedienteEntityTypeId)) {
      $existingCategoria = $updateManager->getFieldStorageDefinition('categoria', $expedienteEntityTypeId);
      if ($existingCategoria) {
        $newAllowed = array_map('t', \Drupal\jaraba_andalucia_ei\Entity\ExpedienteDocumento::CATEGORIAS);
        $existingCategoria->setSetting('allowed_values', $newAllowed);
        $updateManager->updateFieldStorageDefinition($existingCategoria);
        $messages[] = 'expediente_documento.categoria: updated with sto_acuerdo_participacion.';
      }
    }

    return 'update_10012 (Acuerdo/DACI separation) complete: ' . implode(' ', $messages);
  }
  catch (\Throwable $e) {
    return 'Error in update_10012: ' . $e->getMessage();
  }
}

