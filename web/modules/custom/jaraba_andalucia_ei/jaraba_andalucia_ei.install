    return 'Error in update_10013: ' . $e->getMessage();
  }
}

/**
 * Add incentivo tracking fields to programa_participante_ei.
 *
 * New fields: incentivo_fecha_pago, incentivo_renuncia, incentivo_renuncia_fecha.
 * Required by PIIL ICV25 annexes: Recibi_Incentivo_ICV25, Renuncia_Incentivo_ICV25.
 */
function jaraba_andalucia_ei_update_10014(): string {
  $messages = [];

  try {
    $entityDefinitionUpdateManager = \Drupal::entityDefinitionUpdateManager();

    $newFields = [
      'incentivo_fecha_pago' => \Drupal\Core\Field\BaseFieldDefinition::create('datetime')
        ->setName('incentivo_fecha_pago')
        ->setTargetEntityTypeId('programa_participante_ei')
        ->setLabel(t('Fecha Pago Incentivo'))
        ->setDescription(t('Fecha en que se pagó el incentivo económico de €528.'))
        ->setSetting('datetime_type', 'date')
        ->setDisplayConfigurable('form', TRUE)
        ->setDisplayConfigurable('view', TRUE),

      'incentivo_renuncia' => \Drupal\Core\Field\BaseFieldDefinition::create('boolean')
        ->setName('incentivo_renuncia')
        ->setTargetEntityTypeId('programa_participante_ei')
        ->setLabel(t('Renuncia al Incentivo'))
        ->setDescription(t('Indica si el participante ha renunciado al incentivo económico de €528.'))
        ->setDefaultValue(FALSE)
        ->setDisplayConfigurable('form', TRUE)
        ->setDisplayConfigurable('view', TRUE),

      'incentivo_renuncia_fecha' => \Drupal\Core\Field\BaseFieldDefinition::create('datetime')
        ->setName('incentivo_renuncia_fecha')
        ->setTargetEntityTypeId('programa_participante_ei')
        ->setLabel(t('Fecha Renuncia Incentivo'))
        ->setDescription(t('Fecha en que el participante formalizó la renuncia al incentivo.'))
        ->setSetting('datetime_type', 'date')
        ->setDisplayConfigurable('form', TRUE)
        ->setDisplayConfigurable('view', TRUE),
    ];

    foreach ($newFields as $fieldName => $fieldDefinition) {
      if (!$entityDefinitionUpdateManager->getFieldStorageDefinition($fieldName, 'programa_participante_ei')) {
        $entityDefinitionUpdateManager->installFieldStorageDefinition(
          $fieldName,
          'programa_participante_ei',
          'jaraba_andalucia_ei',
          $fieldDefinition,
        );
        $messages[] = "Installed field: $fieldName";
      }
      else {
        $messages[] = "Field already exists: $fieldName";
      }
    }

    // Update entity type definition for ExpedienteDocumento (new CATEGORIAS values).
    $entityTypeManager = \Drupal::entityTypeManager();
    $expedienteType = $entityTypeManager->getDefinition('expediente_documento', FALSE);
    if ($expedienteType) {
      $entityDefinitionUpdateManager->updateEntityType($expedienteType);
      $messages[] = 'expediente_documento: entity type definition updated (new CATEGORIAS).';
    }
  }
  catch (\Throwable $e) {
    return 'Error in update_10014: ' . $e->getMessage();
  }

  return implode(' | ', $messages);
}

/**
 * Add firma workflow fields to expediente_documento + create audit table.
 *
 * Sprint 1 — Plan Maestro Andalucía +ei Clase Mundial.
 * New fields: estado_firma, firma_solicitada_fecha, firma_solicitante_uid,
 * firma_ip, firma_user_agent, firma_metodo, firma_hash_documento,
 * co_firmante_uid, co_firma_fecha, co_firma_metodo, verificacion_hash,
 * verificacion_qr_uri.
 * New table: jaraba_andalucia_ei_firma_audit.
 *
 * UPDATE-FIELD-DEF-001: setName + setTargetEntityTypeId.
 * UPDATE-HOOK-CATCH-001: \Throwable.
 */
function jaraba_andalucia_ei_update_10015(): string {
  $messages = [];

  try {
    $entityDefinitionUpdateManager = \Drupal::entityDefinitionUpdateManager();

    // === Nuevos campos de firma en expediente_documento ===
    $newFields = [];

    $newFields['estado_firma'] = \Drupal\Core\Field\BaseFieldDefinition::create('list_string')
      ->setName('estado_firma')
      ->setTargetEntityTypeId('expediente_documento')
