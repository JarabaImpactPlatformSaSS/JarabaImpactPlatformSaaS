/**
 * Sprint 14: Install MaterialDidacticoEi + new fields on existing entities.
 *
 * UPDATE-HOOK-REQUIRED-001: New entity + new fields require hook_update_N().
 * UPDATE-FIELD-DEF-001: setName() + setTargetEntityTypeId() on each field.
 * UPDATE-HOOK-CATCH-001: catch(\Throwable) not catch(\Exception).
 */
function jaraba_andalucia_ei_update_10023(): string {
  $messages = [];

  try {
    $entityDefinitionUpdateManager = \Drupal::entityDefinitionUpdateManager();
    $entityTypeManager = \Drupal::entityTypeManager();
    $entityFieldManager = \Drupal::service('entity_field.manager');

    // 1. Install new entity: material_didactico_ei.
    $entityType = $entityTypeManager->getDefinition('material_didactico_ei');
    $entityDefinitionUpdateManager->installEntityType($entityType);
    $messages[] = 'Installed entity type: material_didactico_ei.';

    // Install all fields for material_didactico_ei.
    $fieldStorageDefinitions = $entityFieldManager->getFieldStorageDefinitions('material_didactico_ei');
    foreach ($fieldStorageDefinitions as $fieldName => $fieldDefinition) {
      $existing = $entityDefinitionUpdateManager->getFieldStorageDefinition($fieldName, 'material_didactico_ei');
      if (!$existing) {
        $fieldDefinition->setName($fieldName);
        $fieldDefinition->setTargetEntityTypeId('material_didactico_ei');
        $entityDefinitionUpdateManager->installFieldStorageDefinition(
          $fieldName, 'material_didactico_ei', 'jaraba_andalucia_ei', $fieldDefinition
        );
        $messages[] = "material_didactico_ei: installed field $fieldName.";
      }
    }

    // 2. New fields on existing entities.
    $newFieldsByEntity = [
      'sesion_programada_ei' => ['fase_piil', 'contenido_sto', 'subcontenido_sto'],
      'accion_formativa_ei' => ['contenido_sto', 'subcontenido_sto', 'materiales'],
      'actuacion_sto' => ['fase_piil', 'contenido_sto', 'subcontenido_sto'],
      'plan_formativo_ei' => ['horas_orientacion_insercion_previstas', 'cumple_persona_atendida', 'cumple_persona_insertada'],
    ];

    foreach ($newFieldsByEntity as $entityTypeId => $fieldNames) {
      $fields = $entityFieldManager->getFieldStorageDefinitions($entityTypeId);
      foreach ($fieldNames as $fieldName) {
        if (!isset($fields[$fieldName])) {
          $messages[] = "WARNING: $entityTypeId.$fieldName not in field definitions.";
          continue;
        }
        $existing = $entityDefinitionUpdateManager->getFieldStorageDefinition($fieldName, $entityTypeId);
        if (!$existing) {
          $field = $fields[$fieldName];
          $field->setName($fieldName);
          $field->setTargetEntityTypeId($entityTypeId);
          $entityDefinitionUpdateManager->installFieldStorageDefinition(
            $fieldName, $entityTypeId, 'jaraba_andalucia_ei', $field
          );
          $messages[] = "$entityTypeId: installed field $fieldName.";
        }
      }
    }

    $messages[] = 'Sprint 14 schema update complete.';
  }
  catch (\Throwable $e) {
    return 'Error in update_10023: ' . $e->getMessage();
  }

  return implode(' | ', $messages);
}

