      ])
      ->setDisplayConfigurable('view', TRUE);

    $newFields['firma_hash_documento'] = \Drupal\Core\Field\BaseFieldDefinition::create('string')
      ->setName('firma_hash_documento')
      ->setTargetEntityTypeId('expediente_documento')
      ->setLabel(t('Hash del documento'))
      ->setSetting('max_length', 64)
      ->setDisplayConfigurable('view', TRUE);

    $newFields['co_firmante_uid'] = \Drupal\Core\Field\BaseFieldDefinition::create('entity_reference')
      ->setName('co_firmante_uid')
      ->setTargetEntityTypeId('expediente_documento')
      ->setLabel(t('Co-firmante'))
      ->setSetting('target_type', 'user')
      ->setDisplayConfigurable('view', TRUE);

    $newFields['co_firma_fecha'] = \Drupal\Core\Field\BaseFieldDefinition::create('datetime')
      ->setName('co_firma_fecha')
      ->setTargetEntityTypeId('expediente_documento')
      ->setLabel(t('Fecha de co-firma'))
      ->setSetting('datetime_type', 'datetime')
      ->setDisplayConfigurable('view', TRUE);

    $newFields['co_firma_metodo'] = \Drupal\Core\Field\BaseFieldDefinition::create('list_string')
      ->setName('co_firma_metodo')
      ->setTargetEntityTypeId('expediente_documento')
      ->setLabel(t('Método de co-firma'))
      ->setSetting('allowed_values', [
        'tactil' => 'Firma táctil',
        'autofirma' => 'AutoFirma (certificado digital)',
        'sello_empresa' => 'Sello de empresa',
      ])
      ->setDisplayConfigurable('view', TRUE);

    $newFields['verificacion_hash'] = \Drupal\Core\Field\BaseFieldDefinition::create('string')
      ->setName('verificacion_hash')
      ->setTargetEntityTypeId('expediente_documento')
      ->setLabel(t('Hash de verificación'))
      ->setSetting('max_length', 64)
      ->setDisplayConfigurable('view', TRUE);

    $newFields['verificacion_qr_uri'] = \Drupal\Core\Field\BaseFieldDefinition::create('string')
      ->setName('verificacion_qr_uri')
      ->setTargetEntityTypeId('expediente_documento')
      ->setLabel(t('URI del QR'))
      ->setSetting('max_length', 255)
      ->setDisplayConfigurable('view', TRUE);

    foreach ($newFields as $fieldName => $fieldDefinition) {
      if (!$entityDefinitionUpdateManager->getFieldStorageDefinition($fieldName, 'expediente_documento')) {
        $entityDefinitionUpdateManager->installFieldStorageDefinition(
          $fieldName,
          'expediente_documento',
          'jaraba_andalucia_ei',
          $fieldDefinition,
        );
        $messages[] = "Installed field: $fieldName";
      }
      else {
        $messages[] = "Field already exists: $fieldName";
      }
    }

    // Update entity type definition.
    $entityTypeManager = \Drupal::entityTypeManager();
    $expedienteType = $entityTypeManager->getDefinition('expediente_documento', FALSE);
    if ($expedienteType) {
      $entityDefinitionUpdateManager->updateEntityType($expedienteType);
      $messages[] = 'expediente_documento: entity type definition updated (firma workflow fields).';
    }

    // === Crear tabla de auditoría de firma ===
    $database = \Drupal::database();
    if (!$database->schema()->tableExists('jaraba_andalucia_ei_firma_audit')) {
      $schema = jaraba_andalucia_ei_schema();
      $database->schema()->createTable(
        'jaraba_andalucia_ei_firma_audit',
        $schema['jaraba_andalucia_ei_firma_audit'],
      );
      $messages[] = 'Created table: jaraba_andalucia_ei_firma_audit.';
    }
    else {
      $messages[] = 'Table jaraba_andalucia_ei_firma_audit already exists.';
    }
  }
  catch (\Throwable $e) {
    return 'Error in update_10015: ' . $e->getMessage();
  }

  return implode(' | ', $messages);
}

/**
 * Sprint 7: Install PlanEmprendimientoEi entity type.
 *
 * UPDATE-HOOK-REQUIRED-001: Nueva entity DEBE tener installEntityType().
 */
function jaraba_andalucia_ei_update_10016(): string {
  $messages = [];

  try {
    $entityDefinitionUpdateManager = \Drupal::entityDefinitionUpdateManager();
    $entityTypeManager = \Drupal::entityTypeManager();

    // Instalar PlanEmprendimientoEi.
    $planType = $entityTypeManager->getDefinition('plan_emprendimiento_ei', FALSE);
    if ($planType) {
      $entityDefinitionUpdateManager->installEntityType($planType);
      $messages[] = 'Installed entity type: plan_emprendimiento_ei.';
    }
    else {
      $messages[] = 'WARNING: plan_emprendimiento_ei entity type not found. Module cache may need clearing.';
    }
  }
  catch (\Throwable $e) {
    return 'Error in update_10016: ' . $e->getMessage();
  }

  return implode(' | ', $messages);
}

/**
 * Sprint 8: Add barreras_acceso field to ProgramaParticipanteEi.
 *
 * UPDATE-FIELD-DEF-001: setName() + setTargetEntityTypeId() obligatorios.
 */
function jaraba_andalucia_ei_update_10017(): string {
  $messages = [];

  try {
    $entityDefinitionUpdateManager = \Drupal::entityDefinitionUpdateManager();

    // Verificar que no existe ya el campo.
    $existing = $entityDefinitionUpdateManager->getFieldStorageDefinition(
      'barreras_acceso',
      'programa_participante_ei'
    );

    if (!$existing) {
      $field = \Drupal\Core\Field\BaseFieldDefinition::create('text_long')
        ->setName('barreras_acceso')
        ->setTargetEntityTypeId('programa_participante_ei')
        ->setLabel(t('Barreras de acceso'))
        ->setDescription(t('JSON estructurado con 8 tipos de barrera y niveles.'))
        ->setDisplayConfigurable('form', TRUE);

      $entityDefinitionUpdateManager->installFieldStorageDefinition(
        'barreras_acceso',
        'programa_participante_ei',
        'jaraba_andalucia_ei',
        $field
      );
      $messages[] = 'Installed field: barreras_acceso on programa_participante_ei.';
    }
    else {
      $messages[] = 'Field barreras_acceso already exists.';
    }
  }
  catch (\Throwable $e) {
    return 'Error in update_10017: ' . $e->getMessage();
  }

  return implode(' | ', $messages);
}

/**
 * Install 6 new digital access fields on solicitud_ei entity.
 *
 * Fields: nivel_digital, conoce_ia, acceso_ordenador, acceso_internet,
 * disponibilidad_horaria, como_conocio.
 */
function jaraba_andalucia_ei_update_10018(): string {
  $messages = [];

  try {
    $entityDefinitionUpdateManager = \Drupal::entityDefinitionUpdateManager();
    $entityTypeManager = \Drupal::entityTypeManager();

    // UPDATE-HOOK-FIELDABLE-001: Use getFieldStorageDefinitions (NOT getBaseFieldDefinitions).
    $entityType = $entityTypeManager->getDefinition('solicitud_ei');
    $fieldStorageDefinitions = \Drupal::service('entity_field.manager')
      ->getFieldStorageDefinitions('solicitud_ei');

    // Update entity type first.
    $entityDefinitionUpdateManager->updateFieldableEntityType($entityType, $fieldStorageDefinitions);
    $messages[] = 'Updated solicitud_ei entity type definition.';

    // Install each new field individually.
    $newFields = [
      'nivel_digital',
      'conoce_ia',
      'acceso_ordenador',
      'acceso_internet',
      'disponibilidad_horaria',
      'como_conocio',
    ];

    foreach ($newFields as $fieldName) {
      $existing = $entityDefinitionUpdateManager->getFieldStorageDefinition(
        $fieldName,
        'solicitud_ei'
      );

      if (!$existing && isset($fieldStorageDefinitions[$fieldName])) {
        $field = $fieldStorageDefinitions[$fieldName];
        // UPDATE-FIELD-DEF-001: setName + setTargetEntityTypeId obligatorios.
        $field->setName($fieldName);
        $field->setTargetEntityTypeId('solicitud_ei');

        $entityDefinitionUpdateManager->installFieldStorageDefinition(
          $fieldName,
          'solicitud_ei',
          'jaraba_andalucia_ei',
          $field
        );
        $messages[] = "Installed field: $fieldName.";
      }
      else {
        $messages[] = "Field $fieldName already exists or not in definitions.";
      }
    }
  }
  catch (\Throwable $e) {
    return 'Error in update_10018: ' . $e->getMessage();
  }

  return implode(' | ', $messages);
}

/**
 * Sprint 13: Install AccionFormativaEi entity type (with revision support).
 *
 * UPDATE-HOOK-REQUIRED-001: Nueva ContentEntity requiere installEntityType().
 * UPDATE-HOOK-CATCH-001: try-catch con \Throwable.
 */
function jaraba_andalucia_ei_update_10019(): string {
  $messages = [];

  try {
    $entityDefinitionUpdateManager = \Drupal::entityDefinitionUpdateManager();
    $entityTypeManager = \Drupal::entityTypeManager();

    // Install the entity type definition.
    $entityType = $entityTypeManager->getDefinition('accion_formativa_ei');
    $entityDefinitionUpdateManager->installEntityType($entityType);
    $messages[] = 'Installed entity type: accion_formativa_ei (with revision table).';

    // Install all field storage definitions.
    $fieldStorageDefinitions = \Drupal::service('entity_field.manager')
      ->getFieldStorageDefinitions('accion_formativa_ei');

    foreach ($fieldStorageDefinitions as $fieldName => $fieldDefinition) {
      // Skip fields already managed by entity type install.
      $existing = $entityDefinitionUpdateManager->getFieldStorageDefinition(
        $fieldName,
        'accion_formativa_ei'
      );
      if (!$existing) {
        // UPDATE-FIELD-DEF-001: setName + setTargetEntityTypeId obligatorios.
        $fieldDefinition->setName($fieldName);
        $fieldDefinition->setTargetEntityTypeId('accion_formativa_ei');
        $entityDefinitionUpdateManager->installFieldStorageDefinition(
          $fieldName,
          'accion_formativa_ei',
          'jaraba_andalucia_ei',
          $fieldDefinition
        );
        $messages[] = "Installed field: $fieldName.";
      }
    }
  }
  catch (\Throwable $e) {
    return 'Error in update_10019: ' . $e->getMessage();
  }

  return implode(' | ', $messages);
}

