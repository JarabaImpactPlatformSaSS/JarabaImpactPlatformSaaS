<?php

declare(strict_types=1);

/**
 * @file
 * Install, update and uninstall functions for jaraba_andalucia_ei.
 */

/**
 * Implements hook_requirements().
 *
 * Runtime health checks for Andalucía +ei (PIIL CV 2025).
 * Visible at /admin/reports/status.
 */
function jaraba_andalucia_ei_requirements(string $phase): array {
  $requirements = [];

  if ($phase !== 'runtime') {
    return $requirements;
  }

  $entityTypeManager = \Drupal::entityTypeManager();

  // CHECK 1: Entity types installed.
  $expectedEntities = [
    'programa_participante_ei',
    'solicitud_ei',
    'expediente_documento',
    'actuacion_sto',
    'indicador_fse_plus',
    'insercion_laboral',
    'prospeccion_empresarial',
    // Sprint 13:
    'accion_formativa_ei',
    'sesion_programada_ei',
    'inscripcion_sesion_ei',
    'plan_formativo_ei',
  ];

  $missingEntities = [];
  foreach ($expectedEntities as $entityTypeId) {
    if (!$entityTypeManager->hasDefinition($entityTypeId)) {
      $missingEntities[] = $entityTypeId;
    }
  }

  $requirements['jaraba_andalucia_ei_entities'] = [
    'title' => t('Andalucía +ei: Entidades'),
    'severity' => $missingEntities ? REQUIREMENT_ERROR : REQUIREMENT_OK,
    'value' => $missingEntities
      ? t('@count entidades faltantes: @list', [
        '@count' => count($missingEntities),
        '@list' => implode(', ', $missingEntities),
      ])
      : t('@count/11 entidades instaladas', ['@count' => count($expectedEntities)]),
  ];

  // CHECK 2: Critical services available.
  $criticalServices = [
    'jaraba_andalucia_ei.fase_transition_manager',
    'jaraba_andalucia_ei.expediente',
    'jaraba_andalucia_ei.acuerdo_participacion',
    'jaraba_andalucia_ei.daci',
    'jaraba_andalucia_ei.alertas_normativas',
    'jaraba_andalucia_ei.calendario_programa',
    'jaraba_andalucia_ei.coordinador_hub',
    // Sprint 13:
    'jaraba_andalucia_ei.vobo_sae_workflow',
    'jaraba_andalucia_ei.accion_formativa',
    'jaraba_andalucia_ei.sesion_programada',
    'jaraba_andalucia_ei.inscripcion_sesion',
    'jaraba_andalucia_ei.programa_vertical_access',
    'jaraba_andalucia_ei.indicadores_esf',
    'jaraba_andalucia_ei.plan_formativo',
  ];

  $missingServices = [];
  foreach ($criticalServices as $serviceId) {
    if (!\Drupal::hasService($serviceId)) {
      $missingServices[] = $serviceId;
    }
  }

  $requirements['jaraba_andalucia_ei_services'] = [
    'title' => t('Andalucía +ei: Servicios críticos'),
    'severity' => $missingServices ? REQUIREMENT_ERROR : REQUIREMENT_OK,
    'value' => $missingServices
      ? t('@count servicios no disponibles: @list', [
        '@count' => count($missingServices),
        '@list' => implode(', ', $missingServices),
      ])
      : t('@count/7 servicios operativos', ['@count' => count($criticalServices)]),
  ];

  // CHECK 3: Active participants count and phase distribution.
  try {
    $storage = $entityTypeManager->getStorage('programa_participante_ei');
    $totalQuery = $storage->getQuery()->accessCheck(FALSE)->count();
    $total = (int) $totalQuery->execute();

    $activeQuery = $storage->getQuery()->accessCheck(FALSE)
      ->condition('fase_actual', 'baja', '!=')->count();
    $active = (int) $activeQuery->execute();

    $requirements['jaraba_andalucia_ei_participants'] = [
      'title' => t('Andalucía +ei: Participantes'),
      'severity' => REQUIREMENT_INFO,
      'value' => t('@active activos de @total totales', [
        '@active' => $active,
        '@total' => $total,
      ]),
    ];
  }
  catch (\Throwable) {
    $requirements['jaraba_andalucia_ei_participants'] = [
      'title' => t('Andalucía +ei: Participantes'),
      'severity' => REQUIREMENT_WARNING,
      'value' => t('No se pudo consultar participantes.'),
    ];
  }

  // CHECK 4: Acuerdo/DACI fields exist (separation check).
  try {
    $updateManager = \Drupal::entityDefinitionUpdateManager();
    $acuerdoField = $updateManager->getFieldStorageDefinition('acuerdo_participacion_firmado', 'programa_participante_ei');
    $daciField = $updateManager->getFieldStorageDefinition('daci_firmado', 'programa_participante_ei');

    $bothExist = $acuerdoField && $daciField;
    $requirements['jaraba_andalucia_ei_acuerdo_daci'] = [
      'title' => t('Andalucía +ei: Acuerdo/DACI separados'),
      'severity' => $bothExist ? REQUIREMENT_OK : REQUIREMENT_ERROR,
      'value' => $bothExist
        ? t('Campos acuerdo_participacion_firmado y daci_firmado instalados correctamente.')
        : t('Ejecutar drush updatedb para instalar campos de separación Acuerdo/DACI.'),
    ];
  }
  catch (\Throwable) {
    // Skip if entity definition update manager fails.
  }

  // CHECK 5: Logger channel available.
  $requirements['jaraba_andalucia_ei_logger'] = [
    'title' => t('Andalucía +ei: Logger'),
    'severity' => \Drupal::hasService('logger.channel.jaraba_andalucia_ei') ? REQUIREMENT_OK : REQUIREMENT_WARNING,
    'value' => \Drupal::hasService('logger.channel.jaraba_andalucia_ei')
      ? t('Canal de log operativo.')
      : t('Canal de log no disponible.'),
  ];

  return $requirements;
}

