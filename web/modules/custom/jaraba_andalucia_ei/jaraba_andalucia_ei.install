/**
 * Install 11 new fields on programa_participante_ei + update expediente_documento categorías.
 *
 * New fields: dime_score, dime_fecha, horas_orientacion_insercion, asistencia_porcentaje,
 * es_persona_atendida, es_persona_insertada, candidate_profile_id, canvas_id,
 * is_alumni, alumni_fecha, alumni_disponible_mentoria.
 *
 * ExpedienteDocumento: update categoria allowed_values with 11 new categories.
 *
 * UPDATE-FIELD-DEF-001: setName() + setTargetEntityTypeId() on each definition.
 * UPDATE-HOOK-CATCH-001: \Throwable.
 */
function jaraba_andalucia_ei_update_10010(): string {
  $updateManager = \Drupal::entityDefinitionUpdateManager();
  $entityTypeId = 'programa_participante_ei';
  $messages = [];

  try {
    // === 1. Install new fields on programa_participante_ei ===

    $newFields = [
      'dime_score' => \Drupal\Core\Field\BaseFieldDefinition::create('integer')
        ->setName('dime_score')
        ->setTargetEntityTypeId($entityTypeId)
        ->setLabel(t('Score DIME'))
        ->setDescription(t('Puntuación del diagnóstico DIME (0-20).'))
        ->setSetting('unsigned', TRUE)
        ->setDisplayConfigurable('form', TRUE)
        ->setDisplayConfigurable('view', TRUE),

      'dime_fecha' => \Drupal\Core\Field\BaseFieldDefinition::create('datetime')
        ->setName('dime_fecha')
        ->setTargetEntityTypeId($entityTypeId)
        ->setLabel(t('Fecha Diagnóstico DIME'))
        ->setDescription(t('Fecha en que se completó el diagnóstico DIME.'))
        ->setSetting('datetime_type', 'date')
        ->setDisplayConfigurable('form', TRUE)
        ->setDisplayConfigurable('view', TRUE),

      'horas_orientacion_insercion' => \Drupal\Core\Field\BaseFieldDefinition::create('decimal')
        ->setName('horas_orientacion_insercion')
        ->setTargetEntityTypeId($entityTypeId)
        ->setLabel(t('Horas Orientación Inserción'))
        ->setDescription(t('Horas de orientación específicas para inserción laboral.'))
