      ->setSetting('allowed_values', [
        'borrador' => 'Borrador',
        'pendiente_firma' => 'Pendiente de firma',
        'pendiente_firma_tecnico' => 'Pendiente firma técnico',
        'pendiente_firma_participante' => 'Pendiente firma participante',
        'firmado_parcial' => 'Firmado parcialmente',
        'firmado' => 'Firmado',
