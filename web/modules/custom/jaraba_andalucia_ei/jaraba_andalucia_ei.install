        $revisionTable = $entityTypeId . '_revision__' . $fieldName;
        foreach ($existingValues as $entityId => $value) {
          $record = [
            'bundle' => $entityTypeId,
            'deleted' => 0,
            'entity_id' => $entityId,
            'revision_id' => $entityId,
            'langcode' => 'es',
            'delta' => 0,
            $fieldName . '_value' => $value,
          ];
          if ($database->schema()->tableExists($fieldTable)) {
            $database->merge($fieldTable)
              ->keys(['entity_id' => $entityId, 'delta' => 0, 'langcode' => 'es'])
              ->fields($record)
              ->execute();
          }
          if ($database->schema()->tableExists($revisionTable)) {
            $database->merge($revisionTable)
              ->keys(['entity_id' => $entityId, 'revision_id' => $entityId, 'delta' => 0, 'langcode' => 'es'])
              ->fields($record)
              ->execute();
          }
        }
        $messages[] = "Migrated " . count($existingValues) . " existing $entityTypeId.$fieldName values.";
      }
    }
  }
  catch (\Throwable $e) {
    return 'Error in update_10028: ' . $e->getMessage();
  }

  return implode(' | ', $messages);
}

/**
