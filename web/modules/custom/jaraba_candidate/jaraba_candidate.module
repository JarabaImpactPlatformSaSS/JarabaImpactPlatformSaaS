/**
 * Implements hook_page_attachments_alter().
 *
 * - Adjunta la librería modal-system a las rutas del módulo candidato.
 * - Adds Open Graph meta tags for public candidate profiles.
 * - Injects Schema.org Person JSON-LD for public profiles (GAP-SCHEMA-8).
 */
function jaraba_candidate_page_attachments_alter(array &$attachments): void {
  $route_match = \Drupal::routeMatch();
  $route = $route_match->getRouteName() ?: '';

  if (str_starts_with($route, 'jaraba_candidate.')) {
    $attachments['#attached']['library'][] = 'jaraba_candidate/modal-actions';
  }

  // Open Graph meta tags + Schema.org for public candidate profile.
  if ($route === 'jaraba_candidate.profile_view') {
    $profile = $route_match->getParameter('candidate_profile');
    if ($profile && $profile->isPublic()) {
      $title = $profile->getFullName() . ' - ' . ($profile->getHeadline() ?: t('Candidate Profile'));
      $description = mb_substr(strip_tags($profile->getSummary()), 0, 160);
      $url = \Drupal::request()->getSchemeAndHttpHost() . '/profile/' . $profile->id();

      $meta_tags = [
        ['og:title', $title],
        ['og:description', $description],
        ['og:type', 'profile'],
        ['og:url', $url],
        ['twitter:card', 'summary'],
        ['twitter:title', $title],
        ['twitter:description', $description],
      ];

      foreach ($meta_tags as [$property, $content]) {
        $tag = [
          '#tag' => 'meta',
          '#attributes' => [
            'property' => $property,
            'content' => $content,
          ],
        ];
        $attachments['#attached']['html_head'][] = [$tag, 'jaraba_cp_' . $property];
      }

      // Schema.org Person JSON-LD (GAP-SCHEMA-8).
      $schema = [
        '@context' => 'https://schema.org',
        '@type' => 'Person',
        'name' => $profile->getFullName(),
        'url' => $url,
      ];

      $headline = $profile->getHeadline();
      if ($headline) {
        $schema['jobTitle'] = $headline;
      }

      if ($description) {
        $schema['description'] = $description;
      }

      // Address from city + country.
      $city = $profile->get('city')->value ?? '';
      $country = $profile->get('country')->value ?? '';
      if ($city) {
        $address = [
          '@type' => 'PostalAddress',
          'addressLocality' => $city,
        ];
        if ($country) {
          $address['addressCountry'] = $country;
        }
        $schema['address'] = $address;
      }

      // sameAs: social/professional links.
      $sameAs = [];
      foreach (['linkedin_url', 'github_url', 'portfolio_url', 'website_url'] as $field) {
        if ($profile->hasField($field) && !$profile->get($field)->isEmpty()) {
          $sameAs[] = $profile->get($field)->value;
        }
      }
      if (!empty($sameAs)) {
        $schema['sameAs'] = $sameAs;
      }

      // Profile photo.
      if ($profile->hasField('photo') && !$profile->get('photo')->isEmpty()) {
        $file = $profile->get('photo')->entity;
        if ($file) {
          $schema['image'] = \Drupal::service('file_url_generator')
            ->generateAbsoluteString($file->getFileUri());
        }
      }

      // knowsAbout from experience level.
      $experienceLevel = $profile->get('experience_level')->value ?? '';
      if ($experienceLevel) {
        $schema['knowsAbout'] = $experienceLevel;
      }

      $attachments['#attached']['html_head'][] = [
        [
          '#type' => 'html_tag',
          '#tag' => 'script',
          '#attributes' => ['type' => 'application/ld+json'],
          '#value' => json_encode($schema, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE),
        ],
        'schema_org_person',
      ];
    }
  }
}

/**
 * Implements hook_entity_presave().
 *
 * Geocodes the candidate's location using OpenStreetMap/Nominatim.
 */
function jaraba_candidate_entity_presave(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'candidate_profile') {
    return;
  }

  // Check if city or country changed.
  $city = $entity->get('city')->value ?? '';
  $country = $entity->get('country')->value ?? '';

  if (empty($city) || empty($country)) {
    return;
  }

  // Skip if location already set and city/country haven't changed.
  $original = $entity->original ?? NULL;
  if ($original) {
    $originalCity = $original->get('city')->value ?? '';
    $originalCountry = $original->get('country')->value ?? '';
    $hasLocation = !$entity->get('location')->isEmpty();

    if ($hasLocation && $originalCity === $city && $originalCountry === $country) {
      return;
    }
  }

  // Map country codes to names for better geocoding.
  $countryNames = [
    'ES' => 'Spain',
    'PT' => 'Portugal',
    'FR' => 'France',
    'DE' => 'Germany',
    'IT' => 'Italy',
    'GB' => 'United Kingdom',
    'US' => 'United States',
    'MX' => 'Mexico',
    'AR' => 'Argentina',
    'CO' => 'Colombia',
    'CL' => 'Chile',
    'PE' => 'Peru',
    'BR' => 'Brazil',
  ];

  $countryName = $countryNames[$country] ?? $country;
  $address = "$city, $countryName";

  try {
    /** @var \Drupal\geocoder\GeocoderInterface $geocoder */
    $geocoder = \Drupal::service('geocoder');

    // Use OpenStreetMap/Nominatim provider (free, no API key needed).
    $result = $geocoder->geocode($address, ['nominatim']);

    if ($result && !$result->isEmpty()) {
      $coordinates = $result->first()->getCoordinates();
      $entity->set('location', [
        'lat' => $coordinates->getLatitude(),
        'lon' => $coordinates->getLongitude(),
      ]);

      \Drupal::logger('jaraba_candidate')->info(
        'Geocoded @address to @lat, @lon',
        [
          '@address' => $address,
          '@lat' => $coordinates->getLatitude(),
          '@lon' => $coordinates->getLongitude(),
        ]
      );
    }
  }
  catch (\Exception $e) {
    \Drupal::logger('jaraba_candidate')->warning(
      'Failed to geocode @address: @error',
      ['@address' => $address, '@error' => $e->getMessage()]
    );
  }
}

/**
 * Implements template_preprocess_HOOK() for candidate_profile.
 *
 * ENTITY-PREPROCESS-001: Extract primitives, resolve references,
 * generate photo URL. No entity objects in templates.
 */
function template_preprocess_candidate_profile(array &$variables): void {
  /** @var \Drupal\jaraba_candidate\Entity\CandidateProfile $entity */
  $entity = $variables['elements']['#candidate_profile'] ?? NULL;
  if (!$entity) {
    return;
  }

  $profile = [
    'id' => $entity->id(),
    'full_name' => method_exists($entity, 'getFullName') ? $entity->getFullName() : '',
    'headline' => $entity->get('headline')->value ?? '',
    'summary' => $entity->get('summary')->value ?? '',
    'email' => $entity->get('email')->value ?? '',
    'phone' => $entity->get('phone')->value ?? '',
    'city' => $entity->get('city')->value ?? '',
    'province' => $entity->get('province')->value ?? '',
    'country' => $entity->get('country')->value ?? '',
    'experience_years' => (int) ($entity->get('experience_years')->value ?? 0),
    'experience_level' => $entity->get('experience_level')->value ?? '',
    'education_level' => $entity->get('education_level')->value ?? '',
    'availability_status' => $entity->get('availability_status')->value ?? 'not_specified',
    'completion_percent' => (int) ($entity->get('completion_percent')->value ?? 0),
    'is_public' => (bool) ($entity->get('is_public')->value ?? FALSE),
    'is_verified' => (bool) ($entity->get('is_verified')->value ?? FALSE),
    'linkedin_url' => $entity->get('linkedin_url')->value ?? '',
    'github_url' => $entity->get('github_url')->value ?? '',
    'portfolio_url' => $entity->get('portfolio_url')->value ?? '',
    'website_url' => $entity->get('website_url')->value ?? '',
  ];

  // Photo URL.
  if ($entity->hasField('photo') && !$entity->get('photo')->isEmpty()) {
    $file = $entity->get('photo')->entity;
    if ($file) {
      $style = ImageStyle::load('thumbnail');
      $profile['photo_url'] = $style
        ? $style->buildUrl($file->getFileUri())
        : \Drupal::service('file_url_generator')->generateAbsoluteString($file->getFileUri());
    }
  }

  // Preferred job types.
  $profile['preferred_job_types'] = [];
  $jobTypes = $entity->get('preferred_job_types')->value ?? '';
  if (!empty($jobTypes)) {
    $profile['preferred_job_types'] = array_filter(explode(',', $jobTypes));
  }

  $variables['profile'] = $profile;
}

/**
 * Implements template_preprocess_HOOK() for candidate_experience.
 *
 * ENTITY-PREPROCESS-001: Extract work experience primitives.
 */
function template_preprocess_candidate_experience(array &$variables): void {
  /** @var \Drupal\Core\Entity\ContentEntityInterface $entity */
  $entity = $variables['elements']['#candidate_experience'] ?? NULL;
  if (!$entity) {
    return;
  }

  $variables['experience'] = [
    'id' => $entity->id(),
    'company_name' => $entity->get('company_name')->value ?? '',
    'job_title' => $entity->get('job_title')->value ?? '',
    'description' => $entity->get('description')->value ?? '',
    'start_date' => $entity->get('start_date')->value ?? '',
    'end_date' => $entity->get('end_date')->value ?? '',
    'is_current' => (bool) ($entity->get('is_current')->value ?? FALSE),
    'location' => $entity->get('location')->value ?? '',
  ];
}

/**
 * Prepares variables for candidate_education templates.
 *
 * @param array $variables
 *   An associative array containing entity data.
 */
function jaraba_candidate_preprocess_candidate_education(array &$variables): void {
  $entity = $variables['elements']['#candidate_education'] ?? NULL;
  if ($entity === NULL) {
    return;
  }
  $variables['candidate_education'] = $entity;
}

