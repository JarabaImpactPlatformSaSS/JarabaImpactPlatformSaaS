/**
 * Implements hook_entity_access() for LMS entities.
 */
function jaraba_lms_entity_access(EntityInterface $entity, string $operation, AccountInterface $account): \Drupal\Core\Access\AccessResultInterface {
  // Las entidades LMS usan permisos específicos definidos en permissions.yml
  return \Drupal\Core\Access\AccessResult::neutral();
}

/**
 * Implements hook_cron().
 */
function jaraba_lms_cron(): void {
  // Enviar recordatorios de cursos abandonados.
  try {
    $enrollment_service = \Drupal::service('jaraba_lms.enrollment');
    $enrollment_service->sendAbandonedCourseReminders();
  }
  catch (\Exception $e) {
    \Drupal::logger('jaraba_lms')->error('Enrollment cron error: @error', ['@error' => $e->getMessage()]);
  }

  // Procesar certificados pendientes.
  // @todo Implementar CertificationService::processQueuedCertificates()
  //       cuando exista la cola de certificados pendientes.
  try {
    if (\Drupal::hasService('jaraba_lms.certification')) {
      $certification_service = \Drupal::service('jaraba_lms.certification');
      if (method_exists($certification_service, 'processQueuedCertificates')) {
        $certification_service->processQueuedCertificates();
      }
    }
  }
  catch (\Exception $e) {
    \Drupal::logger('jaraba_lms')->error('Certification cron error: @error', ['@error' => $e->getMessage()]);
  }
}

/**
 * Implements hook_entity_update().
 *
 * Automatizaciones al actualizar entidades LMS:
 * - Emitir badge al completar curso (100%)
 * - Otorgar XP por completar curso
 */
function jaraba_lms_entity_update(EntityInterface $entity): void {
  $entity_type = $entity->getEntityTypeId();

  // Solo procesar enrollments
  if ($entity_type !== 'lms_enrollment') {
    return;
  }

  // Verificar si el progreso llegó a 100%
  if (!$entity->hasField('progress_percent')) {
    return;
  }

  $progress = (int) ($entity->get('progress_percent')->value ?? 0);
  $originalProgress = 0;

  // Obtener progreso anterior para detectar cambio
  if (isset($entity->original) && $entity->original->hasField('progress_percent')) {
    $originalProgress = (int) ($entity->original->get('progress_percent')->value ?? 0);
  }

  // Solo actuar si pasó de <100 a 100
  if ($progress >= 100 && $originalProgress < 100) {
    $userId = $entity->get('user_id')->target_id ?? NULL;
    $courseId = $entity->get('course_id')->target_id ?? NULL;

    if (!$userId || !$courseId) {
      return;
    }

    // 1. Emitir badge automáticamente
    _jaraba_lms_auto_issue_badge($userId, $courseId);

    // 2. Otorgar XP por completar curso
    _jaraba_lms_award_course_xp($userId);
  }
}

/**
 * Implements hook_entity_insert() for activity progress.
 *
 * Otorga XP al completar una lección.
 */
function jaraba_lms_entity_insert(EntityInterface $entity): void {
  $entity_type = $entity->getEntityTypeId();

  // Solo procesar activity_progress (lecciones completadas)
  if ($entity_type !== 'activity_progress') {
    return;
  }

  $userId = $entity->get('user_id')->target_id ?? NULL;
  if (!$userId) {
    return;
  }

  // Verificar si está completada
  $completed = $entity->get('completed')->value ?? FALSE;
  if ($completed) {
    _jaraba_lms_award_lesson_xp($userId);
  }
}

/**
 * Helper: Emitir badge al completar curso.
 */
function _jaraba_lms_auto_issue_badge(int $userId, int $courseId): void {
  try {
    if (!\Drupal::hasService('jaraba_lms.open_badge')) {
      return;
    }

    $badgeService = \Drupal::service('jaraba_lms.open_badge');

    // Verificar si ya tiene badge para este curso
    $existingBadges = $badgeService->getUserBadges($userId);
    foreach ($existingBadges as $badge) {
      if (($badge['course_id'] ?? 0) == $courseId) {
        return; // Ya tiene badge
      }
    }

    // Emitir nuevo badge
    $result = $badgeService->issueBadge($courseId, $userId);

    \Drupal::logger('jaraba_lms')->info(
      'Badge auto-emitido para usuario @user, curso @course',
      ['@user' => $userId, '@course' => $courseId]
    );
  }
  catch (\Exception $e) {
    \Drupal::logger('jaraba_lms')->error(
      'Error auto-emitiendo badge: @error',
      ['@error' => $e->getMessage()]
    );
  }
}

/**
 * Helper: Otorgar XP por completar curso.
 */
function _jaraba_lms_award_course_xp(int $userId): void {
  try {
    if (!\Drupal::hasService('jaraba_lms.gamification')) {
      return;
    }

    $gamification = \Drupal::service('jaraba_lms.gamification');
    $gamification->awardXP($userId, 'complete_course');

    \Drupal::logger('jaraba_lms')->info(
      'XP otorgado por curso completo a usuario @user',
      ['@user' => $userId]
    );
  }
  catch (\Exception $e) {
    \Drupal::logger('jaraba_lms')->warning(
      'Error otorgando XP curso: @error',
      ['@error' => $e->getMessage()]
    );
  }
}

/**
 * Helper: Otorgar XP por completar lección.
 */
function _jaraba_lms_award_lesson_xp(int $userId): void {
  try {
    if (!\Drupal::hasService('jaraba_lms.gamification')) {
      return;
    }

    $gamification = \Drupal::service('jaraba_lms.gamification');
    $gamification->awardXP($userId, 'complete_lesson');
  }
  catch (\Exception $e) {
    \Drupal::logger('jaraba_lms')->warning(
      'Error otorgando XP lección: @error',
      ['@error' => $e->getMessage()]
    );
  }
}

/**
 * Implements hook_preprocess_HOOK() for course_detail.
 *
 * Inyecta Schema.org Course JSON-LD automáticamente.
 */
function jaraba_lms_preprocess_course_detail(array &$variables): void {
  $course = $variables['course'] ?? NULL;
  if (!$course) {
    return;
  }

  // Preparar datos para Schema.org.
  $courseData = [
    'title' => $course->label() ?? '',
    'description' => $course->get('description')->value ?? '',
  ];

  // Precio.
  if ($course->hasField('price') && !$course->get('price')->isEmpty()) {
    $courseData['price'] = (float) $course->get('price')->value;
  }

  // Fechas de instancia.
  if ($course->hasField('start_date') && !$course->get('start_date')->isEmpty()) {
    $courseData['start_date'] = $course->get('start_date')->value;
  }
  if ($course->hasField('end_date') && !$course->get('end_date')->isEmpty()) {
    $courseData['end_date'] = $course->get('end_date')->value;
  }

  // Duración.
  if ($course->hasField('duration_hours') && !$course->get('duration_hours')->isEmpty()) {
    $courseData['duration_hours'] = (int) $course->get('duration_hours')->value;
  }

  // Modo (online, presencial, híbrido).
  if ($course->hasField('mode') && !$course->get('mode')->isEmpty()) {
    $courseData['mode'] = $course->get('mode')->value;
  }

  // Nivel educativo.
  if ($course->hasField('level') && !$course->get('level')->isEmpty()) {
    $courseData['level'] = $course->get('level')->value;
  }

  // Skills que enseña.
  if ($course->hasField('skills') && !$course->get('skills')->isEmpty()) {
    $skills = [];
    foreach ($course->get('skills') as $skill) {
      $skills[] = $skill->entity ? $skill->entity->label() : $skill->value;
    }
    $courseData['skills'] = $skills;
  }

  // Instructor.
  $instructor = $variables['instructor'] ?? NULL;
  if ($instructor) {
    $courseData['instructor_name'] = $instructor->getDisplayName();
  }

  // Reviews agregados.
  $reviews = $variables['reviews'] ?? [];
  if (!empty($reviews)) {
    $totalRating = 0;
    foreach ($reviews as $review) {
      $totalRating += $review['rating'] ?? 0;
    }
    $courseData['review_count'] = count($reviews);
    $courseData['rating'] = round($totalRating / count($reviews), 1);
  }

  // Datos del tenant/proveedor.
  $tenant = [];
  try {
    if (\Drupal::hasService('jaraba_page_builder.tenant_resolver')) {
      $tenantEntity = \Drupal::service('jaraba_page_builder.tenant_resolver')->getCurrentTenant();
      if ($tenantEntity) {
        $tenant['name'] = $tenantEntity->label();
        if ($tenantEntity->hasField('field_website')) {
          $tenant['url'] = $tenantEntity->get('field_website')->value ?? '';
        }
      }
    }
  }
  catch (\Exception $e) {
    // Usar valores por defecto.
  }

  // Generar Schema.org JSON-LD.
  try {
    if (\Drupal::hasService('jaraba_page_builder.schema_org')) {
      $schemaService = \Drupal::service('jaraba_page_builder.schema_org');
      $jsonLd = $schemaService->generateCourseSchema($courseData, $tenant);
      
      if (!empty($jsonLd)) {
        $variables['schema_org_json_ld'] = $schemaService->wrapInScriptTag($jsonLd);
      }
    }
  }
  catch (\Exception $e) {
    \Drupal::logger('jaraba_lms')->warning('Error generating Course schema: @error', [
      '@error' => $e->getMessage(),
    ]);
  }
}

/**
 * Implements hook_mail().
 */
function jaraba_lms_mail($key, &$message, $params): void {
  switch ($key) {
    case 'enrollment_created':
      $message['subject'] = t('Inscripción confirmada: @course', [
        '@course' => $params['course_name'],
      ]);
      $message['body'][] = t('Hola @name,', ['@name' => $params['user_name']]);
      $message['body'][] = t('Te has inscrito correctamente en el curso "@course".', [
        '@course' => $params['course_name'],
      ]);
      $message['body'][] = t('Puedes acceder al contenido del curso desde tu panel de formación.');
      break;

    case 'enrollment_completed':
      $message['subject'] = t('¡Felicidades! Has completado: @course', [
        '@course' => $params['course_name'],
      ]);
      $message['body'][] = t('Hola @name,', ['@name' => $params['user_name']]);
      $message['body'][] = t('¡Enhorabuena! Has completado el curso "@course" al 100%.', [
        '@course' => $params['course_name'],
      ]);
      $message['body'][] = t('Tu certificado de finalización está disponible en tu perfil.');
      break;

    case 'enrollment_reminder':
      $message['subject'] = t('¿Continúas con tu curso? @course', [
        '@course' => $params['course_name'] ?? '',
      ]);
      $message['body'][] = t('Hola @name,', ['@name' => $params['user_name']]);
      $message['body'][] = t('Hemos notado que llevas un tiempo sin acceder al curso "@course". Tu progreso actual es del @progress%.', [
        '@course' => $params['course_name'] ?? '',
        '@progress' => $params['progress'] ?? 0,
      ]);
      $message['body'][] = t('¡No pierdas el ritmo! Accede ahora y continúa donde lo dejaste.');
      break;
  }

  // Footer común.
  if (!empty($message['body'])) {
    $message['body'][] = '';
    $message['body'][] = '---';
    $message['body'][] = t('Jaraba Impact Platform - Formación Digital');
  }
}

/**
 * Implements template_preprocess_HOOK() for lms_course.
 *
 * ENTITY-PREPROCESS-001: Extract primitives, resolve references,
 * generate responsive image URLs. No entity objects in templates.
 */
function template_preprocess_lms_course(array &$variables): void {
  /** @var \Drupal\jaraba_lms\Entity\Course $entity */
  $entity = $variables['elements']['#lms_course'] ?? NULL;
  if (!$entity) {
    return;
  }

  $course = [
    'id' => $entity->id(),
    'title' => $entity->label() ?? '',
    'description' => $entity->get('description')->value ?? '',
    'summary' => $entity->get('summary')->value ?? '',
    'duration_minutes' => (int) ($entity->get('duration_minutes')->value ?? 0),
    'difficulty_level' => $entity->get('difficulty_level')->value ?? 'beginner',
    'is_published' => (bool) ($entity->get('is_published')->value ?? FALSE),
    'is_premium' => (bool) ($entity->get('is_premium')->value ?? FALSE),
    'price' => $entity->get('price')->value ?? '0.00',
    'currency' => $entity->get('currency')->value ?? 'EUR',
    'completion_credits' => (int) ($entity->get('completion_credits')->value ?? 0),
    'machine_name' => $entity->get('machine_name')->value ?? '',
  ];

  // Duration formatted.
  $hours = floor($course['duration_minutes'] / 60);
  $mins = $course['duration_minutes'] % 60;
  $course['duration_formatted'] = $hours > 0
    ? $hours . 'h ' . ($mins > 0 ? $mins . 'min' : '')
    : $mins . 'min';

  // Author/instructor.
  if ($entity->hasField('author_id') && !$entity->get('author_id')->isEmpty()) {
    $author = $entity->get('author_id')->entity;
    if ($author) {
      $course['instructor_name'] = $author->getDisplayName();
    }
  }

  // Category.
  if ($entity->hasField('field_category') && !$entity->get('field_category')->isEmpty()) {
    $category = $entity->get('field_category')->entity;
    if ($category) {
      $course['category_name'] = $category->label() ?? '';
    }
  }

  // Thumbnail image.
  if ($entity->hasField('thumbnail') && !$entity->get('thumbnail')->isEmpty()) {
    $file = $entity->get('thumbnail')->entity;
    if ($file) {
      $style = \Drupal\image\Entity\ImageStyle::load('medium');
      $course['thumbnail_url'] = $style
        ? $style->buildUrl($file->getFileUri())
        : \Drupal::service('file_url_generator')->generateAbsoluteString($file->getFileUri());
    }
  }

  // Prerequisites.
  $course['prerequisites'] = [];
  $prereqJson = $entity->get('prerequisites')->value ?? '';
  if (!empty($prereqJson)) {
    $prereqIds = json_decode($prereqJson, TRUE);
    if (is_array($prereqIds)) {
      $course['prerequisites'] = $prereqIds;
    }
  }

  $variables['course'] = $course;
}

/**
 * Implements template_preprocess_HOOK() for lms_lesson.
 *
 * ENTITY-PREPROCESS-001: Extract primitives for lesson templates.
 */
function template_preprocess_lms_lesson(array &$variables): void {
  /** @var \Drupal\jaraba_lms\Entity\Lesson $entity */
  $entity = $variables['elements']['#lms_lesson'] ?? NULL;
  if (!$entity) {
    return;
  }

  $variables['lesson'] = [
    'id' => $entity->id(),
    'title' => $entity->label() ?? '',
    'lesson_type' => $entity->get('lesson_type')->value ?? 'text',
    'content' => $entity->get('content')->value ?? '',
    'video_url' => $entity->get('video_url')->value ?? '',
    'video_provider' => $entity->get('video_provider')->value ?? '',
    'estimated_duration' => (int) ($entity->get('estimated_duration')->value ?? 10),
    'completion_threshold' => (int) ($entity->get('completion_threshold')->value ?? 90),
    'weight' => (int) ($entity->get('weight')->value ?? 0),
    'is_video' => ($entity->get('lesson_type')->value ?? '') === 'video',
    'is_h5p' => ($entity->get('lesson_type')->value ?? '') === 'h5p',
    'h5p_content_id' => (int) ($entity->get('h5p_content_id')->value ?? 0),
  ];

  // YouTube video ID extraction.
  if ($variables['lesson']['is_video'] && !empty($variables['lesson']['video_url'])) {
    if (method_exists($entity, 'getYouTubeVideoId')) {
      $variables['lesson']['youtube_id'] = $entity->getYouTubeVideoId();
    }
  }

  // Formatted duration.
  $mins = $variables['lesson']['estimated_duration'];
  $variables['lesson']['duration_formatted'] = $mins . ' min';
}


/**
 * Prepares variables for course_review templates.
 *
 * @param array $variables
 *   An associative array containing entity data.
 */
function jaraba_lms_preprocess_course_review(array &$variables): void {
  $entity = $variables['elements']['#course_review'] ?? NULL;
  if ($entity === NULL) {
    return;
  }
  $variables['course_review'] = $entity;
}

/**
 * Prepares variables for lms_enrollment templates.
 *
 * @param array $variables
 *   An associative array containing entity data.
 */
function jaraba_lms_preprocess_lms_enrollment(array &$variables): void {
  $entity = $variables['elements']['#lms_enrollment'] ?? NULL;
  if ($entity === NULL) {
    return;
  }
  $variables['lms_enrollment'] = $entity;
}
