        ->setTargetEntityTypeId('addon')
        ->setLabel(t('Descuento del Bundle (%)'))
        ->setDescription(t('Porcentaje de descuento aplicado en el bundle.'))
        ->setDefaultValue(0)
        ->setDisplayOptions('form', ['weight' => 25])
        ->setDisplayConfigurable('form', TRUE)
        ->setDisplayConfigurable('view', TRUE),
    ];

    foreach ($new_fields as $field_name => $field_definition) {
      $existing = $update_manager->getFieldStorageDefinition($field_name, 'addon');
      if (!$existing) {
        $update_manager->installFieldStorageDefinition(
          $field_name,
