    }
  }
  catch (\Throwable $e) {
    $messages[] = 'Field install error: ' . $e->getMessage();
  }

  // --- Part B: Seed 9 Marketing Add-ons (Doc 158 §3.1-3.2) ---
  try {
    $storage = \Drupal::entityTypeManager()->getStorage('addon');

    $marketing_addons = [
