{#
/**
 * @file
 * Template: Catalogo de Add-ons (/addons).
 *
 * ESTRUCTURA:
 * Plantilla que renderiza el catalogo publico de add-ons con filtros por tipo,
 * seccion hero para verticales componibles, y grid de tarjetas.
 * Sigue el patron BEM ej-addons-* y usa CSS variables con var(--ej-*, $fallback).
 *
 * VARIABLES:
 * - addons: Array de add-ons con keys: id, label, description, addon_type,
 *     addon_type_label, price_monthly, price_yearly, is_subscribed, vertical_ref.
 * - addon_types: Array asociativo de tipos validos (key => label).
 * - active_type: Tipo activo actual para filtro ('' = todos).
 * - tenant_subscriptions: Array de suscripciones del tenant actual.
 *
 * RELACIONES:
 * - addons-catalog.html.twig <- AddonCatalogController::catalog() (renderizado por)
 * - addons-catalog.html.twig <- jaraba_addons.module hook_theme (registrado en)
 * - addons-catalog.html.twig <- addons-catalog.css (estilizado por)
 * - addons-catalog.html.twig <- addon-catalog.js (interactividad por)
 *
 * CSS-VAR-ALL-COLORS-001: Todos los colores via var(--ej-*, fallback).
 * ICON-CONVENTION-001: jaraba_icon() duotone, NO emojis.
 * i18n: Todos los textos en {% trans %} bloques.
 * ZERO-REGION-001: Sin CSS inline, sin regions Drupal.
 */
#}

<div class="ej-addons-catalog">

  {# ===== Hero del catalogo ===== #}
  <header class="ej-addons-catalog__header">
    <h1 class="ej-addons-catalog__title">
      {% trans %}Marketplace{% endtrans %}
    </h1>
    <p class="ej-addons-catalog__subtitle">
      {% trans %}Amplifica tu plataforma con verticales adicionales, funcionalidades premium, almacenamiento extra y soporte avanzado.{% endtrans %}
    </p>
  </header>

  {# ===== Filtros por tipo (chips) ===== #}
  <nav class="ej-addons-catalog__filters" aria-label="{% trans %}Filtrar por tipo de add-on{% endtrans %}">
    <a href="{{ path('jaraba_addons.catalog') }}"
       class="ej-addons-catalog__filter-chip {{ active_type == '' ? 'ej-addons-catalog__filter-chip--active' : '' }}"
       data-type="">
      {% trans %}Todos{% endtrans %}
    </a>
    {% for type_key, type_label in addon_types %}
      <a href="{{ path('jaraba_addons.catalog', {'type': type_key}) }}"
         class="ej-addons-catalog__filter-chip ej-addons-catalog__filter-chip--{{ type_key }} {{ active_type == type_key ? 'ej-addons-catalog__filter-chip--active' : '' }}"
         data-type="{{ type_key }}">
        {{ type_label }}
      </a>
    {% endfor %}
  </nav>

  {# ===== Seccion destacada de verticales (cuando se muestran todos o filtro = vertical) ===== #}
  {% set vertical_addons = [] %}
  {% set other_addons = [] %}
  {% for addon in addons %}
    {% if addon.addon_type == 'vertical' %}
      {% set vertical_addons = vertical_addons|merge([addon]) %}
    {% else %}
      {% set other_addons = other_addons|merge([addon]) %}
    {% endif %}
  {% endfor %}

  {% if vertical_addons|length > 0 %}
    <section class="ej-addons-catalog__verticals-section" aria-label="{% trans %}Verticales disponibles{% endtrans %}">
      <h2 class="ej-addons-catalog__section-title">
        {{ jaraba_icon('ui', 'grid', { variant: 'duotone', color: 'azul-corporativo', size: '20px' }) }}
        {% trans %}Verticales Componibles{% endtrans %}
      </h2>
      <p class="ej-addons-catalog__section-desc">
        {% trans %}Anade nuevos verticales de negocio a tu cuenta. Cada vertical incluye su propio portal, herramientas especializadas e inteligencia artificial.{% endtrans %}
      </p>
      <div class="ej-addons-catalog__grid ej-addons-catalog__grid--verticals">
        {% for addon in vertical_addons %}
          <article class="ej-addons-card ej-addons-card--vertical"
                   data-addon-id="{{ addon.id }}"
                   data-addon-type="vertical">

            <div class="ej-addons-card__header">
              <span class="ej-addons-card__type-badge ej-addons-card__type-badge--vertical">
                {{ addon.addon_type_label }}
              </span>
              {% if addon.is_subscribed %}
                <span class="ej-addons-card__subscribed-badge">
                  {% trans %}Activo{% endtrans %}
                </span>
              {% endif %}
            </div>

            <div class="ej-addons-card__body">
              <h3 class="ej-addons-card__name">{{ addon.label }}</h3>
              <p class="ej-addons-card__description">
                {{ addon.description|striptags|length > 160 ? addon.description|striptags|slice(0, 160) ~ '...' : addon.description|striptags }}
              </p>
            </div>

            <div class="ej-addons-card__footer">
              <div class="ej-addons-card__price">
                <span class="ej-addons-card__price-amount">
                  {{ addon.price_monthly|number_format(2, ',', '.') }} &euro;
                </span>
                <span class="ej-addons-card__price-cycle">
                  /{% trans %}mes{% endtrans %}
                </span>
              </div>
              <a href="{{ path('jaraba_addons.catalog.detail', {'addon_id': addon.id}) }}"
                 class="ej-addons-card__cta">
                {% if addon.is_subscribed %}
                  {% trans %}Ver Detalles{% endtrans %}
                {% else %}
                  {% trans %}Activar Vertical{% endtrans %}
                {% endif %}
              </a>
            </div>

          </article>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {# ===== Grid de add-ons no-verticales ===== #}
  {% set display_addons = active_type == 'vertical' ? [] : other_addons %}
  {% if display_addons|length > 0 %}
    {% if vertical_addons|length > 0 %}
      <h2 class="ej-addons-catalog__section-title">
        {{ jaraba_icon('ui', 'package', { variant: 'duotone', color: 'azul-corporativo', size: '20px' }) }}
        {% trans %}Add-ons{% endtrans %}
      </h2>
    {% endif %}
    <div class="ej-addons-catalog__grid">
      {% for addon in display_addons %}
        <article class="ej-addons-card ej-addons-card--{{ addon.addon_type }}"
                 data-addon-id="{{ addon.id }}"
                 data-addon-type="{{ addon.addon_type }}">

          <div class="ej-addons-card__header">
            <span class="ej-addons-card__type-badge ej-addons-card__type-badge--{{ addon.addon_type }}">
              {{ addon.addon_type_label }}
            </span>
            {% if addon.is_subscribed %}
              <span class="ej-addons-card__subscribed-badge">
                {% trans %}Activo{% endtrans %}
              </span>
            {% endif %}
          </div>

          <div class="ej-addons-card__body">
            <h3 class="ej-addons-card__name">{{ addon.label }}</h3>
            <p class="ej-addons-card__description">
              {{ addon.description|striptags|length > 120 ? addon.description|striptags|slice(0, 120) ~ '...' : addon.description|striptags }}
            </p>
          </div>

          <div class="ej-addons-card__footer">
            <div class="ej-addons-card__price">
              <span class="ej-addons-card__price-amount">
                {{ addon.price_monthly|number_format(2, ',', '.') }} &euro;
              </span>
              <span class="ej-addons-card__price-cycle">
                /{% trans %}mes{% endtrans %}
              </span>
            </div>
            <a href="{{ path('jaraba_addons.catalog.detail', {'addon_id': addon.id}) }}"
               class="ej-addons-card__cta">
              {% if addon.is_subscribed %}
                {% trans %}Ver Detalles{% endtrans %}
              {% else %}
                {% trans %}Mas Información{% endtrans %}
              {% endif %}
            </a>
          </div>

        </article>
      {% endfor %}
    </div>
  {% endif %}

  {# ===== Estado vacio ===== #}
  {% if addons|length == 0 %}
    <div class="ej-addons-catalog__empty">
      <div class="ej-addons-catalog__empty-icon" aria-hidden="true">
        {{ jaraba_icon('ui', 'package', { variant: 'duotone', color: 'neutral', size: '64px' }) }}
      </div>
      <h3 class="ej-addons-catalog__empty-title">
        {% trans %}No hay add-ons disponibles{% endtrans %}
      </h3>
      <p class="ej-addons-catalog__empty-message">
        {% if active_type %}
          {% trans %}No se encontraron add-ons del tipo seleccionado. Prueba con otro filtro.{% endtrans %}
        {% else %}
          {% trans %}No hay add-ons disponibles en este momento. Vuelve a consultar mas adelante.{% endtrans %}
        {% endif %}
      </p>
    </div>
  {% endif %}

</div>
