{#
/**
 * @file
 * WhatsApp conversation list item template.
 *
 * Variables:
 * - conversation: WaConversation entity.
 * - phone: Phone number.
 * - lead_type: Lead classification.
 * - status: Conversation status.
 * - message_count: Number of messages.
 */
#}
<div class="wa-list-item wa-list-item--{{ status|default('active') }}">
  <div class="wa-list-item__info">
    <span class="wa-list-item__phone">{{ phone|default('') }}</span>
    <span class="wa-badge wa-badge--{{ lead_type|default('otro') }}">{{ lead_type|default('sin_clasificar') }}</span>
  </div>
  <div class="wa-list-item__meta">
    <span class="wa-list-item__count">{{ message_count|default(0) }} {% trans %}msgs{% endtrans %}</span>
    <span class="wa-badge wa-badge--{{ status|default('active') }}">{{ status|default('active') }}</span>
  </div>
  {% if conversation is defined and conversation is not null %}
    <a href="{{ path('jaraba_whatsapp.panel.conversation', {wa_conversation: conversation.id()}) }}" class="wa-list-item__link">
      {% trans %}Ver{% endtrans %}
    </a>
  {% endif %}
</div>
