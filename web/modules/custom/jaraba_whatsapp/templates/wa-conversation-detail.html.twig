{#
/**
 * @file
 * WhatsApp conversation detail template.
 *
 * Variables:
 * - conversation: WaConversation entity.
 * - messages: Array of WaMessage entities.
 * - phone: Phone number string.
 * - lead_type: Lead classification.
 * - status: Conversation status.
 */
#}
<div class="wa-conversation">
  <div class="wa-conversation__header">
    <h2>{% trans %}Conversación{% endtrans %} #{{ conversation.id }}</h2>
    <div class="wa-conversation__meta">
      <span class="wa-badge wa-badge--{{ status }}">{{ status }}</span>
      <span class="wa-badge wa-badge--lead">{{ lead_type }}</span>
      <span class="wa-conversation__phone">{{ phone }}</span>
    </div>
  </div>

  <div class="wa-conversation__messages" id="wa-messages">
    {% for message in messages %}
      <div class="wa-message wa-message--{{ message.getDirection() }}">
        <div class="wa-message__bubble">
          <span class="wa-message__sender">
            {% if message.getSenderType() == 'user' %}
              {% trans %}Usuario{% endtrans %}
            {% elseif message.getSenderType() == 'agent_ia' %}
              {% trans %}Agente IA{% endtrans %}
            {% elseif message.getSenderType() == 'agent_human' %}
              {% trans %}Agente Humano{% endtrans %}
            {% else %}
              {% trans %}Sistema{% endtrans %}
            {% endif %}
          </span>
          <p class="wa-message__body">{{ message.getBody() }}</p>
        </div>
      </div>
    {% endfor %}
  </div>

  {% if status == 'escalated' or status == 'active' %}
    <div class="wa-conversation__input">
      <form id="wa-send-form" data-conversation-id="{{ conversation.id }}">
        <input type="text"
               id="wa-message-input"
               placeholder="{{ 'Escribe un mensaje...'|trans }}"
               autocomplete="off" />
        <button type="submit" class="button button--primary">
          {% trans %}Enviar{% endtrans %}
        </button>
      </form>
    </div>
  {% endif %}
</div>
