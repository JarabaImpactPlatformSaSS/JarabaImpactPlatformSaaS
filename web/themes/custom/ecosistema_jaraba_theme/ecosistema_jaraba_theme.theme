  $form['metasite']['hero_content']['hero_headline'] = [
    '#type' => 'textfield',
    '#title' => t('Headline (H1)'),
    '#default_value' => $config->get('hero_headline') ?: '',
    '#placeholder' => t('Empleo, emprendimiento y digitalización — impulsados por IA'),
    '#maxlength' => 120,
  ];
  $form['metasite']['hero_content']['hero_subtitle'] = [
    '#type' => 'textarea',
    '#title' => t('Subtítulo'),
    '#default_value' => $config->get('hero_subtitle') ?: '',
    '#rows' => 2,
    '#placeholder' => t('Empleabilidad · Emprendimiento · AgroConecta · ComercioConecta...'),
  ];
  $form['metasite']['hero_content']['hero_cta_primary_text'] = [
    '#type' => 'textfield',
    '#title' => t('CTA Primario Texto'),
    '#default_value' => $config->get('hero_cta_primary_text') ?: '',
    '#placeholder' => t('Empezar gratis'),
  ];
  $form['metasite']['hero_content']['hero_cta_secondary_text'] = [
    '#type' => 'textfield',
    '#title' => t('CTA Secundario Texto'),
    '#default_value' => $config->get('hero_cta_secondary_text') ?: '',
    '#placeholder' => t('Conoce el método'),
  ];
  $form['metasite']['hero_content']['hero_cta_secondary_url'] = [
    '#type' => 'textfield',
    '#title' => t('CTA Secundario URL'),
    '#default_value' => $config->get('hero_cta_secondary_url') ?: '/metodo',
    '#description' => t('Ruta interna del botón secundario del hero.'),
  ];

  // --- Métricas de Social Proof ---
  $form['metasite']['metrics'] = [
    '#type' => 'fieldset',
    '#title' => t('Métricas de Impacto (Social Proof)'),
    '#description' => t('Métricas que se muestran en la sección de estadísticas. Dejar vacío para usar los datos verificables por defecto.'),
  ];
  for ($i = 1; $i <= 4; $i++) {
    $form['metasite']['metrics']["metric_{$i}"] = [
      '#type' => 'fieldset',
      '#title' => t('Métrica @num', ['@num' => $i]),
      '#attributes' => ['class' => ['container-inline']],
    ];
    $form['metasite']['metrics']["metric_{$i}"]["stat_value_{$i}"] = [
      '#type' => 'textfield',
      '#title' => t('Valor'),
      '#default_value' => $config->get("stat_value_{$i}") ?: '',
      '#size' => 10,
      '#placeholder' => t('7'),
    ];
    $form['metasite']['metrics']["metric_{$i}"]["stat_suffix_{$i}"] = [
      '#type' => 'textfield',
      '#title' => t('Sufijo'),
      '#default_value' => $config->get("stat_suffix_{$i}") ?: '',
      '#size' => 5,
      '#placeholder' => '+',
    ];
    $form['metasite']['metrics']["metric_{$i}"]["stat_label_{$i}"] = [
      '#type' => 'textfield',
      '#title' => t('Etiqueta'),
      '#default_value' => $config->get("stat_label_{$i}") ?: '',
      '#size' => 30,
      '#placeholder' => t('Verticales activas'),
    ];
  }

  // =========================================================================
  // TAB 16: PLG / TEXTOS DE CONVERSIÓN
  // =========================================================================
  $form['plg_texts'] = [
    '#type' => 'details',
    '#title' => _ecosistema_jaraba_theme_tab_title('megaphone', t('PLG / Textos de conversión'), '#FF8C42'),
    '#group' => 'jaraba_tabs',
    '#weight' => -10,
  ];

  $form['plg_texts']['plg_free_plan_note'] = [
    '#type' => 'textfield',
    '#title' => t('Nota plan gratuito (pricing preview)'),
    '#description' => t('Texto que aparece bajo el pricing en landings. Ej: "Plan gratuito disponible. Sin tarjeta de crédito."'),
    '#default_value' => $config->get('plg_free_plan_note') ?: 'Plan gratuito disponible. Sin tarjeta de crédito.',
    '#maxlength' => 255,
  ];

  $form['plg_texts']['plg_cta_subtitle'] = [
    '#type' => 'textfield',
    '#title' => t('Subtítulo CTA final'),
    '#description' => t('Texto bajo el botón CTA final de landings. Ej: "Sin tarjeta de crédito. Empieza gratis."'),
    '#default_value' => $config->get('plg_cta_subtitle') ?: 'Sin tarjeta de crédito. Empieza gratis.',
    '#maxlength' => 255,
  ];

  $form['plg_texts']['plg_guarantee_text'] = [
    '#type' => 'textfield',
    '#title' => t('Texto de garantía (checkout/pricing)'),
    '#description' => t('Texto de confianza en páginas de precios. Ej: "Sin tarjeta de crédito. Sin permanencia. Cancela cuando quieras."'),
    '#default_value' => $config->get('plg_guarantee_text') ?: 'Sin tarjeta de crédito. Sin permanencia. Cancela cuando quieras.',
    '#maxlength' => 255,
  ];

  $form['plg_texts']['plg_register_subtitle'] = [
    '#type' => 'textfield',
    '#title' => t('Subtítulo registro'),
    '#description' => t('Texto bajo formularios de registro. Ej: "Crea tu cuenta gratis en menos de 2 minutos. Sin tarjeta de crédito."'),
    '#default_value' => $config->get('plg_register_subtitle') ?: 'Crea tu cuenta gratis en menos de 2 minutos. Sin tarjeta de crédito.',
    '#maxlength' => 255,
  ];

  $form['plg_texts']['plg_annual_discount_percent'] = [
    '#type' => 'number',
    '#title' => t('Descuento anual (%)'),
    '#description' => t('Porcentaje de descuento para planes anuales. Se muestra en el badge del toggle mensual/anual y en textos marketing. ANNUAL-DISCOUNT-001.'),
    '#default_value' => $config->get('plg_annual_discount_percent') ?: 20,
    '#min' => 0,
    '#max' => 50,
    '#step' => 1,
  ];

  $form['plg_texts']['plg_annual_discount_message'] = [
    '#type' => 'textfield',
    '#title' => t('Mensaje descuento anual'),
    '#description' => t('Texto marketing para el descuento anual. Ej: "Ahorra 2 meses con el plan anual".'),
    '#default_value' => $config->get('plg_annual_discount_message') ?: 'Ahorra 2 meses con el plan anual',
    '#maxlength' => 255,
  ];

  $form['plg_texts']['plg_tax_disclaimer'] = [
    '#type' => 'textarea',
    '#title' => t('Aviso fiscal (pricing)'),
    '#description' => t('Texto legal sobre IVA/IGIC/IPSI que aparece en las paginas de precios. GAP-M01: LSSI-CE Art. 10.'),
    '#default_value' => $config->get('plg_tax_disclaimer') ?: 'Todos los precios se muestran en EUR sin IVA. El IVA aplicable (21% en España peninsular) se calculará y desglosará en el proceso de contratación según la normativa vigente. Para Canarias, Ceuta y Melilla se aplican los impuestos indirectos correspondientes (IGIC/IPSI).',
    '#rows' => 3,
  ];

  // NO-HARDCODE-PRICE-001: FAQs editables desde UI.
  $form['plg_texts']['plg_pricing_faq'] = [
    '#type' => 'textarea',
    '#title' => t('FAQs página de precios (JSON)'),
    '#description' => t('Array JSON con preguntas frecuentes. Formato: [{"question":"...","answer":"..."}]. Se muestran en /planes y /planes/{vertical}. Dejar vacío para usar las FAQs por defecto.'),
    '#default_value' => $config->get('plg_pricing_faq') ?: '',
    '#rows' => 8,
    '#attributes' => ['style' => 'font-family: monospace; font-size: 12px;'],
  ];

  // NO-HARDCODE-PRICE-001: Value propositions per vertical (pricing page subtitle).
  $verticalKeys = ['empleabilidad', 'emprendimiento', 'comercioconecta', 'agroconecta', 'jarabalex', 'serviciosconecta', 'formacion', 'andalucia_ei'];
  $form['plg_texts']['plg_vp_section'] = [
    '#type' => 'details',
    '#title' => t('Propuestas de valor por vertical (página de precios)'),
    '#description' => t('Texto que aparece debajo del título "Planes {Vertical}" explicando qué hace el vertical. Si se deja vacío, se usa el texto por defecto del código o la descripción de la entidad Vertical.'),
    '#open' => FALSE,
  ];
  foreach ($verticalKeys as $vk) {
    $form['plg_texts']['plg_vp_section']['plg_vp_' . $vk] = [
      '#type' => 'textarea',
      '#title' => ucfirst(str_replace('_', ' ', $vk)),
      '#default_value' => $config->get('plg_vp_' . $vk) ?: '',
      '#rows' => 2,
      '#maxlength' => 500,
    ];
  }

  // Social proof para pricing (testimonios, logos, estadisticas).
  $form['plg_texts']['plg_social_proof_section'] = [
    '#type' => 'details',
    '#title' => t('Social proof — Paginas de precios'),
    '#description' => t('Datos de confianza que aparecen en /planes. JSON arrays. Si se dejan vacios, se usan datos del sistema de resenas o valores por defecto.'),
    '#open' => FALSE,
  ];

  $form['plg_texts']['plg_social_proof_section']['plg_social_proof_stats'] = [
    '#type' => 'textarea',
    '#title' => t('Estadisticas (JSON)'),
    '#description' => t('Formato: [{"value":"500+","label":"empresas"},{"value":"98%","label":"satisfaccion"}]'),
    '#default_value' => $config->get('plg_social_proof_stats') ?: '',
    '#rows' => 3,
    '#attributes' => ['style' => 'font-family: monospace; font-size: 12px;'],
  ];

  $form['plg_texts']['plg_social_proof_section']['plg_social_proof_logos'] = [
    '#type' => 'textarea',
    '#title' => t('Logos de clientes (JSON)'),
    '#description' => t('Formato: [{"url":"/sites/default/files/logo1.png","alt":"Empresa X"}]'),
    '#default_value' => $config->get('plg_social_proof_logos') ?: '',
    '#rows' => 3,
    '#attributes' => ['style' => 'font-family: monospace; font-size: 12px;'],
  ];

  $form['plg_texts']['plg_social_proof_section']['plg_social_proof_testimonials'] = [
    '#type' => 'textarea',
    '#title' => t('Testimonios (JSON)'),
    '#description' => t('Formato: [{"quote":"...","name":"Ana Garcia","role":"CEO","company":"ACME","avatar_url":"/path/to/photo.jpg"}]'),
    '#default_value' => $config->get('plg_social_proof_testimonials') ?: '',
    '#rows' => 6,
    '#attributes' => ['style' => 'font-family: monospace; font-size: 12px;'],
  ];
}

/**
 * Helper: Obtiene las configuraciones base del tema para inyectar en templates.
 */
/**
 * Normaliza las alternativas del quiz desde el campo map de Drupal.
 *
 * El campo 'map' solo almacena un mapa plano (no array de mapas).
 * Esta función detecta si es un mapa plano y lo envuelve en array.
 */
function _ecosistema_jaraba_theme_normalize_quiz_alternatives($result): array {
  $raw = $result->get('alternative_verticals')->first()?->getValue() ?? [];
  if (empty($raw)) {
    return [];
  }
  // Si tiene 'id' como key directa, es un mapa plano (1 alternativa).
  if (isset($raw['id'])) {
    return [$raw];
  }
  // Si es array indexado de mapas, devolver tal cual.
  return array_values($raw);
}

function _ecosistema_jaraba_theme_get_base_settings($config) {
  return [
    'header_layout' => $config->get('header_layout') ?: 'classic',
    'footer_layout' => $config->get('footer_layout') ?: 'standard',
    'header_sticky' => $config->get('header_sticky') ?? TRUE,
    'enable_header_cta' => $config->get('enable_header_cta') ?? FALSE,
    'header_cta_text' => $config->get('header_cta_text') ?: t('Empezar'),
    'header_cta_url' => $config->get('header_cta_url') ?: '/user/register',
    'enable_footer' => $config->get('enable_footer') ?? TRUE,
    'footer_copyright' => str_replace('[year]', date('Y'), $config->get('footer_copyright') ?: '© [year] Jaraba Impact Platform'),
    'footer_show_powered_by' => $config->get('footer_show_powered_by') ?? TRUE,
    'footer_powered_text' => $config->get('footer_powered_text') ?: 'Jaraba Impact Platform',
    'footer_powered_url' => $config->get('footer_powered_url') ?: 'https://jaraba.io',
    'navigation_items' => $config->get('navigation_items'),
    // Promo banner (configurable desde UI — NO-HARDCODE-PRICE-001).
    'promo_banner_enabled' => (bool) $config->get('enable_promo_banner'),
    'promo_banner_title' => $config->get('promo_banner_title') ?: '',
    'promo_banner_text' => $config->get('promo_banner_text') ?: '',
    'promo_banner_url' => $config->get('promo_banner_url') ?: '',
    'promo_banner_cta' => $config->get('promo_banner_cta') ?: '',
  ];
}

/**
 * Implements hook_preprocess_html().
 *
 * Inyecta CSS variables desde la configuración del tema.
 */
function ecosistema_jaraba_theme_preprocess_html(&$variables) {
  $config = \Drupal::config('ecosistema_jaraba_theme.settings');

  // FE-05 / A11Y-04: Asegurar atributo lang explícito en <html> (WCAG 2.1 Level A).
  // Drupal core lo establece, pero lo reforzamos aquí para garantizar conformidad.
  $language = \Drupal::languageManager()->getCurrentLanguage();
  $variables['html_attributes']['lang'] = $language->getId();
  $variables['html_attributes']['dir'] = $language->getDirection();

  // =========================================================================
  // CHECKOUT: Body classes limpias — sin header/hero/card/footer genéricos.
  // Las rutas de checkout son un funnel de conversión minimalista que NO debe
  // heredar clases del tema genérico (header-layout-classic, hero-layout-*,
  // has-avatar-nav, has-back-to-top, etc.) para evitar CSS contaminante.
  // STRIPE-CHECKOUT-001 §5.5 — Frontend limpio sin chrome de Drupal.
  // =========================================================================
  $route_name = '';
  try {
    $route_name = \Drupal::routeMatch()->getRouteName() ?? '';
  }
  catch (\Throwable $e) {
    // Route not available yet (e.g. 404).
  }
  $checkout_routes = [
    'jaraba_billing.checkout',
    'jaraba_billing.checkout.success',
    'jaraba_billing.checkout.cancel',
  ];
  if (in_array($route_name, $checkout_routes, TRUE)) {
    $variables['attributes']['class'][] = 'page-checkout';
    $variables['attributes']['class'][] = 'clean-layout';
    $variables['attributes']['class'][] = 'full-width-layout';
    // Early return — no añadir clases genéricas del tema.
    return;
  }

  // KIT DIGITAL — Landing pages zero-region.
  if (str_starts_with($route_name, 'jaraba_billing.kit_digital.')) {
    $variables['attributes']['class'][] = 'page-kit-digital';
    $variables['attributes']['class'][] = 'clean-layout';
    $variables['attributes']['class'][] = 'full-width-layout';
    return;
  }

  // Body classes - Header Layout
  $header_layout = $config->get('header_layout') ?: 'classic';
  $variables['attributes']['class'][] = 'header-layout-' . $header_layout;

  // Body classes - Footer Layout
  $footer_layout = $config->get('footer_layout') ?: 'standard';
  $variables['attributes']['class'][] = 'footer-layout-' . $footer_layout;

  // Body classes - Hero Layout
  $hero_layout = $config->get('hero_layout') ?: 'fullscreen';
  $variables['attributes']['class'][] = 'hero-layout-' . $hero_layout;

  // Body classes - Card Style
  $card_style = $config->get('card_style') ?: 'elevated';
  $variables['attributes']['class'][] = 'card-style-' . $card_style;

  // Clase page-front para homepage (landing page limpia sin regiones)
  $is_front = \Drupal::service('path.matcher')->isFrontPage();
  if ($is_front) {
    $variables['attributes']['class'][] = 'page-front';
    $variables['attributes']['class'][] = 'landing-page';

    // SEO-HOMEPAGE-TITLE-001: Sincronizar <title> con og:title.
    // preprocess_page() inyecta og:title y meta description correctamente,
    // pero head_title (que renderiza <title>) quedaba como fallback genérico.
    // Resolvemos aquí porque head_title es variable de html.html.twig.
    $site_name = \Drupal::config('system.site')->get('name') ?: 'Jaraba Impact Platform';
    $homepage_title = '';
    try {
      if (\Drupal::hasService('jaraba_page_builder.homepage_data')) {
        /** @var \Drupal\jaraba_page_builder\Service\HomepageDataService $homepage_service */
        $homepage_service = \Drupal::service('jaraba_page_builder.homepage_data');
        $seo_data = $homepage_service->getHomepageData()['seo'] ?? [];
        $homepage_title = $seo_data['meta_title'] ?? '';
      }
    }
    catch (\Throwable $e) {
      // Servicio no disponible, usar fallback.
    }
    if (empty($homepage_title)) {
      $homepage_title = t('Impulsa tu ecosistema digital | @site', ['@site' => $site_name]);
    }
    $variables['head_title']['title'] = $homepage_title;

    // GEO-HOMEPAGE-001: Geo meta tags para SEO local (Bing, Yahoo, Yandex).
    // NAP-NORMALIZATION-001: coordenadas canónicas Málaga HQ.
    $geo_tags = [
      'geo.region' => 'ES-AN',
      'geo.placename' => 'Málaga, Andalucía, España',
      'geo.position' => '36.7265;-4.4198',
      'ICBM' => '36.7265, -4.4198',
    ];
    foreach ($geo_tags as $geo_name => $geo_content) {
      $variables['#attached']['html_head'][] = [
        ['#tag' => 'meta', '#attributes' => ['name' => $geo_name, 'content' => $geo_content]],
        'homepage_' . str_replace('.', '_', $geo_name),
      ];
    }
  }

  // Clase landing-page para rutas de verticales (full-width como homepage)
  $route = (string) \Drupal::routeMatch()->getRouteName();
  $vertical_routes = [
    'ecosistema_jaraba_core.vertical.empleo',
    'ecosistema_jaraba_core.vertical.talento',
    'ecosistema_jaraba_core.vertical.emprender',
    'ecosistema_jaraba_core.vertical.comercio',
    'ecosistema_jaraba_core.vertical.instituciones',
    // F4 Doc 180 — Landing Pages Verticales con 9 secciones.
    'ecosistema_jaraba_core.landing.agroconecta',
    'ecosistema_jaraba_core.landing.comercioconecta',
    'ecosistema_jaraba_core.landing.serviciosconecta',
    'ecosistema_jaraba_core.landing.empleabilidad',
    'ecosistema_jaraba_core.landing.emprendimiento',
    // JarabaLex — Inteligencia Legal con IA.
    // Plan Elevación JarabaLex Clase Mundial v1 — Fase 0.
    'ecosistema_jaraba_core.landing.jarabalex',
    // Plan Unificacion JarabaLex + Despachos v1 — Fase 5.
    'ecosistema_jaraba_core.landing.legal',
  ];
  if (in_array($route, $vertical_routes)) {
    $variables['attributes']['class'][] = 'landing-page';
    $variables['attributes']['class'][] = 'page-vertical-landing';
    // F12 — Lenis smooth scroll para landing pages verticales.
    $variables['#attached']['library'][] = 'ecosistema_jaraba_theme/lenis-scroll';

    // RUNTIME-VERIFY-001: Vertical-specific body class for SCSS targeting.
    // Produces: <body class="landing-page page-vertical-landing landing-page--talento">
    $landing_vertical_map = [
      'ecosistema_jaraba_core.landing.empleabilidad' => 'empleabilidad',
      'ecosistema_jaraba_core.vertical.talento' => 'talento',
      'ecosistema_jaraba_core.landing.emprendimiento' => 'emprendimiento',
      'ecosistema_jaraba_core.landing.agroconecta' => 'agroconecta',
      'ecosistema_jaraba_core.landing.comercioconecta' => 'comercioconecta',
      'ecosistema_jaraba_core.landing.serviciosconecta' => 'serviciosconecta',
      'ecosistema_jaraba_core.landing.jarabalex' => 'jarabalex',
      'ecosistema_jaraba_core.landing.legal' => 'jarabalex',
      'ecosistema_jaraba_core.vertical.empleo' => 'empleabilidad',
      'ecosistema_jaraba_core.vertical.emprender' => 'emprendimiento',
      'ecosistema_jaraba_core.vertical.comercio' => 'comercioconecta',
      'ecosistema_jaraba_core.vertical.instituciones' => 'demo',
    ];
    if (isset($landing_vertical_map[$route])) {
      $variables['attributes']['class'][] = 'landing-page--' . $landing_vertical_map[$route];
    }
  }

  // Item 1 — Vertical Brand: inject CSS custom properties + body class.
  if (\Drupal::hasService('entity_type.manager')) {
    try {
      $entityTypeManager = \Drupal::entityTypeManager();
      if ($entityTypeManager->hasDefinition('vertical_brand')) {
        // Detect current vertical from route or landing map.
        $currentVertical = $landing_vertical_map[$route] ?? '';
        if ($currentVertical) {
          $brands = $entityTypeManager->getStorage('vertical_brand')
            ->loadByProperties(['vertical' => $currentVertical]);
          if (!empty($brands)) {
            /** @var \Drupal\ecosistema_jaraba_core\Entity\VerticalBrandConfig $brand */
            $brand = reset($brands);
            if ($brand->isEnabled()) {
              $variables['attributes']['class'][] = 'vertical--' . $currentVertical;
              // Inject CSS custom properties from VerticalBrandConfig.
              $css_overrides = '';
              if ($brand->getPrimaryColor()) {
                $css_overrides .= '--ej-vertical-primary: ' . $brand->getPrimaryColor() . '; ';
              }
              if ($brand->getSecondaryColor()) {
                $css_overrides .= '--ej-vertical-secondary: ' . $brand->getSecondaryColor() . '; ';
              }
              if ($css_overrides) {
                $variables['vertical_brand_css'] = ':root { ' . $css_overrides . '}';
              }
            }
          }
        }
      }
    }
    catch (\Throwable) {
      // Theme preprocess should never crash.
    }
  }

  // F6 Doc 181 / Spec f104 — Admin Center Premium body classes.
  $admin_center_body_routes = [
    'ecosistema_jaraba_core.admin.center',
    'ecosistema_jaraba_core.admin.center.tenants',
    'ecosistema_jaraba_core.admin.center.users',
    'ecosistema_jaraba_core.admin.center.finance',
    'ecosistema_jaraba_core.admin.center.alerts',
    'ecosistema_jaraba_core.admin.center.analytics',
    'ecosistema_jaraba_core.admin.center.logs',
    'ecosistema_jaraba_core.admin.center.settings',
  ];
  if (in_array($route, $admin_center_body_routes, TRUE)) {
    $variables['attributes']['class'][] = 'page-admin-center';
    $variables['attributes']['class'][] = 'admin-center-page';
    $variables['attributes']['class'][] = 'full-width-layout';
  }

  // Precios Configurables v2.1 — Plan Admin body classes.
  $plan_admin_routes = [
    'entity.saas_plan_tier.collection',
    'entity.saas_plan_tier.add_form',
    'entity.saas_plan_tier.edit_form',
    'entity.saas_plan_tier.delete_form',
    'entity.saas_plan_features.collection',
    'entity.saas_plan_features.add_form',
    'entity.saas_plan_features.edit_form',
    'entity.saas_plan_features.delete_form',
  ];
  if (in_array($route, $plan_admin_routes, TRUE)) {
    $variables['attributes']['class'][] = 'page-plan-admin';
  }

  // User page body classes (page--user.html.twig is a page template,
  // so body classes must be added here in preprocess_html).
  $user_routes = [
    'entity.user.canonical',
    'entity.user.edit_form',
    'user.logout.confirm',
    'entity.user.contact_form',
    'user.cancel_confirm',
  ];
  if (in_array($route, $user_routes, TRUE)) {
    $variables['attributes']['class'][] = 'user-page';
    $variables['attributes']['class'][] = 'page-user';
    $variables['attributes']['class'][] = 'full-width-layout';
  }

  // Avatar Navigation body class — permite CSS defensivo para bottom nav mobile.
  $enable_avatar_nav = theme_get_setting('enable_avatar_nav', 'ecosistema_jaraba_theme');
  $admin_context = \Drupal::service('router.admin_context');
  if ($enable_avatar_nav !== FALSE && !$admin_context->isAdminRoute()) {
    try {
      $nav_service = \Drupal::service('ecosistema_jaraba_core.avatar_navigation');
      if (!empty($nav_service->getNavigationItems())) {
        $variables['attributes']['class'][] = 'has-avatar-nav';
      }
    }
    catch (\Exception $e) {
      // Servicio no disponible.
    }
  }

  // =========================================================================
  // H9 fix: Title tag tenant-aware para páginas de meta-sitio.
  // Si la página pertenece a un meta-sitio, override <title> con el sufijo
  // del tenant en lugar del sufijo global "| Jaraba".
  // =========================================================================
  $route_match = \Drupal::routeMatch();
  $page_content = $route_match->getParameter('page_content');
  if ($page_content instanceof \Drupal\jaraba_page_builder\Entity\PageContent) {
    try {
      /** @var \Drupal\jaraba_site_builder\Service\MetaSiteResolverService $resolver */
      $resolver = \Drupal::service('jaraba_site_builder.meta_site_resolver');
      $metaSite = $resolver->resolveFromPageContent($page_content);
      if ($metaSite && $metaSite['site_config']) {
        $titleSuffix = $metaSite['site_config']->get('meta_title_suffix')->value ?? '';
        $pageTitle = $page_content->get('meta_title')->value ?? $page_content->get('title')->value ?? '';
        if ($pageTitle && $titleSuffix) {
          // Solo añadir sufijo si el título no lo incluye ya.
          if (!str_contains($pageTitle, $titleSuffix)) {
            $variables['head_title']['title'] = $pageTitle . ' ' . $titleSuffix;
          }
          else {
            $variables['head_title']['title'] = $pageTitle;
          }
        }
        elseif ($pageTitle) {
          $variables['head_title']['title'] = $pageTitle;
        }

        // También añadir body class para meta-sitio.
        $variables['attributes']['class'][] = 'meta-site';
        $variables['attributes']['class'][] = 'meta-site-tenant-' . $metaSite['group_id'];
      }
    }
    catch (\Exception $e) {
      // Servicio no disponible.
    }
  }

  // F4 Doc 180 — Meta SEO tags para landing pages verticales.
  $landing_meta = [
    'ecosistema_jaraba_core.landing.agroconecta' => [
      'title' => 'AgroConecta - Vende sin intermediarios | Ecosistema Jaraba',
      'description' => 'Tu tienda online en 10 minutos. Cobra directamente. Sin comisiones ocultas. Plataforma para productores rurales.',
      'og_type' => 'website',
      'og_image' => '/themes/custom/ecosistema_jaraba_theme/images/og/og-agroconecta.jpg',
    ],
    'ecosistema_jaraba_core.landing.comercioconecta' => [
      'title' => 'ComercioConecta - Digitaliza tu comercio | Ecosistema Jaraba',
      'description' => 'Ofertas flash, click & collect, pedidos online. Todo integrado con tu TPV. Comercio local digitalizado.',
      'og_type' => 'website',
      'og_image' => '/themes/custom/ecosistema_jaraba_theme/images/og/og-comercioconecta.jpg',
    ],
    'ecosistema_jaraba_core.landing.serviciosconecta' => [
      'title' => 'ServiciosConecta - Tu consulta digitalizada | Ecosistema Jaraba',
      'description' => 'Agenda online, videollamadas, cobro automático, firma digital. Todo en un solo lugar para profesionales.',
      'og_type' => 'website',
      'og_image' => '/themes/custom/ecosistema_jaraba_theme/images/og/og-serviciosconecta.jpg',
    ],
    'ecosistema_jaraba_core.landing.empleabilidad' => [
      'title' => 'Empleabilidad - Reinvéntate profesionalmente | Ecosistema Jaraba',
      'description' => 'Formación práctica, CV que destaca, ofertas que encajan contigo. Con ayuda de IA y mentores reales.',
      'og_type' => 'website',
      'og_image' => '/themes/custom/ecosistema_jaraba_theme/images/og/og-empleabilidad.jpg',
    ],
    'ecosistema_jaraba_core.landing.emprendimiento' => [
      'title' => 'Emprendimiento - De idea a negocio rentable | Ecosistema Jaraba',
      'description' => 'Metodología validada + herramientas digitales + mentoría experta. Todo para emprender con garantías.',
      'og_type' => 'website',
      'og_image' => '/themes/custom/ecosistema_jaraba_theme/images/og/og-emprendimiento.jpg',
    ],
    // Quiz de Recomendación de Vertical.
    'ecosistema_jaraba_core.quiz_vertical' => [
      'title' => 'Descubre tu vertical ideal en 30 segundos | Ecosistema Jaraba',
      'description' => 'Test gratuito con IA. Responde 3 preguntas y te recomendamos la herramienta perfecta de entre 9 verticales especializados.',
      'og_type' => 'website',
      'og_image' => '/themes/custom/ecosistema_jaraba_theme/images/og/og-default.jpg',
    ],
    'ecosistema_jaraba_core.quiz_vertical.result' => [
      'title' => 'Tu recomendación personalizada | Ecosistema Jaraba',
      'description' => 'Descubre qué vertical de Jaraba Impact Platform se adapta mejor a tu perfil. Resultado personalizado con IA.',
      'og_type' => 'article',
      'og_image' => '/themes/custom/ecosistema_jaraba_theme/images/og/og-default.jpg',
    ],
  ];
  if (isset($landing_meta[$route])) {
    $meta = $landing_meta[$route];
    $request = \Drupal::request();
    $base_url = $request->getSchemeAndHttpHost();
    $current_url = $base_url . $request->getRequestUri();

    $variables['head_title']['title'] = $meta['title'];

    // Build absolute og:image URL from relative path.
    $og_image_url = $base_url . ($meta['og_image'] ?? '/themes/custom/ecosistema_jaraba_theme/images/og/og-default.jpg');

    $meta_tags = [
      ['name' => 'description', 'content' => $meta['description']],
      ['property' => 'og:title', 'content' => $meta['title']],
      ['property' => 'og:description', 'content' => $meta['description']],
      ['property' => 'og:type', 'content' => $meta['og_type']],
      ['property' => 'og:url', 'content' => $current_url],
      ['property' => 'og:image', 'content' => $og_image_url],
      ['property' => 'og:image:width', 'content' => '1200'],
      ['property' => 'og:image:height', 'content' => '630'],
      ['name' => 'twitter:card', 'content' => 'summary_large_image'],
      ['name' => 'twitter:title', 'content' => $meta['title']],
      ['name' => 'twitter:description', 'content' => $meta['description']],
      ['name' => 'twitter:image', 'content' => $og_image_url],
    ];
    foreach ($meta_tags as $i => $tag) {
      $key = $tag['name'] ?? $tag['property'];
      $variables['page']['#attached']['html_head'][] = [
        [
          '#tag' => 'meta',
          '#attributes' => $tag,
        ],
        'landing_meta_' . $key,
      ];
    }
  }

  // =========================================================================
  // VERTICAL EMPLEABILIDAD — Body classes unificadas
  // Plan Elevación Empleabilidad v1 — Fase 1
  //
  // Aplica a TODAS las rutas de los 4 módulos del vertical empleabilidad.
  // Las clases específicas (page-employability-diagnostic, etc.) se suman.
  // =========================================================================
  $empleabilidad_prefixes = [
    'jaraba_candidate.',
    'jaraba_job_board.',
    'jaraba_diagnostic.',
    'jaraba_self_discovery.',
  ];
  $is_empleabilidad = FALSE;
  foreach ($empleabilidad_prefixes as $prefix) {
    if (str_starts_with($route, $prefix)) {
      $is_empleabilidad = TRUE;
      break;
    }
  }
  if ($is_empleabilidad) {
    $variables['attributes']['class'][] = 'page-empleabilidad';
    $variables['attributes']['class'][] = 'vertical-empleabilidad';
    $variables['attributes']['class'][] = 'dashboard-page';
  }

  // Diagnostico de Empleabilidad - zero-region full-width (Spec 20260120b S3)
  $employability_diagnostic_routes = [
    'jaraba_diagnostic.employability.landing',
    'jaraba_diagnostic.employability.process',
    'jaraba_diagnostic.employability.results',
  ];
  if (in_array($route, $employability_diagnostic_routes)) {
    $variables['attributes']['class'][] = 'page-employability-diagnostic';
    $variables['attributes']['class'][] = 'landing-page';
  }

  // Tenant Dashboard - clean full-width layout
  $tenant_dashboard_routes = [
    'ecosistema_jaraba_core.tenant.dashboard',
    'ecosistema_jaraba_core.tenant.change_plan',
  ];
  if (in_array($route, $tenant_dashboard_routes)) {
    $variables['attributes']['class'][] = 'page-tenant-dashboard';
    $variables['attributes']['class'][] = 'dashboard-page';
    $variables['attributes']['class'][] = 'full-width-layout';
  }

  // Dashboard frontend routes - clase para anular grid hero--split
  // Ver: docs/tecnicos/aprendizajes/2026-01-29_frontend_pages_pattern.md
  $dashboard_frontend_routes = [
    'jaraba_content_hub.dashboard.frontend',       // /content-hub
    'jaraba_content_hub.articles.frontend',        // /content-hub/articles
    'jaraba_content_hub.articles.add.frontend',    // /content-hub/articles/add
    'jaraba_content_hub.articles.edit.frontend',   // /content-hub/articles/{id}/edit
    'jaraba_content_hub.categories.frontend',      // /content-hub/categories
    'jaraba_content_hub.categories.add.frontend',  // /content-hub/categories/add
    'jaraba_content_hub.ai_logs.frontend',         // /content-hub/ai-logs
  ];
  if (in_array($route, $dashboard_frontend_routes)) {
    $variables['attributes']['class'][] = 'dashboard-page';
    $variables['attributes']['class'][] = 'page-content-hub';
  }

  // =========================================================================
  // SITE BUILDER FRONTEND - Clases para anular grid hero--split
  // Ver: .agent/workflows/frontend-page-pattern.md
  // =========================================================================
  $site_builder_frontend_routes = [
    'jaraba_site_builder.frontend.dashboard',    // /site-builder
    'jaraba_site_builder.frontend.tree',         // /site-builder/tree
    'jaraba_site_builder.frontend.config',       // /site-builder/config
    'jaraba_site_builder.frontend.redirects',    // /site-builder/redirects
    'jaraba_site_builder.frontend.sitemap',      // /site-builder/sitemap
    // Admin routes también usan frontend limpio (Directriz 2026).
    'jaraba_site_builder.dashboard',             // /admin/structure/site-builder
    'jaraba_site_builder.tree',                  // /admin/structure/site-builder/tree
    'jaraba_site_builder.settings',              // /admin/structure/site-builder/config
    'jaraba_site_builder.redirects',             // /admin/structure/site-builder/redirects
    'jaraba_site_builder.sitemap',               // /admin/structure/site-builder/sitemap
    // Fase 4 Doc 179: SEO/GEO + IA routes.
    'entity.seo_page_config.collection',         // /admin/content/seo-config
    'entity.seo_page_config.settings',           // /admin/structure/seo-config
  ];
  if (in_array($route, $site_builder_frontend_routes)) {
    $variables['attributes']['class'][] = 'dashboard-page';
    $variables['attributes']['class'][] = 'page-site-builder';
  }

  // SEO entity forms get additional body class.
  if (str_starts_with($route, 'entity.seo_page_config.')) {
    $variables['attributes']['class'][] = 'page-seo-config';
  }

  // =========================================================================
  // PAGE BUILDER FRONTEND - Clases para layout full-width limpio
  // Ver: .agent/workflows/frontend-page-pattern.md
  // =========================================================================
  $page_builder_frontend_routes = [
    'jaraba_page_builder.dashboard',             // /page-builder (Hub Central)
    'jaraba_page_builder.template_picker',       // /page-builder/templates
    'jaraba_page_builder.template_preview',      // /page-builder/templates/{id}/preview
    'jaraba_page_builder.create_from_template',  // /page-builder/create/{template}
    'jaraba_page_builder.my_pages',              // /my-pages
    'jaraba_page_builder.experiments_dashboard', // /page-builder/experiments (Gap 2)
    'jaraba_page_builder.analytics_dashboard',   // /page-builder/analytics (Gap C)
    // Admin settings también usa frontend limpio (Directriz 2026).
    'jaraba_page_builder.settings',              // /admin/config/jaraba/page-builder/settings
    'jaraba_pixels.settings',                     // /pixels (Pixel Manager)
    // -------------------------------------------------------------------------
    // PÁGINAS FRONTEND DE TENANTS - Entidades PageContent (2026-02-02)
    // Usan layout full-width, limpio de regiones Drupal heredadas
    // -------------------------------------------------------------------------
    'entity.page_content.canonical',             // /page/{id} o alias como /pepejaraba
  ];
  if (in_array($route, $page_builder_frontend_routes)) {
    $variables['attributes']['class'][] = 'page-page-builder';
    $variables['attributes']['class'][] = 'page-builder-frontend';
    $variables['attributes']['class'][] = 'full-width-layout';
    // Clase específica para experiments para CSS targeting.
    if ($route === 'jaraba_page_builder.experiments_dashboard') {
      $variables['attributes']['class'][] = 'page-experiments';
      $variables['attributes']['class'][] = 'experiments-dashboard-page';
    }
    // Clase específica para páginas de contenido creadas con Page Builder.
    if ($route === 'entity.page_content.canonical') {
      $variables['attributes']['class'][] = 'page-content-frontend';
      $variables['attributes']['class'][] = 'tenant-page';
    }
  }

  // =========================================================================
  // INTEGRATIONS MARKETPLACE - Layout full-width limpio
  // Rutas /integraciones/* (marketplace de conectores)
  // Ver: web/modules/custom/jaraba_integrations
  // =========================================================================
  $integrations_frontend_routes = [
    'jaraba_integrations.frontend.dashboard',           // /integraciones
    'jaraba_integrations.frontend.connector_detail',    // /integraciones/{connector}
    'jaraba_integrations.frontend.connector_configure', // /integraciones/{connector}/configurar
    'jaraba_integrations.frontend.webhooks',            // /integraciones/webhooks
  ];
  if (in_array($route, $integrations_frontend_routes)) {
    $variables['attributes']['class'][] = 'dashboard-page';
    $variables['attributes']['class'][] = 'page-integrations';
  }

  // =========================================================================
  // CUSTOMER SUCCESS - Dashboard CSM con health scores y playbooks (f113)
  // =========================================================================
  $cs_frontend_routes = [
    'jaraba_customer_success.frontend.dashboard',     // /customer-success
    'jaraba_customer_success.frontend.tenant_detail',  // /customer-success/tenant/{group}
    'jaraba_customer_success.frontend.playbooks',      // /customer-success/playbooks
    'jaraba_customer_success.frontend.expansion',      // /customer-success/expansion
  ];
  if (in_array($route, $cs_frontend_routes)) {
    $variables['attributes']['class'][] = 'dashboard-page';
    $variables['attributes']['class'][] = 'page-customer-success';
  }

  // =========================================================================
  // USAGE DASHBOARD - Uso y facturación self-service (G111 / f111)
  // Ruta /mi-cuenta/uso usa layout limpio full-width
  // =========================================================================
  $usage_frontend_routes = [
    'ecosistema_jaraba_core.usage.dashboard',   // /mi-cuenta/uso
  ];
  if (in_array($route, $usage_frontend_routes)) {
    $variables['attributes']['class'][] = 'dashboard-page';
    $variables['attributes']['class'][] = 'page-mi-cuenta';
    $variables['attributes']['class'][] = 'page-usage-dashboard';
  }

  // =========================================================================
  // HELP CENTER PÚBLICO - Centro de Ayuda en /ayuda (G114 / f114)
