  if (str_starts_with($route_str, 'jaraba_customer_success.')) {
    $suggestions[] = 'page__customer_success';
  }

  // Integrations (rutas adicionales) → page--integrations.html.twig
  if (str_starts_with($route_str, 'jaraba_integrations.')) {
    $suggestions[] = 'page__integrations';
  }

  // =========================================================================
  // STACK COMPLIANCE LEGAL N1 — Templates zero-region para dashboards
  // Plan Implementacion Stack Compliance Legal N1 v1 — FASE 0.
  //
  // Privacidad GDPR → page--privacy.html.twig
  // Términos Legales → page--legal-compliance.html.twig
  // Disaster Recovery → page--dr-status.html.twig
  // =========================================================================
  if (str_starts_with($route_str, 'jaraba_privacy.')) {
    $suggestions[] = 'page__privacy';
  }
  if (str_starts_with($route_str, 'jaraba_legal.')) {
    $suggestions[] = 'page__legal_compliance';
  }
  if (str_starts_with($route_str, 'jaraba_dr.')) {
    $suggestions[] = 'page__dr_status';
  }

  // =========================================================================
  // VERTICAL JARABALEX — Template específico para Legal Intelligence Hub
  // Plan Elevación JarabaLex Clase Mundial v1 — Fase 0.
  //
  // Las rutas jaraba_legal.search, jaraba_legal.dashboard, etc. pertenecen
  // al módulo jaraba_legal_intelligence (no al compliance jaraba_legal).
  // Usan page--legal.html.twig con Copilot FAB legal_copilot.
  // =========================================================================
  $jarabalex_routes = [
    'jaraba_legal.search',
    'jaraba_legal.resolution',
    'jaraba_legal.cite',
    'jaraba_legal.similar',
    'jaraba_legal.public_summary',
    'jaraba_legal.dashboard',
    'jaraba_legal.admin_dashboard',
    'jaraba_legal_intelligence.settings',
  ];
  if (in_array($route_str, $jarabalex_routes)) {
    $suggestions[] = 'page__legal';
  }

  // Caso de éxito + diagnóstico legal → page--jarabalex (landing limpia, sin H1 "Términos Legales").
  $jarabalex_landing_routes = [
    'jaraba_legal.case_study.martinez',
    'jaraba_legal.diagnostico',
  ];
  if (in_array($route_str, $jarabalex_landing_routes)) {
    $suggestions[] = 'page__jarabalex';
  }

  // =========================================================================
  // JARABALEX LEGAL CASES — Templates zero-region para expedientes
  // Plan Implementacion JarabaLex Legal Practice Platform v1 — FASE A1.
  //
  // Dashboard expedientes → page--legal-cases.html.twig
  // Detalle expediente   → page--legal-case-detail.html.twig
  // =========================================================================
  if ($route_str === 'jaraba_legal_cases.dashboard') {
    $suggestions[] = 'page__legal_cases';
  }
  if ($route_str === 'jaraba_legal_cases.case_detail') {
    $suggestions[] = 'page__legal_case_detail';
  }

  // =========================================================================
  // JARABALEX LEGAL CALENDAR — Template zero-region para agenda
  // Plan Implementacion JarabaLex Legal Practice Platform v1 — FASE A2.
  // =========================================================================
  if ($route_str === 'jaraba_legal_calendar.dashboard') {
    $suggestions[] = 'page__legal_calendar';
  }

  // =========================================================================
  // REVIEWS PAGE — REV-PHASE5: Template full-width para paginas de resenas
  // Rutas ecosistema_jaraba_core.reviews.* usan page--reviews.html.twig
  // =========================================================================
  if (str_starts_with($route_str, 'ecosistema_jaraba_core.reviews.')) {
    $suggestions[] = 'page__reviews';
  }
}


/**
 * Implements hook_theme_suggestions_html_alter().
 *
 * Sugiere templates html-- alternativos para rutas específicas.
 * El Canvas Editor necesita control total del HTML para layout full-viewport.
 *
 * @see https://www.drupal.org/node/2354993
 */
function ecosistema_jaraba_theme_theme_suggestions_html_alter(array &$suggestions, array $variables): void {
  $route = \Drupal::routeMatch()->getRouteName();

  // Canvas Editor: usa html--canvas-editor.html.twig
  // Template que tiene control total del HTML sin interferencia de Gin/Admin toolbar
  $canvas_editor_routes = [
    'jaraba_page_builder.canvas_editor',          // /page/{id}/editor
  ];

  if (in_array($route, $canvas_editor_routes)) {
    $suggestions[] = 'html__canvas_editor';
  }
}

/**
 * Implements hook_preprocess_page__admin_center().
 *
 * Inyecta variables para el layout del Admin Center Premium:
 * - admin_center_links: Quick links con iconos SVG para el sidebar
 * - admin_center_title: Titulo de la pagina
 * - user_display_name: Nombre del usuario logueado
 *
 * F6 Doc 181 / Spec f104 — Admin Center Premium.
 *
 * @see page--admin-center.html.twig
 * @see _admin-center-nav.html.twig
 * @see _admin-center-topbar.html.twig
 */
function ecosistema_jaraba_theme_preprocess_page__admin_center(&$variables) {
  // Quick links del sidebar — inyectados desde el servicio aggregator.
  try {
    $aggregator = \Drupal::service('ecosistema_jaraba_core.admin_center_aggregator');
    $variables['admin_center_links'] = $aggregator->getQuickLinks();
  }
  catch (\Exception $e) {
    $variables['admin_center_links'] = [];
  }

  // Titulo de la pagina.
  $variables['admin_center_title'] = $variables['page']['#title'] ?? t('Admin Center');

  // Nombre del usuario logueado.
  $current_user = \Drupal::currentUser();
  $variables['user_display_name'] = $current_user->getDisplayName();
}

/**
 * Implements template_preprocess_page__404().
 *
 * Inyecta variables para la pagina 404 premium con busqueda y quick links.
 */
function ecosistema_jaraba_theme_preprocess_page__404(&$variables): void {
  $variables['site_name'] = \Drupal::config('system.site')->get('name') ?? 'Jaraba Impact Platform';
  $variables['home_url'] = '/';
  $variables['search_url'] = '/search';
  $variables['support_url'] = '/ayuda';
  $variables['quick_links'] = [
    [
      'title' => t('Panel de control'),
      'description' => t('Accede a tu panel principal'),
      'url' => '/user',
      'icon_category' => 'ui',
      'icon_name' => 'home',
    ],
    [
      'title' => t('Centro de ayuda'),
      'description' => t('Encuentra respuestas a tus preguntas'),
      'url' => '/ayuda',
      'icon_category' => 'ui',
      'icon_name' => 'info',
    ],
    [
      'title' => t('Novedades'),
      'description' => t('Descubre las ultimas actualizaciones'),
      'url' => '/',
      'icon_category' => 'ui',
      'icon_name' => 'bolt',
    ],
  ];
}

/**
 * Implements template_preprocess_page__403().
 *
 * Inyecta variables para la pagina 403 con estado condicional auth/anon.
 */
function ecosistema_jaraba_theme_preprocess_page__403(&$variables): void {
  $variables['site_name'] = \Drupal::config('system.site')->get('name') ?? 'Jaraba Impact Platform';
  $variables['is_authenticated'] = \Drupal::currentUser()->isAuthenticated();
  $variables['login_url'] = '/user/login';
  $variables['register_url'] = '/user/register';
  $variables['home_url'] = '/';
  $variables['support_url'] = '/ayuda';
}


/**
 * Implements hook_page_attachments_alter().
 *
 * FIX-016: Attaches route-specific CSS libraries based on current route.
 */
function ecosistema_jaraba_theme_page_attachments_alter(array &$attachments): void {
  $route = \Drupal::routeMatch()->getRouteName();
  if (!$route) {
    return;
  }

  // Map route name prefixes to theme libraries (route CSS + extracted bundles).
  // HAL-AI-12: Each route gets its route-specific CSS plus extracted bundle CSS.
  $routeLibraryMap = [
    // Tenant Settings Hub: exact route match BEFORE prefix match.
    'ecosistema_jaraba_core.tenant_self_service.settings' => ['ecosistema_jaraba_theme/route-tenant-settings'],
    'ecosistema_jaraba_core.tenant_self_service.branding' => ['ecosistema_jaraba_theme/route-tenant-settings'],
    'ecosistema_jaraba_core.tenant_self_service.design' => ['ecosistema_jaraba_theme/route-tenant-settings'],
    'ecosistema_jaraba_core.tenant_self_service.domain' => ['ecosistema_jaraba_theme/route-tenant-settings'],
    'ecosistema_jaraba_core.tenant_self_service.api_keys' => ['ecosistema_jaraba_theme/route-tenant-settings'],
    'ecosistema_jaraba_core.tenant_self_service.webhooks' => ['ecosistema_jaraba_theme/route-tenant-settings'],
    'ecosistema_jaraba_core.tenant_self_service.dashboard' => ['ecosistema_jaraba_theme/route-tenant-dashboard'],
    'ecosistema_jaraba_core.tenant.dashboard' => ['ecosistema_jaraba_theme/route-dashboard', 'ecosistema_jaraba_theme/bundle-ai-dashboard'],
    'ecosistema_jaraba_core.tenant_analytics' => ['ecosistema_jaraba_theme/route-dashboard', 'ecosistema_jaraba_theme/bundle-ai-dashboard'],
    'jaraba_content_hub.' => ['ecosistema_jaraba_theme/route-content-hub', 'ecosistema_jaraba_theme/bundle-content-hub'],
    'entity.content_article.' => ['ecosistema_jaraba_theme/route-content-hub', 'ecosistema_jaraba_theme/bundle-content-hub'],
    'jaraba_page_builder.' => ['ecosistema_jaraba_theme/route-page-builder', 'ecosistema_jaraba_theme/bundle-page-builder-dashboard'],
    'user.login' => ['ecosistema_jaraba_theme/route-auth', 'ecosistema_jaraba_theme/bundle-auth'],
    'user.register' => ['ecosistema_jaraba_theme/route-auth', 'ecosistema_jaraba_theme/bundle-auth'],
    'user.pass' => ['ecosistema_jaraba_theme/route-auth', 'ecosistema_jaraba_theme/bundle-auth'],
    'jaraba_page_builder.landing' => ['ecosistema_jaraba_theme/route-landing'],
    'entity.page_content.canonical' => ['ecosistema_jaraba_theme/route-landing'],
    // RUNTIME-VERIFY-001: Vertical landing pages need route-landing CSS.
    'ecosistema_jaraba_core.landing.empleabilidad' => ['ecosistema_jaraba_theme/route-landing'],
    'ecosistema_jaraba_core.landing.emprendimiento' => ['ecosistema_jaraba_theme/route-landing'],
    'ecosistema_jaraba_core.landing.agroconecta' => ['ecosistema_jaraba_theme/route-landing'],
    'ecosistema_jaraba_core.vertical.talento' => ['ecosistema_jaraba_theme/route-landing'],
    'ecosistema_jaraba_core.landing.comercioconecta' => ['ecosistema_jaraba_theme/route-landing'],
    'ecosistema_jaraba_core.landing.serviciosconecta' => ['ecosistema_jaraba_theme/route-landing'],
    'ecosistema_jaraba_core.landing.jarabalex' => ['ecosistema_jaraba_theme/route-landing'],
    'ecosistema_jaraba_core.landing.legal' => ['ecosistema_jaraba_theme/route-landing'],
    'ecosistema_jaraba_core.vertical.empleo' => ['ecosistema_jaraba_theme/route-landing'],
    'ecosistema_jaraba_core.vertical.emprender' => ['ecosistema_jaraba_theme/route-landing'],
    'ecosistema_jaraba_core.vertical.comercio' => ['ecosistema_jaraba_theme/route-landing'],
    'ecosistema_jaraba_core.vertical.instituciones' => ['ecosistema_jaraba_theme/route-landing'],
    'empleabilidad.' => ['ecosistema_jaraba_theme/route-empleabilidad', 'ecosistema_jaraba_theme/bundle-employability-pages'],
    // GAP-L5: Dashboard-specific CSS for IA Level 5 pages.
    'jaraba_ai_agents.compliance_dashboard' => ['ecosistema_jaraba_theme/route-ai-features', 'ecosistema_jaraba_theme/route-ai-compliance'],
    'jaraba_ai_agents.autonomous_agents_dashboard' => ['ecosistema_jaraba_theme/route-ai-features', 'ecosistema_jaraba_theme/route-autonomous-agents'],
    'jaraba_ai_agents.causal_analytics_dashboard' => ['ecosistema_jaraba_theme/route-ai-features', 'ecosistema_jaraba_theme/route-causal-analytics'],
    'jaraba_ai_agents.' => ['ecosistema_jaraba_theme/route-ai-features', 'ecosistema_jaraba_theme/bundle-ai-dashboard'],
    'jaraba_copilot' => ['ecosistema_jaraba_theme/route-ai-features', 'ecosistema_jaraba_theme/bundle-ai-dashboard'],
    'ecosistema_jaraba_core.static.' => ['ecosistema_jaraba_theme/route-legal-pages'],
    'jaraba_candidate.jobseeker' => ['ecosistema_jaraba_theme/bundle-jobseeker-dashboard'],
    'jaraba_candidate.dashboard' => ['ecosistema_jaraba_theme/bundle-jobseeker-dashboard'],
    'jaraba_agents.' => ['ecosistema_jaraba_theme/bundle-agent-dashboard'],
    'jaraba_business_tools.entrepreneur_dashboard' => ['ecosistema_jaraba_theme/bundle-entrepreneur-dashboard'],
    // Quiz de Recomendación de Vertical.
    'ecosistema_jaraba_core.quiz_vertical' => ['ecosistema_jaraba_theme/route-quiz'],
  ];

  // SETUP-WIZARD-DAILY-001: Attach setup-wizard library on dashboard routes
  // that integrate the Setup Wizard + Daily Actions pattern.
  $wizardDashboardRoutes = [
    'jaraba_andalucia_ei.coordinador_dashboard',
    'jaraba_candidate.dashboard',
    'jaraba_copilot_v2.dashboard',
    'jaraba_comercio_conecta.merchant_portal',
    'jaraba_agroconecta_core.producer_dashboard',
    'jaraba_servicios_conecta.provider_portal',
    'jaraba_legal_intelligence.legal_dashboard',
    'jaraba_content_hub.dashboard.frontend',
    'jaraba_lms.instructor.courses',
    // Secondary roles:
    'jaraba_andalucia_ei.orientador_dashboard',
    'jaraba_lms.my_learning',
    'jaraba_mentoring.mentor_dashboard',
    'jaraba_business_tools.entrepreneur_dashboard',
  ];
  if (in_array($route, $wizardDashboardRoutes, TRUE)) {
    $attachments['#attached']['library'][] = 'ecosistema_jaraba_theme/setup-wizard';
  }

  foreach ($routeLibraryMap as $prefix => $libraries) {
    if ($route === $prefix || str_starts_with($route, $prefix)) {
      foreach ($libraries as $library) {
        $attachments['#attached']['library'][] = $library;
      }
      break;
    }
  }
}
