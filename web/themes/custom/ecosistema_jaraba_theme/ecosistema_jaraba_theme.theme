  // --- Widget Column 1 ---
  $form['footer_options']['footer_widgets'] = [
    '#type' => 'fieldset',
    '#title' => t('📦 Configuración de Widgets (Mega Footer)'),
    '#states' => ['visible' => [':input[name="footer_layout"]' => ['value' => 'mega']]],
