  // Ver: docs/implementacion/20260215c-Plan_Elevacion_Andalucia_EI_Clase_Mundial_v1_Claude.md
  // =========================================================================
  if (str_starts_with((string) $route, 'jaraba_andalucia_ei.') || str_starts_with((string) $route, 'entity.programa_participante_ei.')) {
    $variables['attributes']['class'][] = 'dashboard-page';
    $variables['attributes']['class'][] = 'page-andalucia-ei';
    $variables['attributes']['class'][] = 'vertical-andalucia-ei';
    $variables['attributes']['class'][] = 'full-width-page';
