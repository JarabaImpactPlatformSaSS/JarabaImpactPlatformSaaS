/**
 * Implements hook_preprocess_page__user().
 *
 * Preprocesa todas las páginas del sistema de usuario para inyectar
 * contenido LIMPIO: solo la vista o formulario de la entidad usuario,
 * sin bloques heredados de regiones de Drupal.
 *
 * Directrices aplicadas:
 * - Nuclear #14: Frontend Limpio (Zero Region Policy)
 * - Branding 3.6: Portal Isolation
 */
function ecosistema_jaraba_theme_preprocess_page__user(&$variables) {
  $route = \Drupal::routeMatch()->getRouteName();
  $route_match = \Drupal::routeMatch();
  
  // Determinar el tipo de página de usuario.
  $page_type = 'profile'; // Default
  $user_content = NULL;
  
  // Obtener el usuario de la ruta si existe.
  // NOTA: $variables['user'] es también inyectada por template_preprocess()
  // como AccountProxy global. Aquí la sobreescribimos con la entidad User
  // específica de la ruta. Además, inyectamos 'profile_uid' como variable
  // dedicada para path() en el template (evita ambigüedad con user global).
  // URLs pre-resueltas para el template (ROUTE-LANGPREFIX-001).
  // Se generan aquí en PHP para evitar MissingMandatoryParametersException
  // cuando path() en Twig recibe parámetros NULL/vacíos.
  $variables['profile_uid'] = 0;
  $variables['profile_edit_url'] = NULL;
  $variables['profile_view_url'] = NULL;

  $user = $route_match->getParameter('user');
  if ($user && is_object($user) && method_exists($user, 'id')) {
    $variables['user'] = $user;
    $variables['user_display_name'] = $user->getDisplayName();
    $variables['profile_uid'] = (int) $user->id();
  }
  else {
    $variables['user_display_name'] = t('Usuario');
    // Intentar obtener el usuario actual si no está en la ruta.
    $user = \Drupal::currentUser();
    if ($user->isAuthenticated()) {
      $user = \Drupal::entityTypeManager()->getStorage('user')->load($user->id());
      if ($user) {
        $variables['user'] = $user;
        $variables['user_display_name'] = $user->getDisplayName();
        $variables['profile_uid'] = (int) $user->id();
      }
    }
  }

  // Generar URLs de perfil en PHP (safe, no exceptions).
  $uid = $variables['profile_uid'];
  if ($uid > 0) {
    try {
      $variables['profile_edit_url'] = \Drupal\Core\Url::fromRoute(
        'entity.user.edit_form', ['user' => $uid]
      )->toString();
      $variables['profile_view_url'] = \Drupal\Core\Url::fromRoute(
        'entity.user.canonical', ['user' => $uid]
      )->toString();
    }
    catch (\Throwable $e) {
      // Silenciar — URLs quedan NULL y el template no muestra los links.
    }
  }
  
  // =========================================================================
  // RENDERIZAR CONTENIDO LIMPIO - Solo la entidad o formulario específico
  // =========================================================================
  switch ($route) {
    case 'entity.user.canonical':
      // Página de perfil: renderizar solo la vista de la entidad usuario.
      $page_type = 'profile';
      if ($user && is_object($user) && method_exists($user, 'id')) {
        $view_builder = \Drupal::entityTypeManager()->getViewBuilder('user');
        $user_content = $view_builder->view($user, 'full');
      }
      break;
      
    case 'entity.user.edit_form':
      // Página de edición: renderizar solo el formulario de edición.
      $page_type = 'edit';
      if ($user && is_object($user) && method_exists($user, 'id')) {
        try {
          $form_object = \Drupal::entityTypeManager()
            ->getFormObject('user', 'default')
            ->setEntity($user);
          $user_content = \Drupal::formBuilder()->getForm($form_object);
        }
        catch (\Exception $e) {
          // Fallback: usar contenido de página si el formulario falla.
          \Drupal::logger('ecosistema_jaraba_theme')->error('Error loading user edit form: @error', ['@error' => $e->getMessage()]);
          $user_content = $variables['page']['content'] ?? NULL;
        }
      }
      break;
      
    case 'user.logout.confirm':
      // Página de logout: renderizar solo el formulario de confirmación.
      $page_type = 'logout';
      try {
        $user_content = \Drupal::formBuilder()->getForm('Drupal\user\Form\UserLogoutConfirmForm');
      }
      catch (\Exception $e) {
        \Drupal::logger('ecosistema_jaraba_theme')->error('Error loading logout form: @error', ['@error' => $e->getMessage()]);
        $user_content = $variables['page']['content'] ?? NULL;
      }
      break;
      
    case 'entity.user.contact_form':
      // Página de contacto: renderizar el formulario de contacto.
      $page_type = 'contact';
      // El formulario de contacto es más complejo, usar contenido filtrado.
      $user_content = $variables['page']['content'] ?? NULL;
      break;
      
    case 'user.cancel_confirm':
      // Página de cancelación de cuenta.
      $page_type = 'cancel';
      $user_content = $variables['page']['content'] ?? NULL;
      break;
      
    default:
      // Otras rutas: fallback a contenido de página (aunque debería estar vacío).
      $page_type = 'generic';
      $user_content = $variables['page']['content'] ?? NULL;
      break;
  }
  
  $variables['user_page_type'] = $page_type;
  $variables['user_content'] = $user_content;

  // =========================================================================
  // ENRIQUECIMIENTO DE DATOS - Solo para la vista de perfil
  // Inyecta email, roles, fechas, avatar y accesos rápidos contextuales.
  // =========================================================================
  if ($page_type === 'profile' && $user && is_object($user) && method_exists($user, 'id')) {

    // -- Datos básicos de la cuenta -------------------------------------------
    $variables['user_email'] = method_exists($user, 'getEmail')
      ? $user->getEmail()
      : '';

    // Roles con labels legibles (excluyendo 'authenticated').
    $role_labels = [];
    $role_ids = [];
    try {
      $roles = $user->getRoles(TRUE); // TRUE = excluye 'authenticated'
      $role_storage = \Drupal::entityTypeManager()->getStorage('user_role');
      foreach ($roles as $rid) {
        $role_entity = $role_storage->load($rid);
        if ($role_entity) {
          $role_labels[] = $role_entity->label();
          $role_ids[] = $rid;
        }
      }
    }
    catch (\Exception $e) {
      // Silenciar si el storage no está disponible.
    }
    $variables['user_roles'] = $role_labels;
    $variables['user_role_ids'] = $role_ids;

    // Fechas formateadas.
    $date_formatter = \Drupal::service('date.formatter');
    $variables['user_member_since'] = $date_formatter->format(
      $user->getCreatedTime(),
      'custom',
      'd M Y'
    );
    $last_access = $user->getLastAccessedTime();
    if ($last_access > 0) {
      $variables['user_last_access'] = $date_formatter->formatTimeDiffSince($last_access);
    }
    else {
      $variables['user_last_access'] = t('Nunca');
    }

    // -- Avatar ---------------------------------------------------------------
    $avatar_url = '';
    if ($user->hasField('user_picture') && !$user->get('user_picture')->isEmpty()) {
      $file = $user->get('user_picture')->entity;
      if ($file) {
        $avatar_url = \Drupal::service('file_url_generator')->generateAbsoluteString($file->getFileUri());
      }
    }
    $variables['user_avatar_url'] = $avatar_url;

    // Iniciales como fallback cuando no hay avatar.
    $name = $user->getDisplayName();
    $initials = mb_strtoupper(mb_substr($name, 0, 2));
    $variables['user_initials'] = $initials;

    // -- Quick Access Sections (via UserProfileSectionRegistry) ----------------
    // Patron extensible: tagged services con CompilerPass.
    // Cada modulo registra secciones via tag 'ecosistema_jaraba_core.user_profile_section'.
    // Template page--user.html.twig consume $user_quick_sections sin cambios.
    $uid = (int) $user->id();
    $sections = [];

    if (\Drupal::hasService('ecosistema_jaraba_core.user_profile_section_registry')) {
      try {
        /** @var \Drupal\ecosistema_jaraba_core\UserProfile\UserProfileSectionRegistry $registry */
        $registry = \Drupal::service('ecosistema_jaraba_core.user_profile_section_registry');
        $sections = $registry->buildSectionsArray($uid);
      }
      catch (\Throwable $e) {
        \Drupal::logger('ecosistema_jaraba_theme')->error('Error building profile sections: @error', [
          '@error' => $e->getMessage(),
        ]);
      }
    }

    $variables['user_quick_sections'] = $sections;

    // Attach JS libraries needed by slide-panel sections.
    // These must be on the parent page so Drupal.attachBehaviors() finds them
    // when the slide-panel loads section HTML via AJAX.
    $variables['#attached']['library'][] = 'jaraba_candidate/skills_manager';
    $variables['#attached']['library'][] = 'jaraba_candidate/profile_section_manager';
    $variables['#attached']['library'][] = 'jaraba_candidate/brand_professional';

    // Backward compatibility: aplanar todos los links.
    $flat_links = [];
    foreach ($sections as $section) {
      foreach ($section['links'] as $link) {
        $flat_links[] = $link;
      }
    }
    $variables['user_quick_links'] = $flat_links;

    // -- Setup Wizard + Daily Actions (via AvatarWizardBridgeService) --------
    // Detecta el avatar del usuario y resuelve qué wizard de onboarding y
    // acciones diarias le corresponden. Reutiliza los partials probados
    // _setup-wizard.html.twig y _daily-actions.html.twig de los dashboards.
    // SETUP-WIZARD-DAILY-001 + ZEIGARNIK-PRELOAD-001 + PIPELINE-E2E-001
    $variables['profile_setup_wizard'] = NULL;
    $variables['profile_daily_actions'] = [];
    $variables['profile_wizard_title'] = '';
    $variables['profile_wizard_subtitle'] = '';
    $variables['profile_actions_title'] = '';
    $variables['profile_dashboard_route'] = NULL;
    $variables['profile_avatar_type'] = NULL;

    if (\Drupal::hasService('ecosistema_jaraba_core.avatar_wizard_bridge')) {
      try {
        /** @var \Drupal\ecosistema_jaraba_core\Service\AvatarWizardBridgeService $bridge */
        $bridge = \Drupal::service('ecosistema_jaraba_core.avatar_wizard_bridge');
        $mapping = $bridge->resolveForCurrentUser();

        if ($mapping) {
          $variables['profile_avatar_type'] = $mapping->avatarType;
          $variables['profile_dashboard_route'] = $mapping->dashboardRoute;

          // Setup Wizard.
          if ($mapping->hasWizard()
              && \Drupal::hasService('ecosistema_jaraba_core.setup_wizard_registry')) {
            /** @var \Drupal\ecosistema_jaraba_core\SetupWizard\SetupWizardRegistry $wizardRegistry */
            $wizardRegistry = \Drupal::service('ecosistema_jaraba_core.setup_wizard_registry');
            if ($wizardRegistry->hasWizard($mapping->wizardId)) {
              $variables['profile_setup_wizard'] = $wizardRegistry->getStepsForWizard(
                $mapping->wizardId,
                $mapping->contextId,
              );
            }
          }

          // Daily Actions.
          if ($mapping->hasDailyActions()
              && \Drupal::hasService('ecosistema_jaraba_core.daily_actions_registry')) {
            /** @var \Drupal\ecosistema_jaraba_core\DailyActions\DailyActionsRegistry $actionsRegistry */
            $actionsRegistry = \Drupal::service('ecosistema_jaraba_core.daily_actions_registry');
            if ($actionsRegistry->hasDashboard($mapping->dashboardId)) {
              $variables['profile_daily_actions'] = $actionsRegistry->getActionsForDashboard(
                $mapping->dashboardId,
                $mapping->contextId,
              );
            }
          }

          // Títulos traducibles contextuales al vertical.
          $vertical_labels = [
            'empleabilidad' => t('Empleabilidad'),
            'emprendimiento' => t('Emprendimiento'),
            'comercioconecta' => t('ComercioConecta'),
            'comercio' => t('ComercioConecta'),
            'agroconecta' => t('AgroConecta'),
            'serviciosconecta' => t('ServiciosConecta'),
            'jarabalex' => t('JarabaLex'),
            'formacion' => t('Formación'),
            'andalucia_ei' => t('Andalucía +ei'),
          ];
          $vertical_label = $mapping->vertical
            ? ($vertical_labels[$mapping->vertical] ?? ucfirst($mapping->vertical))
            : '';

          $variables['profile_wizard_title'] = t('Primeros pasos');
          $variables['profile_wizard_subtitle'] = $vertical_label
            ? t('Configura tu espacio en @vertical', ['@vertical' => $vertical_label])
            : t('Configura tu espacio');
          $variables['profile_actions_title'] = t('Acciones de hoy');

          // Attach library del wizard JS (collapse/expand, API refresh).
          $variables['#attached']['library'][] = 'ecosistema_jaraba_theme/setup-wizard';

          // Verificar que la ruta del dashboard existe antes de pasarla al
          // template. Si el módulo vertical no está instalado, path() en Twig
          // lanzaría RouteNotFoundException.
          if ($mapping->dashboardRoute) {
            try {
              $router = \Drupal::service('router.route_provider');
              $router->getRouteByName($mapping->dashboardRoute);
            }
            catch (\Throwable $e) {
              // Ruta no existe (módulo no instalado) → anular CTA.
              $variables['profile_dashboard_route'] = NULL;
            }
          }

          // Cache: wizard/actions son datos per-user dinámicos.
          // Invalidar cache de perfil cuando cambia el estado del usuario.
          $variables['#cache']['contexts'][] = 'user';
          $variables['#cache']['tags'][] = 'user:' . $uid;
          $variables['#cache']['max-age'] = 120;
        }
      }
      catch (\Throwable $e) {
        \Drupal::logger('ecosistema_jaraba_theme')->error(
          'Error loading wizard/actions for profile: @error',
          ['@error' => $e->getMessage()],
        );
      }
    }
  }

  // =========================================================================
  // CONFIGURACIÓN DEL TEMA Y BRANDING
  // =========================================================================
  $config = \Drupal::config('ecosistema_jaraba_theme.settings');
  $site_config = \Drupal::config('system.site');
  
  $variables['theme_settings'] = _ecosistema_jaraba_theme_get_base_settings($config);
  
  $variables['site_name'] = $site_config->get('name') ?: 'Jaraba Impact Platform';
  $variables['site_slogan'] = $site_config->get('slogan') ?: '';
  
  // URL del logo.
  $theme_path = \Drupal::service('extension.path.resolver')->getPath('theme', 'ecosistema_jaraba_theme');
  
  $logo_from_theme = theme_get_setting('logo.url', 'ecosistema_jaraba_theme');
  if ($logo_from_theme) {
    $variables['logo_url'] = $logo_from_theme;
  }
  else {
    $variables['logo_url'] = '/' . $theme_path . '/images/logo.svg';
  }
  
  // Logo blanco para fondos oscuros.
  $logo_white_path = $theme_path . '/images/logo-white.svg';
  if (file_exists(DRUPAL_ROOT . '/' . $logo_white_path)) {
    $variables['logo_url_white'] = '/' . $logo_white_path;
  }
  else {
    $variables['logo_url_white'] = $variables['logo_url'];
  }
}

/**
 * Implements hook_preprocess_breadcrumb().
 */
function ecosistema_jaraba_theme_preprocess_breadcrumb(&$variables) {
  $config = \Drupal::config('ecosistema_jaraba_theme.settings');

  $variables['breadcrumb_style'] = $config->get('breadcrumb_style') ?: 'chevrons';
  $variables['breadcrumb_icons'] = $config->get('breadcrumb_icons') ?? TRUE;
  $variables['breadcrumb_home_icon'] = $config->get('breadcrumb_home_icon') ?? TRUE;

  // Add structured data
  if ($config->get('breadcrumb_schema') ?? TRUE) {
    $items = [];
    $position = 1;
    foreach ($variables['breadcrumb'] as $crumb) {
      $items[] = [
        '@type' => 'ListItem',
        'position' => $position,
        'name' => $crumb['text'],
        'item' => $crumb['url'] ?? '',
      ];
      $position++;
    }

    if (!empty($items)) {
      $schema = [
        '@context' => 'https://schema.org',
        '@type' => 'BreadcrumbList',
        'itemListElement' => $items,
      ];
      $variables['#attached']['html_head'][] = [
        [
          '#tag' => 'script',
          '#attributes' => ['type' => 'application/ld+json'],
          '#value' => json_encode($schema),
        ],
        'jaraba_breadcrumb_schema',
      ];
    }
  }
}

/**
 * Implements hook_theme_suggestions_page_alter().
 *
 * Aplica template de página limpia (sin sidebars) a rutas de dashboards.
 * Template: page--dashboard.html.twig
 *
 * Rutas afectadas:
 * - /employer (Reclutador)
 * - /jobseeker (Candidato)
 * - /entrepreneur/dashboard
 * - /my-company (Productor)
 */
function ecosistema_jaraba_theme_theme_suggestions_page_alter(array &$suggestions, array $variables): void {
  $route = \Drupal::routeMatch()->getRouteName();
  $route_str = (string) $route;

  // =========================================================================
  // ZERO REGION CATCH-ALL — Base template limpio para módulos custom
  //
  // Asigna page__dashboard como fallback de BAJA PRIORIDAD para todas las
  // rutas frontend de módulos custom del ecosistema. Las secciones
  // específicas posteriores SOBREESCRIBEN con templates más específicos.
  //
  // Drupal evalúa sugerencias de última a primera: la última añadida gana.
  // Al ser la primera sección, tiene la prioridad más baja.
  //
  // @see .agent/workflows/frontend-page-pattern.md
  // =========================================================================
  $ecosistema_prefixes = [
    'ecosistema_jaraba_core.', 'jaraba_addons.', 'jaraba_agent_flows.',
    'jaraba_agroconecta.', 'jaraba_analytics.', 'jaraba_blog.',
    'jaraba_business_tools.', 'jaraba_candidate.', 'jaraba_comercio_conecta.',
    'jaraba_content_hub.', 'jaraba_copilot_v2.', 'jaraba_credentials.',
    'jaraba_crm.', 'jaraba_customer_success.', 'jaraba_diagnostic.',
    'jaraba_ads.', 'jaraba_email.', 'jaraba_events.', 'jaraba_funding.', 'jaraba_geo.',
