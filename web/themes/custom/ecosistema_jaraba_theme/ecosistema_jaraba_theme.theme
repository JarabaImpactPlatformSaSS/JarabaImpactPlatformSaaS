    'jaraba_facturae.document_detail',
    'jaraba_facturae.config',
    'jaraba_einvoice_b2b.dashboard',
    'jaraba_einvoice_b2b.documents',
    'jaraba_einvoice_b2b.document_detail',
    'jaraba_einvoice_b2b.payments',
    'jaraba_einvoice_b2b.config',
  ];
  if (in_array($route, $fiscal_routes) || str_starts_with((string) $route, 'jaraba_verifactu.') || str_starts_with((string) $route, 'jaraba_facturae.') || str_starts_with((string) $route, 'jaraba_einvoice_b2b.')) {
    $variables['attributes']['class'][] = 'page-fiscal';
    $variables['attributes']['class'][] = 'dashboard-page';
    $variables['attributes']['class'][] = 'full-width-layout';
    // Clase por submodulo para CSS targeting.
    if (str_starts_with((string) $route, 'jaraba_verifactu.')) {
      $variables['attributes']['class'][] = 'page-verifactu';
    }
    elseif (str_starts_with((string) $route, 'jaraba_facturae.')) {
      $variables['attributes']['class'][] = 'page-facturae';
    }
    elseif (str_starts_with((string) $route, 'jaraba_einvoice_b2b.')) {
      $variables['attributes']['class'][] = 'page-einvoice-b2b';
    }
  }

  // =========================================================================
  // STACK COMPLIANCE LEGAL N1 — Body classes para rutas de privacidad, legal y DR.
  // jaraba_privacy (GDPR/DPA), jaraba_legal (ToS/SLA/AUP), jaraba_dr (DR/Backups).
  // Plan Implementacion Stack Compliance Legal N1 v1 — FASE 0.
  // =========================================================================
  if (str_starts_with((string) $route, 'jaraba_privacy.')) {
    $variables['attributes']['class'][] = 'page-privacy';
    $variables['attributes']['class'][] = 'compliance-page';
    $variables['attributes']['class'][] = 'dashboard-page';
    $variables['attributes']['class'][] = 'full-width-layout';
  }
  if (str_starts_with((string) $route, 'jaraba_legal.')) {
    $variables['attributes']['class'][] = 'page-legal-compliance';
    $variables['attributes']['class'][] = 'compliance-page';
    $variables['attributes']['class'][] = 'dashboard-page';
    $variables['attributes']['class'][] = 'full-width-layout';
  }
  if (str_starts_with((string) $route, 'jaraba_dr.')) {
    $variables['attributes']['class'][] = 'page-dr-status';
    $variables['attributes']['class'][] = 'compliance-page';
    $variables['attributes']['class'][] = 'dashboard-page';
    $variables['attributes']['class'][] = 'full-width-layout';
  }

  // =========================================================================
  // BODY CLASSES MIGRADAS — Clases de page--*.html.twig attributes.addClass()
  //
  // Las page templates NO deben incluir <body> ni attributes.addClass() ya que
  // <body> lo renderiza html.html.twig. Las clases se centralizan aquí.
  // =========================================================================

  // Auth pages: 'auth-page' adicional (page-auth y clean-layout ya cubiertas arriba).
  if (in_array($route, ['user.login', 'user.register', 'user.pass', 'user.reset.form', 'user.reset.login'])) {
    $variables['attributes']['class'][] = 'auth-page';
  }

  // ServiciosConecta provider portal → page--servicios-dashboard.
  if (str_starts_with((string) $route, 'jaraba_servicios_conecta.provider_portal')) {
    $variables['attributes']['class'][] = 'page-wrapper--clean';
    $variables['attributes']['class'][] = 'page--servicios';
    $variables['attributes']['class'][] = 'page--servicios-dashboard';
    $variables['attributes']['class'][] = 'dashboard-page';
  }

  // ServiciosConecta marketplace → page--servicios-marketplace.
  $servicios_marketplace_routes = [
    'jaraba_servicios_conecta.marketplace',
    'jaraba_servicios_conecta.marketplace.detail',
    'jaraba_servicios_conecta.booking.create',
  ];
  if (in_array($route, $servicios_marketplace_routes)) {
    $variables['attributes']['class'][] = 'page-wrapper--clean';
    $variables['attributes']['class'][] = 'page--servicios';
    $variables['attributes']['class'][] = 'page--servicios-marketplace';
  }

  // Agent Dashboard → page--agent-dashboard.
  if (str_starts_with((string) $route, 'jaraba_agent_flows.dashboard') || $route === 'jaraba_agent_flows.agent_dashboard') {
    $variables['attributes']['class'][] = 'page-agent-dashboard';
    $variables['attributes']['class'][] = 'theme-dark';
  }

  // Credential verify → page--verify.
  if ($route === 'jaraba_credentials.verify' || $route === 'jaraba_lms.badge.verify') {
    $variables['attributes']['class'][] = 'page-verify';
    $variables['attributes']['class'][] = 'credential-verify-page';
  }

  // My certifications → page--my-certifications.
  if ($route === 'jaraba_credentials.my_credentials') {
    $variables['attributes']['class'][] = 'certifications-page';
    $variables['attributes']['class'][] = 'page-my-certifications';
  }

  // Pixels stats → page--pixels--stats.
  if ($route === 'jaraba_pixels.stats') {
    $variables['attributes']['class'][] = 'page-pixels-stats';
    $variables['attributes']['class'][] = 'dashboard-page';
  }

  // Skills → additional classes for page--skills.
  if (str_starts_with((string) $route, 'jaraba_skills.')) {
    $variables['attributes']['class'][] = 'skills-page';
  }

  // Revisions → page--revisions.
  if (str_starts_with((string) $route, 'jaraba_page_builder.revision_') || str_starts_with((string) $route, 'jaraba_skills.skill.revisions')) {
    $variables['attributes']['class'][] = 'page-revisions';
    $variables['attributes']['class'][] = 'dashboard-page';
    $variables['attributes']['class'][] = 'layout-revisions';
  }

  // Interactive → additional class for page--interactive.
  if (str_starts_with((string) $route, 'jaraba_interactive.')) {
    $variables['attributes']['class'][] = 'interactive-page';
  }

  // Eventos → additional class for page--eventos.
  if (str_starts_with((string) $route, 'jaraba_events.')) {
    $variables['attributes']['class'][] = 'eventos-page';
  }

  // Referidos → additional class for page--referidos.
  if (str_starts_with((string) $route, 'jaraba_referral.')) {
    $variables['attributes']['class'][] = 'referral-page';
  }

  // Ads → page--ads.
  if (str_starts_with((string) $route, 'jaraba_ads.')) {
    $variables['attributes']['class'][] = 'page-ads';
    $variables['attributes']['class'][] = 'ads-page';
    $variables['attributes']['class'][] = 'dashboard-page';
  }

  // Experimentos → page--experimentos.
  $experimentos_routes = [
    'jaraba_copilot_v2.experiments',
    'jaraba_copilot_v2.experiment_detail',
  ];
  if (in_array($route, $experimentos_routes)) {
    $variables['attributes']['class'][] = 'page-experimentos';
    $variables['attributes']['class'][] = 'ab-testing-page';
  }

  // =========================================================================
  // ERROR PAGES — Body classes para 404 y 403
  // Drupal usa system.404 / system.403 como route names.
  // =========================================================================
  if (str_starts_with($route, 'system.404')) {
    $variables['attributes']['class'][] = 'page--error';
    $variables['attributes']['class'][] = 'page--404';
  }
  if (str_starts_with($route, 'system.403')) {
    $variables['attributes']['class'][] = 'page--error';
    $variables['attributes']['class'][] = 'page--403';
  }

  // =========================================================================
  // ZERO REGION CATCH-ALL — Body classes para módulos custom sin cobertura
  //
  // Añade dashboard-page + full-width-layout + clase por módulo a todas
  // las rutas frontend de módulos custom que no tienen clases específicas
  // en las secciones anteriores. Solo se aplica si no se asignó ya
  // dashboard-page, landing-page, canvas-editor-page o page-auth.
  //
  // @see .agent/workflows/frontend-page-pattern.md
  // =========================================================================
  $existing_classes = $variables['attributes']['class'] ?? [];
  $has_layout_class = in_array('dashboard-page', $existing_classes)
    || in_array('landing-page', $existing_classes)
    || in_array('canvas-editor-page', $existing_classes)
    || in_array('page-auth', $existing_classes)
    || in_array('page-employability-diagnostic', $existing_classes)
    || in_array('page-empleabilidad', $existing_classes);

  if (!$has_layout_class) {
    $module_body_classes = [
      // GAP-L5: IA Level 5 dashboards (specific routes before catch-all).
      'jaraba_ai_agents.compliance_dashboard' => 'page-ai-compliance',
      'jaraba_ai_agents.autonomous_agents_dashboard' => 'page-autonomous-agents',
      'jaraba_ai_agents.causal_analytics_dashboard' => 'page-causal-analytics',
      'jaraba_agroconecta.' => 'page-agroconecta',
      'jaraba_lms.' => 'page-lms',
      'jaraba_mentoring.' => 'page-mentoring',
      'jaraba_onboarding.' => 'page-onboarding',
      'jaraba_self_discovery.' => 'page-self-discovery',
      'jaraba_tenant_knowledge.' => 'page-knowledge',
      'jaraba_legal_knowledge.' => 'page-legal',
      'jaraba_whitelabel.' => 'page-whitelabel',
      'jaraba_security_compliance.' => 'page-security',
      'jaraba_training.' => 'page-training',
      'jaraba_usage_billing.' => 'page-usage-billing',
      'jaraba_addons.' => 'page-addons',
      'jaraba_agent_flows.' => 'page-agent-flows',
      'jaraba_theming.' => 'page-theming',
      'jaraba_social.' => 'page-social',
      'jaraba_insights_hub.' => 'page-insights',
      'jaraba_geo.' => 'page-geo',
      'jaraba_analytics.' => 'page-analytics',
      'jaraba_funding.' => 'page-funding',
      'jaraba_job_board.' => 'page-job-board',
      'jaraba_candidate.' => 'page-candidate',
      'jaraba_paths.' => 'page-paths',
      'jaraba_business_tools.' => 'page-business-tools',
      'jaraba_diagnostic.' => 'page-diagnostic',
      'jaraba_copilot_v2.' => 'page-copilot',
      'jaraba_events.' => 'page-eventos',
      'jaraba_referral.' => 'page-referidos',
      'jaraba_skills.' => 'page-skills',
      'jaraba_servicios_conecta.' => 'page-servicios',
      'jaraba_comercio_conecta.' => 'page-comercio',
      'jaraba_customer_success.' => 'page-customer-success',
      'jaraba_integrations.' => 'page-integrations',
      'jaraba_crm.' => 'page-crm',
      'jaraba_i18n.' => 'page-i18n',
      'jaraba_heatmap.' => 'page-heatmap',
      'jaraba_pixels.' => 'page-pixels',
      'jaraba_credentials.' => 'page-credentials',
      'jaraba_interactive.' => 'page-interactive',
      'jaraba_content_hub.' => 'page-content-hub',
      'ecosistema_jaraba_core.dashboard.' => 'page-dashboard-auto',
      'ecosistema_jaraba_core.demo_' => 'page-demo',
      'ecosistema_jaraba_core.quiz_vertical' => 'page-quiz',
      'ecosistema_jaraba_core.lead_magnet.' => 'page-lead-magnet',
      'ecosistema_jaraba_core.marketplace.' => 'page-marketplace',
      'ecosistema_jaraba_core.onboarding.' => 'page-onboarding-core',
      'ecosistema_jaraba_core.tenant_self_service.' => 'page-self-service',
      'ecosistema_jaraba_core.reseller_portal' => 'page-reseller-portal',
      'entity.saas_plan.' => 'page-saas-plan',
      'entity.content_article.' => 'page-blog-article',
      'entity.content_category.' => 'page-blog-category',
    ];

    foreach ($module_body_classes as $prefix => $css_class) {
      if (str_starts_with($route, $prefix)) {
        $variables['attributes']['class'][] = 'dashboard-page';
        $variables['attributes']['class'][] = 'full-width-layout';
        $variables['attributes']['class'][] = $css_class;
        break;
      }
    }
  }

  if ($config->get('enable_promo_banner')) {
    $variables['attributes']['class'][] = 'has-promo-banner';
  }

  if ($config->get('show_back_to_top')) {
    $variables['attributes']['class'][] = 'has-back-to-top';
    $variables['#attached']['library'][] = 'ecosistema_jaraba_theme/back-to-top';
  }

  $dark_mode = $config->get('dark_mode') ?: 'toggle';
  if ($dark_mode === 'on') {
    $variables['attributes']['class'][] = 'dark-mode';
  }
  elseif ($dark_mode === 'toggle' || $dark_mode === 'auto') {
    $variables['#attached']['library'][] = 'ecosistema_jaraba_theme/dark-mode';
  }

  // CSS Variables mapping
  $mapping = [
    // Brand
    'color_primary' => '--ej-color-primary',
    'color_secondary' => '--ej-color-secondary',
    'color_corporate' => '--ej-color-corporate',
    'color_agro' => '--ej-color-agro',
    'color_success' => '--ej-color-success',
    'color_warning' => '--ej-color-warning',
    'color_danger' => '--ej-color-danger',
    'color_neutral' => '--ej-color-neutral',
    // Backgrounds
    'color_bg_body' => '--ej-bg-body',
    'color_bg_surface' => '--ej-bg-surface',
    'color_bg_dark' => '--ej-bg-dark',
    // Typography
    'color_headings' => '--ej-color-headings',
    'color_body_text' => '--ej-color-body',
    'color_muted' => '--ej-color-muted',
    // Header
    'color_header_bg' => '--ej-header-bg',
    'color_header_text' => '--ej-header-text',
    // Cards
    'color_card_bg' => '--ej-card-bg',
    'color_card_border' => '--ej-card-border',
    // Footer
    'color_footer_bg' => '--ej-footer-bg',
    'color_footer_text' => '--ej-footer-text',
    // Sidebar
    'color_sidebar_bg' => '--ej-sidebar-bg',
    'color_sidebar_title' => '--ej-sidebar-title',
    'color_sidebar_link' => '--ej-sidebar-link',
    'color_sidebar_link_hover' => '--ej-sidebar-link-hover',
    'color_sidebar_link_active' => '--ej-sidebar-link-active',
    // Buttons
    'color_btn_primary_bg' => '--ej-btn-primary-bg',
    'color_btn_primary_text' => '--ej-btn-primary-text',
    'color_btn_secondary_bg' => '--ej-btn-secondary-bg',
    'color_btn_secondary_text' => '--ej-btn-secondary-text',
    // Forms
    'color_input_bg' => '--ej-input-bg',
    'color_input_border' => '--ej-input-border',
    'color_input_focus' => '--ej-input-focus',
    // Products
    'color_product_price' => '--ej-product-price',
    'color_product_badge' => '--ej-product-badge',
    // Banner
    'color_promo_bg' => '--ej-promo-bg',
    'color_promo_text' => '--ej-promo-text',
    // Breadcrumbs
    'color_breadcrumb_text' => '--ej-breadcrumb-text',
    'color_breadcrumb_link' => '--ej-breadcrumb-link',
    'color_breadcrumb_active' => '--ej-breadcrumb-active',
  ];

  $css_vars = '';
  foreach ($mapping as $setting => $var) {
    $val = $config->get($setting);
    if ($val) {
      $css_vars .= "$var: $val;\n";
    }
  }

  // Numeric vars
  $font_size = $config->get('font_size_base') ?: 16;
  $css_vars .= "--ej-font-size-base: {$font_size}px;\n";

  $logo_height = $config->get('logo_height') ?: 45;
  $css_vars .= "--ej-logo-height: {$logo_height}px;\n";

  $card_radius = $config->get('card_border_radius') ?: 12;
  $css_vars .= "--ej-card-radius: {$card_radius}px;\n";

  $btn_radius = $config->get('btn_border_radius') ?: 8;
  $css_vars .= "--ej-btn-radius: {$btn_radius}px;\n";

  $hero_overlay = $config->get('hero_overlay_opacity') ?: 60;
  $css_vars .= "--ej-hero-overlay: {$hero_overlay}%;\n";

  // Fonts
  $font_map = [
    'outfit' => ['"Outfit", sans-serif', 'Outfit:wght@300;400;500;600;700'],
    'montserrat' => ['"Montserrat", sans-serif', 'Montserrat:wght@400;500;700'],
    'poppins' => ['"Poppins", sans-serif', 'Poppins:wght@400;500;700'],
    'inter' => ['"Inter", sans-serif', 'Inter:wght@400;500;700'],
    'lora' => ['"Lora", serif', 'Lora:wght@400;500;700'],
    'playfair' => ['"Playfair Display", serif', 'Playfair+Display:wght@400;500;700'],
    'roboto' => ['"Roboto", sans-serif', 'Roboto:wght@400;500;700'],
  ];

  $h_font = $config->get('typography_headings') ?: 'outfit';
  $b_font = $config->get('typography_body') ?: 'inter';

  $families = [];
  if (isset($font_map[$h_font])) {
    $families[] = $font_map[$h_font][1];
    $css_vars .= "--ej-font-headings: " . $font_map[$h_font][0] . ";\n";
  }
  if (isset($font_map[$b_font])) {
    $families[] = $font_map[$b_font][1];
    $css_vars .= "--ej-font-body: " . $font_map[$b_font][0] . ";\n";
  }
  $families = array_unique($families);

  // Google Fonts
  if (!empty($families)) {
    $gf_url = 'https://fonts.googleapis.com/css2?family=' . implode('&family=', $families) . '&display=swap';
    $variables['#attached']['html_head'][] = [
      [
        '#type' => 'html_tag',
        '#tag' => 'link',
        '#attributes' => ['rel' => 'stylesheet', 'href' => $gf_url],
      ],
      'jaraba_google_fonts',
    ];
  }

  // RTL support: directional CSS custom properties (GAP-RTL).
  $dir = $language->getDirection();
  if ($dir === 'rtl') {
    $css_vars .= "--ej-dir-start: right;\n";
    $css_vars .= "--ej-dir-end: left;\n";
  }
  else {
    $css_vars .= "--ej-dir-start: left;\n";
    $css_vars .= "--ej-dir-end: right;\n";
  }

  // Inject CSS vars
  if (!empty($css_vars)) {
    $variables['#attached']['html_head'][] = [
      [
        '#tag' => 'style',
        '#value' => Markup::create(":root {\n{$css_vars}}\n"),
      ],
      'jaraba_css_vars',
    ];
  }

  // Custom CSS
  $custom_css = $config->get('custom_css');
  if (!empty($custom_css)) {
    $variables['#attached']['html_head'][] = [
      [
        '#tag' => 'style',
        '#value' => Markup::create($custom_css),
      ],
      'jaraba_custom_css',
    ];
  }

  // NOTA: Tenant CSS tokens se inyectan desde jaraba_theming_page_attachments()
  // usando UnifiedThemeResolverService (THEMING-UNIFY-001). Se elimino el
  // bloque duplicado 'jaraba-tenant-tokens' que existia aqui.

  // =========================================================================
  // SEO META TAGS - Homepage optimizada para motores de búsqueda y GEO
  // Soporta datos dinámicos desde HomepageContent o fallbacks hardcodeados
  // =========================================================================
  $is_front = \Drupal::service('path.matcher')->isFrontPage();
  $request = \Drupal::request();
  $site_config = \Drupal::config('system.site');
  $site_name = $site_config->get('name') ?: 'Jaraba Impact Platform';
  
  if ($is_front) {
    // Intentar cargar datos SEO dinámicos desde HomepageContent
    $seo_data = [];
    try {
      /** @var \Drupal\jaraba_page_builder\Service\HomepageDataService $homepage_service */
      $homepage_service = \Drupal::service('jaraba_page_builder.homepage_data');
      $homepage_data = $homepage_service->getHomepageData();
      $seo_data = $homepage_data['seo'] ?? [];
      
      // DEBUG: Log para diagnosticar datos SEO
      \Drupal::logger('ecosistema_jaraba_theme')->debug(
        'SEO Debug - Data loaded: meta_title=[@title], meta_description=[@desc], has_data=@has',
        [
          '@title' => $seo_data['meta_title'] ?? 'NULL',
          '@desc' => substr($seo_data['meta_description'] ?? 'NULL', 0, 50),
          '@has' => !empty($seo_data['meta_title']) || !empty($seo_data['meta_description']) ? 'YES' : 'NO',
        ]
      );
    }
    catch (\Exception $e) {
      // Servicio no disponible, usar fallbacks
      \Drupal::logger('ecosistema_jaraba_theme')->warning('SEO Debug - Exception: @msg', ['@msg' => $e->getMessage()]);
    }

    // Meta Title: preferir dato dinámico
    $meta_title = !empty($seo_data['meta_title']) 
      ? $seo_data['meta_title']
      : t('Impulsa tu ecosistema digital | @site', ['@site' => $site_name]);

    // Meta description: preferir dato dinámico
    $description = !empty($seo_data['meta_description'])
      ? $seo_data['meta_description']
      : t('Plataforma SaaS que conecta talento, negocios y emprendedores con inteligencia artificial. Empleabilidad, emprendimiento, comercio y servicios profesionales en un solo ecosistema.');
    
    // OG Image: preferir dato dinámico
    $og_image = !empty($seo_data['og_image_url'])
      ? $seo_data['og_image_url']
      : $request->getSchemeAndHttpHost() . '/themes/custom/ecosistema_jaraba_theme/images/og-image.jpg';

    $variables['#attached']['html_head'][] = [
      [
        '#tag' => 'meta',
        '#attributes' => [
          'name' => 'description',
          'content' => $description,
        ],
      ],
      'meta_description',
    ];

    // Open Graph tags
    $og_url = $request->getSchemeAndHttpHost() . '/';

    $variables['#attached']['html_head'][] = [
      ['#tag' => 'meta', '#attributes' => ['property' => 'og:type', 'content' => 'website']],
      'og_type',
    ];
    $variables['#attached']['html_head'][] = [
      ['#tag' => 'meta', '#attributes' => ['property' => 'og:title', 'content' => $meta_title]],
      'og_title',
    ];
    $variables['#attached']['html_head'][] = [
      ['#tag' => 'meta', '#attributes' => ['property' => 'og:description', 'content' => $description]],
      'og_description',
    ];
    $variables['#attached']['html_head'][] = [
      ['#tag' => 'meta', '#attributes' => ['property' => 'og:url', 'content' => $og_url]],
      'og_url',
    ];
    $variables['#attached']['html_head'][] = [
      ['#tag' => 'meta', '#attributes' => ['property' => 'og:image', 'content' => $og_image]],
      'og_image',
    ];
    $variables['#attached']['html_head'][] = [
      ['#tag' => 'meta', '#attributes' => ['property' => 'og:site_name', 'content' => $site_name]],
      'og_site_name',
    ];
    $variables['#attached']['html_head'][] = [
      ['#tag' => 'meta', '#attributes' => ['property' => 'og:locale', 'content' => 'es_ES']],
      'og_locale',
    ];

    // Twitter Card tags
    $variables['#attached']['html_head'][] = [
      ['#tag' => 'meta', '#attributes' => ['name' => 'twitter:card', 'content' => 'summary_large_image']],
      'twitter_card',
    ];
    $variables['#attached']['html_head'][] = [
      ['#tag' => 'meta', '#attributes' => ['name' => 'twitter:title', 'content' => $meta_title]],
      'twitter_title',
    ];
    $variables['#attached']['html_head'][] = [
      ['#tag' => 'meta', '#attributes' => ['name' => 'twitter:description', 'content' => $description]],
      'twitter_description',
    ];
    $variables['#attached']['html_head'][] = [
      ['#tag' => 'meta', '#attributes' => ['name' => 'twitter:image', 'content' => $og_image]],
      'twitter_image',
    ];
    
    // Twitter site handle - cuenta principal de Jaraba.
    $variables['#attached']['html_head'][] = [
      ['#tag' => 'meta', '#attributes' => ['name' => 'twitter:site', 'content' => '@JarabaEcosistema']],
      'twitter_site',
    ];
    
    // Twitter creator - dinámico por tenant si está disponible.
    $twitter_creator = '@JarabaEcosistema';
    try {
      // Intentar obtener handle de Twitter del tenant actual.
      $tenant_resolver = \Drupal::service('jaraba_page_builder.tenant_resolver');
      $tenant = $tenant_resolver->getCurrentTenant();
      if ($tenant && $tenant->hasField('field_twitter_handle') && !$tenant->get('field_twitter_handle')->isEmpty()) {
        $twitter_creator = $tenant->get('field_twitter_handle')->value;
      }
    }
    catch (\Exception $e) {
      // Usar handle por defecto.
    }
    $variables['#attached']['html_head'][] = [
      ['#tag' => 'meta', '#attributes' => ['name' => 'twitter:creator', 'content' => $twitter_creator]],
      'twitter_creator',
    ];

    // Canonical URL
    $variables['#attached']['html_head'][] = [
      ['#tag' => 'link', '#attributes' => ['rel' => 'canonical', 'href' => $og_url]],
      'canonical',
    ];
  }

  // =========================================================================
  // GAP-AUD-008: Command Bar (Cmd+K) — Global command palette.
  // Attach library and set variable for authenticated non-admin pages.
  // Toggle via theme setting 'command_bar_enabled' (default TRUE).
  // =========================================================================
  $command_bar_enabled = $config->get('command_bar_enabled') ?? TRUE;
  if ($command_bar_enabled && \Drupal::currentUser()->isAuthenticated()) {
    $variables['#attached']['library'][] = 'ecosistema_jaraba_theme/command-bar';
    $variables['command_bar_enabled'] = TRUE;
  }
  else {
    $variables['command_bar_enabled'] = FALSE;
  }

  // PERF-02: Inyectar critical CSS inline en <head> para evitar render-blocking.
  $theme_path = \Drupal::service('extension.list.theme')->getPath('ecosistema_jaraba_theme');
  $critical_css_file = DRUPAL_ROOT . '/' . $theme_path . '/css/critical/homepage.css';
  if (file_exists($critical_css_file)) {
    $critical_css = file_get_contents($critical_css_file);
    if (!empty($critical_css)) {
      $variables['#attached']['html_head'][] = [
        [
          '#tag' => 'style',
          '#value' => $critical_css,
          '#attributes' => ['id' => 'critical-css'],
        ],
        'critical_css',
      ];
    }
  }

  // =========================================================================
  // BOTTOM NAV MOBILE — body class + library (FASE 5 Elevacion Clase Mundial)
  // Solo para usuarios autenticados en el SaaS, no en meta-sites.
  // El CSS de .bottom-nav ya existe en _mobile-components.scss:150-282.
  // body.has-bottom-nav aplica padding-bottom compensatorio en mobile.
  // =========================================================================
  $is_logged_in = \Drupal::currentUser()->isAuthenticated();
  $is_meta_site = in_array('meta-site', $variables['attributes']['class'] ?? []);
  // Pass to html.html.twig for conditional PED schema include.
  $variables['is_meta_site'] = $is_meta_site;

  // Skip Twig hreflang partial on page_content routes (HreflangService handles those).
  $route_name = \Drupal::routeMatch()->getRouteName();
  $variables['is_page_content'] = ($route_name === 'entity.page_content.canonical');

  // Hreflang: pass available languages to html.html.twig for _hreflang-meta.html.twig.
  $language_manager = \Drupal::languageManager();
  $route_match_hl = \Drupal::routeMatch();
  $route_name_hl = $route_match_hl->getRouteName();
  $route_params_hl = $route_match_hl->getRawParameters()->all();
  $host_hl = \Drupal::request()->getSchemeAndHttpHost();
  $hl_links = [];
  if ($route_name_hl) {
    foreach ($language_manager->getLanguages() as $langcode => $language) {
      try {
        $url = \Drupal\Core\Url::fromRoute($route_name_hl, $route_params_hl, [
          'language' => $language,
          'absolute' => TRUE,
        ]);
        $hl_links[$langcode] = $url->toString();
      }
      catch (\Throwable $e) {
        // UPDATE-HOOK-CATCH-001: \Throwable no \Exception.
        $hl_links[$langcode] = $host_hl . '/' . $langcode;
      }
    }
  }
  $variables['available_languages'] = array_keys($hl_links);
  $variables['language_links'] = $hl_links;
  $variables['current_langcode'] = $language_manager->getCurrentLanguage()->getId();

  if ($is_logged_in && !$is_meta_site) {
    $variables['attributes']['class'][] = 'has-bottom-nav';
    $variables['#attached']['library'][] = 'ecosistema_jaraba_theme/bottom-nav';
    // Quick-Start Overlay — primera visita (FASE 8 Elevacion Clase Mundial).
    $variables['#attached']['library'][] = 'ecosistema_jaraba_theme/quick-start';
  }

  // =========================================================================
  // SEO P1: Preconnect / DNS-prefetch para recursos externos.
  // Reduce latencia de Google Fonts, Stripe, y APIs externas.
  // =========================================================================
  $preconnect_origins = [
    'https://fonts.googleapis.com',
    'https://fonts.gstatic.com',
    'https://js.stripe.com',
  ];
  foreach ($preconnect_origins as $idx => $origin) {
    $variables['page']['#attached']['html_head'][] = [
      [
        '#tag' => 'link',
        '#attributes' => [
          'rel' => 'preconnect',
          'href' => $origin,
          'crossorigin' => 'anonymous',
        ],
      ],
      'preconnect_' . $idx,
    ];
    $variables['page']['#attached']['html_head'][] = [
      [
        '#tag' => 'link',
        '#attributes' => [
          'rel' => 'dns-prefetch',
          'href' => $origin,
        ],
      ],
      'dns_prefetch_' . $idx,
    ];
  }
}

/**
 * Implements hook_preprocess_page().
 */
function ecosistema_jaraba_theme_preprocess_page(&$variables) {
  $config = \Drupal::config('ecosistema_jaraba_theme.settings');
  $variables['theme_settings'] = _ecosistema_jaraba_theme_get_base_settings($config);

  // Default values
  if (!isset($variables['theme_settings']['header_layout'])) {
    $variables['theme_settings']['header_layout'] = 'classic';
  }

  // Logo para page--front.html.twig (Twig limpia sin regiones)
  $logo_settings = theme_get_setting('logo', 'ecosistema_jaraba_theme');
  if (!empty($logo_settings['path'])) {
    $file_url_generator = \Drupal::service('file_url_generator');
    $variables['logo'] = $file_url_generator->generateAbsoluteString($logo_settings['path']);
  }

  // Site name y slogan para landing page
  $site_config = \Drupal::config('system.site');
  $variables['site_name'] = $site_config->get('name') ?: 'Jaraba Impact Platform';
  $variables['site_slogan'] = $site_config->get('slogan') ?: 'Impulsando el talento y la innovación';

  // Item 1 — Vertical Brand: expose Twig variables for templates.
  $variables['vertical_brand_name'] = '';
  $variables['vertical_tagline'] = '';
  $variables['vertical_icon'] = [];
  try {
    if (\Drupal::hasService('entity_type.manager')) {
      $etm = \Drupal::entityTypeManager();
      if ($etm->hasDefinition('vertical_brand')) {
        $route = (string) \Drupal::routeMatch()->getRouteName();
        $brands = $etm->getStorage('vertical_brand')->loadMultiple();
        foreach ($brands as $brand) {
          if ($brand->isEnabled() && $brand->getLandingRoute() === $route) {
            $variables['vertical_brand_name'] = $brand->getPublicName();
            $variables['vertical_tagline'] = $brand->getTagline();
            $variables['vertical_icon'] = [
              'category' => $brand->getIconCategory(),
              'name' => $brand->getIconName(),
            ];
            break;
          }
        }
      }
    }
  }
  catch (\Throwable) {
    // Theme must never crash.
  }

  // =========================================================================
  // THEMING-UNIFY-001: Cascada unificada de tema multi-tenant
  //
  // Usa UnifiedThemeResolverService para resolver la configuracion visual
  // completa del request actual. Funciona para TODAS las rutas (no solo
  // page_content), tanto para usuarios anonimos (por hostname) como
  // autenticados (por TenantContextService).
  //
  // Cascada de 5 niveles:
  // 1. Plataforma (theme settings globales — ya aplicados arriba)
  // 2. Vertical (IndustryPresetService — reservado)
  // 3. Plan (features por plan — reservado)
  // 4. Tenant (TenantThemeConfig — personalizacion visual)
  // 5. Meta-sitio (SiteConfig — override estructural por dominio)
  // =========================================================================
  $variables['meta_site'] = NULL;
  try {
    if (\Drupal::hasService('ecosistema_jaraba_core.unified_theme_resolver')) {
      /** @var \Drupal\ecosistema_jaraba_core\Service\UnifiedThemeResolverService $resolver */
      $resolver = \Drupal::service('ecosistema_jaraba_core.unified_theme_resolver');
      $themeContext = $resolver->resolveForCurrentRequest();

      // Aplicar theme_overrides (cascada Nivel 4 + Nivel 5) sobre theme_settings.
      if (!empty($themeContext['theme_overrides'])) {
        $variables['theme_settings'] = array_merge(
          $variables['theme_settings'],
          $themeContext['theme_overrides']
        );
      }

      // Meta-sitio context para templates (schema.org, canonical, etc.).
      if ($themeContext['meta_site'] !== NULL) {
        $variables['meta_site'] = $themeContext['meta_site'];

        // Override site_name y site_slogan desde el meta-sitio.
        $variables['site_name'] = $themeContext['meta_site']['tenant_name'] ?? $variables['site_name'];

        // SiteConfig para slogan y logo.
        $siteConfig = $themeContext['site_config'];
        if ($siteConfig !== NULL) {
          // Resolver traduccion del SiteConfig para idioma actual.
          $currentLangcode = \Drupal::languageManager()->getCurrentLanguage()->getId();
          if ($siteConfig->isTranslatable() && $siteConfig->hasTranslation($currentLangcode)) {
            $siteConfig = $siteConfig->getTranslation($currentLangcode);
          }

          if (method_exists($siteConfig, 'getTagline')) {
            $variables['site_slogan'] = $siteConfig->getTagline() ?: '';
          }

          // Logo del tenant si esta configurado.
          if ($siteConfig->hasField('site_logo')) {
            $logoFile = $siteConfig->get('site_logo')->entity ?? NULL;
            if ($logoFile) {
              $file_url_generator = \Drupal::service('file_url_generator');
              $variables['logo'] = $file_url_generator->generateAbsoluteString($logoFile->getFileUri());
            }
          }
        }

        // Schema.org type: Person para pepejaraba (marca personal), Organization para el resto.
        $schemaType = 'Organization';
        if (($themeContext['meta_site']['group_id'] ?? 0) == 5) {
          $schemaType = 'Person';
        }
        $variables['meta_site']['schema_type'] = $schemaType;

        // Canonical URL: dominio de produccion del tenant.
        if ($siteConfig !== NULL && $siteConfig->hasField('tenant_id')) {
          $tenantEntity = $siteConfig->get('tenant_id')->entity ?? NULL;
          if ($tenantEntity && $tenantEntity->hasField('domain')) {
            $tenantDomain = $tenantEntity->get('domain')->value ?? NULL;
            if ($tenantDomain) {
              $variables['meta_site']['canonical_url'] = 'https://' . $tenantDomain;
            }
          }
        }
      }
    }
  }
  catch (\Throwable) {
    // UnifiedThemeResolver no disponible o error — usar valores por defecto.
  }

  // =========================================================================
  // I18N: Inject available languages with proper switch links.
  // Uses Drupal's language negotiation to generate correct URLs for
  // the current page in each available language (handles prefixes,
  // content translations, and path aliases).
  // @see templates/partials/_language-switcher.html.twig
  // @see templates/partials/_header-classic.html.twig (lines 163-168)
  // =========================================================================
  $language_manager = \Drupal::languageManager();
  $current_language = $language_manager->getCurrentLanguage();
  $variables['current_langcode'] = $current_language->getId();
  $defaultLangcode = $language_manager->getDefaultLanguage()->getId();

  // I18N-NAVPREFIX-001: Language prefix for all navigation links.
  // When path_prefix negotiation has a prefix for the current language,
  // ALWAYS include it — even for the default language. Drupal's
  // LanguageNegotiationUrl with `es: es` prefix forces /es/ on all requests.
  $langNegConfig = \Drupal::config('language.negotiation');
  $prefixes = $langNegConfig->get('url.prefixes') ?? [];
  $langId = $current_language->getId();
  $variables['language_prefix'] = !empty($prefixes[$langId])
    ? '/' . $prefixes[$langId]
    : '';

  // Build language switch links for the current page.
  $route_match = \Drupal::routeMatch();
  $route_name = $route_match->getRouteName();
  $route_params = $route_match->getRawParameters()->all();

  $language_links = [];

  // I18N-LANGSWITCHER-001: For page_content routes, use the translated
  // path_alias directly instead of Url::fromRoute() which generates /page/ID.
  // page_content has no outbound path processor, so the language switcher
  // must build friendly URLs manually using each translation's path_alias.
  $page_content = NULL;
  if ($route_name === 'entity.page_content.canonical') {
    $page_content = $route_match->getParameter('page_content');
  }

  foreach ($language_manager->getLanguages() as $langcode => $language) {
    try {
      if ($page_content && $page_content->hasTranslation($langcode)) {
        $translation = $page_content->getTranslation($langcode);
        $alias = $translation->get('path_alias')->value ?? '';
        if (!empty($alias)) {
          // Build absolute URL with language prefix for hreflang.
          $host = \Drupal::request()->getSchemeAndHttpHost();
          $prefix = ($langcode !== $defaultLangcode) ? '/' . $langcode : '';
          $language_links[$langcode] = $host . $prefix . $alias;
          continue;
        }
      }

      // Generic route-based URL generation for non-page_content routes.
      // HREFLANG-CONDITIONAL-001: 'absolute' => TRUE obligatorio para hreflang.
      $url = \Drupal\Core\Url::fromRoute($route_name ?: '<front>', $route_params, [
        'language' => $language,
        'absolute' => TRUE,
      ]);
      $language_links[$langcode] = $url->toString();
    }
    catch (\Exception $e) {
      // Fallback to language prefix root if route can't be resolved.
      $language_links[$langcode] = \Drupal::request()->getSchemeAndHttpHost() . '/' . $langcode;
    }
  }
  $variables['available_languages'] = array_keys($language_links);
  $variables['language_links'] = $language_links;

  // =========================================================================
  // MEGAMENU: Solo para SaaS principal (NO meta-sitios)
  //
  // Si $variables['meta_site'] es NULL, estamos en el SaaS principal →
  // activar megamenu. Los meta-sitios ya inyectan sus nav_items via
  // MetaSiteResolverService y NO tendrán header_megamenu.
  //
  // @see _header-classic.html.twig — Usa ts.header_megamenu|default(false)
  // @see docs/implementacion/20260227-Plan_Correccion_Navegacion_Ecosistema_v1.md §7.2
  // =========================================================================
  if (empty($variables['meta_site'])) {
    $variables['theme_settings']['header_megamenu'] = TRUE;

    // Mega menu columns: Fase B — primero intenta datos configurables desde UI
    // (SiteMenuItem entities via MegaMenuBridgeService). Si no hay menú
    // configurado, usa fallback hardcodeado (Fase A).
    $lp = $variables['language_prefix'] ?? '';
    $dynamicColumns = NULL;
    if (\Drupal::hasService('ecosistema_jaraba_core.mega_menu_bridge')) {
      $dynamicColumns = \Drupal::service('ecosistema_jaraba_core.mega_menu_bridge')->getMegaMenuColumns();
    }
    $variables['mega_menu_columns'] = $dynamicColumns ?? [
      [
        'title' => t('Para Personas'),
        'items' => [
          [
            'title' => t('Empleabilidad'),
            'subtitle' => t('Impulsa tu carrera con IA'),
            'icon_cat' => 'verticals',
            'icon_name' => 'empleabilidad',
            'color' => 'verde-innovacion',
            'url' => $lp . '/empleabilidad',
          ],
          [
            'title' => t('Formación'),
            'subtitle' => t('Cursos y certificaciones'),
            'icon_cat' => 'verticals',
            'icon_name' => 'formacion',
            'color' => 'verde-innovacion',
            'url' => $lp . '/formacion',
          ],
        ],
      ],
      [
        'title' => t('Para Empresas'),
        'items' => [
          [
            'title' => t('Emprendimiento'),
            'subtitle' => t('De la idea al negocio'),
            'icon_cat' => 'verticals',
            'icon_name' => 'emprendimiento',
            'color' => 'naranja-impulso',
            'url' => $lp . '/emprendimiento',
          ],
          [
            'title' => t('ComercioConecta'),
            'subtitle' => t('Digitaliza tu comercio'),
            'icon_cat' => 'verticals',
            'icon_name' => 'comercioconecta',
            'color' => 'naranja-impulso',
            'url' => $lp . '/comercioconecta',
          ],
          [
            'title' => t('AgroConecta'),
            'subtitle' => t('Marketplace agroalimentario'),
            'icon_cat' => 'verticals',
            'icon_name' => 'agroconecta',
            'color' => 'naranja-impulso',
            'url' => $lp . '/agroconecta',
          ],
          [
            'title' => t('ServiciosConecta'),
            'subtitle' => t('Gestión de servicios'),
            'icon_cat' => 'verticals',
            'icon_name' => 'serviciosconecta',
            'color' => 'naranja-impulso',
            'url' => $lp . '/serviciosconecta',
          ],
        ],
      ],
      [
        'title' => t('Para Profesionales'),
        'items' => [
          [
            'title' => t('JarabaLex'),
            'subtitle' => t('Inteligencia legal con IA'),
            'icon_cat' => 'verticals',
            'icon_name' => 'jarabalex',
            'color' => 'azul-corporativo',
            'url' => $lp . '/jarabalex',
          ],
          [
            'title' => t('Content Hub'),
            'subtitle' => t('Crea y publica contenido'),
            'icon_cat' => 'content',
            'icon_name' => 'edit',
            'color' => 'azul-corporativo',
            'url' => $lp . '/content-hub',
          ],
        ],
      ],
      [
        'title' => t('Para Instituciones'),
        'has_promo' => TRUE,
        'items' => [
          [
            'title' => t('Andalucía +ei'),
            'subtitle' => t('Empleo e innovación regional'),
            'icon_cat' => 'verticals',
            'icon_name' => 'andalucia-ei',
            'color' => 'verde-innovacion',
            'url' => $lp . '/andalucia-ei',
          ],
        ],
      ],
    ];
  }

  // =========================================================================
  // QUIZ DE RECOMENDACIÓN DE VERTICAL — Datos para templates
  //
  // ZERO-REGION-001: El controller devuelve markup vacío. Los datos se
  // inyectan aquí como variables de template (NO como render arrays con
  // keys sin # — eso causa InvalidArgumentException en Drupal renderer).
  // =========================================================================
  $route = \Drupal::routeMatch()->getRouteName();

  if ($route === 'ecosistema_jaraba_core.quiz_vertical') {
    // Quiz page: inyectar preguntas como JSON en drupalSettings.
    // Drupal renderer trata arrays con keys sin # como render children →
    // InvalidArgumentException. La solución es renderizar el quiz 100% client-side
    // desde drupalSettings, y el servidor solo proporciona el contenedor HTML.
    if (\Drupal::hasService('ecosistema_jaraba_core.vertical_quiz')) {
      $quizService = \Drupal::service('ecosistema_jaraba_core.vertical_quiz');
      // Estructura adaptativa completa: Q1 + Q2/Q3 por perfil + reacciones IA.
      $structure = $quizService->getQuizStructure();
      $variables['#attached']['drupalSettings']['verticalQuiz'] = [
        'structure' => $structure,
        'submitEndpoint' => \Drupal\Core\Url::fromRoute('ecosistema_jaraba_core.quiz_vertical.submit')->toString(),
        'resultBaseUrl' => \Drupal\Core\Url::fromRoute('ecosistema_jaraba_core.quiz_vertical', [], ['absolute' => FALSE])->toString() . '/resultado/',
      ];
    }
    // Full-width container — JS renderiza el quiz adaptativo.
    $variables['quiz_html'] = Markup::create('<div id="quiz-app"></div>');
  }

  if ($route === 'ecosistema_jaraba_core.quiz_vertical.result') {
    // Result page: inyectar resultado como JSON en drupalSettings.
    $variables['quiz_result_html'] = '';
    $uuid = \Drupal::routeMatch()->getParameter('uuid');
    if ($uuid && \Drupal::hasService('ecosistema_jaraba_core.vertical_quiz')) {
      $quizService = \Drupal::service('ecosistema_jaraba_core.vertical_quiz');
      $result = $quizService->getResultByUuid($uuid);
      if ($result) {
        $vertical = $result->getRecommendedVertical();
        $verticalData = $quizService->getVerticalPresentation($vertical);
        $variables['#attached']['drupalSettings']['verticalQuizResult'] = [
          'uuid' => $result->uuid(),
          'vertical_id' => $vertical,
          'vertical_title' => $verticalData['title'] ?? $vertical,
          'path' => $verticalData['path'] ?? $vertical,
          'icon_cat' => $verticalData['icon_cat'] ?? 'verticals',
          'icon_name' => $verticalData['icon_name'] ?? $vertical,
          'color' => $verticalData['color'] ?? 'azul-corporativo',
          'benefits' => array_map('strval', $verticalData['benefits'] ?? []),
          'price_from' => $verticalData['price_from'] ?? '0€',
          'ai_explanation' => $result->get('ai_explanation')->value ?? '',
          'alternatives' => _ecosistema_jaraba_theme_normalize_quiz_alternatives($result),
          'demo_profile' => $verticalData['demo_profile'] ?? '',
          'logged_in' => !empty($variables['logged_in']),
          'language_prefix' => $variables['language_prefix'] ?? '',
        ];
        // El email capture form necesita submitEndpoint para POST.
        $variables['#attached']['drupalSettings']['verticalQuiz'] = [
          'submitEndpoint' => \Drupal\Core\Url::fromRoute('ecosistema_jaraba_core.quiz_vertical.submit')->toString(),
        ];
        $variables['quiz_result_html'] = Markup::create('<div class="quiz-result__container" id="quiz-result-app"></div>');
      }
    }
  }

  // =========================================================================
  // PED META-SITE HOMEPAGE DETECTION
  //
  // El PathProcessor reescribe "/" a "/page/{id}" para meta-sitios, por lo que
  // isFrontPage() devuelve FALSE. Detectamos el homepage de PED comparando el
  // PageContent actual con el homepage_id del SiteConfig del tenant.
  //
  // Variables inyectadas:
  // - is_ped: TRUE si grupo 7 (plataformadeecosistemas.es)
  // - is_meta_homepage: TRUE si el PageContent actual es el homepage del tenant
  // - audience: audiencia detectada (legal, b2g, empleo, emprendimiento)
  // - ped_urls: URLs resueltas con prefijo de idioma (ROUTE-LANGPREFIX-001)
  // =========================================================================
  $variables['is_ped'] = FALSE;
  $variables['is_meta_homepage'] = FALSE;
  $variables['audience'] = NULL;
  $variables['ped_urls'] = [];

  if (!empty($variables['meta_site'])) {
    $variables['is_ped'] = (int) ($variables['meta_site']['group_id'] ?? 0) === 7;

    // Detectar si estamos en la homepage del meta-sitio.
    $route_match_pb = \Drupal::routeMatch();
    if ($route_match_pb->getRouteName() === 'entity.page_content.canonical') {
      $page_content_entity = $route_match_pb->getParameter('page_content');
      if ($page_content_entity instanceof \Drupal\jaraba_page_builder\Entity\PageContent) {
        try {
          /** @var \Drupal\jaraba_site_builder\Service\MetaSiteResolverService $metaResolver */
          $metaResolver = \Drupal::service('jaraba_site_builder.meta_site_resolver');
          $metaSiteData = $metaResolver->resolveFromRequest(\Drupal::request());
          if ($metaSiteData && $metaSiteData['site_config']) {
            $homepageId = $metaSiteData['site_config']->get('homepage_id')->target_id ?? NULL;
            if ($homepageId && (int) $page_content_entity->id() === (int) $homepageId) {
              $variables['is_meta_homepage'] = TRUE;
            }
          }
        }
        catch (\Throwable) {
          // MetaSiteResolver no disponible.
        }
      }
    }

    // Si es homepage de PED: inyectar audiencia y URLs.
    if ($variables['is_ped'] && $variables['is_meta_homepage']) {
      // Audience detection cascade: UTM → cookie → AvatarDetection.
      $audience = NULL;
      $request = \Drupal::request();
      $audience = $request->query->get('audience');
      if (empty($audience) && $request->cookies->has('jaraba_audience')) {
        $audience = $request->cookies->get('jaraba_audience');
      }
      if (empty($audience) && \Drupal::hasService('ecosistema_jaraba_core.avatar_detection')) {
        try {
          $avatarDetection = \Drupal::service('ecosistema_jaraba_core.avatar_detection')->detect();
          $avatarMap = [
            'lawyer' => 'legal',
            'government' => 'b2g',
            'jobseeker' => 'empleo',
            'entrepreneur' => 'emprendimiento',
          ];
          $audience = $avatarMap[$avatarDetection->getAvatarType()] ?? NULL;
        }
        catch (\Throwable) {
        }
      }
      $validAudiences = ['legal', 'b2g', 'empleo', 'emprendimiento'];
      $variables['audience'] = in_array($audience, $validAudiences, TRUE) ? $audience : NULL;

      // PED URLs con prefijo de idioma (ROUTE-LANGPREFIX-001).
      $pedPaths = [
        'register' => '/user/register',
        'jarabalex' => '/jarabalex',
        'contacto' => '/contacto',
        'metodo' => '/metodo',
        'empleabilidad' => '/empleabilidad',
        'emprendimiento' => '/emprendimiento',
        'agroconecta' => '/agroconecta',
        'comercioconecta' => '/comercioconecta',
        'serviciosconecta' => '/serviciosconecta',
        'formacion' => '/formacion',
        'andalucia_ei' => '/andalucia-ei',
        'dashboard' => '/user',
        'demo' => '/demo',
      ];
      foreach ($pedPaths as $key => $path) {
        try {
          if ($key === 'register') {
            $variables['ped_urls'][$key] = \Drupal\Core\Url::fromRoute('user.register')->toString();
          }
          else {
            $variables['ped_urls'][$key] = \Drupal\Core\Url::fromUserInput($path)->toString();
          }
        }
        catch (\Throwable) {
          $variables['ped_urls'][$key] = $path;
        }
      }
    }
  }

  // =========================================================================
  // GLOBAL ped_urls — Resolve ALL internal URLs with language prefix.
  // ROUTE-LANGPREFIX-001: Even the generic flow needs properly prefixed URLs
  // for cross-pollination, CTA banners, etc. PED block above may have already
  // set these; this block ensures they exist for ALL flows.
  // =========================================================================
  if (empty($variables['ped_urls'])) {
    $globalPaths = [
      'register' => '/user/register',
      'empleabilidad' => '/empleabilidad',
      'emprendimiento' => '/emprendimiento',
      'agroconecta' => '/agroconecta',
      'comercioconecta' => '/comercioconecta',
      'serviciosconecta' => '/serviciosconecta',
      'jarabalex' => '/jarabalex',
      'formacion' => '/formacion',
      'andalucia_ei' => '/andalucia-ei',
      'dashboard' => '/user',
      'demo' => '/demo',
      'contacto' => '/contacto',
    ];
    $variables['ped_urls'] = [];
    foreach ($globalPaths as $key => $path) {
      try {
        if ($key === 'register') {
          $variables['ped_urls'][$key] = \Drupal\Core\Url::fromRoute('user.register')->toString();
        }
        else {
          $variables['ped_urls'][$key] = \Drupal\Core\Url::fromUserInput($path)->toString();
        }
      }
      catch (\Throwable) {
        $variables['ped_urls'][$key] = $path;
      }
    }
  }

  // =========================================================================
  // PED CONTACT FORM — Inyectar formulario en página de contacto PED
  // Detecta PageContent ID 79 (contacto de PED, tenant 7) y renderiza
  // el formulario Drupal integrado con CRM + Email.
  // =========================================================================
  $variables['ped_contact_form'] = NULL;
  if (!empty($variables['is_ped'])) {
    $route_match_contact = \Drupal::routeMatch();
    if ($route_match_contact->getRouteName() === 'entity.page_content.canonical') {
      $pc = $route_match_contact->getParameter('page_content');
      if ($pc instanceof \Drupal\jaraba_page_builder\Entity\PageContent) {
        $alias = $pc->get('path_alias')->value ?? '';
        if ($alias === '/contacto') {
          $variables['ped_contact_form'] = \Drupal::formBuilder()->getForm(
            '\Drupal\ecosistema_jaraba_core\Form\PedContactForm'
          );
        }
      }
    }
  }

  // =========================================================================
  // HOMEPAGE CONTENT - Datos dinámicos desde Page Builder
  // Inyecta datos de HomepageContent entity para partials de la homepage
  // =========================================================================
  $is_front = \Drupal::service('path.matcher')->isFrontPage();
  if ($is_front) {
    try {
      /** @var \Drupal\jaraba_page_builder\Service\HomepageDataService $homepage_service */
      $homepage_service = \Drupal::service('jaraba_page_builder.homepage_data');
      $homepage_data = $homepage_service->getHomepageData();

      // Inyectar datos estructurados para partials
      $heroData = $homepage_data['hero'] ?? [];
      // AUDIT-SEC-003: Sanitizar hero subtitle server-side para evitar |raw en Twig.
      if (!empty($heroData['subtitle'])) {
        $heroData['subtitle'] = \Drupal\Component\Utility\Xss::filter(
          $heroData['subtitle'],
          ['strong', 'em', 'br', 'a']
        );
      }
      $variables['homepage'] = [
        'hero' => $heroData,
        'features' => $homepage_data['features'] ?? [],
        'stats' => $homepage_data['stats'] ?? [],
        'intentions' => $homepage_data['intentions'] ?? [],
      ];

      // =====================================================================
      // VERTICAL SELECTOR - Doc 178 §4.1
      // Detecta la vertical del visitante via AvatarDetectionService y
      // pasa los datos al parcial _vertical-selector.html.twig.
      // =====================================================================
      $variables['detected_vertical'] = NULL;
      try {
        $avatar_service = \Drupal::service('ecosistema_jaraba_core.avatar_detection');
        $detection = $avatar_service->detect();
        if ($detection && $detection->vertical) {
          $variables['detected_vertical'] = $detection->vertical;
        }
      }
      catch (\Throwable) {
        // Servicio no disponible, sin detección automática
      }

      // =====================================================================
      // AUDIENCE DETECTION — Hero personalizado por audiencia (PED meta-site)
      // Cascada: 1. UTM ?audience= → 2. Cookie jaraba_audience → 3. Avatar
      // =====================================================================
      $audience = NULL;
      $request = \Drupal::request();

      // Nivel 1: UTM parameter.
      $audience = $request->query->get('audience');

      // Nivel 2: Cookie de sesion (set by audience selector JS).
      if (empty($audience) && $request->cookies->has('jaraba_audience')) {
        $audience = $request->cookies->get('jaraba_audience');
      }

      // Nivel 3: AvatarDetectionService (si disponible).
      if (empty($audience) && \Drupal::hasService('ecosistema_jaraba_core.avatar_detection')) {
        try {
          $avatarDetection = \Drupal::service('ecosistema_jaraba_core.avatar_detection')->detect();
          $avatarMap = [
            'lawyer' => 'legal',
            'government' => 'b2g',
            'jobseeker' => 'empleo',
            'entrepreneur' => 'emprendimiento',
          ];
          $audience = $avatarMap[$avatarDetection->getAvatarType()] ?? NULL;
        }
        catch (\Throwable) {
          // AvatarDetection no disponible o error.
        }
      }

      // Whitelist de audiencias validas.
      $validAudiences = ['legal', 'b2g', 'empleo', 'emprendimiento'];
      $variables['audience'] = in_array($audience, $validAudiences, TRUE) ? $audience : NULL;

      // =====================================================================
      // PED URLs — Resolver URLs internas con prefijo de idioma
      // ROUTE-LANGPREFIX-001: Url::fromRoute() o Url::fromUserInput()
      // PRESAVE-RESILIENCE-001: try-catch para cada URL, fallback a path raw
      // =====================================================================
      $pedPaths = [
        'register' => '/user/register',
        'jarabalex' => '/jarabalex',
        'contacto' => '/contacto',
        'metodo' => '/metodo',
        'empleabilidad' => '/empleabilidad',
        'emprendimiento' => '/emprendimiento',
        'agroconecta' => '/agroconecta',
        'comercioconecta' => '/comercioconecta',
        'serviciosconecta' => '/serviciosconecta',
        'formacion' => '/formacion',
        'andalucia_ei' => '/andalucia-ei',
        'dashboard' => '/user',
        'demo' => '/demo',
      ];
      $variables['ped_urls'] = [];
      foreach ($pedPaths as $key => $path) {
        try {
          if ($key === 'register') {
            $variables['ped_urls'][$key] = \Drupal\Core\Url::fromRoute('user.register')->toString();
          }
          else {
            $variables['ped_urls'][$key] = \Drupal\Core\Url::fromUserInput($path)->toString();
          }
        }
        catch (\Throwable) {
          $variables['ped_urls'][$key] = $path;
        }
      }

      // =====================================================================
      // DYNAMIC PRICING — PLAN-RESOLVER-001 + NO-HARDCODE-PRICE-001
      // Inyectar precios desde MetaSitePricingService para eliminar valores
      // hardcodeados en templates. Cada vertical resuelve sus propios precios.
      // =====================================================================
      $variables['ped_pricing'] = [];
      if (\Drupal::hasService('ecosistema_jaraba_core.metasite_pricing')) {
        try {
          /** @var \Drupal\ecosistema_jaraba_core\Service\MetaSitePricingService $pricingService */
          $pricingService = \Drupal::service('ecosistema_jaraba_core.metasite_pricing');

          // JarabaLex pricing (para comparativa y hero legal).
          $jarabalexTiers = $pricingService->getPricingPreview('jarabalex');
          $jarabalexFromPrice = $pricingService->getFromPrice('jarabalex');
          $variables['ped_pricing']['jarabalex'] = [
            'tiers' => $jarabalexTiers,
            'from_price' => $jarabalexFromPrice,
            // Precio del tier professional para la comparativa.
            'professional_price' => 0.0,
          ];
          foreach ($jarabalexTiers as $tier) {
            if ($tier['tier_key'] === 'professional') {
              $variables['ped_pricing']['jarabalex']['professional_price'] = $tier['price_monthly'];
              break;
            }
          }

          // Empleabilidad pricing (para hero empleo).
          $variables['ped_pricing']['empleabilidad'] = [
            'from_price' => $pricingService->getFromPrice('empleabilidad'),
          ];
        }
        catch (\Throwable) {
          // PRESAVE-RESILIENCE-001: pricing es no-critico.
        }
      }
    }
    catch (\Throwable $e) {
      // Servicio no disponible, usar datos vacíos (partials usan fallbacks)
      \Drupal::logger('ecosistema_jaraba_theme')->notice(
        'HomepageDataService no disponible, usando fallbacks en partials: @msg',
        ['@msg' => $e->getMessage()]
      );
      $variables['homepage'] = [];
    }
  }

  // Copyright - procesar token [year] si viene de configuración del tema
  if (empty($variables['theme_settings']['footer_copyright'])) {
    $variables['footer_copyright'] = t('© @year Jaraba Impact Platform', [
      '@year' => date('Y'),
    ]);
  }
  else {
    // Reemplazar token [year] con el año actual
    $copyright = $variables['theme_settings']['footer_copyright'];
    $copyright = str_replace('[year]', date('Y'), $copyright);
    $variables['footer_copyright'] = $copyright;
  }

  // =========================================================================
  // COPILOT CONTEXT - Inyección global para FAB contextual
  // Servicio CopilotContextService detecta avatar, vertical, tenant, plan
  // =========================================================================
  $variables['copilot_context'] = NULL;
  
  // No mostrar copiloto en rutas admin
  $admin_context = \Drupal::service('router.admin_context');
  if (!$admin_context->isAdminRoute()) {
    try {
      $copilot_service = \Drupal::service('ecosistema_jaraba_core.copilot_context');
      $variables['copilot_context'] = $copilot_service->getContext();
      // Attach copilot library here (not just in Twig) so CSS/JS are included
      // in aggregated output. attach_library() in {% include ... only %} partials
      // does NOT propagate #attached to the render pipeline for CSS aggregation.
      $variables['#attached']['library'][] = 'ecosistema_jaraba_core/contextual-copilot';
    }
    catch (\Exception $e) {
      // Servicio no disponible, no mostrar copiloto
      \Drupal::logger('ecosistema_jaraba_theme')->warning('CopilotContextService no disponible: @msg', ['@msg' => $e->getMessage()]);
    }
  }

  // =========================================================================
  // AVATAR NAVIGATION — Navegacion contextual por avatar/rol
  // Servicio AvatarNavigationService genera items segun avatar detectado
  // =========================================================================
  $variables['avatar_nav'] = NULL;

  $enable_avatar_nav = theme_get_setting('enable_avatar_nav', 'ecosistema_jaraba_theme');
  if ($enable_avatar_nav !== FALSE && !$admin_context->isAdminRoute()) {
    try {
      /** @var \Drupal\ecosistema_jaraba_core\Service\AvatarNavigationService $nav_service */
      $nav_service = \Drupal::service('ecosistema_jaraba_core.avatar_navigation');
      $nav_items = $nav_service->getNavigationItems();
      if (!empty($nav_items)) {
        $variables['avatar_nav'] = [
          'items' => $nav_items,
          'avatar' => $nav_service->getAvatar(),
          'avatar_label' => $nav_service->getAvatarLabel(),
        ];
      }
    }
    catch (\Exception $e) {
      // Servicio no disponible, no mostrar navegacion contextual.
    }
  }

  // =========================================================================
  // PLG texts from theme settings (configurable from UI).
  // NO-HARDCODE-PRICE-001: Textos de conversión configurables desde Apariencia.
  // =========================================================================
  $variables['plg_free_plan_note'] = theme_get_setting('plg_free_plan_note') ?? 'Plan gratuito disponible. Sin tarjeta de crédito.';
  $variables['plg_cta_subtitle'] = theme_get_setting('plg_cta_subtitle') ?? 'Sin tarjeta de crédito. Empieza gratis.';
  $variables['plg_guarantee_text'] = theme_get_setting('plg_guarantee_text') ?? 'Sin tarjeta de crédito. Sin permanencia. Cancela cuando quieras.';
  $variables['plg_register_subtitle'] = theme_get_setting('plg_register_subtitle') ?? 'Crea tu cuenta gratis en menos de 2 minutos. Sin tarjeta de crédito.';

  // =========================================================================
  // ZERO REGION POLICY — Variables limpias para templates custom
  //
  // Extrae system_main_block y system_messages_block de las regiones de Drupal
  // en variables independientes. Las page--*.html.twig custom DEBEN usar
  // {{ clean_content }} en lugar de {{ page.content }} para evitar filtrar
  // bloques heredados (FABs, menús contextuales, tabs, etc).
  //
  // Backward compatible: si una template sigue usando {{ page.content }},
  // funciona como antes. La migración es incremental.
  //
  // @see .agent/workflows/frontend-page-pattern.md
  // =========================================================================
  $variables['clean_content'] = NULL;
  if (isset($variables['page']['content'])) {
    foreach ($variables['page']['content'] as $key => $element) {
      if (is_string($key) && $key[0] === '#') {
        continue;
      }
      if (is_array($element) && ($element['#plugin_id'] ?? '') === 'system_main_block') {
        $variables['clean_content'] = $element;
        break;
      }
    }
  }

  $variables['clean_messages'] = NULL;
  if (isset($variables['page']['highlighted'])) {
    foreach ($variables['page']['highlighted'] as $key => $element) {
      if (is_string($key) && $key[0] === '#') {
        continue;
      }
      if (is_array($element) && ($element['#plugin_id'] ?? '') === 'system_messages_block') {
        $variables['clean_messages'] = $element;
        break;
      }
    }
  }

  // GAP-AUD-010: Proactive Insights bell notification count.
  $variables['proactive_insights_count'] = 0;
  if (\Drupal::currentUser()->isAuthenticated()) {
    try {
      $entityTypeManager = \Drupal::entityTypeManager();
      if ($entityTypeManager->hasDefinition('proactive_insight')) {
        $count = $entityTypeManager->getStorage('proactive_insight')
          ->getQuery()
          ->accessCheck(FALSE)
          ->condition('target_user', \Drupal::currentUser()->id())
          ->condition('read_status', FALSE)
          ->count()
          ->execute();
        $variables['proactive_insights_count'] = (int) $count;
      }
    }
    catch (\Exception $e) {
      // Silently fail — bell will show 0.
    }

    if ($variables['proactive_insights_count'] > 0) {
      $variables['#attached']['library'][] = 'ecosistema_jaraba_theme/proactive-insights';
      $variables['#attached']['drupalSettings']['proactiveInsightsCount'] = $variables['proactive_insights_count'];
    }
  }

  // GP-05: Usage warning banner for dashboards (FairUsePolicyService).
  // ZERO-REGION-001: Datos via preprocess, NO controller.
  // OPTIONAL-SERVICE: FairUsePolicyService puede no existir.
  $variables['usage_warning'] = NULL;
  if (\Drupal::currentUser()->isAuthenticated()
      && \Drupal::hasService('ecosistema_jaraba_core.fair_use_policy')
      && \Drupal::hasService('ecosistema_jaraba_core.tenant_context')) {
    try {
      $tenantContext = \Drupal::service('ecosistema_jaraba_core.tenant_context');
      $currentTenant = $tenantContext->getCurrentTenant();
      if ($currentTenant) {
        $fairUse = \Drupal::service('ecosistema_jaraba_core.fair_use_policy');
        // Verificar recurso mas critico: ai_queries.
        $enforcement = $fairUse->getActiveEnforcement((int) $currentTenant->id(), 'ai_queries');
        if ($enforcement && in_array($enforcement['level'] ?? '', ['warn', 'throttle', 'soft_block'], TRUE)) {
          $variables['usage_warning'] = $enforcement;
          $variables['pricing_url'] = \Drupal\Core\Url::fromRoute('ecosistema_jaraba_core.pricing.page')->toString();
        }
      }
    }
    catch (\Throwable $e) {
      // PRESAVE-RESILIENCE-001: No bloquear renderizado si FairUse falla.
    }
  }

  // RUNTIME-VERIFY-001: Inject vertical_key for FAB Copilot contextual agent.
  // Without this, page--vertical-landing.html.twig defaults to 'public_copilot'
  // for ALL landing pages instead of vertical-specific agents.
  $variables['vertical_key'] = NULL;
  $route = \Drupal::routeMatch()->getRouteName() ?? '';
  $landing_vertical_map = [
    'ecosistema_jaraba_core.landing.empleabilidad' => 'empleabilidad',
    'ecosistema_jaraba_core.vertical.talento' => 'talento',
    'ecosistema_jaraba_core.landing.emprendimiento' => 'emprendimiento',
    'ecosistema_jaraba_core.landing.agroconecta' => 'agroconecta',
    'ecosistema_jaraba_core.landing.comercioconecta' => 'comercioconecta',
    'ecosistema_jaraba_core.landing.serviciosconecta' => 'serviciosconecta',
    'ecosistema_jaraba_core.landing.jarabalex' => 'jarabalex',
    'ecosistema_jaraba_core.landing.legal' => 'jarabalex',
    'ecosistema_jaraba_core.vertical.empleo' => 'empleabilidad',
    'ecosistema_jaraba_core.vertical.emprender' => 'emprendimiento',
    'ecosistema_jaraba_core.vertical.comercio' => 'comercioconecta',
    'ecosistema_jaraba_core.vertical.instituciones' => 'demo',
  ];
  if (isset($landing_vertical_map[$route])) {
    $variables['vertical_key'] = $landing_vertical_map[$route];
  }
}

/**
 * Implements hook_preprocess_page__auth().
 *
 * Preprocesa las páginas de autenticación para inyectar solo el formulario,
 * sin bloques ni regiones de Drupal heredados.
 *
 * Directrices aplicadas:
 * - Nuclear #14: Frontend Limpio (Zero Region Policy)
 * - Branding 3.6: Portal Isolation
 */
function ecosistema_jaraba_theme_preprocess_page__auth(&$variables) {
  $route = \Drupal::routeMatch()->getRouteName();
  $form_builder = \Drupal::formBuilder();
  
  // Determinar qué formulario cargar según la ruta.
  $form = NULL;
  $form_type = 'login'; // Default
  
  switch ($route) {
    case 'user.login':
      $form = $form_builder->getForm('\Drupal\user\Form\UserLoginForm');
      $form_type = 'login';
      break;
      
    case 'user.register':
      $form = \Drupal::entityTypeManager()
        ->getFormObject('user', 'register')
        ->setEntity(\Drupal::entityTypeManager()->getStorage('user')->create());
      $form = $form_builder->getForm($form);
      $form_type = 'register';
      break;
      
    case 'user.pass':
      $form = $form_builder->getForm('\Drupal\user\Form\UserPasswordForm');
      $form_type = 'password';
      break;

    case 'user.reset.form':
      // El formulario ya está construido por el controlador en el bloque principal.
      if (isset($variables['page']['content'])) {
        foreach ($variables['page']['content'] as $key => $element) {
          if (is_array($element) && ($element['#plugin_id'] ?? '') === 'system_main_block') {
            $form = $element;
            break;
          }
        }
      }
      $form_type = 'password';
      break;

    case 'user.logout.confirm':
      $form = $form_builder->getForm('Drupal\user\Form\UserLogoutConfirm');
      $form_type = 'logout';
      break;

    default:
      // Onboarding routes: extract system_main_block content from page.
      if (str_starts_with($route, 'ecosistema_jaraba_core.onboarding.') ||
          str_starts_with($route, 'jaraba_onboarding.')) {
        if (isset($variables['page']['content'])) {
          foreach ($variables['page']['content'] as $key => $element) {
            if (is_array($element) && ($element['#plugin_id'] ?? '') === 'system_main_block') {
              $form = $element;
              break;
            }
          }
        }
        $form_type = 'register';
      }
      break;
  }
  
  // Inyectar variables limpias al template.
  $variables['auth_form'] = $form;
  $variables['auth_form_type'] = $form_type;

  // Inyectar mensajes del sistema directamente (no depende de regiones/bloques).
  // Esto permite mostrar mensajes de confirmación post-registro, errores, etc.
  $variables['auth_messages'] = ['#type' => 'status_messages'];
  
  // Configuración del tema para parciales.
  $config = \Drupal::config('ecosistema_jaraba_theme.settings');
  $site_config = \Drupal::config('system.site');
  
  $variables['theme_settings'] = _ecosistema_jaraba_theme_get_base_settings($config);
  
  $variables['site_name'] = $site_config->get('name') ?: 'Jaraba Impact Platform';
  $variables['site_slogan'] = $site_config->get('slogan') ?: '';
  
  // URL del logo desde la configuración del tema de Drupal.
  $theme_path = \Drupal::service('extension.path.resolver')->getPath('theme', 'ecosistema_jaraba_theme');
  
  // Intentar obtener el logo configurado en el tema.
  $logo_from_theme = theme_get_setting('logo.url', 'ecosistema_jaraba_theme');
  if ($logo_from_theme) {
    $variables['logo_url'] = $logo_from_theme;
  }
  else {
    $variables['logo_url'] = '/' . $theme_path . '/images/logo.svg';
  }
  
  // Logo blanco para fondos oscuros.
  $logo_white_path = $theme_path . '/images/logo-white.svg';
  if (file_exists(DRUPAL_ROOT . '/' . $logo_white_path)) {
    $variables['logo_url_white'] = '/' . $logo_white_path;
  }
  else {
    // Fallback: usar el logo normal con filtro CSS.
    $variables['logo_url_white'] = $variables['logo_url'];
  }
}

/**
 * Implements hook_preprocess_email_wrap().
 *
 * Inyecta el logo del tema y datos de branding en el template de email.
 * El logo se genera como URL absoluta para que los clientes de email
 * puedan renderizarlo correctamente.
 */
function ecosistema_jaraba_theme_preprocess_email_wrap(array &$variables): void {
  $config = \Drupal::config('ecosistema_jaraba_theme.settings');
  $site_config = \Drupal::config('system.site');

  // Logo absoluto para emails.
  // generateAbsoluteString() usa el host de la request actual. En subrequests
  // internas (curl a localhost, cron, drush) genera http://localhost/... que
  // no es accesible para clientes de email. Usamos $GLOBALS['base_url'] que
  // refleja el base_url real de Drupal.
  $logo_settings = theme_get_setting('logo', 'ecosistema_jaraba_theme');
  if (!empty($logo_settings['path'])) {
    $file_url_generator = \Drupal::service('file_url_generator');
    $relative_url = $file_url_generator->generateString($logo_settings['path']);
    $variables['logo_url'] = $GLOBALS['base_url'] . $relative_url;
  }
  else {
    $variables['logo_url'] = '';
  }

  // Branding desde config del tema.
  $variables['site_name'] = $site_config->get('name') ?: 'Jaraba';
  $variables['site_slogan'] = $site_config->get('slogan') ?: '';
  $variables['color_corporate'] = $config->get('color_corporate') ?: '#233D63';
  $variables['color_primary'] = $config->get('color_primary') ?: '#FF8C42';
  $variables['footer_copyright'] = $config->get('footer_copyright') ?: '';
  $variables['footer_powered_text'] = $config->get('footer_powered_text') ?: 'Jaraba Impact Platform';
}

/**
 * Implements hook_preprocess_page__dashboard().
 *
 * Alias de variables genéricas para page--dashboard.html.twig.
 * La extracción real ocurre en preprocess_page() (clean_content/clean_messages).
 *
 * Aplica a todas las rutas que usan page--dashboard.html.twig:
 * - /employer, /jobseeker, /entrepreneur/dashboard, /my-company
 * - /tenant/dashboard, /tenant/change-plan
 * - /business-tools/canvas/*
 */
function ecosistema_jaraba_theme_preprocess_page__dashboard(&$variables) {
  // Alias: la template usa dashboard_content/dashboard_messages
  // que son los mismos clean_content/clean_messages del preprocess genérico.
  $variables['dashboard_content'] = $variables['clean_content'];
  $variables['dashboard_messages'] = $variables['clean_messages'];
}

/**
 * Implements hook_preprocess_page__empleabilidad().
 *
 * Preprocesa las páginas del vertical Empleabilidad para inyectar contexto
 * del Copilot y variables específicas del vertical.
 *
 * Plan Elevación Empleabilidad v1 — Fase 1
 * Template: page--empleabilidad.html.twig (Zero Region Policy + Copilot FAB)
 *
 * Aplica a todas las rutas de:
 * - jaraba_candidate.* (/jobseeker, /my-profile, /my-applications)
 * - jaraba_job_board.* (/employer, /jobs, /job/*)
 * - jaraba_diagnostic.* (/empleabilidad/diagnostico)
 * - jaraba_self_discovery.* (/self-discovery/*)
 */
function ecosistema_jaraba_theme_preprocess_page__empleabilidad(&$variables) {
  // Inyectar contexto del Copilot para el FAB.
  try {
    $copilot_service = \Drupal::service('ecosistema_jaraba_core.copilot_context');
    $variables['copilot_context'] = $copilot_service->getContext();
  }
  catch (\Exception $e) {
    // Servicio no disponible — FAB se renderiza con defaults.
