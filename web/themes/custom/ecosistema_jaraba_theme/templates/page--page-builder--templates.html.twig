{#
/**
 * @file
 * Template de página para el Selector de Plantillas.
 * CORREGIDO: Restaurado paso de variables al header y footer.
 */
#}
<div class="page-wrapper page-wrapper--clean page-wrapper--full-width">

  {% include '@ecosistema_jaraba_theme/partials/_header.html.twig' with {
    site_name: site_name,
    site_slogan: site_slogan,
    logo: logo,
    logged_in: logged_in,
    theme_settings: theme_settings,
    clean_layout: true,
  } only %}

  <main role="main" id="main-content" class="main-content-clean">
    <div class="canvas-clean-container">
      {{ clean_content }}
    </div>
  </main>

  {% include '@ecosistema_jaraba_theme/partials/_footer.html.twig' with {
    site_name: site_name,
    theme_settings: theme_settings,
    clean_layout: true,
  } only %}

</div>
