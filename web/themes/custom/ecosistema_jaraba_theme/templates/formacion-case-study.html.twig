{#
/**
 * @file formacion-case-study.html.twig
 * Caso de éxito: María López, Madrid — storytelling de conversión.
 *
 * VARIABLES:
 * - hero_image, maria_image, before_after_image, course_builder_image,
 *   certificate_image, dashboard_image: string (URL relativa a WebP)
 * - metrics: array of {label, before, after, change}
 * - testimonial: {quote, name, role, company}
 * - timeline: array of {day, title, text}
 * - pricing: {free_features, starter_price, starter_features, professional_price, professional_features}
 * - pricing_url, register_url: string
 *
 * DIRECTIVES: ZERO-REGION-001, i18n (trans), ICON-CONVENTION-001,
 * CSS-VAR-ALL-COLORS-001, DOC-GLOSSARY-001
 */
#}

{# === 1. HERO === #}
<section class="cs-hero" style="background-image: url('{{ hero_image }}');" aria-labelledby="cs-title">
  <div class="cs-hero__overlay"></div>
  <div class="cs-hero__container">
    <span class="cs-hero__eyebrow">{% trans %}Caso de éxito{% endtrans %}</span>
    <h1 id="cs-title" class="cs-hero__title">
      {% trans %}12 alumnos presenciales. 4 meses para llegar a 340 online{% endtrans %}
    </h1>
    <p class="cs-hero__subtitle">
      {% trans %}La historia de María López: cómo una formadora de marketing digital en Madrid pasó de dar cursos presenciales a 12 personas a tener 340 alumnos activos, 4 cursos online y multiplicar por 4 su facturación{% endtrans %}
    </p>
    <div class="cs-hero__ctas">
      <a href="{{ register_url }}" class="btn btn--primary btn--lg" data-track-cta="cs_formacion_hero_trial" data-track-position="case_study_hero">
        {% trans %}Crear mi primer curso gratis{% endtrans %}
      </a>
      <a href="#cs-story" class="btn btn--outline btn--lg cs-hero__scroll-cta">
        {% trans %}Leer la historia{% endtrans %} ↓
      </a>
    </div>
  </div>
</section>

{# === 2. MARÍA (contexto) === #}
<section id="cs-story" class="cs-section cs-context reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--split">
    <div class="cs-section__media">
      <img src="{{ maria_image }}" alt="{% trans %}María López en su espacio de trabajo{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
    </div>
    <div class="cs-section__content">
      <span class="cs-section__eyebrow">{% trans %}La protagonista{% endtrans %}</span>
      <h2 class="cs-section__title">{% trans %}María López, Madrid{% endtrans %}</h2>
      <div class="cs-badges">
        <span class="cs-badge">{% trans %}36 años{% endtrans %}</span>
        <span class="cs-badge">{% trans %}Formadora de marketing{% endtrans %}</span>
        <span class="cs-badge">{% trans %}Consultora freelance{% endtrans %}</span>
      </div>
      <p>{% trans %}María lleva 8 años dando formación presencial en marketing digital. Cursos de 12 plazas en salas de coworking, hojas Excel para el seguimiento y certificados que maqueta uno a uno en Canva. Sabe que debería dar el salto al online, pero cada vez que abre Moodle cierra la pestaña a los 10 minutos.{% endtrans %}</p>
      <p>{% trans %}1.800 euros al mes, techo de cristal por las plazas presenciales y la sensación de que el mercado se le escapa.{% endtrans %}</p>
    </div>
  </div>
</section>

{# === 3. EL DOLOR === #}
<section class="cs-section cs-pain reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <span class="cs-section__eyebrow">{% trans %}El problema{% endtrans %}</span>
    <h2 class="cs-section__title cs-section__title--center">{% trans %}Escalar o quedarse en 12 plazas{% endtrans %}</h2>
    <img src="{{ before_after_image }}" alt="{% trans %}Comparativa antes y después{% endtrans %}" class="cs-pain__image" loading="lazy" width="800" height="800">
    <div class="cs-pain__cards">
      <div class="cs-pain__card">
        <span class="cs-pain__value">12</span>
        <span class="cs-pain__label">{% trans %}plazas máximo por curso{% endtrans %}</span>
      </div>
      <div class="cs-pain__card">
        <span class="cs-pain__value">45%</span>
        <span class="cs-pain__label">{% trans %}tasa de finalización{% endtrans %}</span>
      </div>
      <div class="cs-pain__card">
        <span class="cs-pain__value">3</span>
        <span class="cs-pain__label">{% trans %}semanas para crear un curso{% endtrans %}</span>
      </div>
      <div class="cs-pain__card">
        <span class="cs-pain__value">{{ jaraba_icon('ui', 'alert-circle', { variant: 'duotone', size: '28px', color: 'white' }) }}</span>
        <span class="cs-pain__label">{% trans %}sin plataforma online{% endtrans %}</span>
      </div>
    </div>
  </div>
</section>

{# === 4. EL DESCUBRIMIENTO === #}
<section class="cs-section cs-discovery reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--split">
    <div class="cs-section__content">
      <span class="cs-section__eyebrow">{% trans %}El momento decisivo{% endtrans %}</span>
      <h2 class="cs-section__title">{% trans %}Un curso montado en 2 días{% endtrans %}</h2>
      <p>{% trans %}María ve en LinkedIn que una compañera formadora ha publicado un curso online con certificado verificable y badges. Le pregunta cómo lo ha hecho. La respuesta: "El constructor de cursos con IA me generó la estructura entera. Solo tuve que grabar los vídeos."{% endtrans %}</p>
      <blockquote class="cs-discovery__quote">
        <p>&ldquo;{% trans %}Cuando vi que la IA me proponía 12 módulos con objetivos, quizzes y recursos, y que todo estaba listo para publicar en 2 días, no me lo podía creer. Había perdido meses intentando hacer lo mismo con otras plataformas.{% endtrans %}&rdquo;</p>
        <footer>— María López</footer>
      </blockquote>
    </div>
    <div class="cs-section__media">
      <img src="{{ course_builder_image }}" alt="{% trans %}Constructor de cursos con IA{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
    </div>
  </div>
</section>

{# === 5. LOS 4 MESES (timeline) === #}
<section class="cs-section cs-timeline reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <span class="cs-section__eyebrow">{% trans %}Los 4 meses{% endtrans %}</span>
    <h2 class="cs-section__title cs-section__title--center">{% trans %}De 12 alumnos presenciales a 340 online{% endtrans %}</h2>
    <div class="cs-timeline__split">
      <div class="cs-timeline__media">
        <img src="{{ dashboard_image }}" alt="{% trans %}Dashboard LMS de María{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
      </div>
      <div class="cs-timeline__steps">
        {% for step in timeline %}
          <div class="cs-timeline__step">
            <span class="cs-timeline__day">{{ step.day }}</span>
            <div class="cs-timeline__detail">
              <h3 class="cs-timeline__step-title">{{ step.title }}</h3>
              <p class="cs-timeline__step-text">{{ step.text }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{# === 6. LOS RESULTADOS === #}
<section class="cs-section cs-results reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <span class="cs-section__eyebrow">{% trans %}4 meses después{% endtrans %}</span>
    <h2 class="cs-section__title cs-section__title--center">{% trans %}Los resultados hablan solos{% endtrans %}</h2>
    <div class="cs-results__grid">
      {% for m in metrics %}
        <div class="cs-results__card">
          <span class="cs-results__change">{{ m.change }}</span>
          <span class="cs-results__label">{{ m.label }}</span>
          <div class="cs-results__compare">
            <span class="cs-results__before">{% trans %}Antes:{% endtrans %} {{ m.before }}</span>
            <span class="cs-results__after">{% trans %}Ahora:{% endtrans %} {{ m.after }}</span>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# === 7. CERTIFICADOS Y BADGES === #}
<section class="cs-section cs-chef reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--split">
    <div class="cs-section__media">
      <img src="{{ certificate_image }}" alt="{% trans %}Certificado y badge verificable{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
    </div>
    <div class="cs-section__content">
      <span class="cs-section__eyebrow">{% trans %}El momento cumbre{% endtrans %}</span>
      <h2 class="cs-section__title">{% trans %}Certificados que los alumnos comparten solos{% endtrans %}</h2>
      <blockquote class="cs-discovery__quote">
        <p>&ldquo;{% trans %}Cuando mis alumnos empezaron a compartir sus badges de Open Badges en LinkedIn, las matrículas se dispararon sin hacer publicidad. Cada certificado es marketing gratuito.{% endtrans %}&rdquo;</p>
        <footer>— María López</footer>
      </blockquote>
      <p class="cs-chef__impact">{% trans %}340 alumnos activos en 4 cursos. Tasa de finalización del 78% gracias a la gamificación. NPS de 72 puntos.{% endtrans %}</p>
    </div>
  </div>
</section>

{# === 8. TESTIMONIAL === #}
<section class="cs-section cs-testimonial reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--narrow">
    <blockquote class="cs-testimonial__quote" itemscope itemtype="https://schema.org/Review">
      <p class="cs-testimonial__text" itemprop="reviewBody">
        &ldquo;{{ testimonial.quote }}&rdquo;
      </p>
      <footer class="cs-testimonial__author">
        <div>
          <cite class="cs-testimonial__name" itemprop="author">{{ testimonial.name }}</cite>
          <span class="cs-testimonial__role">{{ testimonial.role }}, {{ testimonial.company }}</span>
        </div>
        <div class="cs-testimonial__stars" itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
          <meta itemprop="ratingValue" content="5">
          <meta itemprop="bestRating" content="5">
          ★★★★★
        </div>
      </footer>
    </blockquote>
  </div>
</section>

{# === 9. MINI PRICING === #}
<section class="cs-section cs-pricing reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <h2 class="cs-section__title cs-section__title--center">{% trans %}Planes Formación{% endtrans %}</h2>
    <div class="cs-pricing__cards">
      <div class="cs-pricing__card">
        <h3>Free</h3>
        <span class="cs-pricing__price">0 &euro;</span>
        <span class="cs-pricing__period">/{% trans %}mes{% endtrans %}</span>
        <p>{{ pricing.free_features }}</p>
        <a href="{{ register_url }}" class="btn btn--outline" data-track-cta="cs_formacion_free" data-track-position="case_study_pricing">{% trans %}Empezar gratis{% endtrans %}</a>
      </div>
      <div class="cs-pricing__card cs-pricing__card--recommended">
        <span class="cs-pricing__badge">{% trans %}El plan de María{% endtrans %}</span>
        <h3>{% trans %}Starter{% endtrans %}</h3>
        <span class="cs-pricing__price">{{ pricing.starter_price }} &euro;</span>
        <span class="cs-pricing__period">/{% trans %}mes{% endtrans %}</span>
        <p>{{ pricing.starter_features }}</p>
        <a href="{{ pricing_url }}" class="btn btn--primary" data-track-cta="cs_formacion_starter" data-track-position="case_study_pricing">{% trans %}Probar 14 días gratis{% endtrans %}</a>
      </div>
      <div class="cs-pricing__card">
        <h3>{% trans %}Profesional{% endtrans %}</h3>
        <span class="cs-pricing__price">{{ pricing.professional_price }} &euro;</span>
        <span class="cs-pricing__period">/{% trans %}mes{% endtrans %}</span>
        <p>{{ pricing.professional_features }}</p>
        <a href="{{ pricing_url }}" class="btn btn--outline" data-track-cta="cs_formacion_professional" data-track-position="case_study_pricing">{% trans %}Ver detalles{% endtrans %}</a>
      </div>
    </div>
  </div>
</section>

{# === 10. CTA FINAL === #}
<section class="cs-section cs-final-cta">
  <div class="cs-section__container cs-section__container--narrow">
    <h2 class="cs-final-cta__title">{% trans %}¿Y si en 4 meses tus cursos llegan a cientos de alumnos?{% endtrans %}</h2>
    <p class="cs-final-cta__subtitle">{% trans %}Sin tarjeta de crédito. Sin permanencia. Primer curso 100% gratis.{% endtrans %}</p>
    <a href="{{ register_url }}" class="btn btn--primary btn--xl" data-track-cta="cs_formacion_final_cta" data-track-position="case_study_bottom">
      {% trans %}Crear mi primer curso gratis{% endtrans %}
    </a>
    <div class="cs-final-cta__trust">
      <span>{{ jaraba_icon('ui', 'shield', { variant: 'duotone', size: '16px', color: 'white' }) }} {% trans %}Datos en la UE{% endtrans %}</span>
      <span>{{ jaraba_icon('legal', 'shield-privacy', { variant: 'duotone', size: '16px', color: 'white' }) }} {% trans %}RGPD 100%{% endtrans %}</span>
      <span>{{ jaraba_icon('ui', 'lock', { variant: 'duotone', size: '16px', color: 'white' }) }} {% trans %}Tu contenido es confidencial{% endtrans %}</span>
    </div>
  </div>
</section>

{# === SCHEMA.ORG === #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "12 alumnos presenciales. 4 meses para llegar a 340 online",
  "author": { "@type": "Organization", "name": "Jaraba Impact Platform" },
  "datePublished": "2026-03-20",
  "publisher": { "@type": "Organization", "name": "PED S.L." },
  "description": "Maria Lopez, formadora de marketing digital en Madrid, paso de dar cursos presenciales a 12 personas a tener 340 alumnos activos, 4 cursos online y multiplicar por 4 su facturacion."
}
</script>
