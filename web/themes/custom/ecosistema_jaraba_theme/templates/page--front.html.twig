        {
          icon_cat: 'users',
          icon_name: 'user-group',
          color: 'verde-innovacion',
          title: 'Talento sin orientacion'|t,
          description: 'Miles de personas en transicion profesional sin diagnostico de competencias, sin CV actualizado, sin matching inteligente.'|t
