        {
          icon_cat: 'legal',
          icon_name: 'search-legal',
          color: 'naranja-impulso',
          title: 'Profesionales sin acceso a IA'|t,
          description: 'Abogados, consultores y autonomos pagando herramientas caras y desconectadas. Sin copiloto, sin firma digital.'|t
