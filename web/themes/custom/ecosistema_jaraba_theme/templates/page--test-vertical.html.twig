{#
/**
 * @file
 * Clean page template for /test-vertical (Quiz de Recomendación de Vertical).
 *
 * ZERO-REGION-001: Sin page.content, sin bloques, sin sidebars.
 * Layout: Header → Quiz content → Footer.
 * El quiz content viene de clean_content (extrae solo system_main_block).
 *
 * @see ecosistema_jaraba_theme_theme_suggestions_page_alter()
 */
#}

{% include '@ecosistema_jaraba_theme/partials/_header.html.twig' with {
  site_name: site_name,
  site_slogan: site_slogan,
  logo: logo,
  logged_in: logged_in,
  theme_settings: theme_settings,
  available_languages: available_languages|default([]),
  current_langcode: current_langcode|default('es'),
  language_prefix: language_prefix|default(''),
  language_links: language_links|default({}),
  mega_menu_columns: mega_menu_columns|default([]),
} only %}

{{ clean_messages }}

{# Full-width main — sin max-width container, JS controla layout completo #}
<main role="main">
  {% if quiz_result_html is defined and quiz_result_html %}
    {{ quiz_result_html }}
  {% elseif quiz_html is defined and quiz_html %}
    {{ quiz_html }}
  {% else %}
    {{ clean_content }}
  {% endif %}
</main>

{% include '@ecosistema_jaraba_theme/partials/_footer.html.twig' with {
  site_name: site_name,
  theme_settings: theme_settings,
  language_prefix: language_prefix|default(''),
  logged_in: logged_in,
} only %}
