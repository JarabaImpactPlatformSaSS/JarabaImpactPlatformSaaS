{#
/**
 * @file
 * info-page-contact.html.twig
 *
 * WhatsApp-first contact page — EMAIL-NOEXPOSE-001.
 * Canal primario: WhatsApp CTA. Secundario: formulario.
 * NUNCA exponer email ni telefono en DOM visible.
 *
 * VARIABLES (declaradas en hook_theme):
 * - content: string — contenido adicional sanitizado (Xss::filterAdmin)
 * - contact_phone: string — NO se renderiza visualmente (solo Schema.org)
 * - contact_address: string — direccion postal
 * - whatsapp_number: string — numero WA sin + (ej: 34623174304)
 * - theme_settings: array — config desde theme settings
 *
 * DIRECTRICES:
 * - EMAIL-NOEXPOSE-001: NUNCA mailto: ni email visible en frontend
 * - CONTACT-SSOT-001: Datos desde theme_settings
 * - WA-CONTEXTUAL-001: WhatsApp como canal prioritario
 * - FUNNEL-COMPLETENESS-001: data-track-cta en CTAs
 * - i18n: {% trans %} bloque (NUNCA |t)
 * - AUDIT-SEC-003: content sanitizado en controller con Xss::filterAdmin()
 */
#}
{{ attach_library('ecosistema_jaraba_theme/contact-form') }}

<div class="static-page static-page--contacto">
  <div class="static-page__container">

    <header class="static-page__header">
      <h1 class="static-page__title">{% trans %}Contacto{% endtrans %}</h1>
      <p class="static-page__subtitle">
        {% trans %}Elige cómo prefieres comunicarte con nosotros.{% endtrans %}
      </p>
    </header>

    <div class="static-page__grid">
      {# Columna 1: Canales de contacto — WhatsApp-first #}
      <div class="static-page__info-card">

        {# Canal primario: WhatsApp #}
        {% if whatsapp_number %}
        <div class="static-page__channel static-page__channel--primary">
          <div class="static-page__channel-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="var(--ej-brand-whatsapp, #25d366)" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div class="static-page__channel-content">
            <strong class="static-page__channel-title">{% trans %}WhatsApp{% endtrans %}</strong>
            <p class="static-page__channel-desc">{% trans %}Respuesta inmediata. Nuestro asistente de IA te atiende 24/7.{% endtrans %}</p>
            <a href="https://wa.me/{{ whatsapp_number }}"
               class="btn btn--whatsapp btn--lg"
               target="_blank"
               rel="noopener noreferrer"
               data-track-cta="contact_page_whatsapp"
               data-track-position="contact_channel_primary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {% trans %}Abrir WhatsApp{% endtrans %}
            </a>
          </div>
        </div>
        {% endif %}

        {# Canal secundario: Formulario #}
        <div class="static-page__channel static-page__channel--secondary">
          <div class="static-page__channel-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--ej-text-secondary, #6b7280)" stroke-width="1.5" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M2 7L12 13L22 7"/>
            </svg>
          </div>
          <div class="static-page__channel-content">
            <strong class="static-page__channel-title">{% trans %}Formulario de contacto{% endtrans %}</strong>
            <p class="static-page__channel-desc">{% trans %}Respondemos en menos de 24 horas laborables.{% endtrans %}</p>
          </div>
        </div>

        {# Direccion postal #}
        {% if contact_address %}
        <div class="static-page__channel">
          <div class="static-page__channel-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--ej-text-secondary, #6b7280)" stroke-width="1.5" aria-hidden="true">
              <path d="M12 2C8.13 2 5 5.13 5 9C5 14.25 12 22 12 22S19 14.25 19 9C19 5.13 15.87 2 12 2Z"/>
              <circle cx="12" cy="9" r="2.5"/>
            </svg>
          </div>
          <div class="static-page__channel-content">
            <strong class="static-page__channel-title">{% trans %}Oficina{% endtrans %}</strong>
            <address class="static-page__address">{{ contact_address|nl2br }}</address>
          </div>
        </div>
        {% endif %}

        {# Horario de atencion #}
        <div class="static-page__channel">
          <div class="static-page__channel-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--ej-text-secondary, #6b7280)" stroke-width="1.5" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div class="static-page__channel-content">
            <strong class="static-page__channel-title">{% trans %}Horario{% endtrans %}</strong>
            <p class="static-page__channel-desc">{% trans %}Lunes a viernes, 9:00 – 18:00 (CET){% endtrans %}</p>
            <p class="static-page__channel-note">{% trans %}WhatsApp con IA: disponible 24/7{% endtrans %}</p>
          </div>
        </div>
      </div>

      {# Columna 2: Formulario de contacto funcional #}
      <div class="contact-form__wrapper" id="contact-form-wrapper">
        <h2 class="contact-form__title">{% trans %}Envíanos un mensaje{% endtrans %}</h2>
        <form class="contact-form" id="contact-form" novalidate>
          <div class="contact-form__field">
            <label for="contact-name">{% trans %}Nombre{% endtrans %} <span aria-hidden="true">*</span></label>
            <input type="text" id="contact-name" name="name" required
                   placeholder="{% trans %}Tu nombre{% endtrans %}" autocomplete="name">
          </div>
          <div class="contact-form__field">
            <label for="contact-email">{% trans %}Email{% endtrans %} <span aria-hidden="true">*</span></label>
            <input type="email" id="contact-email" name="email" required
                   placeholder="{% trans %}tu@email.com{% endtrans %}" autocomplete="email">
          </div>
          <div class="contact-form__field">
            <label for="contact-subject">{% trans %}Asunto{% endtrans %}</label>
            <input type="text" id="contact-subject" name="subject"
                   placeholder="{% trans %}¿Sobre qué quieres hablar?{% endtrans %}">
          </div>
          <div class="contact-form__field">
            <label for="contact-message">{% trans %}Mensaje{% endtrans %} <span aria-hidden="true">*</span></label>
            <textarea id="contact-message" name="message" rows="4" required
                      placeholder="{% trans %}Cuéntanos en qué podemos ayudarte...{% endtrans %}"></textarea>
          </div>
          <div class="contact-form__consent">
            <label>
              <input type="checkbox" name="gdpr" required>
              {% set privacidad_url = path('ecosistema_jaraba_core.static.privacidad') %}
              {% trans %}Acepto la <a href="{{ privacidad_url }}" target="_blank">política de privacidad</a>{% endtrans %}
            </label>
          </div>
          <button type="submit" class="btn btn--primary btn--lg contact-form__submit"
                  data-track-cta="contact_page_form_submit"
                  data-track-position="contact_form">
            {% trans %}Enviar mensaje{% endtrans %}
          </button>
        </form>
        <div class="contact-form__success" id="contact-form-success" style="display:none">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="var(--ej-color-success, #22c55e)" stroke-width="1.5"/>
            <path d="M8 12l3 3 5-6" stroke="var(--ej-color-success, #22c55e)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <h3>{% trans %}¡Mensaje enviado!{% endtrans %}</h3>
          <p>{% trans %}Te responderemos en menos de 24 horas.{% endtrans %}</p>
        </div>
      </div>
    </div>

    {% if content %}
    <div class="static-page__content">
      {{ content|raw }}
    </div>
    {% endif %}

  </div>
</div>
