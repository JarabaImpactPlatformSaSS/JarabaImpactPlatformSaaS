{#
/**
 * @file contenthub-case-study.html.twig
 * Caso de éxito: Bodega Montilla, Córdoba — storytelling de conversión.
 *
 * VARIABLES:
 * - hero_image, luis_image, before_after_image, editor_image,
 *   analytics_image, multichannel_image: string (URL relativa a WebP)
 * - metrics: array of {label, before, after, change}
 * - testimonial: {quote, name, role, company}
 * - timeline: array of {day, title, text}
 * - pricing: {free_features, starter_price, starter_features, professional_price, professional_features}
 * - pricing_url, register_url: string
 *
 * DIRECTIVES: ZERO-REGION-001, i18n (trans), ICON-CONVENTION-001,
 * CSS-VAR-ALL-COLORS-001, DOC-GLOSSARY-001
 */
#}

{# === 1. HERO === #}
<section class="cs-hero" style="background-image: url('{{ hero_image }}');" aria-labelledby="cs-title">
  <div class="cs-hero__overlay"></div>
  <div class="cs-hero__container">
    <span class="cs-hero__eyebrow">{% trans %}Caso de éxito{% endtrans %}</span>
    <h1 id="cs-title" class="cs-hero__title">
      {% trans %}0 visitas orgánicas. 6 meses para llegar a 12.000 al mes{% endtrans %}
    </h1>
    <p class="cs-hero__subtitle">
      {% trans %}La historia de Bodega Montilla: cómo una bodega cordobesa pasó de gastar todo su presupuesto en Google Ads a tener 12.000 visitas orgánicas mensuales, 45 artículos y un coste por lead un 89% menor{% endtrans %}
    </p>
    <div class="cs-hero__ctas">
      <a href="{{ register_url }}" class="btn btn--primary btn--lg" data-track-cta="cs_hub_hero_trial" data-track-position="case_study_hero">
        {% trans %}Crear mi Content Hub gratis{% endtrans %}
      </a>
      <a href="#cs-story" class="btn btn--outline btn--lg cs-hero__scroll-cta">
        {% trans %}Leer la historia{% endtrans %} ↓
      </a>
    </div>
  </div>
</section>

{# === 2. LUIS (contexto) === #}
<section id="cs-story" class="cs-section cs-context reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--split">
    <div class="cs-section__media">
      <img src="{{ luis_image }}" alt="{% trans %}Luis Moreno en la bodega{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
    </div>
    <div class="cs-section__content">
      <span class="cs-section__eyebrow">{% trans %}El protagonista{% endtrans %}</span>
      <h2 class="cs-section__title">{% trans %}Luis Moreno, Bodega Montilla (Córdoba){% endtrans %}</h2>
      <div class="cs-badges">
        <span class="cs-badge">{% trans %}33 años{% endtrans %}</span>
        <span class="cs-badge">{% trans %}Director de marketing{% endtrans %}</span>
        <span class="cs-badge">{% trans %}Vinos Montilla-Moriles{% endtrans %}</span>
      </div>
      <p>{% trans %}Luis lleva el marketing de una bodega familiar con 80 años de historia. Todo el presupuesto se va en Google Ads: 2.800 euros al mes que desaparecen en cuanto deja de pagar. Cero contenido propio, cero posicionamiento orgánico, cero activos digitales a largo plazo.{% endtrans %}</p>
      <p>{% trans %}Sabe que debería tener un blog, pero cada vez que se sienta a escribir tarda 4 horas en un artículo que nadie lee.{% endtrans %}</p>
    </div>
  </div>
</section>

{# === 3. EL DOLOR === #}
<section class="cs-section cs-pain reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <span class="cs-section__eyebrow">{% trans %}El problema{% endtrans %}</span>
    <h2 class="cs-section__title cs-section__title--center">{% trans %}Pagar ads eternamente o construir activos propios{% endtrans %}</h2>
    <img src="{{ before_after_image }}" alt="{% trans %}Comparativa antes y después{% endtrans %}" class="cs-pain__image" loading="lazy" width="800" height="800">
    <div class="cs-pain__cards">
      <div class="cs-pain__card">
        <span class="cs-pain__value">0</span>
        <span class="cs-pain__label">{% trans %}visitas orgánicas{% endtrans %}</span>
      </div>
      <div class="cs-pain__card">
        <span class="cs-pain__value">0</span>
        <span class="cs-pain__label">{% trans %}artículos publicados{% endtrans %}</span>
      </div>
      <div class="cs-pain__card">
        <span class="cs-pain__value">4h</span>
        <span class="cs-pain__label">{% trans %}por artículo manual{% endtrans %}</span>
      </div>
      <div class="cs-pain__card">
        <span class="cs-pain__value">{{ jaraba_icon('ui', 'alert-circle', { variant: 'duotone', size: '28px', color: 'white' }) }}</span>
        <span class="cs-pain__label">{% trans %}100% dependiente de ads{% endtrans %}</span>
      </div>
    </div>
  </div>
</section>

{# === 4. EL DESCUBRIMIENTO === #}
<section class="cs-section cs-discovery reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--split">
    <div class="cs-section__content">
      <span class="cs-section__eyebrow">{% trans %}El momento decisivo{% endtrans %}</span>
      <h2 class="cs-section__title">{% trans %}8 artículos en una semana (sin sufrir){% endtrans %}</h2>
      <p>{% trans %}Luis ve en un webinar que una bodega de Ribera del Duero ha triplicado sus visitas con content marketing. La clave: un editor con IA que genera borradores optimizados para SEO. Prueba el Content Hub esa misma noche y pública su primer artículo en 25 minutos.{% endtrans %}</p>
      <blockquote class="cs-discovery__quote">
        <p>&ldquo;{% trans %}La IA me propuso un calendario editorial con 12 keywords estratégicas para nuestra denominación de origen. El primer borrador estaba tan bien que solo tuve que añadir anécdotas de la bodega. En una semana publiqué 8 artículos. Antes habría tardado 2 meses.{% endtrans %}&rdquo;</p>
        <footer>— Luis Moreno</footer>
      </blockquote>
    </div>
    <div class="cs-section__media">
      <img src="{{ editor_image }}" alt="{% trans %}Editor de contenido con IA y SEO score{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
    </div>
  </div>
</section>

{# === 5. LOS 6 MESES (timeline) === #}
<section class="cs-section cs-timeline reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <span class="cs-section__eyebrow">{% trans %}Los 6 meses{% endtrans %}</span>
    <h2 class="cs-section__title cs-section__title--center">{% trans %}De 0 a 12.000 visitas orgánicas{% endtrans %}</h2>
    <div class="cs-timeline__split">
      <div class="cs-timeline__media">
        <img src="{{ analytics_image }}" alt="{% trans %}Analytics SEO del Content Hub{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
      </div>
      <div class="cs-timeline__steps">
        {% for step in timeline %}
          <div class="cs-timeline__step">
            <span class="cs-timeline__day">{{ step.day }}</span>
            <div class="cs-timeline__detail">
              <h3 class="cs-timeline__step-title">{{ step.title }}</h3>
              <p class="cs-timeline__step-text">{{ step.text }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{# === 6. LOS RESULTADOS === #}
<section class="cs-section cs-results reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <span class="cs-section__eyebrow">{% trans %}6 meses después{% endtrans %}</span>
    <h2 class="cs-section__title cs-section__title--center">{% trans %}Los resultados hablan solos{% endtrans %}</h2>
    <div class="cs-results__grid">
      {% for m in metrics %}
        <div class="cs-results__card">
          <span class="cs-results__change">{{ m.change }}</span>
          <span class="cs-results__label">{{ m.label }}</span>
          <div class="cs-results__compare">
            <span class="cs-results__before">{% trans %}Antes:{% endtrans %} {{ m.before }}</span>
            <span class="cs-results__after">{% trans %}Ahora:{% endtrans %} {{ m.after }}</span>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# === 7. MULTICANAL === #}
<section class="cs-section cs-chef reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--split">
    <div class="cs-section__media">
      <img src="{{ multichannel_image }}" alt="{% trans %}Contenido distribuido en múltiples canales{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
    </div>
    <div class="cs-section__content">
      <span class="cs-section__eyebrow">{% trans %}El momento cumbre{% endtrans %}</span>
      <h2 class="cs-section__title">{% trans %}El blog genera más clientes que los anuncios{% endtrans %}</h2>
      <blockquote class="cs-discovery__quote">
        <p>&ldquo;{% trans %}Cuando vi que en el mes 5 el blog traía más leads que Google Ads, redujimos el presupuesto de anuncios un 60%. El contenido trabaja para nosotros 24/7. Cada artículo es un activo que sigue trayendo visitas meses después de publicarlo.{% endtrans %}&rdquo;</p>
        <footer>— Luis Moreno</footer>
      </blockquote>
      <p class="cs-chef__impact">{% trans %}12.000 visitas orgánicas al mes. 8 keywords en top 3 de Google. 2.400 suscriptores de newsletter. Presupuesto de ads reducido un 60%.{% endtrans %}</p>
    </div>
  </div>
</section>

{# === 8. TESTIMONIAL === #}
<section class="cs-section cs-testimonial reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--narrow">
    <blockquote class="cs-testimonial__quote" itemscope itemtype="https://schema.org/Review">
      <p class="cs-testimonial__text" itemprop="reviewBody">
        &ldquo;{{ testimonial.quote }}&rdquo;
      </p>
      <footer class="cs-testimonial__author">
        <div>
          <cite class="cs-testimonial__name" itemprop="author">{{ testimonial.name }}</cite>
          <span class="cs-testimonial__role">{{ testimonial.role }}, {{ testimonial.company }}</span>
        </div>
        <div class="cs-testimonial__stars" itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
          <meta itemprop="ratingValue" content="5">
          <meta itemprop="bestRating" content="5">
          ★★★★★
        </div>
      </footer>
    </blockquote>
  </div>
</section>

{# === 9. MINI PRICING === #}
<section class="cs-section cs-pricing reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <h2 class="cs-section__title cs-section__title--center">{% trans %}Planes Content Hub{% endtrans %}</h2>
    <div class="cs-pricing__cards">
      <div class="cs-pricing__card">
        <h3>Free</h3>
        <span class="cs-pricing__price">0 &euro;</span>
        <span class="cs-pricing__period">/{% trans %}mes{% endtrans %}</span>
        <p>{{ pricing.free_features }}</p>
        <a href="{{ register_url }}" class="btn btn--outline" data-track-cta="cs_hub_free" data-track-position="case_study_pricing">{% trans %}Empezar gratis{% endtrans %}</a>
      </div>
      <div class="cs-pricing__card cs-pricing__card--recommended">
        <span class="cs-pricing__badge">{% trans %}El plan de Luis{% endtrans %}</span>
        <h3>{% trans %}Starter{% endtrans %}</h3>
        <span class="cs-pricing__price">{{ pricing.starter_price }} &euro;</span>
        <span class="cs-pricing__period">/{% trans %}mes{% endtrans %}</span>
        <p>{{ pricing.starter_features }}</p>
        <a href="{{ pricing_url }}" class="btn btn--primary" data-track-cta="cs_hub_starter" data-track-position="case_study_pricing">{% trans %}Probar 14 días gratis{% endtrans %}</a>
      </div>
      <div class="cs-pricing__card">
        <h3>{% trans %}Profesional{% endtrans %}</h3>
        <span class="cs-pricing__price">{{ pricing.professional_price }} &euro;</span>
        <span class="cs-pricing__period">/{% trans %}mes{% endtrans %}</span>
        <p>{{ pricing.professional_features }}</p>
        <a href="{{ pricing_url }}" class="btn btn--outline" data-track-cta="cs_hub_professional" data-track-position="case_study_pricing">{% trans %}Ver detalles{% endtrans %}</a>
      </div>
    </div>
  </div>
</section>

{# === 10. CTA FINAL === #}
<section class="cs-section cs-final-cta">
  <div class="cs-section__container cs-section__container--narrow">
    <h2 class="cs-final-cta__title">{% trans %}¿Y si en 6 meses tu contenido trabaja para ti 24/7?{% endtrans %}</h2>
    <p class="cs-final-cta__subtitle">{% trans %}Sin tarjeta de crédito. Sin permanencia. 5 artículos gratis con IA.{% endtrans %}</p>
    <a href="{{ register_url }}" class="btn btn--primary btn--xl" data-track-cta="cs_hub_final_cta" data-track-position="case_study_bottom">
      {% trans %}Crear mi Content Hub gratis{% endtrans %}
    </a>
    <div class="cs-final-cta__trust">
      <span>{{ jaraba_icon('ui', 'shield', { variant: 'duotone', size: '16px', color: 'white' }) }} {% trans %}Datos en la UE{% endtrans %}</span>
      <span>{{ jaraba_icon('legal', 'shield-privacy', { variant: 'duotone', size: '16px', color: 'white' }) }} {% trans %}RGPD 100%{% endtrans %}</span>
      <span>{{ jaraba_icon('ui', 'lock', { variant: 'duotone', size: '16px', color: 'white' }) }} {% trans %}Tu contenido es confidencial{% endtrans %}</span>
    </div>
  </div>
</section>

{# === SCHEMA.ORG === #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "0 visitas organicas. 6 meses para llegar a 12.000 al mes",
  "author": { "@type": "Organization", "name": "Jaraba Impact Platform" },
  "datePublished": "2026-03-20",
  "publisher": { "@type": "Organization", "name": "PED S.L." },
  "description": "Bodega Montilla (Cordoba) paso de 0 visitas organicas y dependencia total de Google Ads a 12.000 visitas mensuales, 45 articulos y un coste por lead un 89% menor con Content Hub."
}
</script>
