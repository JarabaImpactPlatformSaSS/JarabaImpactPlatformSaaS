{#
/**
 * @file
 * page--vertical-landing.html.twig - Template para landing pages de verticales.
 *
 * ARQUITECTURA:
 * - Zero Region Policy — usa {{ clean_content }}
 * - Reutiliza partials de header y footer
 * - Usa variables CSS var(--ej-*)
 * - i18n con {% trans %}
 *
 * RUTAS:
 * - /empleo, /talento, /emprender, /comercio, /instituciones
 * - /jarabalex, /legal, /agroconecta, /comercioconecta, etc.
 *
 * @see ecosistema_jaraba_theme.theme para preprocess
 */
#}
{% set site_name = site_name|default('Jaraba Impact Platform') %}

{{ attach_library('ecosistema_jaraba_core/global') }}
{{ attach_library('ecosistema_jaraba_theme/progressive-profiling') }}

{# Sprint 4 SEO/GEO: Schema.org contextual por vertical #}
{% if vertical_key is defined and vertical_key %}
  {% include '@ecosistema_jaraba_theme/partials/_vertical-schema.html.twig' with {
    vertical_key: vertical_key,
    site_name: site_name,
  } only %}
{% endif %}

<div class="page-wrapper page-wrapper--clean page-wrapper--landing">

  {# HEADER - Partial reutilizable con menú móvil #}
  {% include '@ecosistema_jaraba_theme/partials/_header.html.twig' with {
    site_name: site_name,
    site_slogan: site_slogan,
    logo: logo,
    logged_in: logged_in,
    theme_settings: theme_settings
  } %}

  {# MAIN CONTENT - Full width #}
  <main id="main-content" class="landing-main">
    
    {% if clean_messages %}
      <div class="highlighted container">
        {{ clean_messages }}
      </div>
    {% endif %}

    {# CONTENIDO DE LA PÁGINA (render del controlador) #}
    {{ clean_content }}

    {# PROMO BANNER — Configurable desde Theme Settings #}
    {% if theme_settings.promo_banner_enabled|default(false) %}
      {% include '@ecosistema_jaraba_theme/partials/_promo-banner.html.twig' with {
        promo_title: theme_settings.promo_banner_title|default(''),
        promo_text: theme_settings.promo_banner_text|default(''),
        promo_url: theme_settings.promo_banner_url|default(''),
        promo_cta: theme_settings.promo_banner_cta|default(''),,
    'available_languages': available_languages|default([]),
    'current_langcode': current_langcode|default('es'),
    'language_prefix': language_prefix|default(''),
    'language_links': language_links|default({}),
    'mega_menu_columns': mega_menu_columns|default([]),
  } only %}
    {% endif %}

  </main>

  {# FOOTER - Partial configurable desde UI #}
  {% include '@ecosistema_jaraba_theme/partials/_footer.html.twig' with {
    site_name: site_name,
    logo: logo,
    footer_copyright: footer_copyright,
    theme_settings: theme_settings
  } %}

  {# FAB COPILOTO #}
  {% include '@ecosistema_jaraba_theme/partials/_copilot-fab.html.twig' with {
    agent_context: vertical_key|default('public') ~ '_copilot',
    avatar_type: 'general',
    fab_color: 'var(--ej-color-impulse, #FF8C42)',
    is_expanded: false
  } %}

</div>
