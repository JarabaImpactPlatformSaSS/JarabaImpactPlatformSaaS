{#
/**
 * @file
 * page--checkout.html.twig — Checkout Stripe Embebido (Premium).
 *
 * Template zero-region para /planes/checkout/* (checkout, success, cancel).
 * Layout limpio full-width, sin regiones ni bloques de Drupal.
 *
 * ARQUITECTURA:
 * - ZERO-REGION-001: Sin {{ page.* }}, solo {{ clean_content }}
 * - Body class 'page-checkout clean-layout full-width-layout' via hook_preprocess_html()
 * - Variables CSS var(--ej-*) inyectadas desde theme settings UI
 * - Footer copyright configurable desde Apariencia > Ecosistema Jaraba Theme
 * - ROUTE-LANGPREFIX-001: URLs con language_prefix
 *
 * STRIPE-CHECKOUT-001 §5.3
 */
#}
{% set site_name = site_name|default('Jaraba Impact Platform') %}
{% set lp = language_prefix|default('') %}
{% set copyright = footer_copyright|default('&copy; [year] ' ~ site_name)|replace({'[year]': 'now'|date('Y')}) %}

{{ attach_library('ecosistema_jaraba_theme/global-styling') }}

{# ================================================================
   HEADER CHECKOUT — 3 zonas: Logo | Seguridad | Volver
   ================================================================ #}
<header class="checkout-header" role="banner">
  <div class="checkout-header__inner">
    <a href="{{ lp }}/" class="checkout-header__logo" aria-label="{% trans %}Volver al inicio{% endtrans %}" rel="home">
      {% if logo %}
        <img src="{{ logo }}" alt="{{ site_name }}" class="checkout-header__logo-img" loading="eager">
      {% endif %}
      <span class="checkout-header__logo-text">{{ site_name }}</span>
    </a>

    <div class="checkout-header__center">
      <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
        <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
      </svg>
      <span>{% trans %}Checkout seguro{% endtrans %}</span>
    </div>

    <a href="{{ path('ecosistema_jaraba_core.pricing.page') }}" class="checkout-header__back">
      <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
      </svg>
      {% trans %}Volver a planes{% endtrans %}
    </a>
  </div>
</header>

{# ================================================================
   DRUPAL MESSAGES
   ================================================================ #}
{% if clean_messages %}
  <div class="checkout-messages">
    {{ clean_messages }}
  </div>
{% endif %}

{# ================================================================
   MAIN CONTENT — Checkout embebido (full-width)
   ================================================================ #}
<main id="main-content" class="checkout-main" role="main">
  {{ clean_content }}
</main>

{# ================================================================
   FOOTER CHECKOUT — Minimal, configurable desde theme settings UI
   ================================================================ #}
<footer class="checkout-footer" role="contentinfo">
  <div class="checkout-footer__inner">
    <div class="checkout-footer__security">
      <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
        <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
      </svg>
      {% trans %}Powered by Stripe{% endtrans %}
    </div>
    <div class="checkout-footer__links">
      <a href="{{ lp }}/terminos-uso">{% trans %}Terminos de uso{% endtrans %}</a>
      <a href="{{ lp }}/politica-privacidad">{% trans %}Politica de privacidad{% endtrans %}</a>
    </div>
    <p class="checkout-footer__copyright">{{ copyright }}</p>
  </div>
</footer>
