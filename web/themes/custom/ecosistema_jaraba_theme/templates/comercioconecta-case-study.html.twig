{#
/**
 * @file comercioconecta-case-study.html.twig
 * Caso de éxito: Boutique La Mariposa, Sevilla — storytelling de conversión.
 *
 * VARIABLES:
 * - hero_image, carmen_image, before_after_image, qr_image,
 *   dashboard_image, influencer_image: string (URL relativa a WebP)
 * - metrics: array of {label, before, after, change}
 * - testimonial: {quote, name, role, company}
 * - timeline: array of {day, title, text}
 * - pricing_url, register_url: string
 *
 * DIRECTIVES: ZERO-REGION-001, i18n (trans), ICON-CONVENTION-001,
 * CSS-VAR-ALL-COLORS-001, DOC-GLOSSARY-001
 */
#}

{# === 1. HERO === #}
<section class="cs-hero" style="background-image: url('{{ hero_image }}');" aria-labelledby="cs-title">
  <div class="cs-hero__overlay"></div>
  <div class="cs-hero__container">
    <span class="cs-hero__eyebrow">{% trans %}Caso de éxito{% endtrans %}</span>
    <h1 id="cs-title" class="cs-hero__title">
      {% trans %}Un QR en el escaparate que vende mientras duermes{% endtrans %}
    </h1>
    <p class="cs-hero__subtitle">
      {% trans %}La historia de Boutique La Mariposa: cómo una tienda de 40 m² en Sevilla aumentó un 47% su facturación con ComercioConecta{% endtrans %}
    </p>
    <div class="cs-hero__ctas">
      <a href="{{ pricing_url }}" class="btn btn--primary btn--lg" data-track-cta="cs_comercio_hero_trial" data-track-position="case_study_hero">
        {% trans %}Probar ComercioConecta gratis{% endtrans %}
      </a>
      <a href="#cs-story" class="btn btn--outline btn--lg cs-hero__scroll-cta">
        {% trans %}Leer la historia{% endtrans %} ↓
      </a>
    </div>
  </div>
</section>

{# === 2. LA BOUTIQUE (contexto) === #}
<section id="cs-story" class="cs-section cs-context reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--split">
    <div class="cs-section__media">
      <img src="{{ carmen_image }}" alt="{% trans %}Carmen Ruiz en su boutique{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
    </div>
    <div class="cs-section__content">
      <span class="cs-section__eyebrow">{% trans %}La boutique{% endtrans %}</span>
      <h2 class="cs-section__title">{% trans %}Boutique La Mariposa, Sevilla{% endtrans %}</h2>
      <div class="cs-badges">
        <span class="cs-badge">{% trans %}40 m²{% endtrans %}</span>
        <span class="cs-badge">{% trans %}Barrio Santa Cruz{% endtrans %}</span>
        <span class="cs-badge">{% trans %}Moda artesanal andaluza{% endtrans %}</span>
      </div>
      <p>{% trans %}Carmen Ruiz tiene 44 años y lleva 26 al frente de su boutique en el casco histórico de Sevilla. Vestidos de lino de Cádiz, bolsos de piel de Ubrique, joyas de diseñadoras andaluzas. Conoce a cada clienta por su nombre.{% endtrans %}</p>
      <p>{% trans %}Pero si no entran por la puerta, no venden. Sin web, sin tienda online, sin presencia en Google. Cuando la persiana baja, la facturación se detiene.{% endtrans %}</p>
    </div>
  </div>
</section>

{# === 3. EL DOLOR === #}
<section class="cs-section cs-pain reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <span class="cs-section__eyebrow">{% trans %}El problema{% endtrans %}</span>
    <h2 class="cs-section__title cs-section__title--center">{% trans %}Antes de ComercioConecta{% endtrans %}</h2>
    <img src="{{ before_after_image }}" alt="{% trans %}Comparativa antes y después{% endtrans %}" class="cs-pain__image" loading="lazy" width="800" height="800">
    <div class="cs-pain__cards">
      <div class="cs-pain__card">
        <span class="cs-pain__value">0 €</span>
        <span class="cs-pain__label">{% trans %}ventas online{% endtrans %}</span>
      </div>
      <div class="cs-pain__card">
        <span class="cs-pain__value">68</span>
        <span class="cs-pain__label">{% trans %}clientas (solo barrio){% endtrans %}</span>
      </div>
      <div class="cs-pain__card">
        <span class="cs-pain__value">4</span>
        <span class="cs-pain__label">{% trans %}meses con pérdidas/año{% endtrans %}</span>
      </div>
      <div class="cs-pain__card">
        <span class="cs-pain__value">{{ jaraba_icon('ui', 'alert-circle', { variant: 'duotone', size: '28px', color: 'white' }) }}</span>
        <span class="cs-pain__label">{% trans %}sin presencia digital{% endtrans %}</span>
      </div>
    </div>
  </div>
</section>

{# === 4. EL QR DEL ESCAPARATE === #}
<section class="cs-section cs-discovery reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--split">
    <div class="cs-section__content">
      <span class="cs-section__eyebrow">{% trans %}El momento decisivo{% endtrans %}</span>
      <h2 class="cs-section__title">{% trans %}Un escaparate que no cierra nunca{% endtrans %}</h2>
      <p>{% trans %}En un networking de comerciantes de Sevilla, Marta (dueña de una tienda gourmet en Triana) le muestra un QR en su escaparate. Lo escaneas y aparece el catálogo con precios, ofertas flash y botón de compra con Bizum. A las 11 de la noche, turistas compran sin que Marta esté en la tienda.{% endtrans %}</p>
      <blockquote class="cs-discovery__quote">
        <p>&ldquo;{% trans %}Carmen, mi tienda factura las 24 horas. El QR del escaparate genera el 25% de mis ventas. Turistas que pasan a las 11 de la noche, ven un queso en el cristal, escanean el QR y lo compran para recoger al día siguiente.{% endtrans %}&rdquo;</p>
        <footer>— {% trans %}Marta, tienda gourmet en Triana{% endtrans %}</footer>
      </blockquote>
    </div>
    <div class="cs-section__media">
      <img src="{{ qr_image }}" alt="{% trans %}Escaneando QR en escaparate de boutique{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
    </div>
  </div>
</section>

{# === 5. LOS 14 DÍAS (timeline) === #}
<section class="cs-section cs-timeline reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <span class="cs-section__eyebrow">{% trans %}Los 14 días{% endtrans %}</span>
    <h2 class="cs-section__title cs-section__title--center">{% trans %}La transformación paso a paso{% endtrans %}</h2>
    <div class="cs-timeline__split">
      <div class="cs-timeline__media">
        <img src="{{ dashboard_image }}" alt="{% trans %}Dashboard de comerciante ComercioConecta{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
      </div>
      <div class="cs-timeline__steps">
        {% for step in timeline %}
          <div class="cs-timeline__step">
            <span class="cs-timeline__day">{% trans %}Día{% endtrans %} {{ step.day }}</span>
            <div class="cs-timeline__detail">
              <h3 class="cs-timeline__step-title">{{ step.title }}</h3>
              <p class="cs-timeline__step-text">{{ step.text }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{# === 6. LOS RESULTADOS === #}
<section class="cs-section cs-results reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <span class="cs-section__eyebrow">{% trans %}3 meses después{% endtrans %}</span>
    <h2 class="cs-section__title cs-section__title--center">{% trans %}Los resultados hablan solos{% endtrans %}</h2>
    <div class="cs-results__grid">
      {% for m in metrics %}
        <div class="cs-results__card">
          <span class="cs-results__change">{{ m.change }}</span>
          <span class="cs-results__label">{{ m.label }}</span>
          <div class="cs-results__compare">
            <span class="cs-results__before">{% trans %}Antes:{% endtrans %} {{ m.before }}</span>
            <span class="cs-results__after">{% trans %}Ahora:{% endtrans %} {{ m.after }}</span>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# === 7. LA INFLUENCER === #}
<section class="cs-section cs-chef reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--split">
    <div class="cs-section__media">
      <img src="{{ influencer_image }}" alt="{% trans %}Influencer de moda con bolso artesanal de Ubrique{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
    </div>
    <div class="cs-section__content">
      <span class="cs-section__eyebrow">{% trans %}El momento cumbre{% endtrans %}</span>
      <h2 class="cs-section__title">{% trans %}Una influencer escanea el QR del escaparate{% endtrans %}</h2>
      <blockquote class="cs-discovery__quote">
        <p>&ldquo;{% trans %}Vi el QR y me llamó la atención porque nunca había visto algo así en una tienda de barrio. Escaneé, vi los bolsos de Ubrique con la historia del artesano que los hace, y pensé: esto es exactamente lo que mi comunidad busca. Moda con historia, no moda de usar y tirar.{% endtrans %}&rdquo;</p>
        <footer>— {% trans %}Ana Belén Romero, influencer de moda sostenible (45K seguidores){% endtrans %}</footer>
      </blockquote>
      <p class="cs-chef__impact">{% trans %}87.000 visualizaciones en Instagram. 34 ventas nuevas la semana siguiente (2.890 €), 12 de ellas desde fuera de Sevilla.{% endtrans %}</p>
    </div>
  </div>
</section>

{# === 8. TESTIMONIAL === #}
<section class="cs-section cs-testimonial reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--narrow">
    <blockquote class="cs-testimonial__quote" itemscope itemtype="https://schema.org/Review">
      <p class="cs-testimonial__text" itemprop="reviewBody">
        &ldquo;{{ testimonial.quote }}&rdquo;
      </p>
      <footer class="cs-testimonial__author">
        <div>
          <cite class="cs-testimonial__name" itemprop="author">{{ testimonial.name }}</cite>
          <span class="cs-testimonial__role">{{ testimonial.role }}, {{ testimonial.company }}</span>
        </div>
        <div class="cs-testimonial__stars" itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
          <meta itemprop="ratingValue" content="5">
          <meta itemprop="bestRating" content="5">
          ★★★★★
        </div>
      </footer>
    </blockquote>
  </div>
</section>

{# === 9. MINI PRICING === #}
<section class="cs-section cs-pricing reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <h2 class="cs-section__title cs-section__title--center">{% trans %}Planes ComercioConecta{% endtrans %}</h2>
    <div class="cs-pricing__cards">
      <div class="cs-pricing__card">
        <h3>Free</h3>
        <span class="cs-pricing__price">0 &euro;</span>
        <span class="cs-pricing__period">/{% trans %}mes{% endtrans %}</span>
        <p>{{ pricing.free_features }}</p>
        <a href="{{ register_url }}" class="btn btn--outline" data-track-cta="cs_comercio_free" data-track-position="case_study_pricing">{% trans %}Empezar gratis{% endtrans %}</a>
      </div>
      <div class="cs-pricing__card cs-pricing__card--recommended">
        <span class="cs-pricing__badge">{% trans %}El plan de Carmen{% endtrans %}</span>
        <h3>{% trans %}Starter{% endtrans %}</h3>
        <span class="cs-pricing__price">{{ pricing.starter_price }} &euro;</span>
        <span class="cs-pricing__period">/{% trans %}mes{% endtrans %}</span>
        <p>{{ pricing.starter_features }}</p>
        <a href="{{ pricing_url }}" class="btn btn--primary" data-track-cta="cs_comercio_starter" data-track-position="case_study_pricing">{% trans %}Probar 14 días gratis{% endtrans %}</a>
      </div>
      <div class="cs-pricing__card">
        <h3>{% trans %}Profesional{% endtrans %}</h3>
        <span class="cs-pricing__price">{{ pricing.professional_price }} &euro;</span>
        <span class="cs-pricing__period">/{% trans %}mes{% endtrans %}</span>
        <p>{{ pricing.professional_features }}</p>
        <a href="{{ pricing_url }}" class="btn btn--outline" data-track-cta="cs_comercio_professional" data-track-position="case_study_pricing">{% trans %}Ver detalles{% endtrans %}</a>
      </div>
    </div>
  </div>
</section>

{# === 10. CTA FINAL === #}
<section class="cs-section cs-final-cta">
  <div class="cs-section__container cs-section__container--narrow">
    <h2 class="cs-final-cta__title">{% trans %}¿Y si el próximo QR en un escaparate cuenta la historia de tu tienda?{% endtrans %}</h2>
    <p class="cs-final-cta__subtitle">{% trans %}Sin tarjeta de crédito. Sin permanencia. 14 días gratis.{% endtrans %}</p>
    <a href="{{ register_url }}" class="btn btn--primary btn--xl" data-track-cta="cs_comercio_final_cta" data-track-position="case_study_bottom">
      {% trans %}Probar ComercioConecta gratis{% endtrans %}
    </a>
    <div class="cs-final-cta__trust">
      <span>{{ jaraba_icon('ui', 'shield', { variant: 'duotone', size: '16px', color: 'white' }) }} {% trans %}Datos en la UE{% endtrans %}</span>
      <span>{{ jaraba_icon('legal', 'shield-privacy', { variant: 'duotone', size: '16px', color: 'white' }) }} {% trans %}RGPD 100%{% endtrans %}</span>
      <span>{{ jaraba_icon('ui', 'lock', { variant: 'duotone', size: '16px', color: 'white' }) }} {% trans %}Pagos seguros (Stripe){% endtrans %}</span>
    </div>
  </div>
</section>

{# === SCHEMA.ORG === #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Un QR en el escaparate que vende mientras duermes: Boutique La Mariposa, Sevilla",
  "author": { "@type": "Organization", "name": "Jaraba Impact Platform" },
  "datePublished": "2026-03-20",
  "publisher": { "@type": "Organization", "name": "PED S.L." },
  "description": "Boutique La Mariposa, 40 m2 en el casco historico de Sevilla, paso de cero ventas online a aumentar un 47% su facturacion con un QR en el escaparate y ComercioConecta."
}
</script>
