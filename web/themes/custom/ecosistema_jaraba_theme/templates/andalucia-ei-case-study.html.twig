{#
/**
 * @file andalucia-ei-case-study.html.twig
 * Caso de éxito: PED S.L. — dogfooding Andalucía +ei.
 *
 * VARIABLES:
 * - hero_image, protagonist_image, before_after_image, dashboard_image,
 *   mentoring_image, report_image: string (URL relativa a WebP)
 * - metrics: array of {label, before, after, change}
 * - testimonial_hero: {quote, name, role, company}
 * - testimonial: {quote, name, role, company}
 * - timeline: array of {day, title, text}
 * - pricing_url, register_url: string
 *
 * DIRECTIVES: ZERO-REGION-001, i18n (trans), ICON-CONVENTION-001,
 * CSS-VAR-ALL-COLORS-001, DOC-GLOSSARY-001
 */
#}

{# === 1. HERO === #}
<section class="cs-hero" style="background-image: url('{{ hero_image }}');" aria-labelledby="cs-title">
  <div class="cs-hero__overlay"></div>
  <div class="cs-hero__container">
    <span class="cs-hero__eyebrow">{% trans %}Caso de éxito{% endtrans %}</span>
    <h1 id="cs-title" class="cs-hero__title">
      {% trans %}De gestionar 50 itinerarios en Excel a un ecosistema digital con IA{% endtrans %}
    </h1>
    <p class="cs-hero__subtitle">
      {% trans %}La historia de PED S.L.: cómo la empresa que construye el SaaS lo usa para gestionar su propio Programa Integrado de Inserción Laboral en Andalucía{% endtrans %}
    </p>
    <div class="cs-hero__ctas">
      <a href="{{ register_url }}" class="btn btn--primary btn--lg" data-track-cta="cs_ei_hero_demo" data-track-position="case_study_hero">
        {% trans %}Solicitar demo{% endtrans %}
      </a>
      <a href="#cs-story" class="btn btn--outline btn--lg cs-hero__scroll-cta">
        {% trans %}Leer la historia{% endtrans %} ↓
      </a>
    </div>
  </div>
</section>

{# === 2. PROTAGONISTA (contexto) === #}
<section id="cs-story" class="cs-section cs-context reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--split">
    <div class="cs-section__media">
      <img src="{{ protagonist_image }}" alt="{% trans %}Equipo técnico del programa Andalucía +ei{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
    </div>
    <div class="cs-section__content">
      <span class="cs-section__eyebrow">{% trans %}El protagonista{% endtrans %}</span>
      <h2 class="cs-section__title">{% trans %}Plataforma de Ecosistemas Digitales S.L.{% endtrans %}</h2>
      <div class="cs-badges">
        <span class="cs-badge">{% trans %}Málaga{% endtrans %}</span>
        <span class="cs-badge">{% trans %}Inserción laboral{% endtrans %}</span>
        <span class="cs-badge">{% trans %}Programa +ei{% endtrans %}</span>
      </div>
      <p>{% trans %}PED S.L. gestionó en 2023 un Programa Integrado de Inserción Laboral (PIIL) subvencionado por la Junta de Andalucía. 50 participantes en 8 provincias, 8 orientadores, itinerarios de autoempleo, formación, sesiones de orientación — todo coordinado con hojas Excel compartidas y email.{% endtrans %}</p>
      <p>{% trans %}La experiencia les mostró exactamente qué necesitaban: así nació Andalucía +ei. En 2025 obtuvieron la concesión de la 2ª edición y la gestionan íntegramente desde su propio SaaS.{% endtrans %}</p>
    </div>
  </div>
</section>

{# === 3. EL DOLOR === #}
<section class="cs-section cs-pain reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <span class="cs-section__eyebrow">{% trans %}El problema{% endtrans %}</span>
    <h2 class="cs-section__title cs-section__title--center">{% trans %}8 provincias, 8 hojas Excel, 0 visibilidad{% endtrans %}</h2>
    <img src="{{ before_after_image }}" alt="{% trans %}Comparativa antes y después{% endtrans %}" class="cs-pain__image" loading="lazy" width="800" height="800">
    <div class="cs-pain__cards">
      <div class="cs-pain__card">
        <span class="cs-pain__value">50</span>
        <span class="cs-pain__label">{% trans %}participantes en Excel{% endtrans %}</span>
      </div>
      <div class="cs-pain__card">
        <span class="cs-pain__value">8</span>
        <span class="cs-pain__label">{% trans %}provincias sin coordinación{% endtrans %}</span>
      </div>
      <div class="cs-pain__card">
        <span class="cs-pain__value">{{ jaraba_icon('ui', 'clock', { variant: 'duotone', size: '28px', color: 'white' }) }}</span>
        <span class="cs-pain__label">{% trans %}semanas por informe SAE{% endtrans %}</span>
      </div>
      <div class="cs-pain__card">
        <span class="cs-pain__value">{{ jaraba_icon('ui', 'alert-circle', { variant: 'duotone', size: '28px', color: 'white' }) }}</span>
        <span class="cs-pain__label">{% trans %}sin seguimiento individualizado{% endtrans %}</span>
      </div>
    </div>
  </div>
</section>

{# === 4. EL MOMENTO DECISIVO === #}
<section class="cs-section cs-discovery reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--split">
    <div class="cs-section__content">
      <span class="cs-section__eyebrow">{% trans %}El momento decisivo{% endtrans %}</span>
      <h2 class="cs-section__title">{% trans %}Si no existe, lo construimos{% endtrans %}</h2>
      <p>{% trans %}Tras 18 meses gestionando el PIIL con Excel, el equipo de PED S.L. tenía claro que no existía en el mercado una herramienta adaptada a la gestión de programas de inserción laboral con itinerarios individualizados, formación integrada y reporting automático para el SAE.{% endtrans %}</p>
      <blockquote class="cs-discovery__quote">
        <p>&ldquo;{{ testimonial_hero.quote }}&rdquo;</p>
        <footer>— {{ testimonial_hero.name }}, {{ testimonial_hero.role }}</footer>
      </blockquote>
    </div>
    <div class="cs-section__media">
      <img src="{{ mentoring_image }}" alt="{% trans %}Diseño del ecosistema Andalucía +ei{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
    </div>
  </div>
</section>

{# === 5. TIMELINE === #}
<section class="cs-section cs-timeline reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <span class="cs-section__eyebrow">{% trans %}La evolución{% endtrans %}</span>
    <h2 class="cs-section__title cs-section__title--center">{% trans %}De Excel a plataforma de impacto{% endtrans %}</h2>
    <div class="cs-timeline__split">
      <div class="cs-timeline__media">
        <img src="{{ dashboard_image }}" alt="{% trans %}Dashboard de gestión del programa{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
      </div>
      <div class="cs-timeline__steps">
        {% for step in timeline %}
          <div class="cs-timeline__step">
            <span class="cs-timeline__day">{{ step.day }}</span>
            <div class="cs-timeline__detail">
              <h3 class="cs-timeline__step-title">{{ step.title }}</h3>
              <p class="cs-timeline__step-text">{{ step.text }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{# === 6. LOS RESULTADOS === #}
<section class="cs-section cs-results reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <span class="cs-section__eyebrow">{% trans %}1ª edición vs 2ª edición{% endtrans %}</span>
    <h2 class="cs-section__title cs-section__title--center">{% trans %}Los resultados hablan solos{% endtrans %}</h2>
    <div class="cs-results__grid">
      {% for m in metrics %}
        <div class="cs-results__card">
          <span class="cs-results__change">{{ m.change }}</span>
          <span class="cs-results__label">{{ m.label }}</span>
          <div class="cs-results__compare">
            <span class="cs-results__before">{% trans %}1ª ed:{% endtrans %} {{ m.before }}</span>
            <span class="cs-results__after">{% trans %}2ª ed:{% endtrans %} {{ m.after }}</span>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# === 7. LA VISIÓN === #}
<section class="cs-section cs-chef reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--split">
    <div class="cs-section__media">
      <img src="{{ report_image }}" alt="{% trans %}Panel de gestión del programa PIIL{% endtrans %}" class="cs-section__image" loading="lazy" width="600" height="600">
    </div>
    <div class="cs-section__content">
      <span class="cs-section__eyebrow">{% trans %}La visión{% endtrans %}</span>
      <h2 class="cs-section__title">{% trans %}Un SaaS nacido de la necesidad real{% endtrans %}</h2>
      <blockquote class="cs-discovery__quote">
        <p>&ldquo;{{ testimonial.quote }}&rdquo;</p>
        <footer>— {{ testimonial.name }}</footer>
      </blockquote>
      <p class="cs-chef__impact">{% trans %}50 participantes en la 1ª edición. 45 en la 2ª. 23 inserciones laborales verificadas. 8 provincias unificadas en un solo panel.{% endtrans %}</p>
    </div>
  </div>
</section>

{# === 8. TESTIMONIAL === #}
<section class="cs-section cs-testimonial reveal-element reveal-fade-up">
  <div class="cs-section__container cs-section__container--narrow">
    <blockquote class="cs-testimonial__quote" itemscope itemtype="https://schema.org/Review">
      <p class="cs-testimonial__text" itemprop="reviewBody">
        &ldquo;{{ testimonial_hero.quote }}&rdquo;
      </p>
      <footer class="cs-testimonial__author">
        <div>
          <cite class="cs-testimonial__name" itemprop="author">{{ testimonial_hero.name }}</cite>
          <span class="cs-testimonial__role">{{ testimonial_hero.role }}, {{ testimonial_hero.company }}</span>
        </div>
        <div class="cs-testimonial__stars" itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
          <meta itemprop="ratingValue" content="5">
          <meta itemprop="bestRating" content="5">
          ★★★★★
        </div>
      </footer>
    </blockquote>
  </div>
</section>

{# === 9. CTA (sin pricing — B2G/B2B) === #}
<section class="cs-section cs-pricing reveal-element reveal-fade-up">
  <div class="cs-section__container">
    <h2 class="cs-section__title cs-section__title--center">{% trans %}Solución para entidades gestoras de programas de empleo{% endtrans %}</h2>
    <div class="cs-pricing__cards">
      <div class="cs-pricing__card cs-pricing__card--recommended" style="max-width: 480px; margin: 0 auto;">
        <span class="cs-pricing__badge">{% trans %}Programa Andalucía +ei{% endtrans %}</span>
        <h3>{% trans %}Enterprise{% endtrans %}</h3>
        <span class="cs-pricing__price" style="font-size: 1.5rem;">{% trans %}Precio a medida{% endtrans %}</span>
        <p>{% trans %}Tu marca, tu dominio. Gestión de participantes, itinerarios IPAE, formación, seguimiento de inserción, copilot IA y reporting automático para el SAE.{% endtrans %}</p>
        <a href="{{ register_url }}" class="btn btn--primary" data-track-cta="cs_ei_enterprise" data-track-position="case_study_pricing">{% trans %}Solicitar demo{% endtrans %}</a>
      </div>
    </div>
  </div>
</section>

{# === 10. CTA FINAL === #}
<section class="cs-section cs-final-cta">
  <div class="cs-section__container cs-section__container--narrow">
    <h2 class="cs-final-cta__title">{% trans %}¿Gestionas programas de inserción laboral?{% endtrans %}</h2>
    <p class="cs-final-cta__subtitle">{% trans %}Tu marca. Tu plataforma. Itinerarios individualizados con IA. Informes automáticos para justificación ante organismos públicos.{% endtrans %}</p>
    <a href="{{ register_url }}" class="btn btn--primary btn--xl" data-track-cta="cs_ei_final_cta" data-track-position="case_study_bottom">
      {% trans %}Solicitar demo{% endtrans %}
    </a>
    <div class="cs-final-cta__trust">
      <span>{{ jaraba_icon('ui', 'shield', { variant: 'duotone', size: '16px', color: 'white' }) }} {% trans %}Datos en la UE{% endtrans %}</span>
      <span>{{ jaraba_icon('legal', 'shield-privacy', { variant: 'duotone', size: '16px', color: 'white' }) }} {% trans %}RGPD y LOPDGDD{% endtrans %}</span>
      <span>{{ jaraba_icon('ui', 'lock', { variant: 'duotone', size: '16px', color: 'white' }) }} {% trans %}Aislamiento de datos por tenant{% endtrans %}</span>
    </div>
  </div>
</section>

{# === SCHEMA.ORG === #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "De gestionar 50 itinerarios de inserción laboral en Excel a un ecosistema digital con IA",
  "author": { "@type": "Organization", "name": "Jaraba Impact Platform" },
  "datePublished": "2026-03-23",
  "publisher": { "@type": "Organization", "name": "PED S.L." },
  "description": "PED S.L. gestiono su primer Programa Integrado de Insercion Laboral con Excel en 8 provincias. La experiencia les llevo a construir Andalucia +ei, el SaaS que ahora usan para gestionar la 2a edicion."
}
</script>
