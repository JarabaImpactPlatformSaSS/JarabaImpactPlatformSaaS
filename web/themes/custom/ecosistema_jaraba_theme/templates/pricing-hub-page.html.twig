{#
/**
 * @file pricing-hub-page.html.twig
 * Hub page /planes — Vertical comparator linking to /{vertical}/planes.
 *
 * Displays a grid of 7 priority verticals, each with starting price,
 * icon, tagline and CTA to its vertical pricing page.
 *
 * VARIABLES:
 * - verticals: Array of vertical data with:
 *   - key: string (machine_name)
 *   - label: string (display name)
 *   - tagline: string (short description)
 *   - icon_category: string (for jaraba_icon)
 *   - icon_name: string (for jaraba_icon)
 *   - from_price: string (e.g. '0€/mes')
 *   - from_label: string (e.g. 'Empieza gratis')
 *   - plans_url: string (URL to /{vertical}/planes)
 * - page_title: string
 * - page_subtitle: string
 * - faq_items: array of {question, answer}
 * - guarantee_text: string
 *
 * DIRECTIVES:
 * - ZERO-REGION-001: Clean template, no page.content
 * - i18n: {% trans %} on all static text
 * - ICON-CONVENTION-001: jaraba_icon with variant duotone
 * - CSS-VAR-ALL-COLORS-001: var(--ej-*) with fallbacks
 * - ROUTE-LANGPREFIX-001: All URLs via path()/url()
 *
 * @see \Drupal\ecosistema_jaraba_core\Controller\PricingController::pricingPage()
 */
#}

{# === MAIN WRAPPER — rounded dark container === #}
<div class="pricing-wrapper">

{# === HERO SECTION === #}
<section class="pricing-hub-hero reveal-element reveal-fade-up" aria-labelledby="hub-title">
  <canvas class="pricing-hub-hero__particles" aria-hidden="true"></canvas>
  <div class="pricing-hub-hero__container">
    <span class="pricing-hub-hero__eyebrow">{% trans %}Planes y Precios{% endtrans %}</span>
    <h1 id="hub-title" class="pricing-hub-hero__title">
      {{ page_title }}
    </h1>
    <p class="pricing-hub-hero__subtitle">
      {{ page_subtitle }}
    </p>
  </div>
</section>

{# === VERTICALS GRID === #}
<section class="pricing-hub-grid reveal-element reveal-fade-up" aria-label="{% trans %}Verticales disponibles{% endtrans %}">
  <div class="pricing-hub-grid__container">
    {% for vertical in verticals %}
      <article class="pricing-hub-card"
               aria-labelledby="hub-card-{{ vertical.key }}">
        <div class="pricing-hub-card__icon">
          {{ jaraba_icon(vertical.icon_category, vertical.icon_name, { variant: 'duotone', size: '40px', color: 'naranja-impulso' }) }}
        </div>
        <h2 id="hub-card-{{ vertical.key }}" class="pricing-hub-card__name">
          {{ vertical.label }}
        </h2>
        <p class="pricing-hub-card__tagline">{{ vertical.tagline }}</p>
        <div class="pricing-hub-card__price">
          <span class="pricing-hub-card__from-label">{{ vertical.from_label }}</span>
        </div>
        <a href="{{ vertical.plans_url }}"
           class="btn btn--primary btn--md pricing-hub-card__cta"
           data-track-cta="hub_{{ vertical.key }}"
           data-track-position="pricing_hub">
          {% trans %}Ver planes{% endtrans %}
        </a>
      </article>
    {% endfor %}
  </div>
</section>

{# === TIERS OVERVIEW === #}
<section class="pricing-hub-overview reveal-element reveal-fade-up" aria-labelledby="hub-overview-title">
  <div class="pricing-hub-overview__container">
    <h2 id="hub-overview-title" class="pricing-hub-overview__title">
      {% trans %}4 niveles para cada vertical{% endtrans %}
    </h2>
    <p class="pricing-hub-overview__subtitle">
      {% trans %}Todos los verticales ofrecen 4 planes — desde gratuito hasta enterprise — adaptados a tu nivel de necesidad.{% endtrans %}
    </p>

    {# NO-HARDCODE-PRICE-001: Tiers dinámicos desde MetaSitePricingService #}
    <div class="pricing-hub-overview__tiers">
      {% for tier in overview_tiers %}
        <div class="pricing-hub-overview__tier{% if tier.is_recommended %} pricing-hub-overview__tier--recommended{% endif %}">
          {% if tier.is_recommended %}
            <span class="pricing-hub-overview__tier-badge">{% trans %}Más popular{% endtrans %}</span>
          {% endif %}
          <h3 class="pricing-hub-overview__tier-name">{{ tier.label }}</h3>
          <p class="pricing-hub-overview__tier-price">
            {% if tier.price_monthly == 0 %}
              {% trans %}Gratis{% endtrans %}
            {% elseif tier.price_monthly > 0 %}
              {% trans %}Desde {{ tier.price_monthly|number_format(0) }}€/mes + IVA{% endtrans %}
            {% else %}
              {% trans %}A medida{% endtrans %}
            {% endif %}
          </p>
          {% if tier.description %}
            <p class="pricing-hub-overview__tier-desc">{{ tier.description }}</p>
          {% endif %}
        </div>
      {% else %}
        {# Fallback si no hay tiers configurados #}
        <div class="pricing-hub-overview__tier">
          <h3 class="pricing-hub-overview__tier-name">{% trans %}Starter{% endtrans %}</h3>
          <p class="pricing-hub-overview__tier-price">{% trans %}Gratis{% endtrans %}</p>
        </div>
        <div class="pricing-hub-overview__tier pricing-hub-overview__tier--recommended">
          <span class="pricing-hub-overview__tier-badge">{% trans %}Más popular{% endtrans %}</span>
          <h3 class="pricing-hub-overview__tier-name">{% trans %}Profesional{% endtrans %}</h3>
          <p class="pricing-hub-overview__tier-price">{% trans %}Contactar{% endtrans %}</p>
        </div>
        <div class="pricing-hub-overview__tier">
          <h3 class="pricing-hub-overview__tier-name">{% trans %}Empresa{% endtrans %}</h3>
          <p class="pricing-hub-overview__tier-price">{% trans %}A medida{% endtrans %}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# === TAX DISCLAIMER — GAP-M01: LSSI-CE Art. 10 === #}
<section class="pricing-tax-disclaimer reveal-element reveal-fade-up" aria-label="{% trans %}Información fiscal{% endtrans %}">
  <div class="pricing-tax-disclaimer__container">
    <p class="pricing-tax-disclaimer__text">
      {# NO-HARDCODE-PRICE-001: Tax disclaimer configurable desde Theme Settings (plg_tax_disclaimer) #}
      {{ tax_disclaimer|default('Todos los precios se muestran en EUR sin IVA. El IVA aplicable (21% en España peninsular) se calculará y desglosará en el proceso de contratación según la normativa vigente. Para Canarias, Ceuta y Melilla se aplican los impuestos indirectos correspondientes (IGIC/IPSI).'|trans) }}
    </p>
  </div>
</section>

{# === GUARANTEE === #}
<section class="pricing-guarantee reveal-element reveal-fade-up">
  <div class="pricing-guarantee__container">
    <span class="pricing-guarantee__icon" aria-hidden="true">
      {{ jaraba_icon('ui', 'shield', { variant: 'duotone', size: '24px', color: 'verde-innovacion' }) }}
    </span>
    <p class="pricing-guarantee__text">{{ guarantee_text }}</p>
  </div>
</section>

{# === PROMO BANNER: Configurable desde Theme Settings (promo_banner_*) === #}
{% if ts.promo_banner_enabled|default(false) %}
  {% include '@ecosistema_jaraba_theme/partials/_promo-banner.html.twig' with {
    promo_title: ts.promo_banner_title|default(''),
    promo_text: ts.promo_banner_text|default(''),
    promo_url: ts.promo_banner_url|default(''),
    promo_cta: ts.promo_banner_cta|default(''),
  } only %}
{% endif %}

{# === FAQ === #}
{% if faq_items is not empty %}
  <section class="pricing-faq reveal-element reveal-fade-up" aria-labelledby="hub-faq-title">
    <div class="pricing-faq__container">
      <h2 id="hub-faq-title" class="pricing-faq__title">
        {% trans %}Preguntas frecuentes{% endtrans %}
      </h2>
      <div class="pricing-faq__list" itemscope itemtype="https://schema.org/FAQPage">
        {% for item in faq_items %}
          <details class="pricing-faq__item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary class="pricing-faq__question" itemprop="name">
              {{ item.question }}
              <span class="pricing-faq__chevron" aria-hidden="true">
                {{ jaraba_icon('ui', 'chevron-down', { size: '20px' }) }}
              </span>
            </summary>
            <div class="pricing-faq__answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text">{{ item.answer }}</p>
            </div>
          </details>
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{# === FINAL CTA === #}
<section class="pricing-final-cta reveal-element reveal-fade-up">
  <div class="pricing-final-cta__container">
    <h2 class="pricing-final-cta__title">
      {% trans %}¿Listo para empezar?{% endtrans %}
    </h2>
    <p class="pricing-final-cta__subtitle">
      {{ plg_register_subtitle|default('Crea tu cuenta gratis en menos de 2 minutos. Sin tarjeta de crédito.'|trans) }}
    </p>
    <a href="{{ path('user.register') }}"
       class="btn btn--primary btn--xl pricing-final-cta__btn"
       data-track-cta="hub_final_cta"
       data-track-position="pricing_hub_bottom">
      {% trans %}Crear cuenta gratuita{% endtrans %}
    </a>
  </div>
</section>

</div>{# /.pricing-wrapper #}

{# === SCHEMA.ORG — NO-HARDCODE-PRICE-001: dinamico desde overview_tiers === #}
{% if overview_tiers is not empty %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Jaraba Impact Platform",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "url": "{{ url('ecosistema_jaraba_core.pricing.page', {}, {absolute: true}) }}",
  "offers": [
    {% for tier in overview_tiers %}
    {
      {% if tier.price_monthly is defined and tier.price_monthly > 0 %}
      "@type": "AggregateOffer",
      "name": "{{ tier.label|replace({'"': '\\"'}) }}",
      "priceCurrency": "EUR",
      "lowPrice": "{{ tier.price_monthly|number_format(0) }}",
      "highPrice": "{{ (tier.price_monthly * 3)|number_format(0) }}",
      {% else %}
      "@type": "Offer",
      "name": "{{ tier.label|replace({'"': '\\"'}) }}",
      "priceCurrency": "EUR",
      "price": "0",
      {% endif %}
      "availability": "https://schema.org/InStock",
      "description": "{{ tier.description|default('')|replace({'"': '\\"'}) }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}
