{#
 # AI Review Summary.
 #
 # Variables:
 # - summary: string (AI-generated text)
 #
 # REV-PHASE5: Resumen generado con IA.
 #}
{% if summary %}
<div class="review-summary">
  <div class="review-summary__header">
    <span class="review-summary__icon" aria-hidden="true">{{ jaraba_icon('ai', 'sparkles', {variant: 'duotone', color: 'azul-corporativo', size: '18px'}) }}</span>
    <span class="review-summary__label">{% trans %}Resumen generado con IA{% endtrans %}</span>
  </div>
  <p class="review-summary__text">{{ summary }}</p>
</div>
{% endif %}
