{#
/**
 * @file _cross-pollination.html.twig
 * Cross-Pollination — 8 verticales como tarjetas premium con iconos duotone.
 *
 * DIRECTRICES:
 * - ICON-CONVENTION-001: jaraba_icon() duotone con colores de marca
 * - ICON-DUOTONE-001: variant duotone por defecto
 * - i18n: {% trans %} en todos los textos
 * - BEM: .cross-pollination__*
 */
#}

{% set lp = language_prefix|default('') %}
{% set urls = ped_urls|default({}) %}

{% set verticals = [
  { id: 'empleabilidad', title: 'Empleabilidad'|t, desc: 'CV con IA, matching de empleo, preparación de entrevistas y diagnóstico profesional.'|t, icon_cat: 'verticals', icon_name: 'empleabilidad', color: 'verde-innovacion', url: urls.empleabilidad|default(lp ~ '/empleabilidad') },
  { id: 'emprendimiento', title: 'Emprendimiento'|t, desc: 'Lean Canvas, validación de hipótesis, copiloto startup y conexión con inversores.'|t, icon_cat: 'verticals', icon_name: 'emprendimiento', color: 'naranja-impulso', url: urls.emprendimiento|default(lp ~ '/emprendimiento') },
  { id: 'agroconecta', title: 'AgroConecta'|t, desc: 'Marketplace agroalimentario, trazabilidad de lotes, QR inteligente y previsión de demanda.'|t, icon_cat: 'verticals', icon_name: 'agroconecta', color: 'verde-oliva', url: urls.agroconecta|default(lp ~ '/agroconecta') },
  { id: 'comercioconecta', title: 'ComercioConecta'|t, desc: 'Tienda online, gestión de pedidos, pagos Stripe + Bizum y fidelización de clientes.'|t, icon_cat: 'verticals', icon_name: 'comercioconecta', color: 'naranja-impulso', url: urls.comercioconecta|default(lp ~ '/comercioconecta') },
  { id: 'serviciosconecta', title: 'ServiciosConecta'|t, desc: 'CRM de clientes, presupuestos automáticos, calendario compartido y facturación.'|t, icon_cat: 'verticals', icon_name: 'serviciosconecta', color: 'verde-innovacion', url: urls.serviciosconecta|default(lp ~ '/serviciosconecta') },
  { id: 'jarabalex', title: 'JarabaLex'|t, desc: 'Buscador legal con IA, gestión de expedientes, alertas BOE/BOJA y copiloto jurídico.'|t, icon_cat: 'verticals', icon_name: 'jarabalex', color: 'azul-corporativo', url: urls.jarabalex|default(lp ~ '/jarabalex') },
  { id: 'formacion', title: 'Formación'|t, desc: 'Cursos con certificación, itinerarios adaptativos y seguimiento de progreso con IA.'|t, icon_cat: 'verticals', icon_name: 'formacion', color: 'verde-innovacion', url: urls.formacion|default(lp ~ '/formacion') },
  { id: 'andalucia_ei', title: 'Andalucía +ei'|t, desc: 'Gestión de programas FSE+, seguimiento de participantes e informes automatizados.'|t, icon_cat: 'verticals', icon_name: 'andalucia-ei', color: 'verde-innovacion', url: urls.andalucia_ei|default(lp ~ '/andalucia-ei') },
] %}

<section class="cross-pollination reveal-element reveal-fade-up"
         id="verticales"
         aria-label="{% trans %}Verticales de la plataforma{% endtrans %}">
  <div class="cross-pollination__container">

    <div class="cross-pollination__header">
      <span class="cross-pollination__eyebrow">{% trans %}Un ecosistema, múltiples verticales{% endtrans %}</span>
      <h2 class="cross-pollination__title">{% trans %}Encuentra el servicio que necesitas{% endtrans %}</h2>
      <p class="cross-pollination__subtitle">
        {% trans %}Cada vertical está diseñado para un reto específico. Todos comparten IA, firma digital, copiloto y la misma metodología probada.{% endtrans %}
      </p>
    </div>

    <div class="cross-pollination__grid" role="list">
      {% for v in verticals %}
        <a href="{{ v.url }}" class="cross-pollination__card"
           role="listitem"
           data-track-cta="xpoll_{{ v.id }}"
           data-track-position="homepage_cross_pollination"
           style="--reveal-delay: {{ loop.index0 * 0.06 }}s;">
          <div class="cross-pollination__icon">
            {{ jaraba_icon(v.icon_cat, v.icon_name, { variant: 'duotone', size: '36px', color: v.color }) }}
          </div>
          <h3 class="cross-pollination__card-title">{{ v.title }}</h3>
          <p class="cross-pollination__card-desc">{{ v.desc }}</p>
          <span class="cross-pollination__card-cta">{% trans %}Explorar{% endtrans %} →</span>
        </a>
      {% endfor %}
    </div>

  </div>
</section>
