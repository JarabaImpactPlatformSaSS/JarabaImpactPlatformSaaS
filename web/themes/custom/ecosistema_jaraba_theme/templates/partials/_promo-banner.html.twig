{#
/**
 * @file
 * _promo-banner.html.twig — Banner promocional configurable.
 *
 * Contenido 100% configurable desde Theme Settings UI (tab "Promociones").
 * NO hardcodear textos — todos vienen de variables del tema.
 * Reutilizable en: pricing page, homepage, landings, dashboards.
 *
 * Variables (desde theme_settings.promo_banner_*):
 * - promo_title: string (título del banner)
 * - promo_text: string (descripción)
 * - promo_url: string (URL del CTA — generada con path() en preprocess)
 * - promo_cta: string (texto del botón CTA)
 *
 * Directrices:
 * - TWIG-INCLUDE-ONLY-001: Incluir con keyword only.
 * - CSS-VAR-ALL-COLORS-001: Colores via var(--ej-*).
 * - NO-HARDCODE-PRICE-001: Sin precios ni textos hardcoded.
 * - ICON-CONVENTION-001: Sin emojis, SVG inline si necesario.
 */
#}

{% if promo_title and promo_url %}
<section class="promo-banner reveal-element reveal-fade-up" role="complementary">
  <div class="promo-banner__container">
    <div class="promo-banner__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" width="32" height="32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </div>
    <div class="promo-banner__content">
      <h3 class="promo-banner__title">{{ promo_title }}</h3>
      {% if promo_text %}
        <p class="promo-banner__text">{{ promo_text }}</p>
      {% endif %}
    </div>
    {% if promo_cta %}
      <a href="{{ promo_url }}" class="promo-banner__cta">
        {{ promo_cta }}
        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </a>
    {% endif %}
  </div>
</section>
{% endif %}
