{#
/**
 * @file
 * templates/partials/_hero.html.twig
 *
 * Hero Section del homepage — meta-sitio público.
 * Optimizado para conversión con copy específico y CTA claros.
 *
 * VARIABLES:
 * - theme_settings: Configuración del tema (hero_layout, overrides)
 * - hero: Array con datos dinámicos del Page Builder (opcional)
 * - logged_in: TRUE si el usuario está autenticado
 *
 * DIRECTRICES:
 * - i18n: {% trans %} en todos los textos estáticos
 * - ICON-CONVENTION-001: SVG inline, sin emoji
 * - CSS: BEM .hero-landing__*, var(--ej-*)
 * - SEO: H1 único, aria-labelledby
 * - BRAND-FONT-001: Outfit como font principal
 *
 * DESIGN DECISIONS (Auditoría Meta-Sitio Feb 2026):
 * - Eliminada _intentions-grid (navigation overload: 16→11 opciones)
 * - Fallback headline: de genérico a propuesta de valor específica
 * - Secondary CTA: /metodo en lugar de /login (top-of-funnel frío)
 * - Trust bar: verificable (RGPD, IA, cifrado)
 *
 * @see 20260226-Plan_Implementacion_MetaSitio_Remediacion_Integral_v1.md
 */
#}
{% set ts = theme_settings|default({}) %}
{% set hero_layout = ts.hero_layout|default('fullscreen') %}

{# Datos dinámicos con fallbacks i18n optimizados para conversión #}
{% set h = hero|default({}) %}

{# Detectar meta-sitio PED para aplicar identidad corporativa #}
{% set is_ped = meta_site is defined and meta_site and meta_site.group_id|default(0) == 7 %}

{# Audiencia detectada via UTM/cookie/AvatarDetection #}
{% set audience = audience|default(null) %}

{# URLs resueltas con prefijo de idioma (inyectadas desde preprocess) #}
{% set urls = ped_urls|default({}) %}

{# Contenido por audiencia — fallbacks i18n #}
{% set hero_variants = {
  'legal': {
    'eyebrow': '+154.000 abogados en Espana aun sin IA en su despacho'|t,
    'title': 'Tu despacho merece inteligencia legal de verdad — a precio de autonomo'|t,
    'subtitle': ('Busca en CENDOJ, BOE y EUR-Lex con IA. Gestiona expedientes, agenda, facturación y LexNET. ' ~ ped_pricing.jarabalex.from_price.from_label|default('Desde 29 EUR/mes') ~ '.')|t,
    'cta_primary_text': 'Prueba JarabaLex gratis'|t,
    'cta_primary_url': urls.jarabalex|default('/jarabalex'),
    'cta_secondary_text': 'Ver demo de 2 minutos'|t,
  },
  'b2g': {
    'eyebrow': '25,9M EUR en programas FSE gestionados con éxito, 30+ años de experiencia'|t,
    'title': 'La plataforma digital para programas de empleo y emprendimiento con fondos europeos'|t,
    'subtitle': 'Gestión integral de participantes, fases, horas IA-tracked, justificacion FSE y copiloto para tecnicos.'|t,
    'cta_primary_text': 'Solicitar demo institucional'|t,
    'cta_primary_url': urls.contacto|default('/contacto'),
    'cta_secondary_text': 'Descargar dossier'|t,
  },
  'empleo': {
    'eyebrow': '+50.000 personas formadas · +3.200 empleos facilitados · 30+ años de experiencia'|t,
    'title': 'Tu proximo paso profesional empieza aqui — con IA que te guia'|t,
    'subtitle': 'Diagnóstico de competencias, CV con IA, preparacion de entrevistas y matching inteligente. Gratis para empezar.'|t,
    'cta_primary_text': 'Empieza gratis'|t,
    'cta_primary_url': urls.register|default('/user/register'),
    'cta_secondary_text': 'Conoce el metodo'|t,
  },
} %}

{% set variant = hero_variants[audience]|default(null) %}

{% if is_ped %}
{# ================================================================ #}
{# HERO PED — Identidad corporativa azul+dorado, por audiencia      #}
{# ================================================================ #}
<section class="ped-hero" aria-labelledby="hero-title" data-hero-variant="{{ audience|default('default') }}">
  <div class="ped-hero__container">
    {# Urgency badge — HOMEPAGE-ELEVATION-001 F1 #}
    <span class="ped-hero__urgency">
      <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true"><circle cx="10" cy="10" r="8" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M10 5v5l3 3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      {% if meta_site is defined and meta_site and meta_site.group_id|default(0) == 7 %}
        {% trans %}Plazas abiertas — Andalucía +ei 2ª Edición{% endtrans %}
      {% else %}
        {% trans %}14 dias gratis — Sin tarjeta de crédito{% endtrans %}
      {% endif %}
    </span>

    <span class="ped-hero__eyebrow">
      {% if variant %}
        {{ variant.eyebrow }}
      {% elseif h.eyebrow %}
        {{ h.eyebrow }}
      {% else %}
        {% trans %}+100M EUR en fondos europeos gestionados · +50.000 personas formadas · 11 agentes IA{% endtrans %}
      {% endif %}
    </span>

    <h1 id="hero-title">
      {% if variant %}
        {{ variant.title }}
      {% elseif h.title %}
        {{ h.title }}
      {% else %}
        {% trans %}Empleo, justicia y negocio digital — impulsados por IA, en una sola plataforma{% endtrans %}
      {% endif %}
    </h1>

    <p>
      {% if variant %}
        {{ variant.subtitle }}
      {% elseif h.subtitle %}
        {{ h.subtitle|raw }}
      {% else %}
        {% trans %}10 verticales especializados. 11 agentes IA. Firma digital y copiloto integrado. Una sola plataforma para profesionales, empresas e instituciones.{% endtrans %}
      {% endif %}
    </p>

    <div class="ped-hero__actions">
      {% if logged_in %}
        <a href="{{ urls.dashboard|default('/user') }}"
           class="btn-primary btn-primary--large"
           data-track-cta="hero_dashboard"
           data-track-position="homepage_hero">
          <span>{% trans %}Ir al dashboard{% endtrans %}</span>
        </a>
      {% else %}
        <a href="{{ variant ? variant.cta_primary_url : (h.cta_primary.url|default(urls.register|default('/user/register'))) }}"
           class="btn-primary btn-primary--large"
           data-track-cta="hero_register"
           data-track-position="homepage_hero">
          <span>{{ variant ? variant.cta_primary_text : (h.cta_primary.text|default('Empezar gratis'|t)) }}</span>
        </a>
      {% endif %}

      <a href="#product-demo"
         class="btn-secondary btn-secondary--large"
         data-track-cta="hero_platform_preview"
         data-track-position="homepage_hero">
        <span>{{ variant ? variant.cta_secondary_text : (h.cta_secondary.text|default('Ver la plataforma en acción'|t)) }}</span>
        <svg class="btn-icon" viewBox="0 0 20 20" width="20" height="20" aria-hidden="true">
          <path d="M8 4L14 10L8 16" fill="none" stroke="currentColor" stroke-width="2"/>
        </svg>
      </a>
    </div>
    {# Quiz CTA — solo para SaaS, no para PED corporativo #}
    {% if not (meta_site is defined and meta_site and meta_site.group_id|default(0) == 7) %}
    <p class="hero-landing__quiz-link">
      {% trans %}¿No sabes cuál elegir?{% endtrans %}
      <a href="{{ language_prefix|default('') }}/test-vertical"
         data-track-cta="hero_quiz" data-track-position="homepage_hero">
        {% trans %}Haz el test de 30 segundos{% endtrans %} →
      </a>
    </p>
    {% endif %}

    {# Trust badges PED — HOMEPAGE-ELEVATION-001 F1 #}
    <div class="ped-hero__trust-bar" aria-label="{% trans %}Certificaciones y garantias{% endtrans %}">
      <span class="ped-hero__trust-badge">
        <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true"><path d="M10 1L3 5v6c0 5.55 3.84 9.74 7 11 3.16-1.26 7-5.45 7-11V5L10 1z" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M7 10l2 2 4-4" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
        {% trans %}RGPD{% endtrans %}
      </span>
      <span class="ped-hero__trust-separator" aria-hidden="true">·</span>
      <span class="ped-hero__trust-badge">
        <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true"><circle cx="10" cy="10" r="3" fill="currentColor"/><path d="M10 1v4M10 15v4M1 10h4M15 10h4M3.93 3.93l2.83 2.83M13.24 13.24l2.83 2.83M3.93 16.07l2.83-2.83M13.24 6.76l2.83-2.83" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
        {% trans %}11 Agentes IA{% endtrans %}
      </span>
      <span class="ped-hero__trust-separator" aria-hidden="true">·</span>
      <span class="ped-hero__trust-badge">
        <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true"><rect x="3" y="8" width="14" height="10" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M6 8V5a4 4 0 0 1 8 0v3" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="13" r="1.5" fill="currentColor"/></svg>
        {% trans %}Servidor EU{% endtrans %}
      </span>
      <span class="ped-hero__trust-separator" aria-hidden="true">·</span>
      <span class="ped-hero__trust-badge">
        <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true"><path d="M4 4h12M4 10h12M4 16h6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        {% trans %}10 Verticales{% endtrans %}
      </span>
    </div>
  </div>
</section>

{% else %}
{# ================================================================ #}
{# HERO GENERICO — Sin cambios respecto al flujo actual             #}
{# ================================================================ #}
<section class="hero-landing hero-landing--{{ hero_layout }}" aria-labelledby="hero-title" data-hero-video="true">

  {# Animated Background #}
  <div class="hero-landing__bg">
    <div class="hero-landing__gradient"></div>
    {% if hero_layout == 'animated' %}
      <div class="hero-landing__particles"></div>
    {% endif %}
  </div>

  {# Content — Copy optimizado para conversión #}
  <div class="hero-landing__content">
    {# Urgency badge — HOMEPAGE-ELEVATION-001 F1 #}
    <span class="hero-landing__urgency">
      <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true"><circle cx="10" cy="10" r="8" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M10 5v5l3 3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      {% trans %}14 dias gratis — Sin tarjeta de crédito{% endtrans %}
    </span>

    <span class="hero-landing__eyebrow">
      {% if h.eyebrow %}
        {{ h.eyebrow }}
      {% else %}
        {% trans %}+100M€ en fondos europeos gestionados · 30+ años de experiencia{% endtrans %}
      {% endif %}
    </span>

    <h1 id="hero-title" class="hero-landing__title">
      {% if h.title %}
        {{ h.title }}
      {% else %}
        {% trans %}Empleo, emprendimiento y digitalización — impulsados por IA, en una sola plataforma{% endtrans %}
      {% endif %}
    </h1>

    <div class="hero-landing__subtitle">
      {% if h.subtitle %}
        {{ h.subtitle|raw }}
      {% else %}
        {% trans %}Empleo · Emprendimiento · AgroConecta · ComercioConecta · ServiciosConecta · JarabaLex · Formación — 10 verticales especializados, 11 agentes IA, firma digital y copiloto integrado.{% endtrans %}
      {% endif %}
    </div>
  </div>

  {# CTAs Principales — Top-of-funnel: registro + demo visual #}
  <div class="hero-landing__actions">
    {% set urls = ped_urls|default({}) %}
    {% if logged_in %}
      <a href="{{ urls.dashboard|default(path('user.page')) }}"
         class="btn-primary btn-primary--large btn-primary--glow"
         data-track-cta="hero_dashboard"
         data-track-position="homepage_hero">
        <svg class="btn-icon" viewBox="0 0 20 20" width="20" height="20" aria-hidden="true">
          <path d="M10 2L13 8H18L14 12L16 18L10 14L4 18L6 12L2 8H7L10 2Z" fill="currentColor"/>
        </svg>
        <span>{% trans %}Ir al dashboard{% endtrans %}</span>
      </a>
    {% else %}
      <a href="{{ h.cta_primary.url|default(urls.register|default(path('user.register'))) }}"
         class="btn-primary btn-primary--large btn-primary--glow"
         data-track-cta="hero_register"
         data-track-position="homepage_hero">
        <svg class="btn-icon" viewBox="0 0 20 20" width="20" height="20" aria-hidden="true">
          <path d="M10 2L13 8H18L14 12L16 18L10 14L4 18L6 12L2 8H7L10 2Z" fill="currentColor"/>
        </svg>
        <span>{% if ab_variants.homepage_hero_cta.label is defined %}{{ ab_variants.homepage_hero_cta.label }}{% elseif h.cta_primary.text %}{{ h.cta_primary.text }}{% else %}{% trans %}Empezar gratis{% endtrans %}{% endif %}</span>
      </a>
    {% endif %}

    <a href="#product-demo"
       class="btn-secondary btn-secondary--large"
       data-track-cta="hero_platform_preview"
       data-track-position="homepage_hero">
      <span>{% if h.cta_secondary.text %}{{ h.cta_secondary.text }}{% else %}{% trans %}Ver la plataforma en acción{% endtrans %}{% endif %}</span>
      <svg class="btn-icon" viewBox="0 0 20 20" width="20" height="20" aria-hidden="true">
        <path d="M8 4L14 10L8 16" fill="none" stroke="currentColor" stroke-width="2"/>
      </svg>
    </a>
  </div>
  {# Quiz CTA — visible para todos (anónimos y logueados) #}
  <p class="hero-landing__quiz-link">
    {% trans %}¿No sabes cuál elegir?{% endtrans %}
    <a href="{{ language_prefix|default('') }}/test-vertical"
       data-track-cta="hero_quiz" data-track-position="homepage_hero">
      {% trans %}Haz el test de 30 segundos{% endtrans %} →
    </a>
  </p>

  {# Trust Bar — Credibilidad verificable #}
  <div class="hero-landing__trust-bar" aria-label="{% trans %}Certificaciones y estándares{% endtrans %}">
    <span class="hero-landing__trust-badge">
      <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true"><path d="M10 1L3 5v6c0 5.55 3.84 9.74 7 11 3.16-1.26 7-5.45 7-11V5L10 1z" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M7 10l2 2 4-4" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
      {% trans %}Cumplimiento RGPD{% endtrans %}
    </span>
    <span class="hero-landing__trust-separator" aria-hidden="true">·</span>
    <span class="hero-landing__trust-badge">
      <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true"><circle cx="10" cy="10" r="3" fill="currentColor"/><path d="M10 1v4M10 15v4M1 10h4M15 10h4M3.93 3.93l2.83 2.83M13.24 13.24l2.83 2.83M3.93 16.07l2.83-2.83M13.24 6.76l2.83-2.83" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
      {% trans %}Copiloto IA Integrado{% endtrans %}
    </span>
    <span class="hero-landing__trust-separator" aria-hidden="true">·</span>
    <span class="hero-landing__trust-badge">
      <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true"><rect x="3" y="8" width="14" height="10" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M6 8V5a4 4 0 0 1 8 0v3" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="13" r="1.5" fill="currentColor"/></svg>
      {% trans %}Datos Cifrados{% endtrans %}
    </span>
    <span class="hero-landing__trust-separator" aria-hidden="true">·</span>
    <span class="hero-landing__trust-badge">
      <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true"><path d="M4 4h12M4 10h12M4 16h6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      {% trans %}Metodología Probada{% endtrans %}
    </span>
  </div>

  {# Video Hero — HOMEPAGE-ELEVATION-001 F5: demo-showcase autoplaying #}
  {% set homepage_video = h.video_url|default('/themes/custom/ecosistema_jaraba_theme/videos/demo-showcase.mp4') %}
  <div class="hero-landing__video-wrap">
    <video class="hero-landing__video"
           autoplay muted loop playsinline
           data-hero-video-el
           aria-label="{% trans %}Demostración de la plataforma{% endtrans %}">
      <source src="{{ homepage_video }}" type="video/mp4">
    </video>
  </div>

  {# Scroll Indicator #}
  <div class="hero-landing__scroll" aria-hidden="true">
    <span>{% if h.scroll_text %}{{ h.scroll_text }}{% else %}{% trans %}Descubre más{% endtrans %}{% endif %}</span>
    <div class="hero-landing__scroll-mouse"></div>
  </div>

</section>
{% endif %}
