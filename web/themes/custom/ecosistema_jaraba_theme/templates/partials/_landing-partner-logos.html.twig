        </svg>
      </span>
    </li>

    {# UE NextGenerationEU #}
    <li class="landing-partners__item">
      <span class="landing-partners__logo" aria-label="{% trans %}Financiado por la Unión Europea — NextGenerationEU{% endtrans %}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 130 30" height="28" aria-hidden="true" focusable="false">
          {# EU circle of stars (simplified) #}
          <g transform="translate(14,15)">
            <circle r="10" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.6"/>
            {# 12 stars arranged in circle #}
            <g fill="currentColor">
              <circle cx="0"   cy="-8"  r="1.2"/>
              <circle cx="4"   cy="-6.9" r="1.2"/>
              <circle cx="6.9" cy="-4"  r="1.2"/>
              <circle cx="8"   cy="0"   r="1.2"/>
