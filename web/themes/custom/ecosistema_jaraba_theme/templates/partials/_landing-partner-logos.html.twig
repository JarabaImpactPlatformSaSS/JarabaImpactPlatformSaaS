    {# MRW #}
    <li class="landing-partners__item">
      <span class="landing-partners__logo" aria-label="MRW">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 30" height="28" aria-hidden="true" focusable="false">
          <rect width="80" height="30" rx="4" fill="currentColor" opacity="0.08"/>
          <text x="40" y="21" font-family="Arial, sans-serif" font-weight="700" font-size="15" text-anchor="middle" fill="currentColor" letter-spacing="1">MRW</text>
        </svg>
      </span>
    </li>

    {# SEUR #}
    <li class="landing-partners__item">
      <span class="landing-partners__logo" aria-label="SEUR">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 30" height="28" aria-hidden="true" focusable="false">
          <rect width="80" height="30" rx="4" fill="currentColor" opacity="0.08"/>
          <text x="40" y="21" font-family="Arial, sans-serif" font-weight="700" font-size="15" text-anchor="middle" fill="currentColor" letter-spacing="1">SEUR</text>
        </svg>
      </span>
    </li>

    {# Kit Digital #}
    <li class="landing-partners__item">
      <span class="landing-partners__logo" aria-label="{% trans %}Kit Digital{% endtrans %}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 110 30" height="28" aria-hidden="true" focusable="false">
          <rect width="110" height="30" rx="4" fill="currentColor" opacity="0.08"/>
          <rect x="6" y="6" width="18" height="18" rx="3" fill="currentColor" opacity="0.7"/>
          <text x="12" y="19" font-family="Arial, sans-serif" font-weight="900" font-size="10" text-anchor="middle" fill="white">KD</text>
          <text x="65" y="21" font-family="Arial, sans-serif" font-weight="700" font-size="13" text-anchor="middle" fill="currentColor">Kit Digital</text>
        </svg>
      </span>
    </li>

