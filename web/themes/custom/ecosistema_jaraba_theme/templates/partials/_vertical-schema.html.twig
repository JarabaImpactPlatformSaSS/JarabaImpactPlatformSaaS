{#
/**
 * @file
 * _vertical-schema.html.twig — Schema.org JSON-LD contextual por vertical.
 *
 * Sprint 4 SEO/GEO: Inyecta schemas especificos por vertical en landings.
 * Mejora la visibilidad en Google, AI Overviews, Perplexity y ChatGPT Search.
 *
 * Variables:
 * - vertical_key: string (agroconecta, comercioconecta, etc.)
 * - site_name: string
 *
 * Directrices:
 * - TWIG-INCLUDE-ONLY-001: Incluir con keyword only.
 * - TWIG-URL-RENDER-ARRAY-001: usar path() no url().
 * - i18n: textos traducibles con |t.
 * - NAP-NORMALIZATION-001: phone y email canonicos.
 */
#}

{% set front = path('<front>') %}
{% set phone = ts.contact_phone|default('') %}
{% set schema_email = ts.contact_schema_email|default('') %}
{% set wa_number = ts.whatsapp_number|default('') %}

{% if vertical_key == 'agroconecta' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "AgroConecta — {{ 'Marketplace Agroalimentario'|t }}",
  "applicationCategory": "BusinessApplication",
  "applicationSubCategory": "{{ 'Marketplace de proximidad agroalimentario con trazabilidad QR'|t }}",
  "operatingSystem": "All",
  "url": "{{ path('ecosistema_jaraba_core.landing.agroconecta') }}",
  "offers": {
    "@type": "AggregateOffer",
    "lowPrice": "49",
    "highPrice": "249",
    "priceCurrency": "EUR"
  },
  "featureList": [
    "{{ 'Trazabilidad QR a nivel de lote con DOP/IGP/Eco'|t }}",
    "{{ 'Marketplace multi-tienda para productores agroalimentarios'|t }}",
    "{{ 'Storytelling de productor con video y landing personalizada'|t }}",
    "{{ 'ProducerCopilotAgent con IA agro-especifica'|t }}"
  ]
}
</script>

