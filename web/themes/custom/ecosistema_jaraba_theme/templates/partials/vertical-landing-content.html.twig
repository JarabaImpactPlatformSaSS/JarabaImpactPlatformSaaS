{#
/**
 * @file vertical-landing-content.html.twig
 * Orquestador de landing pages verticales — 9 secciones via parciales.
 *
 * Se incluye desde page--vertical-landing.html.twig.
 *
 * VARIABLES (todas bajo vertical_data):
 * - key: Identificador del vertical (agroconecta, comercioconecta, etc.)
 * - color: Color del vertical (CSS token)
 * - hero: { headline, subtitle, icon, cta_primary, cta_secondary }
 * - pain_points: Array de { icon, text }
 * - steps: Array de { title, description }
 * - features: Array de { icon, title, description }
 * - social_proof: { testimonials: [], metrics: [] }
 * - lead_magnet: { title, description, url, cta_text, icon }
 * - pricing: { headline, from_price, currency, period, cta_text, cta_url, features_preview }
 * - faq: Array de { question, answer }
 * - final_cta: { headline, subheadline, cta }
 *
 * @see docs/implementacion/2026-02-12_F4_Landing_Pages_Verticales_Doc180_Implementacion.md
 */
#}

{% set data = vertical_data|default({}) %}
{% set key = data.key|default('default') %}
{% set vertical_color = data.color|default('impulse') %}

<div class="vertical-landing vertical-landing--{{ key }}">

  {# 1. Hero #}
  {% include '@ecosistema_jaraba_theme/partials/_landing-hero.html.twig' with {
    hero: data.hero|default({}),
    color: vertical_color,
    vertical_key: key,
  } only %}

  {# 1b. Trust Badges (debajo del hero) #}
  {% include '@ecosistema_jaraba_theme/partials/_landing-trust-badges.html.twig' with {
    trust_badges: data.hero.trust_badges|default([]),
    vertical_key: key,
  } only %}

  {# 2. Pain Points #}
  {% include '@ecosistema_jaraba_theme/partials/_landing-pain-points.html.twig' with {
    pain_points: data.pain_points|default([]),
    color: vertical_color,
    vertical_key: key,
  } only %}

  {# 3. Solution Steps #}
  {% include '@ecosistema_jaraba_theme/partials/_landing-solution-steps.html.twig' with {
    steps: data.steps|default([]),
    color: vertical_color,
    vertical_key: key,
  } only %}

  {# 4. Features Grid #}
  {% include '@ecosistema_jaraba_theme/partials/_landing-features-grid.html.twig' with {
    features: data.features|default([]),
    color: vertical_color,
    vertical_key: key,
  } only %}

  {# 4b. Comparison Table (opcional — solo si comparison definido) #}
  {% if data.comparison is defined %}
    {% include '@ecosistema_jaraba_theme/partials/_landing-comparison.html.twig' with {
      comparison: data.comparison|default({}),
      color: vertical_color,
      vertical_key: key,
    } only %}
  {% endif %}

  {# 5. Social Proof #}
  {% include '@ecosistema_jaraba_theme/partials/_landing-social-proof.html.twig' with {
    social_proof: data.social_proof|default({}),
    color: vertical_color,
    vertical_key: key,
  } only %}

  {# 5b. Trust Strip — Technology & Institutional Partners (TRUST-STRIP-001) #}
  {% include '@ecosistema_jaraba_theme/partials/_trust-strip.html.twig' with {
    trust_title: data.tech_partners.title|default('Tecnología de confianza'|trans),
    trust_subtitle: data.tech_partners.subtitle|default(''),
    tech_partners: data.tech_partners.tech|default([]),
    institutional_partners: data.tech_partners.institutional|default([]),
    vertical_key: key,
    theme_path: 'themes/custom/ecosistema_jaraba_theme',
    show_badges: false,
    marquee: true,
  } only %}

  {# 6. Lead Magnet #}
  {% include '@ecosistema_jaraba_theme/partials/_landing-lead-magnet.html.twig' with {
    lead_magnet: data.lead_magnet|default({}),
    color: vertical_color,
    vertical_key: key,
  } only %}

  {# 7. Pricing Preview #}
  {% include '@ecosistema_jaraba_theme/partials/_landing-pricing-preview.html.twig' with {
    pricing: data.pricing|default({}),
    color: vertical_color,
    vertical_key: key,
  } only %}

  {# 8. FAQ + Schema.org #}
  {% include '@ecosistema_jaraba_theme/partials/_landing-faq.html.twig' with {
    faq: data.faq|default([]),
    vertical_key: key,
  } only %}

  {# 9. Final CTA #}
  {% include '@ecosistema_jaraba_theme/partials/_landing-final-cta.html.twig' with {
    final_cta: data.final_cta|default({}),
    color: vertical_color,
    vertical_key: key,
  } only %}

  {# 10. Sticky CTA Bar (fija en bottom, visible on scroll) #}
  {% include '@ecosistema_jaraba_theme/partials/_landing-sticky-cta.html.twig' with {
    sticky_cta: {
      text: '14 días gratis — Sin tarjeta de crédito'|trans,
      cta: data.hero.cta|default({})
    },
    vertical_key: key,
  } only %}

</div>
