{#
/**
 * @file _landing-hero.html.twig
 * Parcial reutilizable: Hero section para landing pages verticales.
 *
 * Dos modos de layout:
 * - Sin hero_image: centrado con gradiente de fondo (original)
 * - Con hero_image: split layout (texto izquierda + imagen derecha en desktop)
 *
 * VARIABLES:
 * - hero.headline: Titulo principal (string)
 * - hero.subheadline: Subtitulo descriptivo (string)
 * - hero.cta: { text, url } CTA principal
 * - hero.cta_secondary: { text, url } CTA secundario (opcional)
 * - hero.icon: { category, name } Icono del vertical
 * - hero.hero_image: URL de imagen visible (opcional — activa split layout)
 * - hero.hero_image_alt: Alt text para la imagen (opcional)
 * - hero.trust_badges: Array de { icon: {category, name}, label } (opcional)
 * - color: Color del vertical (impulse, agro, innovation, corporate)
 * - vertical_key: ID del vertical
 *
 * @see docs/implementacion/2026-02-12_F4_Landing_Pages_Verticales_Doc180_Implementacion.md
 */
#}

{% set hero = hero|default({}) %}
{% set has_image = hero.hero_image is defined and hero.hero_image %}

<section class="landing-hero landing-hero--{{ vertical_key|default('default') }} {{ has_image ? 'landing-hero--split' : '' }}">
  <div class="landing-hero__bg">
    <div class="landing-hero__gradient"></div>
  </div>

  <div class="landing-hero__inner">
    <div class="landing-hero__content">
      {% if hero.icon is defined %}
        <span class="landing-hero__icon">
          {{ jaraba_icon(hero.icon.category|default('verticals'), hero.icon.name|default('rocket'), {
            variant: 'duotone',
            color: color|default('impulse'),
            size: '64px'
          }) }}
        </span>
      {% endif %}

      <span class="landing-hero__urgency">
        {{ jaraba_icon('ui', 'clock', { variant: 'duotone', size: '16px', color: 'verde-innovacion' }) }}
        {% trans %}14 días gratis — Sin tarjeta de crédito{% endtrans %}
      </span>

      <h1 class="landing-hero__title">{{ hero.headline }}</h1>
      <p class="landing-hero__subtitle">{{ hero.subheadline }}</p>

      <div class="landing-hero__actions">
        {% if hero.cta is defined %}
          <a href="{{ hero.cta.url }}"
             class="btn btn--primary btn--lg"
             data-track-cta="hero_{{ vertical_key|default('') }}"
             data-track-position="hero">
            {{ hero.cta.text }}
          </a>
        {% endif %}
        {% if hero.cta_secondary is defined %}
          <a href="{{ hero.cta_secondary.url }}"
             class="btn btn--outline btn--lg"
             data-track-cta="hero_secondary_{{ vertical_key|default('') }}"
             data-track-position="hero">
            {{ hero.cta_secondary.text }}
          </a>
        {% endif %}
      </div>

      {# Trust badges (RGPD, eIDAS, EU AI Act, etc.) #}
      {% if hero.trust_badges is defined and hero.trust_badges|length > 0 %}
        <div class="landing-hero__trust-badges">
          {% for badge in hero.trust_badges %}
            <span class="landing-hero__trust-badge">
              {{ jaraba_icon(badge.icon.category, badge.icon.name, { size: '16px', variant: 'duotone' }) }}
              {{ badge.label }}
            </span>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {# Imagen visible (split layout — solo si hero_image definido) #}
    {% if has_image %}
      <div class="landing-hero__image-wrap">
        <img class="landing-hero__image"
             src="{{ hero.hero_image }}"
             alt="{{ hero.hero_image_alt|default('') }}"
             loading="eager"
             width="560" height="400">
      </div>
    {% endif %}
  </div>
</section>
