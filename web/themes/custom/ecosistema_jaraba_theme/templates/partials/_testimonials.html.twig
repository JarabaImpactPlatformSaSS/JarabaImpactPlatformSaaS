{#
/**
 * @file _testimonials.html.twig
 * Testimonios premium — Historias reales con resultados concretos.
 *
 * DIRECTRICES:
 * - i18n: {% trans %} en todos los textos
 * - ICON-CONVENTION-001: jaraba_icon() duotone
 * - BEM: .testimonials__*
 */
#}

<section id="testimonios" class="testimonials reveal-element reveal-fade-up"
         aria-labelledby="testimonials-title">
  <div class="testimonials__container">

    <span class="testimonials__eyebrow">{% trans %}Historias Reales{% endtrans %}</span>
    <h2 id="testimonials-title" class="testimonials__title">
      {% trans %}Profesionales que ya se han transformado{% endtrans %}
    </h2>
    <p class="testimonials__subtitle">
      {% trans %}Personas reales del programa Andalucía +ei que han reinventado su carrera con el Método Jaraba.{% endtrans %}
    </p>

    <div class="testimonials__grid" role="list">

      {# Testimonio 1: Marcela Calabia #}
      <article class="testimonials__card reveal-element reveal-fade-up" role="listitem" style="--reveal-delay: 0.1s;">
        <div class="testimonials__quote-icon" aria-hidden="true">
          {{ jaraba_icon('ui', 'quote', { variant: 'duotone', size: '28px', color: 'naranja-impulso' }) }}
        </div>
        <blockquote class="testimonials__text">
          {% trans %}Este curso es oro puro. Es el mejor tiempo invertido que van a poder disponer. Ninguno de los cursos de pago que he hecho me ha dado lo que me dio este curso gratuito.{% endtrans %}
        </blockquote>
        <div class="testimonials__author">
          <div class="testimonials__author-avatar testimonials__author-avatar--naranja" aria-hidden="true">MC</div>
          <div class="testimonials__author-info">
            <cite class="testimonials__author-name">Marcela Calabia</cite>
            <span class="testimonials__author-role">{% trans %}Coach de Comunicación Estratégica{% endtrans %}</span>
          </div>
        </div>
        <div class="testimonials__result">
          {{ jaraba_icon('actions', 'check-circle', { variant: 'duotone', size: '18px', color: 'verde-innovacion' }) }}
          <span>{% trans %}2 emprendimientos lanzados como autónoma{% endtrans %}</span>
        </div>
      </article>

      {# Testimonio 2: Ángel Martínez #}
      <article class="testimonials__card reveal-element reveal-fade-up" role="listitem" style="--reveal-delay: 0.2s;">
        <div class="testimonials__quote-icon" aria-hidden="true">
          {{ jaraba_icon('ui', 'quote', { variant: 'duotone', size: '28px', color: 'verde-innovacion' }) }}
        </div>
        <blockquote class="testimonials__text">
          {% trans %}La formación de PED es oro puro. Ahora tengo conciencia de que ES POSIBLE. Es un acierto total.{% endtrans %}
        </blockquote>
        <div class="testimonials__author">
          <div class="testimonials__author-avatar testimonials__author-avatar--verde" aria-hidden="true">ÁM</div>
          <div class="testimonials__author-info">
            <cite class="testimonials__author-name">Ángel Martínez</cite>
            <span class="testimonials__author-role">{% trans %}Cofundador de Camino Viejo{% endtrans %}</span>
          </div>
        </div>
        <div class="testimonials__result">
          {{ jaraba_icon('actions', 'check-circle', { variant: 'duotone', size: '18px', color: 'verde-innovacion' }) }}
          <span>{% trans %}Negocio de gastrobiking en Cazalla de la Sierra{% endtrans %}</span>
        </div>
      </article>

      {# Testimonio 3: Luis Miguel Criado #}
      <article class="testimonials__card reveal-element reveal-fade-up" role="listitem" style="--reveal-delay: 0.3s;">
        <div class="testimonials__quote-icon" aria-hidden="true">
          {{ jaraba_icon('ui', 'quote', { variant: 'duotone', size: '28px', color: 'azul-corporativo' }) }}
        </div>
        <blockquote class="testimonials__text">
          {% trans %}El programa me dio las herramientas para dar los pasos más difíciles: empezar a cotizar y conseguir mis primeras ayudas. Sin depender de una gestoría.{% endtrans %}
        </blockquote>
        <div class="testimonials__author">
          <div class="testimonials__author-avatar testimonials__author-avatar--azul" aria-hidden="true">LM</div>
          <div class="testimonials__author-info">
            <cite class="testimonials__author-name">Luis Miguel Criado</cite>
            <span class="testimonials__author-role">{% trans %}Terapeuta y Emprendedor{% endtrans %}</span>
          </div>
        </div>
        <div class="testimonials__result">
          {{ jaraba_icon('actions', 'check-circle', { variant: 'duotone', size: '18px', color: 'verde-innovacion' }) }}
          <span>{% trans %}Alta de autónomo + ayuda de la Junta de Andalucía{% endtrans %}</span>
        </div>
      </article>

    </div>

    <div class="testimonials__cta">
      <a href="{{ (language_prefix|default('')) ~ '/blog' }}"
         class="btn-secondary btn-secondary--large"
         data-track-cta="testimonials_see_all"
         data-track-position="homepage_testimonials">
        {% trans %}Ver todos los casos{% endtrans %} →
      </a>
    </div>

  </div>
</section>
