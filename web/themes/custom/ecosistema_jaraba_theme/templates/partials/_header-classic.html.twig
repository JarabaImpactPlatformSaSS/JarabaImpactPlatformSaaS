{#
/**
 * @file
 * Header sub-partial: Classic — Megamenu por audiencia.
 *
 * Layout: Logo izquierda, megamenu "Soluciones" + links directos centro,
 * selector idioma + auth + CTA derecha.
 * Mobile: Hamburguesa → overlay con accordion de grupos.
 *
 * Usa CSS classes existentes: header--mega, mega-panel__*, language-switcher.
 *
 * Variables esperadas:
 * - site_name, site_slogan, logo, logged_in
 * - nav_items: fallback array de { text, url } (para meta-sitios sin megamenu)
 * - theme_settings: configuración completa del tema
 * - available_languages, current_langcode: para selector de idioma
 * - language_prefix: "" for default lang, "/en" or "/pt-br" for others (I18N-NAVPREFIX-001)
 */
#}
{% set ts = theme_settings|default({}) %}
{% set show_auth = ts.header_show_auth|default(true) %}
{% set use_megamenu = ts.header_megamenu|default(false) %}
{% set lp = language_prefix|default('') %}

<header class="landing-header landing-header--classic{{ use_megamenu ? ' header--mega' : '' }}" role="banner">
  <div class="landing-header__container header__container">

    {# ── Logo + Branding ── #}
    <a href="{{ lp }}/" class="landing-header__brand" rel="home">
      {% if logo %}
        <img src="{{ logo }}" alt="{{ site_name }}" class="landing-header__logo" />
      {% endif %}
      <div class="landing-header__text">
        <span class="landing-header__name">{{ site_name }}</span>
        <span class="landing-header__slogan">{{ site_slogan }}</span>
      </div>
    </a>

    {# ── Navegación Principal: Megamenu por audiencia ── #}
    <nav class="landing-header__nav" aria-label="{% trans %}Main navigation{% endtrans %}">
      {% if use_megamenu %}
      <ul class="header__menu">
        {# Dropdown: Soluciones (megamenu 3 columnas) #}
        <li class="header__menu-item has-mega-menu">
          <button class="header__menu-link" aria-expanded="false" aria-haspopup="true">
            {% trans %}Soluciones{% endtrans %}
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
              <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="header__mega-panel" role="menu" aria-label="{% trans %}Solutions menu{% endtrans %}">
            <div class="mega-panel__container">
              <div class="mega-panel__columns">
                {% for column in mega_menu_columns|default([]) %}
                  <div class="mega-panel__column">
                    <h3 class="mega-panel__title">{{ column.title }}</h3>
                    <ul class="mega-panel__list">
                      {% for item in column.items|default([]) %}
                        <li>
                          <a href="{{ item.url }}" class="mega-panel__link">
                            <span class="mega-panel__link-icon">
                              {{ jaraba_icon(item.icon_cat, item.icon_name, { variant: 'duotone', size: '28px', color: item.color }) }}
                            </span>
                            <span class="mega-panel__link-text">
                              <strong>{{ item.title }}</strong>
                              <small>{{ item.subtitle }}</small>
                            </span>
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                    {% if column.has_promo|default(false) %}
                      <div class="mega-panel__promo">
                        {% if logged_in %}
                          <h4>{% trans %}Amplía tu ecosistema{% endtrans %}</h4>
                          <p>{% trans %}Activa verticales adicionales y desbloquea nuevas herramientas para tu negocio.{% endtrans %}</p>
                          <a href="{{ lp }}/addons" class="btn-primary btn-primary--sm"
                             data-track-cta="megamenu_addons" data-track-position="megamenu_promo">
                            {% trans %}Ver catálogo{% endtrans %} →
                          </a>
                        {% else %}
                          <h4>{% trans %}¿No sabes cuál elegir?{% endtrans %}</h4>
                          <p>{% trans %}Descubre en 30 segundos cuál es la solución perfecta para ti.{% endtrans %}</p>
                          <a href="{{ lp }}/test-vertical" class="btn-primary btn-primary--sm"
                             data-track-cta="megamenu_quiz" data-track-position="megamenu_promo">
                            {% trans %}Hacer el test{% endtrans %} →
                          </a>
                        {% endif %}
                      </div>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
            </div>
          </div>
        </li>

        {# Links directos (fuera del megamenu) #}
        <li class="header__menu-item">
          <a href="{{ lp }}/planes" class="header__menu-link">{% trans %}Precios{% endtrans %}</a>
        </li>
        {% if ts.promo_banner_enabled|default(false) and ts.promo_banner_url|default('') %}
        <li class="header__menu-item">
          <a href="{{ lp }}{{ ts.promo_banner_url }}" class="header__menu-link header__menu-link--highlight">
            {{ ts.promo_banner_cta|default('Kit Digital'|t) }}
          </a>
        </li>
        {% endif %}
        <li class="header__menu-item">
          <a href="{{ lp }}/casos-de-exito" class="header__menu-link">{% trans %}Casos de Éxito{% endtrans %}</a>
        </li>
      </ul>

      {% else %}
      {# Fallback: navegación plana para meta-sitios #}
      <ul class="landing-nav">
        {% for item in nav_items|default([]) %}
          <li><a href="{{ lp }}{{ item.url }}">{{ item.text }}</a></li>
        {% endfor %}
      </ul>
      {% endif %}
    </nav>

    {# ── Acciones: Idioma + Auth + CTA ── #}
    <div class="landing-header__actions">
      {# Selector de idioma (si hay más de 1 idioma disponible) #}
      {% if available_languages|default([])|length > 1 %}
        {% include '@ecosistema_jaraba_theme/partials/_language-switcher.html.twig' with {
          available_languages: available_languages,
          current_langcode: current_langcode|default('es'),
          language_links: language_links|default({}),
        } only %}
      {% endif %}

      {# Auth actions #}
      {% if show_auth %}
        {% if logged_in %}
          <a href="{{ lp }}/user" class="btn-ghost">{% trans %}Mi cuenta{% endtrans %}</a>
        {% else %}
          <a href="{{ lp }}/user/login" class="btn-ghost">{% trans %}Iniciar sesión{% endtrans %}</a>
        {% endif %}
      {% endif %}

      {# CTA principal — respeta enable_header_cta de theme settings / SiteConfig #}
      {% if ts.enable_header_cta|default(false) %}
        <a href="{{ lp }}{{ ts.header_cta_url|default('/user/register') }}" class="btn-primary btn-primary--glow"
           data-track-cta="header_cta_primary" data-track-position="header_classic">
          {{ ts.header_cta_text|default('Empieza gratis'|t) }} →
        </a>
      {% endif %}
    </div>

    {# Mobile Menu Toggle #}
    <button class="landing-header__toggle" aria-label="{% trans %}Toggle menu{% endtrans %}" aria-expanded="false">
      <span class="hamburger"></span>
    </button>
  </div>
</header>
