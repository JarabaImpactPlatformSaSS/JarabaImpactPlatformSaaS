{#
/**
 * @file
 * _subscription-card.html.twig — Tarjeta de suscripción PLG.
 *
 * Muestra plan actual, estado, features incluidos/bloqueados,
 * barras de uso y CTA de upgrade.
 *
 * Variables:
 * - ctx: SubscriptionContext array completo (de SubscriptionContextService).
 *   - ctx.plan: {id, name, tier, tier_label, vertical, price_monthly, is_free}
 *   - ctx.subscription: {status, status_label, trial_ends, trial_days_remaining}
 *   - ctx.features.included: [{key, label, icon_cat, icon_name}]
 *   - ctx.features.locked: [{key, label, icon_cat, icon_name, available_in}]
 *   - ctx.usage: [{key, label, current, limit, percentage, status}]
 *   - ctx.upgrade: {available, next_tier_label, next_tier_price, checkout_url, pricing_url}
 *
 * PLG-UPGRADE-UI-001 §3.3
 * TWIG-INCLUDE-ONLY-001: Se incluye con keyword only.
 * i18n: Todos los textos con {% trans %}.
 * CSS: var(--ej-*) para todos los colores.
 */
#}

{% if ctx.plan is defined %}
<div class="subscription-card">

  {# === PLAN HEADER === #}
  <div class="subscription-card__header">
    <div class="subscription-card__plan-info">
      <span class="subscription-card__tier subscription-card__tier--{{ ctx.plan.tier }}">
        {{ ctx.plan.tier_label }}
      </span>
      {% if ctx.plan.vertical_label %}
        <span class="subscription-card__vertical">{{ ctx.plan.vertical_label }}</span>
      {% endif %}
    </div>

    <div class="subscription-card__status subscription-card__status--{{ ctx.subscription.status }}">
      {% if ctx.subscription.status == 'trial' and ctx.subscription.trial_days_remaining > 0 %}
        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
        </svg>
        {% trans %}{{ ctx.subscription.trial_days_remaining }} días restantes{% endtrans %}
      {% else %}
        {{ ctx.subscription.status_label }}
      {% endif %}
    </div>
  </div>

  {% if not ctx.plan.is_free and ctx.plan.price_monthly > 0 %}
    <div class="subscription-card__price">
      <span class="subscription-card__amount">{{ ctx.plan.price_monthly|number_format(0, ',', '.') }}&euro;</span>
      <span class="subscription-card__cycle">/{% trans %}mes{% endtrans %}</span>
    </div>
  {% endif %}

  {# === FEATURES INCLUIDOS === #}
  {% if ctx.features.included is not empty %}
    <div class="subscription-card__features">
      <h3 class="subscription-card__features-title">
        {% trans %}Incluido en tu plan{% endtrans %}
      </h3>
      <ul class="subscription-card__features-list">
        {% for feature in ctx.features.included|slice(0, 6) %}
          <li class="subscription-card__feature subscription-card__feature--included">
            <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            {{ feature.label }}
          </li>
        {% endfor %}
        {% if ctx.features.included|length > 6 %}
          {% set extra_count = ctx.features.included|length - 6 %}
          <li class="subscription-card__feature subscription-card__feature--more">
            {% trans %}+{{ extra_count }} funcionalidades más{% endtrans %}
          </li>
        {% endif %}
      </ul>
    </div>
  {% endif %}

  {# === FEATURES BLOQUEADOS (UPGRADE) === #}
  {% if ctx.features.locked is not empty %}
    <div class="subscription-card__locked">
      <h3 class="subscription-card__locked-title">
        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
          <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
        </svg>
        {% trans %}Disponible con upgrade{% endtrans %}
      </h3>
      <ul class="subscription-card__features-list">
        {% for feature in ctx.features.locked|slice(0, 4) %}
          <li class="subscription-card__feature subscription-card__feature--locked">
            <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
              <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
            </svg>
            <span>{{ feature.label }}</span>
            <span class="subscription-card__available-in">{{ feature.available_in }}</span>
          </li>
        {% endfor %}
        {% if ctx.features.locked|length > 4 %}
          {% set extra_locked = ctx.features.locked|length - 4 %}
          <li class="subscription-card__feature subscription-card__feature--more-locked">
            {% trans %}+{{ extra_locked }} funcionalidades más{% endtrans %}
          </li>
        {% endif %}
      </ul>
    </div>
  {% endif %}

  {# === BARRAS DE USO === #}
  {% if ctx.usage is not empty %}
    <div class="subscription-card__usage">
      {% for item in ctx.usage %}
        <div class="subscription-card__usage-item">
          <div class="subscription-card__usage-label">
            <span>{{ item.label }}</span>
            <span class="subscription-card__usage-count">{{ item.current }}/{{ item.limit }}</span>
          </div>
          <div class="subscription-card__usage-bar">
            <div class="subscription-card__usage-fill subscription-card__usage-fill--{{ item.status }}"
                 style="width: {{ item.percentage }}%"
                 role="progressbar"
                 aria-valuenow="{{ item.current }}"
                 aria-valuemin="0"
                 aria-valuemax="{{ item.limit }}"
                 aria-label="{{ item.label }}: {{ item.current }} {% trans %}de{% endtrans %} {{ item.limit }}">
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  {# === ADD-ONS ACTIVOS === #}
  {% if ctx.addons is defined and ctx.addons.active is not empty %}
    <div class="subscription-card__addons">
      <h3 class="subscription-card__addons-title">
        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
          <path d="M7 3a1 1 0 000 2h6a1 1 0 100-2H7zM4 7a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1zM2 11a2 2 0 012-2h12a2 2 0 012 2v4a2 2 0 01-2 2H4a2 2 0 01-2-2v-4z"/>
        </svg>
        {% trans %}Add-ons activos{% endtrans %}
      </h3>
      <div class="subscription-card__addons-list">
        {% for addon in ctx.addons.active %}
          <div class="subscription-card__addon-item">
            {{ jaraba_icon(addon.icon_cat, addon.icon_name, { variant: 'duotone', color: 'azul-corporativo', size: '16px' }) }}
            <span class="subscription-card__addon-name">{{ addon.label }}</span>
            <span class="subscription-card__addon-price">{{ addon.price|number_format(0, ',', '.') }}&euro;/{% trans %}mes{% endtrans %}</span>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {# === ADD-ONS RECOMENDADOS === #}
  {% if ctx.addons is defined and ctx.addons.recommended is not empty %}
    <div class="subscription-card__recommended">
      <h3 class="subscription-card__recommended-title">
        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        {% trans %}Recomendado para ti{% endtrans %}
      </h3>
      <div class="subscription-card__recommended-list">
        {% for addon in ctx.addons.recommended %}
          <a href="{{ path('jaraba_addons.catalog.detail', {'addon_id': addon.addon_id}) }}"
             class="subscription-card__recommended-item">
            {{ jaraba_icon(addon.icon_cat, addon.icon_name, { variant: 'duotone', color: 'naranja-impulso', size: '16px' }) }}
            <span class="subscription-card__recommended-name">{{ addon.label }}</span>
            <span class="subscription-card__recommended-price">{{ addon.price|number_format(0, ',', '.') }}&euro;/{% trans %}mes{% endtrans %}</span>
            <span class="subscription-card__recommended-badge">{% trans %}+ Añadir{% endtrans %}</span>
          </a>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {# === RESUMEN DE FACTURACION === #}
  {% if ctx.billing is defined and ctx.billing.total_monthly > 0 %}
    <div class="subscription-card__billing">
      <div class="subscription-card__billing-row">
        <span>{% trans %}Total mensual{% endtrans %}</span>
        <span class="subscription-card__billing-total">{{ ctx.billing.total_monthly|number_format(0, ',', '.') }}&euro;/{% trans %}mes{% endtrans %}</span>
      </div>
      {% if ctx.billing.next_invoice_date %}
        <div class="subscription-card__billing-row subscription-card__billing-row--secondary">
          <span>{% trans %}Próxima factura{% endtrans %}</span>
          <span>{{ ctx.billing.next_invoice_date }}</span>
        </div>
      {% endif %}
    </div>
  {% endif %}

  {# === PORTAL STRIPE (self-service: cancel/upgrade/metodo pago) === #}
  {% if not ctx.plan.is_free and ctx.subscription.status != 'none' %}
    <div class="subscription-card__portal">
      <button type="button"
              class="subscription-card__portal-btn"
              data-portal-trigger
              data-portal-return-url="{{ path('ecosistema_jaraba_core.tenant_self_service.plan') }}"
              aria-label="{% trans %}Gestionar suscripción en portal de pagos{% endtrans %}">
        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
          <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/>
        </svg>
        {% trans %}Gestionar suscripción{% endtrans %}
      </button>

      {# === PAUSE / CANCEL OPTIONS — Retencion clase mundial === #}
      {% if ctx.plan.status is defined and ctx.plan.status in ['active', 'trial'] %}
        <div class="subscription-card__actions-secondary">
          {# Pause button — PauseSubscriptionService #}
          <button type="button"
                  class="subscription-card__pause-btn"
                  data-pause-trigger
                  data-pause-url="{{ path('jaraba_billing.api.pause_subscription') }}"
                  aria-label="{% trans %}Pausar suscripción temporalmente{% endtrans %}">
            {{ jaraba_icon('ui', 'pause', { variant: 'duotone', size: '14px', color: 'neutral' }) }}
            {% trans %}Pausar (1-3 meses){% endtrans %}
          </button>

          {# Cancel button — opens cancellation flow with reason survey #}
          <button type="button"
                  class="subscription-card__cancel-btn"
                  data-cancel-trigger
                  data-cancel-url="{{ path('jaraba_billing.api.cancel_subscription') }}"
                  aria-label="{% trans %}Cancelar suscripción{% endtrans %}">
            {% trans %}Cancelar suscripción{% endtrans %}
          </button>
        </div>
      {% endif %}

      {# Paused state indicator #}
      {% if ctx.plan.status is defined and ctx.plan.status == 'paused' %}
        <div class="subscription-card__paused-notice">
          {{ jaraba_icon('ui', 'pause', { variant: 'duotone', size: '16px', color: 'naranja-impulso' }) }}
          <span>{% trans %}Suscripción pausada{% endtrans %}</span>
          {% if ctx.plan.resume_date is defined %}
            <span class="subscription-card__resume-date">
              {% trans %}Se reanuda el {{ ctx.plan.resume_date }}{% endtrans %}
            </span>
          {% endif %}
          <button type="button"
                  class="subscription-card__resume-btn"
                  data-resume-trigger
                  data-resume-url="{{ path('jaraba_billing.api.resume_subscription') }}"
                  aria-label="{% trans %}Reanudar suscripción ahora{% endtrans %}">
            {% trans %}Reanudar ahora{% endtrans %}
          </button>
        </div>
      {% endif %}
    </div>
  {% endif %}

  {# === CTA UPGRADE === #}
  {% if ctx.upgrade.available %}
    <div class="subscription-card__upgrade">
      {% if ctx.upgrade.checkout_url %}
        {# TODOS los planes (incluido Enterprise) → checkout directo con Stripe #}
        <a href="{{ ctx.upgrade.checkout_url }}" class="subscription-card__upgrade-btn">
          <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
            <path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"/>
          </svg>
          {% trans %}Mejorar a {{ ctx.upgrade.next_tier_label }}{% endtrans %}
        </a>
      {% endif %}
      {% if ctx.addons is defined %}
        <a href="{{ path('jaraba_addons.catalog') }}" class="subscription-card__addons-link">
          {% trans %}Explorar Add-ons{% endtrans %}
          <svg viewBox="0 0 20 20" fill="currentColor" width="12" height="12" aria-hidden="true">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </a>
      {% endif %}
      {% if ctx.upgrade.pricing_url %}
        <a href="{{ ctx.upgrade.pricing_url }}" class="subscription-card__compare-link">
          {% trans %}Comparar planes{% endtrans %}
          <svg viewBox="0 0 20 20" fill="currentColor" width="12" height="12" aria-hidden="true">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </a>
      {% endif %}
    </div>
  {% endif %}

</div>
{% endif %}
