{#
/**
 * @file
 * templates/partials/_header.html.twig
 *
 * DISPATCHER: Incluye el sub-partial de header según theme_settings.header_layout
 *
 * Variables esperadas:
 * - site_name: Nombre del sitio
 * - site_slogan: Eslogan del sitio
 * - logo: URL del logo
 * - logged_in: TRUE si el usuario está autenticado
 * - theme_settings.header_layout: 'classic', 'minimal', 'transparent', etc.
 * - theme_settings.navigation_items: Navegación configurable (Texto|URL)
 *
 * Layouts disponibles:
 * - classic: Logo, nav horizontal, acciones, hamburguesa en móvil
 * - minimal: Solo logo + hamburguesa (sin nav horizontal)
 * - transparent: Como classic pero fondo transparente
 */
#}
{% set site_name = site_name|default('Jaraba Impact Platform') %}
{% set site_slogan = site_slogan|default('Impulsando el talento y la innovación') %}
{% set ts = theme_settings|default({}) %}
{% set layout_raw = ts.header_layout|default('classic') %}

{# FE-06: Validar layout contra whitelist antes del include dinámico #}
{% set allowed_layouts = ['classic', 'minimal', 'transparent'] %}
{% set layout = layout_raw in allowed_layouts ? layout_raw : 'classic' %}

{# ── Parsear navigation_items: "Texto|URL" por línea → array de {text, url} ── #}
{% set nav_items_raw = ts.navigation_items|default("Empleabilidad|/empleabilidad\nTalento|/talento\nEmprendimiento|/emprendimiento\nComercioConecta|/comercioconecta\nInstituciones|/instituciones") %}
{% set nav_items = [] %}
{% for line in nav_items_raw|split("\n") %}
  {% set parts = line|split('|') %}
  {% if parts|length >= 2 %}
    {% set nav_items = nav_items|merge([{ text: parts[0]|trim, url: parts[1]|trim }]) %}
  {% endif %}
{% endfor %}

{{ attach_library('ecosistema_jaraba_theme/mobile-menu') }}
{% if available_languages|default([])|length > 1 %}
  {{ attach_library('ecosistema_jaraba_theme/language-switcher') }}
{% endif %}

{# GAP-AUD-010: Proactive Insights bell notification #}
{% if logged_in and proactive_insights_count is defined and proactive_insights_count > 0 %}
  {% include '@ecosistema_jaraba_theme/partials/_proactive-insights-bell.html.twig' with {
    proactive_insights_count: proactive_insights_count,
    logged_in: logged_in,
  } only %}
{% endif %}

{# I18N-NAVPREFIX-001: language_prefix = "" for default lang, "/en" or "/pt-br" for others #}
{% set lp = language_prefix|default('') %}

{# MEGAMENU-INJECT-001: Si mega_menu_columns no fue pasado explícitamente
   por el page template (include ... only sin la variable), usar el fallback
   inyectado en theme_settings._mega_menu_columns desde preprocess_page. #}
{% set resolved_mega_columns = mega_menu_columns|default(ts._mega_menu_columns|default([])) %}

{# Incluir sub-partial según layout validado — pasamos nav_items parseados #}
{% include '@ecosistema_jaraba_theme/partials/_header-' ~ layout ~ '.html.twig' with {
  site_name: site_name,
  site_slogan: site_slogan,
  logo: logo,
  logged_in: logged_in,
  nav_items: nav_items,
  theme_settings: theme_settings,
  available_languages: available_languages|default([]),
  current_langcode: current_langcode|default('es'),
  language_prefix: lp,
  language_links: language_links|default({}),
  mega_menu_columns: resolved_mega_columns,
} only %}

{# Mobile Menu Overlay (compartido por todos los layouts) #}
{# NAV-006: Condicional — megamenu accordion para SaaS, lista plana para meta-sitios #}
{% set use_megamenu = ts.header_megamenu|default(false) %}

<div class="mobile-menu-overlay" aria-hidden="true">
  <nav class="mobile-menu-nav" aria-label="{% trans %}Mobile navigation{% endtrans %}">
    {% if use_megamenu %}
    {# Mega menu accordion — datos desde mega_menu_columns (PHP preprocess) #}
    {% for column in resolved_mega_columns %}
      <details class="mobile-menu-group"{{ loop.first ? ' open' : '' }}>
        <summary class="mobile-menu-group__title">{{ column.title }}</summary>
        <ul class="mobile-menu-list">
          {% for item in column.items|default([]) %}
            <li><a href="{{ item.url }}">{{ item.title }}</a></li>
          {% endfor %}
        </ul>
      </details>
    {% endfor %}
    {# Links directos — configurables desde preprocess (SaaS: Precios/Casos, PED: Impacto/Casos) #}
    {% if ts.megamenu_direct_links|default([])|length > 0 %}
    <ul class="mobile-menu-list mobile-menu-list--direct">
      {% for direct_link in ts.megamenu_direct_links %}
        <li><a href="{{ direct_link.url }}">{{ direct_link.text }}</a></li>
      {% endfor %}
    </ul>
    {% endif %}
    {% else %}
    {# Navegación plana (meta-sitios) #}
    {% set has_cases_mobile = false %}
    <ul class="mobile-menu-list">
      {% for item in nav_items %}
        {% if 'caso' in item.url|lower or 'caso' in item.text|lower or 'testimonio' in item.url|lower %}
          {% set has_cases_mobile = true %}
          <li><a href="{{ lp }}/casos-de-exito">{{ item.text }}</a></li>
        {% else %}
          <li><a href="{{ lp }}{{ item.url }}">{{ item.text }}</a></li>
        {% endif %}
      {% endfor %}
      {% if not has_cases_mobile %}
        <li><a href="{{ lp }}/casos-de-exito">{% trans %}Casos de Éxito{% endtrans %}</a></li>
      {% endif %}
    </ul>
    {% endif %}
  </nav>

  {# Selector de idioma en mobile #}
  {% if available_languages|default([])|length > 1 %}
    <div class="mobile-menu-lang">
      {% include '@ecosistema_jaraba_theme/partials/_language-switcher.html.twig' with {
        available_languages: available_languages|default([]),
        current_langcode: current_langcode|default('es'),
      } only %}
    </div>
  {% endif %}

  <div class="mobile-menu-actions">
    {% if logged_in %}
      <a href="{{ lp }}/user" class="btn-ghost">{% trans %}Mi cuenta{% endtrans %}</a>
    {% else %}
      <a href="{{ lp }}/user/login" class="btn-ghost">{% trans %}Iniciar sesión{% endtrans %}</a>
      <a href="{{ lp }}/user/register" class="btn-primary btn-primary--glow">{% trans %}Empieza gratis{% endtrans %} →</a>
    {% endif %}
  </div>

{# Avatar Navigation — Barra contextual por rol/avatar #}
{% if avatar_nav is defined and avatar_nav and avatar_nav.items|length > 0 %}
  {% include '@ecosistema_jaraba_theme/partials/_avatar-nav.html.twig' with {
    items: avatar_nav.items,
    avatar: avatar_nav.avatar,
    avatar_label: avatar_nav.avatar_label,
  } only %}
{% endif %}
</div>
