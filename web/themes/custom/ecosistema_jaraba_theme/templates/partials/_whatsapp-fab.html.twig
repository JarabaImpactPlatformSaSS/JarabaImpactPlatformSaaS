{#
/**
 * @file _whatsapp-fab.html.twig
 * Widget flotante de WhatsApp — contextual, desktop+móvil.
 *
 * Evolución del FAB básico a widget clase mundial con:
 * - Aparición progresiva (delay + scroll threshold)
 * - Mensaje contextual por vertical/página (WA-CONTEXTUAL-001)
 * - Estado expandido en desktop con preview + CTA
 * - Configurable 100% desde Theme Settings (WA-FAB-CONFIG-001)
 *
 * VARIABLES (via {% include ... only %}):
 * - whatsapp_enabled: boolean
 * - whatsapp_number: string (sin +, ej: '34623174304')
 * - whatsapp_display: string ('mobile'|'desktop'|'both')
 * - whatsapp_position: string ('left'|'right')
 *
 * DIRECTRICES:
 * - i18n: {% trans %} bloque en todos los textos (NUNCA filtro |t)
 * - CSS: BEM .whatsapp-fab__*, var(--ej-*) (CSS-VAR-ALL-COLORS-001)
 * - A11Y: aria-label, aria-expanded, focus-visible, prefers-reduced-motion
 * - TWIG-INCLUDE-ONLY-001: Se incluye con keyword only
 * - FUNNEL-COMPLETENESS-001: data-track-cta + data-track-position
 * - CONTACT-SSOT-001: Datos desde theme_settings, NUNCA hardcoded
 *
 * @see ecosistema_jaraba_theme/js/whatsapp-fab-contextual.js
 * @see ecosistema_jaraba_theme/scss/components/_whatsapp-fab.scss
 */
#}

{% if whatsapp_enabled and whatsapp_number %}
  {% set wa_display = whatsapp_display|default('both') %}
  {% set wa_position = whatsapp_position|default('left') %}
  {% set wa_href = 'https://wa.me/' ~ whatsapp_number %}

  <div class="whatsapp-fab"
       data-wa-display="{{ wa_display }}"
       data-wa-position="{{ wa_position }}"
       data-track-cta="whatsapp_fab_contextual"
       data-track-position="global_fab">

    {# Tooltip con mensaje contextual — inyectado por JS desde drupalSettings #}
    <div class="whatsapp-fab__tooltip" aria-hidden="true"></div>

    {# Botón FAB principal #}
    <a href="{{ wa_href }}"
       class="whatsapp-fab__button"
       target="_blank"
       rel="noopener noreferrer"
       aria-label="{% trans %}Contactar por WhatsApp{% endtrans %}"
       aria-expanded="false">
      <svg class="whatsapp-fab__icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="whatsapp-fab__label">{% trans %}WhatsApp{% endtrans %}</span>
    </a>

    {# Panel expandido — solo desktop, toggle por JS #}
    <div class="whatsapp-fab__expanded" role="dialog" aria-label="{% trans %}Contacto por WhatsApp{% endtrans %}">
      <div class="whatsapp-fab__expanded-header">
        <span class="whatsapp-fab__expanded-title">{% trans %}Chatea con nosotros{% endtrans %}</span>
        <button class="whatsapp-fab__close" aria-label="{% trans %}Cerrar{% endtrans %}" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <div class="whatsapp-fab__expanded-body">
        <p class="whatsapp-fab__expanded-status">
          <span class="whatsapp-fab__status-dot"></span>
          {% trans %}Disponible ahora{% endtrans %}
        </p>
        <p class="whatsapp-fab__expanded-message">
          {# Mensaje inyectado por JS desde drupalSettings.jarabaWhatsApp.messages #}
        </p>
        <a href="{{ wa_href }}"
           class="whatsapp-fab__expanded-cta"
           target="_blank"
           rel="noopener noreferrer"
           data-track-cta="whatsapp_expanded_cta"
           data-track-position="expanded_panel">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="vertical-align: middle; margin-right: 6px;">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {% trans %}Abrir WhatsApp{% endtrans %}
        </a>
      </div>
    </div>
  </div>
{% endif %}
