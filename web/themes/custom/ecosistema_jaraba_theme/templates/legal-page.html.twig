{#
/**
 * @file
 * legal-page.html.twig
 *
 * Template genérico para páginas legales: privacidad, términos, cookies.
 *
 * VARIABLES (desde StaticPageController):
 * - page_type: 'privacy' | 'terms' | 'cookies'
 * - title: Título de la página
 * - content: HTML desde Theme Settings
 * - last_updated: Fecha de última actualización
 *
 * DIRECTRICES:
 * - FRONTEND-PAGE-001: Full-width clean layout
 * - i18n: {% trans %}
 * - LEGAL-CONFIG-001: contenido editable desde admin
 */
#}

<div class="static-page static-page--legal static-page--{{ page_type|default('generic') }}">
  <div class="static-page__container">

    <header class="static-page__header">
      <h1 class="static-page__title">{{ title }}</h1>
      {% if last_updated %}
        <p class="static-page__meta">
          {% trans %}Última actualización:{% endtrans %} <time>{{ last_updated }}</time>
        </p>
      {% endif %}
    </header>

    {% if content %}
      <div class="static-page__content static-page__content--legal">
        {# AUDIT-SEC-003: content is pre-sanitized with Xss::filterAdmin() in StaticPageController #}
        {{ content|raw }}
      </div>
    {% else %}
      <div class="static-page__content static-page__content--legal">
        <p class="static-page__placeholder">
          {% trans %}El contenido de esta página está siendo preparado. Configúralo desde Apariencia > Ecosistema Jaraba Theme > Páginas Legales.{% endtrans %}
        </p>
      </div>
    {% endif %}

    <footer class="static-page__footer-nav">
      <nav aria-label="{% trans %}Páginas legales{% endtrans %}">
        <ul class="static-page__legal-links">
          {# ROUTE-LANGPREFIX-001: use path() for proper /es/ prefix, NEVER hardcoded URLs #}
          <li><a href="{{ path('ecosistema_jaraba_core.static.privacidad') }}">{% trans %}Privacidad{% endtrans %}</a></li>
          <li><a href="{{ path('ecosistema_jaraba_core.static.terminos') }}">{% trans %}Términos{% endtrans %}</a></li>
          <li><a href="{{ path('ecosistema_jaraba_core.static.cookies') }}">{% trans %}Cookies{% endtrans %}</a></li>
          <li><a href="{{ path('ecosistema_jaraba_core.contact') }}">{% trans %}Contacto{% endtrans %}</a></li>
        </ul>
      </nav>
    </footer>

  </div>
</div>
