{#
/**
 * @file
 * Landing page template para Andalucia +ei programa.
 *
 * Zero Region Policy: No renderiza page.content ni sidebars.
 * Solo header + contenido directo + footer.
 * Mobile-first, layout full-width.
 */
#}

{{ attach_library('ecosistema_jaraba_theme/global') }}

{% include '@ecosistema_jaraba_theme/partials/_header.html.twig' with {
  'site_name': site_name,
  'site_slogan': site_slogan|default(''),
  'logo': logo,
  'logged_in': logged_in,
  'theme_settings': theme_settings|default({}),
  'available_languages': available_languages|default([]),
  'current_langcode': current_langcode|default('es'),
  'language_prefix': language_prefix|default(''),
  'language_links': language_links|default({}),
  'mega_menu_columns': mega_menu_columns|default([]),
} only %}

<main id="main-content" class="aei-landing" role="main">
  {{ clean_content }}
</main>

{% include '@ecosistema_jaraba_theme/partials/_footer.html.twig' with {,
    'site_name': site_name,
    'theme_settings': theme_settings|default({}),
    'language_prefix': language_prefix|default(''),
    'logged_in': logged_in,
  } only %}
