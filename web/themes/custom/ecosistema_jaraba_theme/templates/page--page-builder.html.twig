{#
/**
 * @file
 * page--page-builder.html.twig - Template limpia para páginas del Page Builder.
 *
 * ARQUITECTURA LIMPIA SaaS (2026-02-02):
 * - SIN regiones heredadas de Drupal (sidebar, nav, breadcrumb)
 * - SIN menús del ecosistema principal (Empleo/Talento/etc)
 * - Full-width, mobile-first
 * - Solo renderiza el contenido del PageContent entity via viewBuilder
 * - Header propio ultra-limpio (solo logo, sin navegación del ecosistema)
 * - El tenant NO tiene acceso al tema admin de Drupal
 *
 * RUTAS AFECTADAS:
 * - /page-builder/* (dashboard, templates, preview, create)
 * - /page/{id} o alias como /pepejaraba (entity.page_content.canonical)
 * - /my-pages
 *
 * DIRECTRICES:
 * - Nuclear #14: Frontend Limpio (Zero Region Policy — usa {{ clean_content }})
 * - Directriz: "SaaS debe tener control absoluto sobre el frontend limpio"
 *
 * @see ecosistema_jaraba_theme_theme_suggestions_page_alter()
 * @see PageContentViewBuilder::view()
 */
#}
{% set site_name = site_name|default('Jaraba Impact Platform') %}

{# Librerías del Page Builder #}
{{ attach_library('ecosistema_jaraba_theme/global') }}
{{ attach_library('jaraba_page_builder/page-builder') }}

{# Sprint 9-12-15: Tracking + Experiments + Heatmap para meta-sitios #}
{% if meta_site %}
  {{ attach_library('ecosistema_jaraba_theme/metasite-tracking') }}
  {{ attach_library('ecosistema_jaraba_theme/metasite-experiments') }}
  {{ attach_library('jaraba_heatmap/tracker') }}
{% endif %}

{# =========================================================================
   HEADER — Meta-sitio: full header con nav del tenant
                Non-meta-sitio: ultra-limpio, solo logo + acciones
   ========================================================================= #}
{% if meta_site %}
  {# Meta-sitio: usar el partial configurable que ya lee theme_settings.navigation_items #}
  {% include '@ecosistema_jaraba_theme/partials/_header.html.twig' with {
    site_name: site_name,
    site_slogan: site_slogan|default(''),
    logo: logo,
    logged_in: logged_in,
    theme_settings: theme_settings,
    available_languages: available_languages|default([]),
    current_langcode: current_langcode|default('es'),
    language_links: language_links|default({}),
  } %}
{% else %}
  {# Non-meta-sitio (page-builder dashboard, preview, etc.): header limpio sin nav #}
  <header class="landing-header landing-header--tenant" role="banner">
    <div class="landing-header__container">
      <a href="{{ path('<front>') }}" class="landing-header__brand" rel="home">
        {% if logo %}
          <img src="{{ logo }}" alt="{{ site_name }}" class="landing-header__logo" />
        {% endif %}
        <div class="landing-header__text">
          <span class="landing-header__name">{{ site_name }}</span>
        </div>
      </a>
      <div class="landing-header__actions">
        {% if logged_in %}
          <a href="{{ path('user.page') }}" class="btn-ghost">{% trans %}Mi cuenta{% endtrans %}</a>
          <a href="{{ path('user.logout') }}" class="btn-ghost">{% trans %}Cerrar sesión{% endtrans %}</a>
        {% else %}
          <a href="{{ path('user.login') }}" class="btn-ghost">{% trans %}Iniciar sesión{% endtrans %}</a>
        {% endif %}
      </div>
    </div>
  </header>
{% endif %}

{# =========================================================================
   MAIN CONTENT - Full-width, Sin Regiones Drupal Heredadas
   El contenido viene directamente del PageContentViewBuilder, no de bloques
   ========================================================================= #}

{# Detectar homepage PED para flujo AIDA optimizado #}
{% set ped_homepage = is_ped|default(false) and is_meta_homepage|default(false) %}

{% if ped_homepage %}
  {{ attach_library('ecosistema_jaraba_theme/scroll-animations') }}
{% endif %}

<main id="main-content" class="page-builder-main page-builder-frontend">
  {% if clean_messages %}
    <div class="highlighted container">
      {{ clean_messages }}
    </div>
  {% endif %}

  {% if ped_homepage %}
    {# ================================================================ #}
    {# PED HOMEPAGE — Flujo AIDA completo via Twig partials             #}
    {# Bypass del canvas_data legacy: todo el contenido de clase         #}
    {# mundial se renderiza desde partials optimizados                   #}
    {# ================================================================ #}

    {# 1. HERO — Atencion (3 segundos), audience-aware #}
    {% include '@ecosistema_jaraba_theme/partials/_hero.html.twig' with {
      theme_settings: theme_settings,
      logged_in: logged_in,
      hero: {},
      audience: audience|default(null),
      meta_site: meta_site,
    } %}

    {# 2. AUDIENCIA SELECTOR — Interes (segmentar antes de informar) #}
    {% include '@ecosistema_jaraba_theme/partials/_audience-selector.html.twig' %}

    {# 3. STATS DE IMPACTO — Credibilidad cuantificable #}
    {% include '@ecosistema_jaraba_theme/partials/_stats.html.twig' with {
      stats: [],
      is_ped: true,
    } %}

    {# 4. VERTICAL DESTACADO: JarabaLex — Deseo (TAM #1 legal) #}
    {% include '@ecosistema_jaraba_theme/partials/_vertical-highlight.html.twig' with {
      highlight_id: 'vertical-legal',
      highlight_variant: 'dark',
      highlight_eyebrow: 'JarabaLex — Inteligencia Legal IA'|t,
      highlight_title: 'Todo lo que tu despacho necesita. Al precio que mereces.'|t,
      highlight_subtitle: 'Busqueda semantica en 8 fuentes oficiales, gestion de expedientes, agenda, facturacion, LexNET y un copiloto legal que te ahorra el 30% de tu tiempo.'|t,
      highlight_features: [
        { icon_cat: 'legal', icon_name: 'search-legal', icon_color: 'white', title: 'Busqueda IA multi-fuente'|t, description: 'CENDOJ, EUR-Lex, CURIA, HUDOC, BOE, DGT, TEAC, EDPB'|t },
        { icon_cat: 'ui', icon_name: 'folder', icon_color: 'white', title: 'Gestion integral'|t, description: 'Expedientes, agenda juridica, boveda documental, facturacion'|t },
        { icon_cat: 'ui', icon_name: 'link', icon_color: 'white', title: 'LexNET integrado'|t, description: 'Comunicaciones judiciales sin salir de la plataforma'|t },
        { icon_cat: 'ai', icon_name: 'copilot', icon_color: 'white', title: 'Copiloto legal IA'|t, description: 'Redaccion, analisis jurisprudencial, alertas normativas'|t },
      ],
      highlight_comparison: [
        { name: 'Aranzadi', price: '300+ EUR/mes'|t, description: 'Solo base de datos'|t },
        { name: 'vLex', price: '150+ EUR/mes'|t, description: 'Solo busqueda'|t },
        { name: 'JarabaLex', price: (ped_pricing.jarabalex.professional_price|default(59) ~ ' EUR/mes')|t, description: 'TODO integrado con IA'|t, is_jaraba: true },
      ],
      highlight_cta_text: 'Prueba JarabaLex gratis 14 dias'|t,
      highlight_cta_url: ped_urls.jarabalex|default('/jarabalex'),
    } %}

    {# 5. VERTICAL DESTACADO: Instituciones B2G — Deseo (ventaja competitiva) #}
    {% include '@ecosistema_jaraba_theme/partials/_vertical-highlight.html.twig' with {
      highlight_id: 'vertical-b2g',
      highlight_variant: 'light',
      highlight_eyebrow: 'Solucion B2G — Fondos Europeos'|t,
      highlight_title: 'La plataforma que necesitan tus programas de empleo y emprendimiento'|t,
      highlight_subtitle: 'Gestion integral de participantes, fases, horas IA-tracked, justificacion FSE y copiloto para tecnicos AEDL.'|t,
      highlight_features: [
        { icon_cat: 'navigation', icon_name: 'layers', title: 'Gestion de programas'|t, description: 'Participantes, fases, itinerarios y seguimiento integral'|t },
        { icon_cat: 'ai', icon_name: 'copilot', title: 'Copiloto para tecnicos'|t, description: 'Asistente IA especializado en gestion de fondos europeos'|t },
        { icon_cat: 'analytics', icon_name: 'chart-bar', title: 'Justificacion FSE'|t, description: 'Reportes automatizados para auditorias de fondos estructurales'|t },
        { icon_cat: 'ui', icon_name: 'clock', title: 'Horas IA-tracked'|t, description: 'Control horario inteligente con validacion automatica'|t },
      ],
      highlight_cta_text: 'Solicitar demo institucional'|t,
      highlight_cta_url: ped_urls.contacto|default('/contacto'),
    } %}

    {# 6. PARTNERS INSTITUCIONALES — Credibilidad #}
    {% include '@ecosistema_jaraba_theme/partials/_partners-institucional.html.twig' with {
      theme_path: directory,
      partners_variant: 'full',
    } only %}

    {# 7. CTA BANNER FINAL — Ultima oportunidad de conversion #}
    {% include '@ecosistema_jaraba_theme/partials/_cta-banner-final.html.twig' %}

  {% else %}
    {# Páginas normales del Page Builder: renderizar canvas_data #}
    <div class="page-builder-content full-width">
      {{ clean_content }}
    </div>

    {# Formulario de contacto PED — integrado con CRM + Email #}
    {% if ped_contact_form %}
      <section class="ped-section">
        <div class="ped-section__container">
          <h2>{% trans %}Envíanos un mensaje{% endtrans %}</h2>
          <p>{% trans %}Rellena el formulario y te responderemos en menos de 24 horas.{% endtrans %}</p>
          {{ ped_contact_form }}
        </div>
      </section>
    {% endif %}

    {# PARTNERS INSTITUCIONALES — Credibilidad para meta-sitios del ecosistema #}
    {% if meta_site %}
      {% include '@ecosistema_jaraba_theme/partials/_partners-institucional.html.twig' with {
        theme_path: directory,
        partners_variant: 'full',
      } only %}
    {% endif %}
  {% endif %}
</main>

{# SCHEMA.ORG — Datos estructurados dinamicos por meta-sitio.
   PED (group_id 7) ya tiene _ped-schema.html.twig en html.html.twig (Corporation + WebSite).
   Solo inyectar _meta-site-schema para otros meta-sitios que no tienen schema dedicado. #}
{% if meta_site and meta_site.group_id|default(0) != 7 %}
  {% include '@ecosistema_jaraba_theme/partials/_meta-site-schema.html.twig' ignore missing %}
{% endif %}

{# FOOTER - Partial configurable desde UI #}
{% include '@ecosistema_jaraba_theme/partials/_footer.html.twig' with {
  site_name: site_name,
  logo: logo|default(''),
  theme_settings: theme_settings|default({})
} %}

{# Copiloto FAB contextual si está habilitado #}
{% if copilot_context %}
  {% include '@ecosistema_jaraba_theme/partials/_copilot-fab.html.twig' with {
    copilot: copilot_context
  } %}
{% endif %}
