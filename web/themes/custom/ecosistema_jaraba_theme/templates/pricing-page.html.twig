{#
/**
 * @file pricing-page.html.twig
 * Pricing page — Dynamic data from SaasPlanTier/SaasPlanFeatures cascade.
 *
 * Used for both /planes (hub fallback) and /{vertical}/planes (vertical-specific).
 *
 * VARIABLES:
 * - tiers: Array of tiers with:
 *   - tier_key: string (e.g. 'starter', 'professional', 'enterprise')
 *   - label: string (display name)
 *   - description: string
 *   - features: string[] (list of enabled features)
 *   - limits: object (key -> int, -1 = unlimited)
 *   - is_recommended: bool (TRUE for 'professional')
 *   - price_monthly: float (EUR, 0 for free)
 *   - price_yearly: float (EUR annual total)
 * - page_title: string
 * - page_subtitle: string
 * - guarantee_text: string
 * - faq_items: array of {question, answer}
 * - vertical_key: string (machine name, empty for hub/default)
 * - vertical_label: string (display name, empty for hub/default)
 *
 * DIRECTIVES:
 * - i18n: {% trans %} on all static text
 * - ICON-CONVENTION-001: jaraba_icon('category', 'name', {variant: 'duotone'})
 * - ICON-COLOR-001: Jaraba palette colors only
 * - CSS-VAR-ALL-COLORS-001: var(--ej-*) with inline fallbacks
 * - BRAND-FONT-001: Outfit as primary font-family
 * - TWIG-XSS-001: All data with autoescaping, NEVER |raw
 * - ROUTE-LANGPREFIX-001: URLs via path() / url(), never hardcoded
 *
 * DYNAMIC DATA:
 * Tiers and features from SaasPlanTier and SaasPlanFeatures ConfigEntities
 * via MetaSitePricingService -> PlanResolverService cascade:
 *   1. Specific: {vertical}_{tier}
 *   2. Default: _default_{tier}
 *   3. Fallback: hardcoded service data
 *
 * @see \Drupal\ecosistema_jaraba_core\Controller\PricingController::pricingPage()
 * @see \Drupal\ecosistema_jaraba_core\Controller\PricingController::verticalPricingPage()
 * @see \Drupal\ecosistema_jaraba_core\Service\MetaSitePricingService
 */
#}

{# === HERO SECTION === #}
<section class="pricing-hero reveal-element reveal-fade-up" aria-labelledby="pricing-title">
  <div class="pricing-hero__container">
    <span class="pricing-hero__eyebrow">{% trans %}Planes y Precios{% endtrans %}</span>
    <h1 id="pricing-title" class="pricing-hero__title">
      {{ page_title }}
    </h1>
    <p class="pricing-hero__subtitle">
      {{ page_subtitle }}
    </p>

    {# === BILLING TOGGLE (Monthly / Annual) === #}
    <div class="pricing-toggle" role="radiogroup" aria-label="{% trans %}Frecuencia de facturación{% endtrans %}">
      <button type="button"
              class="pricing-toggle__option pricing-toggle__option--active"
              data-billing="monthly"
              aria-pressed="true">
        {% trans %}Mensual{% endtrans %}
      </button>
      <button type="button"
              class="pricing-toggle__option"
              data-billing="yearly"
              aria-pressed="false">
        {% trans %}Anual{% endtrans %}
        <span class="pricing-toggle__badge">-17%</span>
      </button>
    </div>
  </div>
</section>

{# === PRICING CARDS GRID === #}
<section class="pricing-grid reveal-element reveal-fade-up" aria-label="{% trans %}Comparar planes{% endtrans %}">
  <div class="pricing-grid__container">
    {% for tier in tiers %}
      {# Calculate annual monthly equivalent for display #}
      {% set yearly_monthly = tier.price_yearly > 0 ? (tier.price_yearly / 12)|round(0) : 0 %}
      {% set savings_pct = tier.price_monthly > 0 ? (((tier.price_monthly * 12 - tier.price_yearly) / (tier.price_monthly * 12)) * 100)|round(0) : 0 %}

      <article class="pricing-card{% if tier.is_recommended %} pricing-card--recommended{% endif %}"
               id="plan-{{ tier.tier_key }}"
               aria-labelledby="plan-title-{{ tier.tier_key }}"
               data-tier="{{ tier.tier_key }}"
               data-price-monthly="{{ tier.price_monthly }}"
               data-price-yearly="{{ tier.price_yearly }}"
               data-price-yearly-monthly="{{ yearly_monthly }}">

        {# Badge "Most popular" for recommended plan #}
        {% if tier.is_recommended %}
          <div class="pricing-card__badge" aria-label="{% trans %}Plan más popular{% endtrans %}">
            {% trans %}Más popular{% endtrans %}
          </div>
        {% endif %}

        {# Plan name + description #}
        <div class="pricing-card__header">
          <h2 id="plan-title-{{ tier.tier_key }}" class="pricing-card__name">
            {{ tier.label }}
          </h2>
          <p class="pricing-card__description">{{ tier.description }}</p>
        </div>

        {# Price display — dynamic from cascade data #}
        <div class="pricing-card__price">
          {% if tier.tier_key == 'starter' and tier.price_monthly <= 0 %}
            <span class="pricing-card__amount">{% trans %}Gratis{% endtrans %}</span>
            <span class="pricing-card__period">{% trans %}para siempre{% endtrans %}</span>
          {% else %}
            {# Monthly price (shown by default) #}
            <span class="pricing-card__amount pricing-card__amount--monthly">
              {{ tier.price_monthly|number_format(0, ',', '.') }}&euro;
            </span>
            {# Annual monthly equivalent (hidden by default) #}
            <span class="pricing-card__amount pricing-card__amount--yearly" hidden>
              {{ yearly_monthly|number_format(0, ',', '.') }}&euro;
            </span>
            <span class="pricing-card__period">/{% trans %}mes{% endtrans %}</span>
            {# Annual billing note (hidden by default) #}
            <span class="pricing-card__billing-note pricing-card__billing-note--yearly" hidden>
              {% trans %}Facturado anualmente{% endtrans %}
              {% if savings_pct > 0 %}
                <strong>({% trans %}-{{ savings_pct }}%{% endtrans %})</strong>
              {% endif %}
            </span>
          {% endif %}
        </div>

        {# Limits display — key limits from cascade #}
        {% if tier.limits is not empty %}
          <div class="pricing-card__limits">
            {% for limit_key, limit_value in tier.limits %}
              {% if limit_value != 0 %}
                <div class="pricing-card__limit">
                  {% if limit_value == -1 or limit_value >= 9999 %}
                    <span class="pricing-card__limit-value pricing-card__limit-value--unlimited">
                      {% trans %}Ilimitado{% endtrans %}
                    </span>
                  {% else %}
                    <span class="pricing-card__limit-value">{{ limit_value }}</span>
                  {% endif %}
                  <span class="pricing-card__limit-label">
                    {{ limit_key|replace({'_': ' '})|capitalize|t }}
                  </span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}

        {# Features list #}
        {% if tier.features is not empty %}
          <ul class="pricing-card__features" role="list">
            {% for feature in tier.features %}
              <li class="pricing-card__feature">
                <svg class="pricing-card__check" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M13.3 4.7L6 12 2.7 8.7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{{ feature|t }}</span>
              </li>
            {% endfor %}
          </ul>
        {% endif %}

        {# CTA button — vertical-aware URLs via Drupal path() #}
        <div class="pricing-card__cta">
          {% if tier.tier_key == 'starter' %}
            {% if vertical_key %}
              <a href="{{ path('user.register') }}?plan=starter&vertical={{ vertical_key }}"
            {% else %}
              <a href="{{ path('user.register') }}?plan=starter"
            {% endif %}
               class="btn btn--primary btn--lg pricing-card__btn"
               data-track-cta="pricing_starter"
               data-track-position="pricing_page"
               {% if vertical_key %}data-track-vertical="{{ vertical_key }}"{% endif %}>
              {% trans %}Empezar gratis{% endtrans %}
            </a>
          {% elseif tier.tier_key == 'enterprise' %}
            <a href="{{ path('ecosistema_jaraba_core.contact') }}?asunto=plan-empresa{% if vertical_key %}&vertical={{ vertical_key }}{% endif %}"
               class="btn btn--outline btn--lg pricing-card__btn"
               data-track-cta="pricing_enterprise"
               data-track-position="pricing_page"
               {% if vertical_key %}data-track-vertical="{{ vertical_key }}"{% endif %}>
              {% trans %}Contactar{% endtrans %}
            </a>
          {% else %}
            {% if vertical_key %}
              <a href="{{ path('user.register') }}?plan={{ tier.tier_key }}&vertical={{ vertical_key }}"
            {% else %}
              <a href="{{ path('user.register') }}?plan={{ tier.tier_key }}"
            {% endif %}
               class="btn btn--primary btn--lg pricing-card__btn"
               data-track-cta="pricing_{{ tier.tier_key }}"
               data-track-position="pricing_page"
               {% if vertical_key %}data-track-vertical="{{ vertical_key }}"{% endif %}>
              {% trans %}Empezar ahora{% endtrans %}
            </a>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
</section>

{# === GUARANTEE SECTION === #}
<section class="pricing-guarantee reveal-element reveal-fade-up">
  <div class="pricing-guarantee__container">
    <svg class="pricing-guarantee__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <p class="pricing-guarantee__text">{{ guarantee_text }}</p>
  </div>
</section>

{# === FAQ SECTION === #}
{% if faq_items is not empty %}
  <section class="pricing-faq reveal-element reveal-fade-up" aria-labelledby="pricing-faq-title">
    <div class="pricing-faq__container">
      <h2 id="pricing-faq-title" class="pricing-faq__title">
        {% trans %}Preguntas frecuentes{% endtrans %}
      </h2>

      <div class="pricing-faq__list" itemscope itemtype="https://schema.org/FAQPage">
        {% for item in faq_items %}
          <details class="pricing-faq__item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary class="pricing-faq__question" itemprop="name">
              {{ item.question }}
              <svg class="pricing-faq__chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="pricing-faq__answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text">{{ item.answer }}</p>
            </div>
          </details>
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{# === FINAL CTA === #}
<section class="pricing-final-cta reveal-element reveal-fade-up">
  <div class="pricing-final-cta__container">
    <h2 class="pricing-final-cta__title">
      {% trans %}¿Listo para empezar?{% endtrans %}
    </h2>
    <p class="pricing-final-cta__subtitle">
      {% trans %}Crea tu cuenta gratis en menos de 2 minutos. Sin tarjeta de crédito.{% endtrans %}
    </p>
    <a href="{{ path('user.register') }}{% if vertical_key %}?vertical={{ vertical_key }}{% endif %}"
       class="btn btn--primary btn--xl pricing-final-cta__btn"
       data-track-cta="pricing_final_cta"
       data-track-position="pricing_page_bottom"
       {% if vertical_key %}data-track-vertical="{{ vertical_key }}"{% endif %}>
      {% trans %}Crear cuenta gratuita{% endtrans %}
    </a>
  </div>
</section>

{# === SCHEMA.ORG STRUCTURED DATA === #}
{# SoftwareApplication + dynamic Offer per tier + availability #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Jaraba Impact Platform{% if vertical_label %} — {{ vertical_label }}{% endif %}",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  {% if vertical_key %}
  "url": "{{ url('ecosistema_jaraba_core.pricing.vertical', {vertical_key: vertical_key}, {absolute: true}) }}",
  {% else %}
  "url": "{{ url('ecosistema_jaraba_core.pricing.page', {}, {absolute: true}) }}",
  {% endif %}
  "offers": [
    {% for tier in tiers %}
    {
      "@type": "Offer",
      "name": {{ tier.label|json_encode(constant('JSON_UNESCAPED_UNICODE')) }},
      "priceCurrency": "EUR",
      "price": "{{ tier.price_monthly|default(0) }}",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "url": "{{ url('user.register', {}, {absolute: true}) }}",
      "description": {{ tier.description|json_encode(constant('JSON_UNESCAPED_UNICODE')) }}
    }{% if not loop.last %},{% endif %}

    {% endfor %}
  ]
}
</script>
