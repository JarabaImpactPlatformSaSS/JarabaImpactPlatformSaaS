# =============================================================================
# MariaDB 10.11 — Production tuning for Jaraba Impact Platform
# =============================================================================
# Source: Runbook v2, section 7.2 (20260311a-131b)
#
# ENV-PARITY-001: This file is the single source of truth for MariaDB config.
# Lando uses MariaDB defaults; production MUST use these settings.
#
# Install:
#   Docker: mount as /etc/mysql/conf.d/jaraba.cnf in docker-compose
#   Native: copy to /etc/mysql/mariadb.conf.d/99-jaraba.cnf
# =============================================================================

[mysqld]
# --- InnoDB Buffer Pool ---
# Year 1: 16G (DB ~10 GB fits entirely in RAM).
# Year 2: increase to 24G. Year 3+: increase to 40G.
# Do NOT pre-allocate 40G when DB is 10G — wastes RAM.
innodb_buffer_pool_size = 16G
innodb_buffer_pool_instances = 8
innodb_log_file_size = 1G
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT
innodb_file_per_table = 1

# --- NVMe I/O tuning ---
innodb_io_capacity = 4000
innodb_io_capacity_max = 8000

# --- Connections ---
# Multi-tenant SaaS: PHP-FPM workers + Supervisor AI workers + cron.
max_connections = 300

# --- Packet size ---
# CRITICAL: GrapesJS canvas_data blobs are 2-10 MB.
# Default 16M WILL truncate saves. Must be >= 256M.
max_allowed_packet = 256M

# --- Character set ---
character_set_server = utf8mb4
collation_server = utf8mb4_unicode_ci

# --- Slow query log ---
slow_query_log = 1
long_query_time = 2

# --- Binary log (point-in-time recovery) ---
# Year 1-3: no replica, binlog only for PITR.
# Reduce retention to save disk (5-25 GB savings).
log_bin = /var/lib/mysql/mysql-bin
binlog_format = ROW
expire_logs_days = 3
