{
  "web/modules/custom/**/*.php": [
    "bash scripts/lint/phpstan-staged.sh",
    "php scripts/validation/validate-optional-param-order.php"
  ],
  "web/themes/custom/**/*.scss": [
    "php scripts/validation/validate-compiled-assets.php",
    "php scripts/validation/validate-scss-css-costageing.php"
  ],
  "web/modules/custom/**/*.scss": [
    "php scripts/validation/validate-module-scss-freshness.php"
  ],
  "docs/00_*.md": [
    "bash scripts/maintenance/verify-doc-integrity.sh"
  ],
  "web/**/*.html.twig": [
    "php scripts/validation/validate-twig-syntax.php",
    "php scripts/validation/validate-twig-ortografia.php",
    "php scripts/validation/validate-twig-no-email.php"
  ],
  "web/modules/custom/**/*.services.yml": [
    "php scripts/validation/validate-phantom-args.php",
    "php scripts/validation/validate-optional-deps.php",
    "php scripts/validation/validate-circular-deps.php",
    "php scripts/validation/validate-logger-injection.php",
    "php scripts/validation/validate-optional-param-order.php"
  ],
  "web/modules/custom/**/*.routing.yml": [
    "bash scripts/validation/validate-all.sh --fast"
  ],
  "web/modules/custom/**/*.js": [
    "php scripts/validation/validate-js-syntax.php",
    "php scripts/validation/validate-twig-no-email.php"
  ],
  "web/themes/custom/**/*.js": [
    "php scripts/validation/validate-js-syntax.php",
    "php scripts/validation/validate-twig-no-email.php"
  ],
  "CLAUDE.md": [
    "php scripts/validation/validate-claude-md-size.php"
  ]
}
